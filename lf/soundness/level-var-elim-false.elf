%%% Soundness regression: the nat-offset `leq-lvl` cannot prove a false level
%%% inequality.  `S u <= u` (leq-lvl (lsucc (lvar z)) (lvar z) z) reduces, via
%%% leq-lvl/split's zero branch, to `1 <= 0` = leq-lvl (lsucc lzero) lzero z.
%%% That leaf is UNPROVABLE: the only left-succ rule `leq-lvl/sL` concludes an
%%% offset `(s N)`, never `z`, so it cannot fire at offset z, and no other rule
%%% head-matches.  This is the nat soundness gate (replacing Carneiro's integer
%%% `-1 >= 0` refutation).  The attempt below applies leq-lvl/sL at offset z;
%%% Twelf rejects it (z vs s N) -> ABORT.  Migrated 2026-06-06.  Expected: ABORT.
bad : leq-lvl (lsucc lzero) lzero z = leq-lvl/sL leq-lvl/lz.
