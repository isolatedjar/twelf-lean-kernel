%%% Expected outcome: accept
%%% Some level computation
%% def levelComp5
levelComp5/type-wf :
   {u : lvl} defeq (esort (lsucc u)) (esort (lsucc u)) (esort (lsucc (lsucc u)))
   = [u] (defeq/sort-refl-at (lsucc u)).

levelComp5/value-typed :
   {u : lvl} defeq (esort u) (esort u) (esort (lsucc u))
   = [u] (defeq/sort-refl-at u).

levelComp5/decl : {u : lvl} declared "levelComp5" (lcons u lnil)
   (esort (lsucc u))
   (defn (esort u))
   (dkind-ok/defn (levelComp5/type-wf u) (levelComp5/value-typed u)).

