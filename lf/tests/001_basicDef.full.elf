%%% Expected outcome: accept
%%% Basic definition
%% def basicDef
%%% HOLE
basicDef/type-wf-sort : lvl.

%%% HOLE
basicDef/type-wf : defeq (esort (lsucc lzero)) (esort (lsucc lzero)) (esort basicDef/type-wf-sort).

%%% HOLE
basicDef/value-typed : defeq (esort lzero) (esort lzero) (esort (lsucc lzero)).

basicDef/decl : declared "basicDef" lnil
   (esort (lsucc lzero))
   (defn (esort lzero))
   (dkind-ok/defn basicDef/type-wf basicDef/value-typed).

