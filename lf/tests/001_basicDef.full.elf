%%% Expected outcome: accept
%%% Basic definition
%% def basicDef
basicDef/type-wf-sort : lvl
   = (lsucc (lsucc lzero)).

basicDef/type-wf : defeq (esort (lsucc lzero)) (esort (lsucc lzero)) (esort basicDef/type-wf-sort)
   = defeq/sort-refl.

basicDef/value-typed : defeq (esort lzero) (esort lzero) (esort (lsucc lzero))
   = defeq/sort-refl.

basicDef/name : name "basicDef" (is-decl (esort (lsucc lzero)) (defn (esort lzero))).

basicDef/decl : declared "basicDef" (esort (lsucc lzero)) (defn (esort lzero))
   = declared/ok basicDef/name (dkind-ok/defn basicDef/type-wf basicDef/value-typed).
