%% def predWithTypeField
%%% HOLE
predWithTypeField/type-wf-sort : lvl.

%%% HOLE
predWithTypeField/type-wf : defeq (esort lzero) (esort lzero) (esort predWithTypeField/type-wf-sort).

%%% HOLE
predWithTypeField/value-typed : defeq (econst "PredWithTypeField" lnil) (econst "PredWithTypeField" lnil) (esort lzero).

predWithTypeField/name : name "predWithTypeField" (is-decl (esort lzero) (defn (econst "PredWithTypeField" lnil))).

predWithTypeField/decl : declared "predWithTypeField" (esort lzero) (defn (econst "PredWithTypeField" lnil))
   = declared/ok predWithTypeField/name (dkind-ok/defn predWithTypeField/type-wf predWithTypeField/value-typed).

