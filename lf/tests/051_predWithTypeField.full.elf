%%% Expected outcome: accept
%%% An inductive proposition can have constructors with fields of arbitrary level.
%% inductive PredWithTypeField
PredWithTypeField/type-wf-sort : lvl
   = (lsucc lzero).

PredWithTypeField/type-wf : of (esort lzero) (esort PredWithTypeField/type-wf-sort)
   = defeq/sort-refl.

PredWithTypeField/ends-in-sort : ends-in-sort (esort lzero)
   = ends-in-sort/sort.

PredWithTypeField/rec-name : name "PredWithTypeField.rec" (is-rec-for "PredWithTypeField").

PredWithTypeField/clf : count-leading-foralls (esort lzero) liz
   = (count-leading-foralls/zero not-forall/sort).

PredWithTypeField/cnd : cnames-distinct (ccons "PredWithTypeField.mk" cnil)
   = (cnames-distinct/cons cnames-distinct/nil all-string-neq/nil).

PredWithTypeField/name : name "PredWithTypeField" (is-decl (esort lzero) (indt (ccons "PredWithTypeField.mk" cnil) liz)).

PredWithTypeField/decl : declared "PredWithTypeField" (esort lzero) (indt (ccons "PredWithTypeField.mk" cnil) liz)
   = declared/ok-indt PredWithTypeField/name PredWithTypeField/rec-name PredWithTypeField/clf PredWithTypeField/cnd (dkind-ok/indt PredWithTypeField/type-wf PredWithTypeField/ends-in-sort).

%% ctor PredWithTypeField.mk (of PredWithTypeField)
PredWithTypeField_mk/type-wf-sort : lvl
   = (limax (lsucc (lsucc lzero)) lzero).

PredWithTypeField_mk/type-wf : of (eforall (esort (lsucc lzero)) ([x] (econst "PredWithTypeField" lnil))) (esort PredWithTypeField_mk/type-wf-sort)
   = (defeq/forall
       defeq/sort-refl
       ([x]
         ([h]
           (defeq/const
             PredWithTypeField/decl
             (inst-expr/sort lvl-inst/zero))))).

PredWithTypeField_mk/positivity : ctor-positive "PredWithTypeField" lnil (eforall (esort (lsucc lzero)) ([x] (econst "PredWithTypeField" lnil)))
   = (ctor-positive/intro ([S] (eforall (esort (lsucc lzero)) ([x] S))) (ctor-spine/arg
       (strict-pos/no-occur (esort (lsucc lzero)) no-self-ref/sort)
       ([x] ([y] (ctor-spine/result applies-self/refl))))).

PredWithTypeField_mk/eisl : ends-in-sort-with-level (esort lzero) lzero
   = ends-in-sort-with-level/sort.

PredWithTypeField_mk/cmem : cmem "PredWithTypeField.mk" (ccons "PredWithTypeField.mk" cnil)
   = cmem/here.

%%% HOLE: PredWithTypeField_mk/fuo — prover for field-universes-ok-skip-params not yet implemented
PredWithTypeField_mk/fuo : field-universes-ok-skip-params liz (eforall (esort (lsucc lzero)) ([x] (econst "PredWithTypeField" lnil))) lzero.

PredWithTypeField_mk/name : name "PredWithTypeField.mk" (is-decl (eforall (esort (lsucc lzero)) ([x] (econst "PredWithTypeField" lnil))) (ctor "PredWithTypeField" liz)).

PredWithTypeField_mk/decl : declared "PredWithTypeField.mk" (eforall (esort (lsucc lzero)) ([x] (econst "PredWithTypeField" lnil))) (ctor "PredWithTypeField" liz)
   = declared/ok-ctor PredWithTypeField_mk/name PredWithTypeField/name PredWithTypeField_mk/cmem PredWithTypeField_mk/eisl PredWithTypeField_mk/fuo (dkind-ok/ctor PredWithTypeField_mk/type-wf PredWithTypeField_mk/positivity).

%% recursor PredWithTypeField.rec
PredWithTypeField_rec/type-wf-sort : lvl
   = (limax
       (limax lzero (lsucc lzero))
       (limax (limax (lsucc (lsucc lzero)) lzero) (limax lzero lzero))).

PredWithTypeField_rec/type-wf : of
  (eforall (eforall (econst "PredWithTypeField" lnil) ([x] (esort lzero)))
    ([x] (eforall (eforall (esort (lsucc lzero)) ([y] (eapp x (eapp (econst "PredWithTypeField.mk" lnil) y)))) ([y] (eforall (econst "PredWithTypeField" lnil) ([z] (eapp x z)))))))
  (esort PredWithTypeField_rec/type-wf-sort)
   = (defeq/forall
       (defeq/forall
         (defeq/const PredWithTypeField/decl (inst-expr/sort lvl-inst/zero))
         ([x] ([h] defeq/sort-refl)))
       ([x]
         ([h]
           (defeq/forall
             (defeq/forall
               defeq/sort-refl
               ([y]
                 ([h1]
                   (defeq/app
                     h
                     (defeq/app
                       (defeq/const
                         PredWithTypeField_mk/decl
                         (inst-expr/forall
                           (inst-expr/sort (lvl-inst/succ lvl-inst/zero))
                           ([x] ([h] (inst-expr/const lvls-inst/nil)))))
                       h1)))))
             ([y]
               ([h1]
                 (defeq/forall
                   (defeq/const
                     PredWithTypeField/decl
                     (inst-expr/sort lvl-inst/zero))
                   ([z] ([h2] (defeq/app h h2)))))))))).

PredWithTypeField_rec/decl : declared "PredWithTypeField.rec"
  (eforall (eforall (econst "PredWithTypeField" lnil) ([x] (esort lzero)))
    ([x] (eforall (eforall (esort (lsucc lzero)) ([y] (eapp x (eapp (econst "PredWithTypeField.mk" lnil) y)))) ([y] (eforall (econst "PredWithTypeField" lnil) ([z] (eapp x z)))))))
  (irec "PredWithTypeField")
   = declared/ok-irec PredWithTypeField/rec-name (dkind-ok/irec PredWithTypeField_rec/type-wf).

%% def predWithTypeField
predWithTypeField/type-wf-sort : lvl
   = (lsucc lzero).

predWithTypeField/type-wf : of (esort lzero) (esort predWithTypeField/type-wf-sort)
   = defeq/sort-refl.

predWithTypeField/value-typed : of (econst "PredWithTypeField" lnil) (esort lzero)
   = (defeq/const PredWithTypeField/decl (inst-expr/sort lvl-inst/zero)).

predWithTypeField/name : name "predWithTypeField" (is-decl (esort lzero) (defn (econst "PredWithTypeField" lnil))).

predWithTypeField/decl : declared "predWithTypeField" (esort lzero) (defn (econst "PredWithTypeField" lnil))
   = declared/ok predWithTypeField/name (dkind-ok/defn predWithTypeField/type-wf predWithTypeField/value-typed).
