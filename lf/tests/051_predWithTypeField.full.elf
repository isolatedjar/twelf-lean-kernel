%%% Expected outcome: accept
%%% An inductive proposition can have constructors with fields of arbitrary level.
%% inductive PredWithTypeField
%%% HOLE
PredWithTypeField/type-wf-sort : lvl.

%%% HOLE
PredWithTypeField/type-wf : defeq (esort lzero) (esort lzero) (esort PredWithTypeField/type-wf-sort).

%%% HOLE
PredWithTypeField/ends-in-sort : ends-in-sort (esort lzero).

PredWithTypeField/name : name "PredWithTypeField" (is-decl (esort lzero) indt).

PredWithTypeField/decl : declared "PredWithTypeField" (esort lzero) indt
   = declared/ok PredWithTypeField/name (dkind-ok/indt PredWithTypeField/type-wf PredWithTypeField/ends-in-sort).

%% ctor PredWithTypeField.mk (of PredWithTypeField)
%%% HOLE
PredWithTypeField_mk/type-wf-sort : lvl.

%%% HOLE
PredWithTypeField_mk/type-wf : defeq (eforall (esort (lsucc lzero)) ([x] (econst "PredWithTypeField" lnil))) (eforall (esort (lsucc lzero)) ([x] (econst "PredWithTypeField" lnil))) (esort PredWithTypeField_mk/type-wf-sort).

%%% HOLE
PredWithTypeField_mk/positivity : ctor-positive "PredWithTypeField" lnil (eforall (esort (lsucc lzero)) ([x] (econst "PredWithTypeField" lnil))).

PredWithTypeField_mk/name : name "PredWithTypeField.mk" (is-decl (eforall (esort (lsucc lzero)) ([x] (econst "PredWithTypeField" lnil))) ctor).

PredWithTypeField_mk/decl : declared "PredWithTypeField.mk" (eforall (esort (lsucc lzero)) ([x] (econst "PredWithTypeField" lnil))) ctor
   = declared/ok PredWithTypeField_mk/name (dkind-ok/ctor PredWithTypeField_mk/type-wf PredWithTypeField_mk/positivity).

%% recursor PredWithTypeField.rec
%%% HOLE
PredWithTypeField_rec/type-wf-sort : lvl.

%%% HOLE
PredWithTypeField_rec/type-wf : defeq (eforall (eforall (econst "PredWithTypeField" lnil) ([x] (esort lzero))) ([x] (eforall (eforall (esort (lsucc lzero)) ([y] (eapp x (eapp (econst "PredWithTypeField.mk" lnil) y)))) ([y] (eforall (econst "PredWithTypeField" lnil) ([z] (eapp x z))))))) (eforall (eforall (econst "PredWithTypeField" lnil) ([x] (esort lzero))) ([x] (eforall (eforall (esort (lsucc lzero)) ([y] (eapp x (eapp (econst "PredWithTypeField.mk" lnil) y)))) ([y] (eforall (econst "PredWithTypeField" lnil) ([z] (eapp x z))))))) (esort PredWithTypeField_rec/type-wf-sort).

PredWithTypeField_rec/name : name "PredWithTypeField.rec" (is-decl (eforall (eforall (econst "PredWithTypeField" lnil) ([x] (esort lzero))) ([x] (eforall (eforall (esort (lsucc lzero)) ([y] (eapp x (eapp (econst "PredWithTypeField.mk" lnil) y)))) ([y] (eforall (econst "PredWithTypeField" lnil) ([z] (eapp x z))))))) irec).

PredWithTypeField_rec/decl : declared "PredWithTypeField.rec" (eforall (eforall (econst "PredWithTypeField" lnil) ([x] (esort lzero))) ([x] (eforall (eforall (esort (lsucc lzero)) ([y] (eapp x (eapp (econst "PredWithTypeField.mk" lnil) y)))) ([y] (eforall (econst "PredWithTypeField" lnil) ([z] (eapp x z))))))) irec
