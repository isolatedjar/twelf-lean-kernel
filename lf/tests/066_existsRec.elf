%%% Expected outcome: accept
%%% Inductive predicates eliminate into Prop if they have one constructors and it carries data.
%% inductive Exists
Exists/type-wf :
   {u : lvl} defeq (eforall (esort u) ([x] (eforall (eforall x ([y] (esort lzero))) ([y] (esort lzero))))) (eforall (esort u) ([x] (eforall (eforall x ([y] (esort lzero))) ([y] (esort lzero))))) (esort (limax (lsucc u) (limax (limax u (lsucc lzero)) (lsucc lzero))))
   = [u] (defeq/forall (defeq/sort-refl-at u) ([x] [y] (defeq/forall (defeq/forall y ([z] [w] (defeq/sort-refl-at lzero))) ([z] [w] (defeq/sort-refl-at lzero))))).

Exists/ends-in-sort :
   {u : lvl} ends-in-sort (eforall (esort u) ([x] (eforall (eforall x ([y] (esort lzero))) ([y] (esort lzero)))))
   = [u] (ends-in-sort/forall ([x] (ends-in-sort/forall ([y] ends-in-sort/sort)))).

Exists/decl : {u : lvl} declared "Exists" (lcons u lnil)
   (eforall (esort u) ([x] (eforall (eforall x ([y] (esort lzero))) ([y] (esort lzero)))))
   indt
   (dkind-ok/indt (Exists/type-wf u) (Exists/ends-in-sort u)).

%% inductive ctor Exists.intro
Exists_intro/type-wf :
   {u : lvl} defeq (eforall (esort u) ([x] (eforall (eforall x ([y] (esort lzero))) ([y] (eforall x ([z] (eforall (eapp y z) ([w] (eapp (eapp (econst "Exists" (lcons u lnil)) x) y))))))))) (eforall (esort u) ([x] (eforall (eforall x ([y] (esort lzero))) ([y] (eforall x ([z] (eforall (eapp y z) ([w] (eapp (eapp (econst "Exists" (lcons u lnil)) x) y))))))))) (esort (limax (lsucc u) (limax (limax u (lsucc lzero)) (limax u (limax lzero lzero)))))
   = [u] (defeq/forall (defeq/sort-refl-at u) ([x] [y] (defeq/forall (defeq/forall y ([z] [w] (defeq/sort-refl-at lzero))) ([z] [w] (defeq/forall y ([x1] [y1] (defeq/forall (defeq/app w y1) ([z1] [w1] (defeq/app (defeq/app (defeq/const (Exists/decl u)) y) w))))))))).

Exists_intro/positivity :
   {u : lvl} ctor-positive "Exists" (lcons u lnil) (eforall (esort u) ([x] (eforall (eforall x ([y] (esort lzero))) ([y] (eforall x ([z] (eforall (eapp y z) ([w] (eapp (eapp (econst "Exists" (lcons u lnil)) x) y)))))))))
   = [u] (ctor-positive/intro ([S] (eforall (esort u) ([x] (eforall (eforall x ([y] (esort lzero))) ([y] (eforall x ([z] (eforall (eapp y z) ([w] (eapp (eapp S x) y)))))))))) ([S] (ctor-spine/arg (strict-pos/absent absent/sort) ([_y0] [_h0] (ctor-spine/arg (strict-pos/absent (absent/forall _h0 ([_y1] [_h1] absent/sort))) ([_y1] [_h1] (ctor-spine/arg (strict-pos/absent _h0) ([_y2] [_h2] (ctor-spine/arg (strict-pos/absent (absent/app _h1 _h2)) ([_y3] [_h3] (ctor-spine/result (applies-self/app (applies-self/app applies-self/refl))))))))))))).

Exists_intro/decl : {u : lvl} declared "Exists.intro" (lcons u lnil)
   (eforall (esort u) ([x] (eforall (eforall x ([y] (esort lzero))) ([y] (eforall x ([z] (eforall (eapp y z) ([w] (eapp (eapp (econst "Exists" (lcons u lnil)) x) y)))))))))
   ctor
   (dkind-ok/ctor (Exists_intro/type-wf u) (Exists_intro/positivity u)).

%% inductive recursor Exists.rec
Exists_rec/type-wf :
   {u : lvl} defeq (eforall (esort u) ([x] (eforall (eforall x ([y] (esort lzero))) ([y] (eforall (eforall (eapp (eapp (econst "Exists" (lcons u lnil)) x) y) ([z] (esort lzero))) ([z] (eforall (eforall x ([w] (eforall (eapp y w) ([x1] (eapp z (eapp (eapp (eapp (eapp (econst "Exists.intro" (lcons u lnil)) x) y) w) x1)))))) ([w] (eforall (eapp (eapp (econst "Exists" (lcons u lnil)) x) y) ([x1] (eapp z x1))))))))))) (eforall (esort u) ([x] (eforall (eforall x ([y] (esort lzero))) ([y] (eforall (eforall (eapp (eapp (econst "Exists" (lcons u lnil)) x) y) ([z] (esort lzero))) ([z] (eforall (eforall x ([w] (eforall (eapp y w) ([x1] (eapp z (eapp (eapp (eapp (eapp (econst "Exists.intro" (lcons u lnil)) x) y) w) x1)))))) ([w] (eforall (eapp (eapp (econst "Exists" (lcons u lnil)) x) y) ([x1] (eapp z x1))))))))))) (esort (limax (lsucc u) (limax (limax u (lsucc lzero)) (limax (limax lzero (lsucc lzero)) (limax (limax u (limax lzero lzero)) (limax lzero lzero))))))
   = [u] (defeq/forall (defeq/sort-refl-at u) ([x] [y] (defeq/forall (defeq/forall y ([z] [w] (defeq/sort-refl-at lzero))) ([z] [w] (defeq/forall (defeq/forall (defeq/app (defeq/app (defeq/const (Exists/decl u)) y) w) ([x1] [y1] (defeq/sort-refl-at lzero))) ([x1] [y1] (defeq/forall (defeq/forall y ([z1] [w1] (defeq/forall (defeq/app w w1) ([x2] [y2] (defeq/app y1 (defeq/app (defeq/app (defeq/app (defeq/app (defeq/const (Exists_intro/decl u)) y) w) w1) y2)))))) ([z1] [w1] (defeq/forall (defeq/app (defeq/app (defeq/const (Exists/decl u)) y) w) ([x2] [y2] (defeq/app y1 y2))))))))))).

Exists_rec/decl : {u : lvl} declared "Exists.rec" (lcons u lnil)
   (eforall (esort u) ([x] (eforall (eforall x ([y] (esort lzero))) ([y] (eforall (eforall (eapp (eapp (econst "Exists" (lcons u lnil)) x) y) ([z] (esort lzero))) ([z] (eforall (eforall x ([w] (eforall (eapp y w) ([x1] (eapp z (eapp (eapp (eapp (eapp (econst "Exists.intro" (lcons u lnil)) x) y) w) x1)))))) ([w] (eforall (eapp (eapp (econst "Exists" (lcons u lnil)) x) y) ([x1] (eapp z x1)))))))))))
   irec
   (dkind-ok/irec (Exists_rec/type-wf u)).

%% def existsRec
existsRec/type-wf :
   {u : lvl} defeq (eforall (esort u) ([x] (eforall (eforall x ([y] (esort lzero))) ([y] (eforall (eforall (eapp (eapp (econst "Exists" (lcons u lnil)) x) y) ([z] (esort lzero))) ([z] (eforall (eforall x ([w] (eforall (eapp y w) ([x1] (eapp z (eapp (eapp (eapp (eapp (econst "Exists.intro" (lcons u lnil)) x) y) w) x1)))))) ([w] (eforall (eapp (eapp (econst "Exists" (lcons u lnil)) x) y) ([x1] (eapp z x1))))))))))) (eforall (esort u) ([x] (eforall (eforall x ([y] (esort lzero))) ([y] (eforall (eforall (eapp (eapp (econst "Exists" (lcons u lnil)) x) y) ([z] (esort lzero))) ([z] (eforall (eforall x ([w] (eforall (eapp y w) ([x1] (eapp z (eapp (eapp (eapp (eapp (econst "Exists.intro" (lcons u lnil)) x) y) w) x1)))))) ([w] (eforall (eapp (eapp (econst "Exists" (lcons u lnil)) x) y) ([x1] (eapp z x1))))))))))) (esort (limax (lsucc u) (limax (limax u (lsucc lzero)) (limax (limax lzero (lsucc lzero)) (limax (limax u (limax lzero lzero)) (limax lzero lzero))))))
   = [u] (defeq/forall (defeq/sort-refl-at u) ([x] [y] (defeq/forall (defeq/forall y ([z] [w] (defeq/sort-refl-at lzero))) ([z] [w] (defeq/forall (defeq/forall (defeq/app (defeq/app (defeq/const (Exists/decl u)) y) w) ([x1] [y1] (defeq/sort-refl-at lzero))) ([x1] [y1] (defeq/forall (defeq/forall y ([z1] [w1] (defeq/forall (defeq/app w w1) ([x2] [y2] (defeq/app y1 (defeq/app (defeq/app (defeq/app (defeq/app (defeq/const (Exists_intro/decl u)) y) w) w1) y2)))))) ([z1] [w1] (defeq/forall (defeq/app (defeq/app (defeq/const (Exists/decl u)) y) w) ([x2] [y2] (defeq/app y1 y2))))))))))).

existsRec/value-typed :
   {u : lvl} defeq (econst "Exists.rec" (lcons u lnil)) (econst "Exists.rec" (lcons u lnil)) (eforall (esort u) ([x] (eforall (eforall x ([y] (esort lzero))) ([y] (eforall (eforall (eapp (eapp (econst "Exists" (lcons u lnil)) x) y) ([z] (esort lzero))) ([z] (eforall (eforall x ([w] (eforall (eapp y w) ([x1] (eapp z (eapp (eapp (eapp (eapp (econst "Exists.intro" (lcons u lnil)) x) y) w) x1)))))) ([w] (eforall (eapp (eapp (econst "Exists" (lcons u lnil)) x) y) ([x1] (eapp z x1)))))))))))
   = [u] (defeq/const (Exists_rec/decl u)).

existsRec/decl : {u : lvl} declared "existsRec" (lcons u lnil)
   (eforall (esort u) ([x] (eforall (eforall x ([y] (esort lzero))) ([y] (eforall (eforall (eapp (eapp (econst "Exists" (lcons u lnil)) x) y) ([z] (esort lzero))) ([z] (eforall (eforall x ([w] (eforall (eapp y w) ([x1] (eapp z (eapp (eapp (eapp (eapp (econst "Exists.intro" (lcons u lnil)) x) y) w) x1)))))) ([w] (eforall (eapp (eapp (econst "Exists" (lcons u lnil)) x) y) ([x1] (eapp z x1)))))))))))
   (defn (econst "Exists.rec" (lcons u lnil)))
   (dkind-ok/defn (existsRec/type-wf u) (existsRec/value-typed u)).

%mode declared +N +LS -T -DK -W.
%worlds () (declared _ _ _ _ _).
%unique declared +N +LS -1T -1DK *W.
