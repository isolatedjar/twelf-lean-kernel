%% thm quotIndReduction
quotIndReduction/render-type : {u : lvl} expr =
   [u] (eforall (esort u) ([x] (eforall (eforall x ([y] (eforall x ([z] (esort lzero))))) ([y] (eforall (eforall (eapp (eapp (econst "Quot" (lcons u lnil)) x) y) ([z] (esort lzero))) ([z] (eforall (eforall x ([w] (eapp z (eapp (eapp (eapp (econst "Quot.mk" (lcons u lnil)) x) y) w)))) ([w] (eforall x ([x1] (eapp (eapp (eapp (econst "Eq" (lcons lzero lnil)) (eapp z (eapp (eapp (eapp (econst "Quot.mk" (lcons u lnil)) x) y) x1))) (eapp (eapp (eapp (eapp (eapp (econst "Quot.ind" (lcons u lnil)) x) y) z) w) (eapp (eapp (eapp (econst "Quot.mk" (lcons u lnil)) x) y) x1))) (eapp w x1)))))))))))).
quotIndReduction/render-value : {u : lvl} expr =
   [u] (elam (esort u) ([x] (elam (eforall x ([y] (eforall x ([z] (esort lzero))))) ([y] (elam (eforall (eapp (eapp (econst "Quot" (lcons u lnil)) x) y) ([z] (esort lzero))) ([z] (elam (eforall x ([w] (eapp z (eapp (eapp (eapp (econst "Quot.mk" (lcons u lnil)) x) y) w)))) ([w] (elam x ([x1] (eapp (eapp (econst "Eq.refl" (lcons lzero lnil)) (eapp z (eapp (eapp (eapp (econst "Quot.mk" (lcons u lnil)) x) y) x1))) (eapp (eapp (eapp (eapp (eapp (econst "Quot.ind" (lcons u lnil)) x) y) z) w) (eapp (eapp (eapp (econst "Quot.mk" (lcons u lnil)) x) y) x1))))))))))))).

