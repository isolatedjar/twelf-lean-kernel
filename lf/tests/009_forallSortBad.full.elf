%%% Expected outcome: reject
%%% The binding domain of a forall has to be a sort
%% def id
%%% HOLE
id/type-wf-sort : {u : lvl} lvl.

%%% HOLE
id/type-wf : {u : lvl} defeq (eforall (esort u) ([x] (eforall x ([y] x)))) (eforall (esort u) ([x] (eforall x ([y] x)))) (esort (id/type-wf-sort u)).

%%% HOLE
id/value-typed : {u : lvl} defeq (elam (esort u) ([x] (elam x ([y] y)))) (elam (esort u) ([x] (elam x ([y] y)))) (eforall (esort u) ([x] (eforall x ([y] x)))).

id/decl : {u : lvl} declared "id" (lcons u lnil)
   (eforall (esort u) ([x] (eforall x ([y] x))))
   (defn (elam (esort u) ([x] (elam x ([y] y)))))
   (dkind-ok/defn (id/type-wf u) (id/value-typed u)).

%% def forallSortBad
%%% HOLE
forallSortBad/type-wf-sort : lvl.

%%% HOLE
forallSortBad/type-wf : defeq (esort lzero) (esort lzero) (esort forallSortBad/type-wf-sort).

%%% HOLE
forallSortBad/value-typed : defeq (eforall (eapp (eapp (econst "id" (lcons (lsucc (lsucc lzero)) lnil)) (esort (lsucc lzero))) (esort lzero)) ([x] (eforall x ([y] (eforall y ([z] y)))))) (eforall (eapp (eapp (econst "id" (lcons (lsucc (lsucc lzero)) lnil)) (esort (lsucc lzero))) (esort lzero)) ([x] (eforall x ([y] (eforall y ([z] y)))))) (esort lzero).

forallSortBad/decl : declared "forallSortBad" lnil
   (esort lzero)
   (defn (eforall (eapp (eapp (econst "id" (lcons (lsucc (lsucc lzero)) lnil)) (esort (lsucc lzero))) (esort lzero)) ([x] (eforall x ([y] (eforall y ([z] y)))))))
   (dkind-ok/defn forallSortBad/type-wf forallSortBad/value-typed).

