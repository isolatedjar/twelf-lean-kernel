%%% Expected outcome: reject
%%% Rejection: recursive occurrence in *index position*, behind a further arrow.
%%% 
%%% We build an indexed inductive `I : Type → Type` with a constructor argument
%%% `Nat → I (I α)`, so the recursive occurrence appears as an index argument.
%% inductive Nat
%%% HOLE
Nat/type-wf-sort : lvl.

%%% HOLE
Nat/type-wf : defeq (esort (lsucc lzero)) (esort (lsucc lzero)) (esort Nat/type-wf-sort).

%%% HOLE
Nat/ends-in-sort : ends-in-sort (esort (lsucc lzero)).

Nat/name : name "Nat" (is-decl (esort (lsucc lzero)) indt).

Nat/decl : declared "Nat" (esort (lsucc lzero)) indt
   = declared/ok Nat/name (dkind-ok/indt Nat/type-wf Nat/ends-in-sort).

%% ctor Nat.zero (of Nat)
%%% HOLE
Nat_zero/type-wf-sort : lvl.

%%% HOLE
Nat_zero/type-wf : defeq (econst "Nat" lnil) (econst "Nat" lnil) (esort Nat_zero/type-wf-sort).

%%% HOLE
Nat_zero/positivity : ctor-positive "Nat" lnil (econst "Nat" lnil).

Nat_zero/name : name "Nat.zero" (is-decl (econst "Nat" lnil) ctor).

Nat_zero/decl : declared "Nat.zero" (econst "Nat" lnil) ctor
   = declared/ok Nat_zero/name (dkind-ok/ctor Nat_zero/type-wf Nat_zero/positivity).

%% ctor Nat.succ (of Nat)
%%% HOLE
Nat_succ/type-wf-sort : lvl.

%%% HOLE
Nat_succ/type-wf : defeq (eforall (econst "Nat" lnil) ([x] (econst "Nat" lnil))) (eforall (econst "Nat" lnil) ([x] (econst "Nat" lnil))) (esort Nat_succ/type-wf-sort).

%%% HOLE
Nat_succ/positivity : ctor-positive "Nat" lnil (eforall (econst "Nat" lnil) ([x] (econst "Nat" lnil))).

Nat_succ/name : name "Nat.succ" (is-decl (eforall (econst "Nat" lnil) ([x] (econst "Nat" lnil))) ctor).

Nat_succ/decl : declared "Nat.succ" (eforall (econst "Nat" lnil) ([x] (econst "Nat" lnil))) ctor
   = declared/ok Nat_succ/name (dkind-ok/ctor Nat_succ/type-wf Nat_succ/positivity).

%% recursor Nat.rec
%%% HOLE
Nat_rec/type-wf-sort : lvl.

%%% HOLE
Nat_rec/type-wf : defeq (eforall (eforall (econst "Nat" lnil) ([x] (esort (lvar liz)))) ([x] (eforall (eapp x (econst "Nat.zero" lnil)) ([y] (eforall (eforall (econst "Nat" lnil) ([z] (eforall (eapp x z) ([w] (eapp x (eapp (econst "Nat.succ" lnil) z)))))) ([z] (eforall (econst "Nat" lnil) ([w] (eapp x w))))))))) (eforall (eforall (econst "Nat" lnil) ([x] (esort (lvar liz)))) ([x] (eforall (eapp x (econst "Nat.zero" lnil)) ([y] (eforall (eforall (econst "Nat" lnil) ([z] (eforall (eapp x z) ([w] (eapp x (eapp (econst "Nat.succ" lnil) z)))))) ([z] (eforall (econst "Nat" lnil) ([w] (eapp x w))))))))) (esort Nat_rec/type-wf-sort).

Nat_rec/name : name "Nat.rec" (is-decl (eforall (eforall (econst "Nat" lnil) ([x] (esort (lvar liz)))) ([x] (eforall (eapp x (econst "Nat.zero" lnil)) ([y] (eforall (eforall (econst "Nat" lnil) ([z] (eforall (eapp x z) ([w] (eapp x (eapp (econst "Nat.succ" lnil) z)))))) ([z] (eforall (econst "Nat" lnil) ([w] (eapp x w))))))))) irec).

Nat_rec/decl : declared "Nat.rec" (eforall (eforall (econst "Nat" lnil) ([x] (esort (lvar liz)))) ([x] (eforall (eapp x (econst "Nat.zero" lnil)) ([y] (eforall (eforall (econst "Nat" lnil) ([z] (eforall (eapp x z) ([w] (eapp x (eapp (econst "Nat.succ" lnil) z)))))) ([z] (eforall (econst "Nat" lnil) ([w] (eapp x w))))))))) irec
   = declared/ok Nat_rec/name (dkind-ok/irec Nat_rec/type-wf).

%% inductive reflOccInIndex
%%% HOLE
reflOccInIndex/type-wf-sort : lvl.

%%% HOLE
reflOccInIndex/type-wf : defeq (eforall (esort (lsucc lzero)) ([x] (esort (lsucc lzero)))) (eforall (esort (lsucc lzero)) ([x] (esort (lsucc lzero)))) (esort reflOccInIndex/type-wf-sort).

%%% HOLE
reflOccInIndex/ends-in-sort : ends-in-sort (eforall (esort (lsucc lzero)) ([x] (esort (lsucc lzero)))).

reflOccInIndex/name : name "reflOccInIndex" (is-decl (eforall (esort (lsucc lzero)) ([x] (esort (lsucc lzero)))) indt).

reflOccInIndex/decl : declared "reflOccInIndex" (eforall (esort (lsucc lzero)) ([x] (esort (lsucc lzero)))) indt
   = declared/ok reflOccInIndex/name (dkind-ok/indt reflOccInIndex/type-wf reflOccInIndex/ends-in-sort).

%% ctor reflOccInIndex.mk (of reflOccInIndex)
%%% HOLE
reflOccInIndex_mk/type-wf-sort : lvl.

%%% HOLE
reflOccInIndex_mk/type-wf : defeq (eforall (esort (lsucc lzero)) ([x] (eforall (eforall (econst "Nat" lnil) ([y] (eapp (econst "reflOccInIndex" lnil) (eapp (econst "reflOccInIndex" lnil) y)))) ([y] (eapp (econst "reflOccInIndex" lnil) x))))) (eforall (esort (lsucc lzero)) ([x] (eforall (eforall (econst "Nat" lnil) ([y] (eapp (econst "reflOccInIndex" lnil) (eapp (econst "reflOccInIndex" lnil) y)))) ([y] (eapp (econst "reflOccInIndex" lnil) x))))) (esort reflOccInIndex_mk/type-wf-sort).

%%% HOLE
reflOccInIndex_mk/positivity : ctor-positive "reflOccInIndex" lnil (eforall (esort (lsucc lzero)) ([x] (eforall (eforall (econst "Nat" lnil) ([y] (eapp (econst "reflOccInIndex" lnil) (eapp (econst "reflOccInIndex" lnil) y)))) ([y] (eapp (econst "reflOccInIndex" lnil) x))))).

reflOccInIndex_mk/name : name "reflOccInIndex.mk" (is-decl (eforall (esort (lsucc lzero)) ([x] (eforall (eforall (econst "Nat" lnil) ([y] (eapp (econst "reflOccInIndex" lnil) (eapp (econst "reflOccInIndex" lnil) y)))) ([y] (eapp (econst "reflOccInIndex" lnil) x))))) ctor).

reflOccInIndex_mk/decl : declared "reflOccInIndex.mk" (eforall (esort (lsucc lzero)) ([x] (eforall (eforall (econst "Nat" lnil) ([y] (eapp (econst "reflOccInIndex" lnil) (eapp (econst "reflOccInIndex" lnil) y)))) ([y] (eapp (econst "reflOccInIndex" lnil) x))))) ctor
   = declared/ok reflOccInIndex_mk/name (dkind-ok/ctor reflOccInIndex_mk/type-wf reflOccInIndex_mk/positivity).

%% recursor reflOccInIndex.rec
%%% HOLE
reflOccInIndex_rec/type-wf-sort : lvl.

%%% HOLE
reflOccInIndex_rec/type-wf : defeq (esort lzero) (esort lzero) (esort reflOccInIndex_rec/type-wf-sort).

reflOccInIndex_rec/name : name "reflOccInIndex.rec" (is-decl (esort lzero) irec).

reflOccInIndex_rec/decl : declared "reflOccInIndex.rec" (esort lzero) irec
   = declared/ok reflOccInIndex_rec/name (dkind-ok/irec reflOccInIndex_rec/type-wf).

