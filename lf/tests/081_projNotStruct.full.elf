%%% Expected outcome: reject
%%% Projection out something that is not a structure
%% inductive N
N/type-wf-sort : lvl
   = (lsucc (lsucc lzero)).

N/type-wf : of (esort (lsucc lzero)) (esort N/type-wf-sort)
   = defeq/sort-refl.

N/ends-in-sort : ends-in-sort (esort (lsucc lzero))
   = ends-in-sort/sort.

N/rec-name : name "N.rec" (is-rec-for "N").

N/name : name "N" (is-decl (esort (lsucc lzero)) indt).

N/decl : declared "N" (esort (lsucc lzero)) indt
   = declared/ok N/name (dkind-ok/indt N/type-wf N/ends-in-sort).

%% ctor N.zero (of N)
N_zero/type-wf-sort : lvl
   = (lsucc lzero).

N_zero/type-wf : of (econst "N" lnil) (esort N_zero/type-wf-sort)
   = (defeq/const N/decl (inst-expr/sort (lvl-inst/succ lvl-inst/zero))).

N_zero/positivity : ctor-positive "N" lnil (econst "N" lnil)
   = (ctor-positive/intro ([S] S) (ctor-spine/result applies-self/refl)).

N_zero/eisl : ends-in-sort-with-level (esort (lsucc lzero)) (lsucc lzero)
   = ends-in-sort-with-level/sort.

%%% HOLE: N_zero/fuo — prover for field-universes-ok-skip-params not yet implemented
N_zero/fuo : field-universes-ok-skip-params liz (econst "N" lnil) (lsucc lzero).

N_zero/name : name "N.zero" (is-decl (econst "N" lnil) ctor).

N_zero/decl : declared "N.zero" (econst "N" lnil) ctor
   = declared/ok N_zero/name (dkind-ok/ctor N_zero/type-wf N_zero/positivity N/decl N_zero/eisl N_zero/fuo).

%% ctor N.succ (of N)
N_succ/type-wf-sort : lvl
   = (limax (lsucc lzero) (lsucc lzero)).

N_succ/type-wf : of (eforall (econst "N" lnil) ([x] (econst "N" lnil))) (esort N_succ/type-wf-sort)
   = (defeq/forall
       (defeq/const N/decl (inst-expr/sort (lvl-inst/succ lvl-inst/zero)))
       ([x]
         ([h]
           (defeq/const
             N/decl
             (inst-expr/sort (lvl-inst/succ lvl-inst/zero)))))).

N_succ/positivity : ctor-positive "N" lnil (eforall (econst "N" lnil) ([x] (econst "N" lnil)))
   = (ctor-positive/intro ([S] (eforall S ([x] S))) (ctor-spine/arg
       (strict-pos/head applies-self/refl)
       ([x] ([y] (ctor-spine/result applies-self/refl))))).

N_succ/eisl : ends-in-sort-with-level (esort (lsucc lzero)) (lsucc lzero)
   = ends-in-sort-with-level/sort.

%%% HOLE: N_succ/fuo — prover for field-universes-ok-skip-params not yet implemented
N_succ/fuo : field-universes-ok-skip-params liz (eforall (econst "N" lnil) ([x] (econst "N" lnil))) (lsucc lzero).

N_succ/name : name "N.succ" (is-decl (eforall (econst "N" lnil) ([x] (econst "N" lnil))) ctor).

N_succ/decl : declared "N.succ" (eforall (econst "N" lnil) ([x] (econst "N" lnil))) ctor
   = declared/ok N_succ/name (dkind-ok/ctor N_succ/type-wf N_succ/positivity N/decl N_succ/eisl N_succ/fuo).

%% recursor N.rec
N_rec/type-wf-sort : lvl
   = (limax
       (limax (lsucc lzero) (lsucc (lvar liz)))
       (limax
         (lvar liz)
         (limax
           (limax (lsucc lzero) (limax (lvar liz) (lvar liz)))
           (limax (lsucc lzero) (lvar liz))))).

N_rec/type-wf : of (eforall (eforall (econst "N" lnil) ([x] (esort (lvar liz))))
                  ([x]
                    (eforall (eapp x (econst "N.zero" lnil))
                      ([y]
                        (eforall (eforall (econst "N" lnil) ([z] (eforall (eapp x z) ([w] (eapp x (eapp (econst "N.succ" lnil) z))))))
                          ([z] (eforall (econst "N" lnil) ([w] (eapp x w))))))))) (esort N_rec/type-wf-sort)
   = (defeq/forall
       (defeq/forall
         (defeq/const N/decl (inst-expr/sort (lvl-inst/succ lvl-inst/zero)))
         ([x] ([h] defeq/sort-refl)))
       ([x]
         ([h]
           (defeq/forall
             (defeq/app
               h
               (defeq/const N_zero/decl (inst-expr/const lvls-inst/nil)))
             ([y]
               ([h1]
                 (defeq/forall
                   (defeq/forall
                     (defeq/const
                       N/decl
                       (inst-expr/sort (lvl-inst/succ lvl-inst/zero)))
                     ([z]
                       ([h2]
                         (defeq/forall
                           (defeq/app h h2)
                           ([w]
                             ([h3]
                               (defeq/app
                                 h
                                 (defeq/app
                                   (defeq/const
                                     N_succ/decl
                                     (inst-expr/forall
                                       (inst-expr/const lvls-inst/nil)
                                       ([x]
                                         ([h]
                                           (inst-expr/const lvls-inst/nil)))))
                                   h2))))))))
                   ([z]
                     ([h2]
                       (defeq/forall
                         (defeq/const
                           N/decl
                           (inst-expr/sort (lvl-inst/succ lvl-inst/zero)))
                         ([w] ([h3] (defeq/app h h3))))))))))))).

N_rec/decl : declared "N.rec" (eforall (eforall (econst "N" lnil) ([x] (esort (lvar liz))))
                                ([x]
                                  (eforall (eapp x (econst "N.zero" lnil))
                                    ([y]
                                      (eforall (eforall (econst "N" lnil) ([z] (eforall (eapp x z) ([w] (eapp x (eapp (econst "N.succ" lnil) z))))))
                                        ([z] (eforall (econst "N" lnil) ([w] (eapp x w))))))))) irec
   = declared/ok-irec N/rec-name (dkind-ok/irec N_rec/type-wf).

%% def projNotStruct
projNotStruct/type-wf-sort : lvl
   = (limax (lsucc lzero) (lsucc lzero)).

projNotStruct/type-wf : of (eforall (econst "N" lnil) ([x] (econst "N" lnil))) (esort projNotStruct/type-wf-sort)
   = (defeq/forall
       (defeq/const N/decl (inst-expr/sort (lvl-inst/succ lvl-inst/zero)))
       ([x]
         ([h]
           (defeq/const
             N/decl
             (inst-expr/sort (lvl-inst/succ lvl-inst/zero)))))).

%%% HOLE
projNotStruct/value-typed : of (elam (econst "N" lnil) ([x] (eproj "N" 0 x))) (eforall (econst "N" lnil) ([x] (econst "N" lnil))).

projNotStruct/name : name "projNotStruct" (is-decl (eforall (econst "N" lnil) ([x] (econst "N" lnil))) (defn (elam (econst "N" lnil) ([x] (eproj "N" 0 x))))).

projNotStruct/decl : declared "projNotStruct" (eforall (econst "N" lnil) ([x] (econst "N" lnil))) (defn (elam (econst "N" lnil) ([x] (eproj "N" 0 x))))
   = declared/ok projNotStruct/name (dkind-ok/defn projNotStruct/type-wf projNotStruct/value-typed).
