%%% Expected outcome: reject
%%% Rejection: recursive occurrence on the *left* of an arrow,
*behind further arrows* inside a constructor argument.

The constructor argument is a function type `Nat → (I → Nat)`.
%% inductive Nat
Nat/type-wf :
   defeq (esort (lsucc lzero)) (esort (lsucc lzero)) (esort (lsucc (lsucc lzero)))
   = (defeq/sort-refl-at (lsucc lzero)).

Nat/decl : declared "Nat" lnil
   (esort (lsucc lzero))
   indt
   (dkind-ok/indt Nat/type-wf).

%% inductive ctor Nat.zero
Nat_zero/type-wf :
   defeq (econst "Nat" lnil) (econst "Nat" lnil) (esort (lsucc lzero))
   = (defeq/const Nat/decl).

Nat_zero/decl : declared "Nat.zero" lnil
   (econst "Nat" lnil)
   ctor
   (dkind-ok/ctor Nat_zero/type-wf).

%% inductive ctor Nat.succ
Nat_succ/type-wf :
   defeq (eforall (econst "Nat" lnil) ([x] (econst "Nat" lnil))) (eforall (econst "Nat" lnil) ([x] (econst "Nat" lnil))) (esort (limax (lsucc lzero) (lsucc lzero)))
   = (defeq/forall (defeq/const Nat/decl) ([x] [y] (defeq/const Nat/decl))).

Nat_succ/decl : declared "Nat.succ" lnil
   (eforall (econst "Nat" lnil) ([x] (econst "Nat" lnil)))
   ctor
   (dkind-ok/ctor Nat_succ/type-wf).

%% inductive recursor Nat.rec
Nat_rec/type-wf :
   {u : lvl} defeq (eforall (eforall (econst "Nat" lnil) ([x] (esort u))) ([x] (eforall (eapp x (econst "Nat.zero" lnil)) ([y] (eforall (eforall (econst "Nat" lnil) ([z] (eforall (eapp x z) ([w] (eapp x (eapp (econst "Nat.succ" lnil) z)))))) ([z] (eforall (econst "Nat" lnil) ([w] (eapp x w))))))))) (eforall (eforall (econst "Nat" lnil) ([x] (esort u))) ([x] (eforall (eapp x (econst "Nat.zero" lnil)) ([y] (eforall (eforall (econst "Nat" lnil) ([z] (eforall (eapp x z) ([w] (eapp x (eapp (econst "Nat.succ" lnil) z)))))) ([z] (eforall (econst "Nat" lnil) ([w] (eapp x w))))))))) (esort (limax (limax (lsucc lzero) (lsucc u)) (limax u (limax (limax (lsucc lzero) (limax u u)) (limax (lsucc lzero) u)))))
   = [u] (defeq/forall (defeq/forall (defeq/const Nat/decl) ([x] [y] (defeq/sort-refl-at u))) ([x] [y] (defeq/forall (defeq/app y (defeq/const Nat_zero/decl)) ([z] [w] (defeq/forall (defeq/forall (defeq/const Nat/decl) ([x1] [y1] (defeq/forall (defeq/app y y1) ([z1] [w1] (defeq/app y (defeq/app (defeq/const Nat_succ/decl) y1)))))) ([x1] [y1] (defeq/forall (defeq/const Nat/decl) ([z1] [w1] (defeq/app y w1))))))))).

Nat_rec/decl : {u : lvl} declared "Nat.rec" (lcons u lnil)
   (eforall (eforall (econst "Nat" lnil) ([x] (esort u))) ([x] (eforall (eapp x (econst "Nat.zero" lnil)) ([y] (eforall (eforall (econst "Nat" lnil) ([z] (eforall (eapp x z) ([w] (eapp x (eapp (econst "Nat.succ" lnil) z)))))) ([z] (eforall (econst "Nat" lnil) ([w] (eapp x w)))))))))
   irec
   (dkind-ok/irec (Nat_rec/type-wf u)).

%% inductive reflOccLeft
reflOccLeft/type-wf :
   defeq (esort (lsucc lzero)) (esort (lsucc lzero)) (esort (lsucc (lsucc lzero)))
   = (defeq/sort-refl-at (lsucc lzero)).

reflOccLeft/decl : declared "reflOccLeft" lnil
   (esort (lsucc lzero))
   indt
   (dkind-ok/indt reflOccLeft/type-wf).

%% inductive ctor reflOccLeft.mk
reflOccLeft_mk/type-wf :
   defeq (eforall (eforall (econst "Nat" lnil) ([x] (eforall (econst "reflOccLeft" lnil) ([y] (econst "Nat" lnil))))) ([x] (econst "reflOccLeft" lnil))) (eforall (eforall (econst "Nat" lnil) ([x] (eforall (econst "reflOccLeft" lnil) ([y] (econst "Nat" lnil))))) ([x] (econst "reflOccLeft" lnil))) (esort (limax (limax (lsucc lzero) (limax (lsucc lzero) (lsucc lzero))) (lsucc lzero)))
   = (defeq/forall (defeq/forall (defeq/const Nat/decl) ([x] [y] (defeq/forall (defeq/const reflOccLeft/decl) ([z] [w] (defeq/const Nat/decl))))) ([x] [y] (defeq/const reflOccLeft/decl))).

reflOccLeft_mk/decl : declared "reflOccLeft.mk" lnil
   (eforall (eforall (econst "Nat" lnil) ([x] (eforall (econst "reflOccLeft" lnil) ([y] (econst "Nat" lnil))))) ([x] (econst "reflOccLeft" lnil)))
   ctor
   (dkind-ok/ctor reflOccLeft_mk/type-wf).

%% inductive recursor reflOccLeft.rec
reflOccLeft_rec/type-wf :
   defeq (esort lzero) (esort lzero) (esort (lsucc lzero))
   = (defeq/sort-refl-at lzero).

reflOccLeft_rec/decl : declared "reflOccLeft.rec" lnil
   (esort lzero)
   irec
   (dkind-ok/irec reflOccLeft_rec/type-wf).

%mode declared +N +LS -T -DK -W.
%worlds () (declared _ _ _ _ _).
%unique declared +N +LS -1T -1DK *W.
