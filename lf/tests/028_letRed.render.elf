%%% Render-only view of: 028_letRed
%%% Reducing a let
%% axiom aProp
%%% HOLE
aProp/type-wf-sort : lvl.

%%% HOLE
aProp/type-wf : of (esort lzero) (esort aProp/type-wf-sort).

aProp/name : name "aProp" (is-decl (esort lzero) ax).

aProp/decl : declared "aProp" (esort lzero) ax
   = declared/ok aProp/name (dkind-ok/ax aProp/type-wf).

%% def letRed
%%% HOLE
letRed/type-wf-sort : lvl.

%%% HOLE
letRed/type-wf : of (eapp (elam (esort (lsucc lzero)) ([x] x)) (esort lzero)) (esort letRed/type-wf-sort).

%%% HOLE
letRed/value-typed : of (econst "aProp" lnil) (eapp (elam (esort (lsucc lzero)) ([x] x)) (esort lzero)).

letRed/name : name "letRed" (is-decl (eapp (elam (esort (lsucc lzero)) ([x] x)) (esort lzero)) (defn (econst "aProp" lnil))).

letRed/decl : declared "letRed" (eapp (elam (esort (lsucc lzero)) ([x] x)) (esort lzero)) (defn (econst "aProp" lnil))
   = declared/ok letRed/name (dkind-ok/defn letRed/type-wf letRed/value-typed).
