%%% Expected outcome: accept
%%% An inductive type can have fields of level up to that of the inductive.
%% inductive TypeWithTypeField
%%% HOLE
TypeWithTypeField/type-wf : defeq (esort (lsucc (lsucc lzero))) (esort (lsucc (lsucc lzero))) (esort lzero).

%%% HOLE
TypeWithTypeField/ends-in-sort : ends-in-sort (esort (lsucc (lsucc lzero))).

TypeWithTypeField/decl : declared "TypeWithTypeField" lnil
   (esort (lsucc (lsucc lzero)))
   indt
   (dkind-ok/indt TypeWithTypeField/type-wf TypeWithTypeField/ends-in-sort).

%% ctor TypeWithTypeField.mk (of TypeWithTypeField)
%%% HOLE
TypeWithTypeField_mk/type-wf : defeq (eforall (esort (lsucc lzero)) ([x] (econst "TypeWithTypeField" lnil))) (eforall (esort (lsucc lzero)) ([x] (econst "TypeWithTypeField" lnil))) (esort lzero).

%%% HOLE
TypeWithTypeField_mk/positivity : ctor-positive "TypeWithTypeField" lnil (eforall (esort (lsucc lzero)) ([x] (econst "TypeWithTypeField" lnil))).

TypeWithTypeField_mk/decl : declared "TypeWithTypeField.mk" lnil
   (eforall (esort (lsucc lzero)) ([x] (econst "TypeWithTypeField" lnil)))
   ctor
   (dkind-ok/ctor TypeWithTypeField_mk/type-wf TypeWithTypeField_mk/positivity).

%% recursor TypeWithTypeField.rec
%%% HOLE
TypeWithTypeField_rec/type-wf : {u : lvl} defeq (eforall (eforall (econst "TypeWithTypeField" lnil) ([x] (esort u))) ([x] (eforall (eforall (esort (lsucc lzero)) ([y] (eapp x (eapp (econst "TypeWithTypeField.mk" lnil) y)))) ([y] (eforall (econst "TypeWithTypeField" lnil) ([z] (eapp x z))))))) (eforall (eforall (econst "TypeWithTypeField" lnil) ([x] (esort u))) ([x] (eforall (eforall (esort (lsucc lzero)) ([y] (eapp x (eapp (econst "TypeWithTypeField.mk" lnil) y)))) ([y] (eforall (econst "TypeWithTypeField" lnil) ([z] (eapp x z))))))) (esort lzero).

TypeWithTypeField_rec/decl : {u : lvl} declared "TypeWithTypeField.rec" (lcons u lnil)
   (eforall (eforall (econst "TypeWithTypeField" lnil) ([x] (esort u))) ([x] (eforall (eforall (esort (lsucc lzero)) ([y] (eapp x (eapp (econst "TypeWithTypeField.mk" lnil) y)))) ([y] (eforall (econst "TypeWithTypeField" lnil) ([z] (eapp x z)))))))
   irec
   (dkind-ok/irec (TypeWithTypeField_rec/type-wf u)).

%% def typeWithTypeField
%%% HOLE
typeWithTypeField/type-wf : defeq (esort (lsucc (lsucc lzero))) (esort (lsucc (lsucc lzero))) (esort lzero).

%%% HOLE
typeWithTypeField/value-typed : defeq (econst "TypeWithTypeField" lnil) (econst "TypeWithTypeField" lnil) (esort (lsucc (lsucc lzero))).

typeWithTypeField/decl : declared "typeWithTypeField" lnil
   (esort (lsucc (lsucc lzero)))
   (defn (econst "TypeWithTypeField" lnil))
   (dkind-ok/defn typeWithTypeField/type-wf typeWithTypeField/value-typed).

