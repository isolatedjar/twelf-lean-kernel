%%% Expected outcome: accept
%%% An inductive type can have fields of level up to that of the inductive.
%% inductive TypeWithTypeField
TypeWithTypeField/type-wf-sort : lvl
   = (lsucc (lsucc (lsucc lzero))).

TypeWithTypeField/type-wf : of (esort (lsucc (lsucc lzero))) (esort TypeWithTypeField/type-wf-sort)
   = defeq/sort-refl.

TypeWithTypeField/ends-in-sort : ends-in-sort (esort (lsucc (lsucc lzero)))
   = ends-in-sort/sort.

TypeWithTypeField/rec-name : name "TypeWithTypeField.rec" (is-rec-for "TypeWithTypeField").

TypeWithTypeField/name : name "TypeWithTypeField" (is-decl (esort (lsucc (lsucc lzero))) indt).

TypeWithTypeField/decl : declared "TypeWithTypeField" (esort (lsucc (lsucc lzero))) indt
   = declared/ok TypeWithTypeField/name (dkind-ok/indt TypeWithTypeField/type-wf TypeWithTypeField/ends-in-sort).

%% ctor TypeWithTypeField.mk (of TypeWithTypeField)
TypeWithTypeField_mk/type-wf-sort : lvl
   = (limax (lsucc (lsucc lzero)) (lsucc (lsucc lzero))).

TypeWithTypeField_mk/type-wf : of (eforall (esort (lsucc lzero)) ([x] (econst "TypeWithTypeField" lnil))) (esort TypeWithTypeField_mk/type-wf-sort)
   = (defeq/forall
       defeq/sort-refl
       ([x]
         ([h]
           (defeq/const
             TypeWithTypeField/decl
             (inst-expr/sort (lvl-inst/succ (lvl-inst/succ lvl-inst/zero))))))).

TypeWithTypeField_mk/positivity : ctor-positive "TypeWithTypeField" lnil (eforall (esort (lsucc lzero)) ([x] (econst "TypeWithTypeField" lnil)))
   = (ctor-positive/intro ([S] (eforall (esort (lsucc lzero)) ([x] S))) (ctor-spine/arg
       (strict-pos/no-occur (esort (lsucc lzero)) no-self-ref/sort)
       ([x] ([y] (ctor-spine/result applies-self/refl))))).

TypeWithTypeField_mk/name : name "TypeWithTypeField.mk" (is-decl (eforall (esort (lsucc lzero)) ([x] (econst "TypeWithTypeField" lnil))) ctor).

TypeWithTypeField_mk/decl : declared "TypeWithTypeField.mk" (eforall (esort (lsucc lzero)) ([x] (econst "TypeWithTypeField" lnil))) ctor
   = declared/ok TypeWithTypeField_mk/name (dkind-ok/ctor TypeWithTypeField_mk/type-wf TypeWithTypeField_mk/positivity).

%% recursor TypeWithTypeField.rec
TypeWithTypeField_rec/type-wf-sort : lvl
   = (limax
       (limax (lsucc (lsucc lzero)) (lsucc (lvar liz)))
       (limax
         (limax (lsucc (lsucc lzero)) (lvar liz))
         (limax (lsucc (lsucc lzero)) (lvar liz)))).

TypeWithTypeField_rec/type-wf : of (eforall (eforall (econst "TypeWithTypeField" lnil) ([x] (esort (lvar liz))))
                                  ([x]
                                    (eforall (eforall (esort (lsucc lzero)) ([y] (eapp x (eapp (econst "TypeWithTypeField.mk" lnil) y))))
                                      ([y] (eforall (econst "TypeWithTypeField" lnil) ([z] (eapp x z))))))) (esort TypeWithTypeField_rec/type-wf-sort)
   = (defeq/forall
       (defeq/forall
         (defeq/const
           TypeWithTypeField/decl
           (inst-expr/sort (lvl-inst/succ (lvl-inst/succ lvl-inst/zero))))
         ([x] ([h] defeq/sort-refl)))
       ([x]
         ([h]
           (defeq/forall
             (defeq/forall
               defeq/sort-refl
               ([y]
                 ([h1]
                   (defeq/app
                     h
                     (defeq/app
                       (defeq/const
                         TypeWithTypeField_mk/decl
                         (inst-expr/forall
                           (inst-expr/sort (lvl-inst/succ lvl-inst/zero))
                           ([x] ([h] (inst-expr/const lvls-inst/nil)))))
                       h1)))))
             ([y]
               ([h1]
                 (defeq/forall
                   (defeq/const
                     TypeWithTypeField/decl
                     (inst-expr/sort
                       (lvl-inst/succ (lvl-inst/succ lvl-inst/zero))))
                   ([z] ([h2] (defeq/app h h2)))))))))).

TypeWithTypeField_rec/decl : declared "TypeWithTypeField.rec" (eforall (eforall (econst "TypeWithTypeField" lnil) ([x] (esort (lvar liz)))) ([x] (eforall (eforall (esort (lsucc lzero)) ([y] (eapp x (eapp (econst "TypeWithTypeField.mk" lnil) y)))) ([y] (eforall (econst "TypeWithTypeField" lnil) ([z] (eapp x z))))))) irec
   = declared/ok-irec TypeWithTypeField/rec-name (dkind-ok/irec TypeWithTypeField_rec/type-wf).

%% def typeWithTypeField
typeWithTypeField/type-wf-sort : lvl
   = (lsucc (lsucc (lsucc lzero))).

typeWithTypeField/type-wf : of (esort (lsucc (lsucc lzero))) (esort typeWithTypeField/type-wf-sort)
   = defeq/sort-refl.

typeWithTypeField/value-typed : of (econst "TypeWithTypeField" lnil) (esort (lsucc (lsucc lzero)))
   = (defeq/const
       TypeWithTypeField/decl
       (inst-expr/sort (lvl-inst/succ (lvl-inst/succ lvl-inst/zero)))).

typeWithTypeField/name : name "typeWithTypeField" (is-decl (esort (lsucc (lsucc lzero))) (defn (econst "TypeWithTypeField" lnil))).

typeWithTypeField/decl : declared "typeWithTypeField" (esort (lsucc (lsucc lzero))) (defn (econst "TypeWithTypeField" lnil))
   = declared/ok typeWithTypeField/name (dkind-ok/defn typeWithTypeField/type-wf typeWithTypeField/value-typed).
