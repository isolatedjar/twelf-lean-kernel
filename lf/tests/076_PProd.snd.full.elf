%%% Expected outcome: accept
%%% Type-checking projection functions
%% inductive PProd
%%% HOLE
PProd/type-wf-sort : {u : lvl} {v : lvl} lvl.

%%% HOLE
PProd/type-wf : {u : lvl} {v : lvl} defeq (eforall (esort u) ([x] (eforall (esort v) ([y] (esort (lmax (lmax (lsucc lzero) u) v)))))) (eforall (esort u) ([x] (eforall (esort v) ([y] (esort (lmax (lmax (lsucc lzero) u) v)))))) (esort (PProd/type-wf-sort u v)).

%%% HOLE
PProd/ends-in-sort : {u : lvl} {v : lvl} ends-in-sort (eforall (esort u) ([x] (eforall (esort v) ([y] (esort (lmax (lmax (lsucc lzero) u) v)))))).

PProd/name : {u : lvl} {v : lvl} name "PProd" (is-decl (lcons u (lcons v lnil)) (eforall (esort u) ([x] (eforall (esort v) ([y] (esort (lmax (lmax (lsucc lzero) u) v)))))) indt).

PProd/decl : {u : lvl} {v : lvl} declared "PProd" (lcons u (lcons v lnil))
   (eforall (esort u) ([x] (eforall (esort v) ([y] (esort (lmax (lmax (lsucc lzero) u) v))))))
   indt
   (PProd/name u v)
   (dkind-ok/indt (PProd/type-wf u v) (PProd/ends-in-sort u v)).

%% ctor PProd.mk (of PProd)
%%% HOLE
PProd_mk/type-wf-sort : {u : lvl} {v : lvl} lvl.

%%% HOLE
PProd_mk/type-wf : {u : lvl} {v : lvl} defeq (eforall (esort u) ([x] (eforall (esort v) ([y] (eforall x ([z] (eforall y ([w] (eapp (eapp (econst "PProd" (lcons u (lcons v lnil))) x) y))))))))) (eforall (esort u) ([x] (eforall (esort v) ([y] (eforall x ([z] (eforall y ([w] (eapp (eapp (econst "PProd" (lcons u (lcons v lnil))) x) y))))))))) (esort (PProd_mk/type-wf-sort u v)).

%%% HOLE
PProd_mk/positivity : {u : lvl} {v : lvl} ctor-positive "PProd" (lcons u (lcons v lnil)) (eforall (esort u) ([x] (eforall (esort v) ([y] (eforall x ([z] (eforall y ([w] (eapp (eapp (econst "PProd" (lcons u (lcons v lnil))) x) y))))))))).

PProd_mk/name : {u : lvl} {v : lvl} name "PProd.mk" (is-decl (lcons u (lcons v lnil)) (eforall (esort u) ([x] (eforall (esort v) ([y] (eforall x ([z] (eforall y ([w] (eapp (eapp (econst "PProd" (lcons u (lcons v lnil))) x) y))))))))) ctor).

PProd_mk/decl : {u : lvl} {v : lvl} declared "PProd.mk" (lcons u (lcons v lnil))
   (eforall (esort u) ([x] (eforall (esort v) ([y] (eforall x ([z] (eforall y ([w] (eapp (eapp (econst "PProd" (lcons u (lcons v lnil))) x) y)))))))))
   ctor
   (PProd_mk/name u v)
   (dkind-ok/ctor (PProd_mk/type-wf u v) (PProd_mk/positivity u v)).

%% recursor PProd.rec
%%% HOLE
PProd_rec/type-wf-sort : {u_1 : lvl} {u : lvl} {v : lvl} lvl.

%%% HOLE
PProd_rec/type-wf : {u_1 : lvl} {u : lvl} {v : lvl} defeq (eforall (esort u) ([x] (eforall (esort v) ([y] (eforall (eforall (eapp (eapp (econst "PProd" (lcons u (lcons v lnil))) x) y) ([z] (esort u_1))) ([z] (eforall (eforall x ([w] (eforall y ([x1] (eapp z (eapp (eapp (eapp (eapp (econst "PProd.mk" (lcons u (lcons v lnil))) x) y) w) x1)))))) ([w] (eforall (eapp (eapp (econst "PProd" (lcons u (lcons v lnil))) x) y) ([x1] (eapp z x1))))))))))) (eforall (esort u) ([x] (eforall (esort v) ([y] (eforall (eforall (eapp (eapp (econst "PProd" (lcons u (lcons v lnil))) x) y) ([z] (esort u_1))) ([z] (eforall (eforall x ([w] (eforall y ([x1] (eapp z (eapp (eapp (eapp (eapp (econst "PProd.mk" (lcons u (lcons v lnil))) x) y) w) x1)))))) ([w] (eforall (eapp (eapp (econst "PProd" (lcons u (lcons v lnil))) x) y) ([x1] (eapp z x1))))))))))) (esort (PProd_rec/type-wf-sort u_1 u v)).

PProd_rec/name : {u_1 : lvl} {u : lvl} {v : lvl} name "PProd.rec" (is-decl (lcons u_1 (lcons u (lcons v lnil))) (eforall (esort u) ([x] (eforall (esort v) ([y] (eforall (eforall (eapp (eapp (econst "PProd" (lcons u (lcons v lnil))) x) y) ([z] (esort u_1))) ([z] (eforall (eforall x ([w] (eforall y ([x1] (eapp z (eapp (eapp (eapp (eapp (econst "PProd.mk" (lcons u (lcons v lnil))) x) y) w) x1)))))) ([w] (eforall (eapp (eapp (econst "PProd" (lcons u (lcons v lnil))) x) y) ([x1] (eapp z x1))))))))))) irec).

PProd_rec/decl : {u_1 : lvl} {u : lvl} {v : lvl} declared "PProd.rec" (lcons u_1 (lcons u (lcons v lnil)))
   (eforall (esort u) ([x] (eforall (esort v) ([y] (eforall (eforall (eapp (eapp (econst "PProd" (lcons u (lcons v lnil))) x) y) ([z] (esort u_1))) ([z] (eforall (eforall x ([w] (eforall y ([x1] (eapp z (eapp (eapp (eapp (eapp (econst "PProd.mk" (lcons u (lcons v lnil))) x) y) w) x1)))))) ([w] (eforall (eapp (eapp (econst "PProd" (lcons u (lcons v lnil))) x) y) ([x1] (eapp z x1)))))))))))
   irec
   (PProd_rec/name u_1 u v)
   (dkind-ok/irec (PProd_rec/type-wf u_1 u v)).

%% def PProd.fst
%%% HOLE
PProd_fst/type-wf-sort : {u : lvl} {v : lvl} lvl.

%%% HOLE
PProd_fst/type-wf : {u : lvl} {v : lvl} defeq (eforall (esort u) ([x] (eforall (esort v) ([y] (eforall (eapp (eapp (econst "PProd" (lcons u (lcons v lnil))) x) y) ([z] x)))))) (eforall (esort u) ([x] (eforall (esort v) ([y] (eforall (eapp (eapp (econst "PProd" (lcons u (lcons v lnil))) x) y) ([z] x)))))) (esort (PProd_fst/type-wf-sort u v)).

%%% HOLE
PProd_fst/value-typed : {u : lvl} {v : lvl} defeq (elam (esort u) ([x] (elam (esort v) ([y] (elam (eapp (eapp (econst "PProd" (lcons u (lcons v lnil))) x) y) ([z] (eproj "PProd" 0 z))))))) (elam (esort u) ([x] (elam (esort v) ([y] (elam (eapp (eapp (econst "PProd" (lcons u (lcons v lnil))) x) y) ([z] (eproj "PProd" 0 z))))))) (eforall (esort u) ([x] (eforall (esort v) ([y] (eforall (eapp (eapp (econst "PProd" (lcons u (lcons v lnil))) x) y) ([z] x)))))).

PProd_fst/name : {u : lvl} {v : lvl} name "PProd.fst" (is-decl (lcons u (lcons v lnil)) (eforall (esort u) ([x] (eforall (esort v) ([y] (eforall (eapp (eapp (econst "PProd" (lcons u (lcons v lnil))) x) y) ([z] x)))))) (defn (elam (esort u) ([x] (elam (esort v) ([y] (elam (eapp (eapp (econst "PProd" (lcons u (lcons v lnil))) x) y) ([z] (eproj "PProd" 0 z))))))))).

PProd_fst/decl : {u : lvl} {v : lvl} declared "PProd.fst" (lcons u (lcons v lnil))
   (eforall (esort u) ([x] (eforall (esort v) ([y] (eforall (eapp (eapp (econst "PProd" (lcons u (lcons v lnil))) x) y) ([z] x))))))
   (defn (elam (esort u) ([x] (elam (esort v) ([y] (elam (eapp (eapp (econst "PProd" (lcons u (lcons v lnil))) x) y) ([z] (eproj "PProd" 0 z))))))))
   (PProd_fst/name u v)
   (dkind-ok/defn (PProd_fst/type-wf u v) (PProd_fst/value-typed u v)).

%% def PProd.snd
%%% HOLE
PProd_snd/type-wf-sort : {u : lvl} {v : lvl} lvl.

%%% HOLE
PProd_snd/type-wf : {u : lvl} {v : lvl} defeq (eforall (esort u) ([x] (eforall (esort v) ([y] (eforall (eapp (eapp (econst "PProd" (lcons u (lcons v lnil))) x) y) ([z] y)))))) (eforall (esort u) ([x] (eforall (esort v) ([y] (eforall (eapp (eapp (econst "PProd" (lcons u (lcons v lnil))) x) y) ([z] y)))))) (esort (PProd_snd/type-wf-sort u v)).

%%% HOLE
PProd_snd/value-typed : {u : lvl} {v : lvl} defeq (elam (esort u) ([x] (elam (esort v) ([y] (elam (eapp (eapp (econst "PProd" (lcons u (lcons v lnil))) x) y) ([z] (eproj "PProd" 1 z))))))) (elam (esort u) ([x] (elam (esort v) ([y] (elam (eapp (eapp (econst "PProd" (lcons u (lcons v lnil))) x) y) ([z] (eproj "PProd" 1 z))))))) (eforall (esort u) ([x] (eforall (esort v) ([y] (eforall (eapp (eapp (econst "PProd" (lcons u (lcons v lnil))) x) y) ([z] y)))))).

PProd_snd/name : {u : lvl} {v : lvl} name "PProd.snd" (is-decl (lcons u (lcons v lnil)) (eforall (esort u) ([x] (eforall (esort v) ([y] (eforall (eapp (eapp (econst "PProd" (lcons u (lcons v lnil))) x) y) ([z] y)))))) (defn (elam (esort u) ([x] (elam (esort v) ([y] (elam (eapp (eapp (econst "PProd" (lcons u (lcons v lnil))) x) y) ([z] (eproj "PProd" 1 z))))))))).

PProd_snd/decl : {u : lvl} {v : lvl} declared "PProd.snd" (lcons u (lcons v lnil))
   (eforall (esort u) ([x] (eforall (esort v) ([y] (eforall (eapp (eapp (econst "PProd" (lcons u (lcons v lnil))) x) y) ([z] y))))))
   (defn (elam (esort u) ([x] (elam (esort v) ([y] (elam (eapp (eapp (econst "PProd" (lcons u (lcons v lnil))) x) y) ([z] (eproj "PProd" 1 z))))))))
   (PProd_snd/name u v)
   (dkind-ok/defn (PProd_snd/type-wf u v) (PProd_snd/value-typed u v)).

