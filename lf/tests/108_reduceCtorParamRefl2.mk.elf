%%% Expected outcome: accept
%%% When checking inductives, we expect the kernel to reduce the types of constructor arguments in all
%%% positive positions.
%% def id
id/type-wf :
   {u : lvl} defeq (eforall (esort u) ([x] (eforall x ([y] x)))) (eforall (esort u) ([x] (eforall x ([y] x)))) (esort (limax (lsucc u) (limax u u)))
   = [u] (defeq/forall (defeq/sort-refl-at u) ([x] [y] (defeq/forall y ([z] [w] y)))).

id/value-typed :
   {u : lvl} defeq (elam (esort u) ([x] (elam x ([y] y)))) (elam (esort u) ([x] (elam x ([y] y)))) (eforall (esort u) ([x] (eforall x ([y] x))))
   = [u] (defeq/lam (defeq/sort-refl-at u) ([x] [y] (defeq/lam y ([z] [w] w)))).

id/decl : {u : lvl} declared "id" (lcons u lnil)
   (eforall (esort u) ([x] (eforall x ([y] x))))
   (defn (elam (esort u) ([x] (elam x ([y] y)))))
   (dkind-ok/defn (id/type-wf u) (id/value-typed u)).

%% def constType
constType/type-wf :
   defeq (eforall (esort (lsucc lzero)) ([x] (eforall (esort (lsucc lzero)) ([y] (esort (lsucc lzero)))))) (eforall (esort (lsucc lzero)) ([x] (eforall (esort (lsucc lzero)) ([y] (esort (lsucc lzero)))))) (esort (limax (lsucc (lsucc lzero)) (limax (lsucc (lsucc lzero)) (lsucc (lsucc lzero)))))
   = (defeq/forall (defeq/sort-refl-at (lsucc lzero)) ([x] [y] (defeq/forall (defeq/sort-refl-at (lsucc lzero)) ([z] [w] (defeq/sort-refl-at (lsucc lzero)))))).

constType/value-typed :
   defeq (elam (esort (lsucc lzero)) ([x] (elam (esort (lsucc lzero)) ([y] x)))) (elam (esort (lsucc lzero)) ([x] (elam (esort (lsucc lzero)) ([y] x)))) (eforall (esort (lsucc lzero)) ([x] (eforall (esort (lsucc lzero)) ([y] (esort (lsucc lzero))))))
   = (defeq/lam (defeq/sort-refl-at (lsucc lzero)) ([x] [y] (defeq/lam (defeq/sort-refl-at (lsucc lzero)) ([z] [w] y)))).

constType/decl : declared "constType" lnil
   (eforall (esort (lsucc lzero)) ([x] (eforall (esort (lsucc lzero)) ([y] (esort (lsucc lzero))))))
   (defn (elam (esort (lsucc lzero)) ([x] (elam (esort (lsucc lzero)) ([y] x)))))
   (dkind-ok/defn constType/type-wf constType/value-typed).

%% inductive reduceCtorParamRefl2
reduceCtorParamRefl2/type-wf :
   defeq (eforall (esort (lsucc lzero)) ([x] (esort (lsucc lzero)))) (eforall (esort (lsucc lzero)) ([x] (esort (lsucc lzero)))) (esort (limax (lsucc (lsucc lzero)) (lsucc (lsucc lzero))))
   = (defeq/forall (defeq/sort-refl-at (lsucc lzero)) ([x] [y] (defeq/sort-refl-at (lsucc lzero)))).

reduceCtorParamRefl2/ends-in-sort :
   ends-in-sort (eforall (esort (lsucc lzero)) ([x] (esort (lsucc lzero))))
   = (ends-in-sort/forall ([x] ends-in-sort/sort)).

reduceCtorParamRefl2/decl : declared "reduceCtorParamRefl2" lnil
   (eforall (esort (lsucc lzero)) ([x] (esort (lsucc lzero))))
   indt
   (dkind-ok/indt reduceCtorParamRefl2/type-wf reduceCtorParamRefl2/ends-in-sort).

