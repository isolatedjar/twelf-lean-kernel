PProd_rec/type-wf-sort : lvl
   = (limax
       (lsucc (lvar (lis liz)))
       (limax
         (lsucc (lvar (lis (lis liz))))
         (limax
           (limax
             (lmax (lmax (lsucc lzero) (lvar (lis liz))) (lvar (lis (lis liz))))
             (lsucc (lvar liz)))
           (limax
             (limax (lvar (lis liz)) (limax (lvar (lis (lis liz))) (lvar liz)))
             (limax
               (lmax
                 (lmax (lsucc lzero) (lvar (lis liz)))
                 (lvar (lis (lis liz))))
               (lvar liz)))))).

