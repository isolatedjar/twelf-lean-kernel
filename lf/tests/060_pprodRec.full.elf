                                               lvl-nth/zero)))))))))))
                         h)
                       h1)
                     ([z] ([h2] defeq/sort-refl)))
                   ([z]
                     ([h2]
                       (defeq/forall
                         (defeq/forall
                           h
                           ([w]
                             ([h3]
