                                 h1
                                 ([x1]
                                   ([h4]
                                     (defeq/app
                                       h2
                                       (defeq/app
                                         (defeq/app
                                           (defeq/app
                                             (defeq/app
                                               (defeq/const
                                                 PProd_mk/decl
                                                 (inst-expr/forall
