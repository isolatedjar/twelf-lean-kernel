%%% Expected outcome: accept
%%% Asserting the type of the generated recursor
%% inductive PProd
PProd/type-wf-sort : lvl
   = (limax
       (lsucc (lvar liz))
       (limax
         (lsucc (lvar (lis liz)))
         (lsucc (lmax (lmax (lsucc lzero) (lvar liz)) (lvar (lis liz)))))).

PProd/type-wf : of (eforall (esort (lvar liz)) ([x] (eforall (esort (lvar (lis liz))) ([y] (esort (lmax (lmax (lsucc lzero) (lvar liz)) (lvar (lis liz)))))))) (esort PProd/type-wf-sort)
   = (defeq/forall
       defeq/sort-refl
       ([x] ([h] (defeq/forall defeq/sort-refl ([y] ([h1] defeq/sort-refl)))))).

PProd/ends-in-sort : ends-in-sort (eforall (esort (lvar liz)) ([x] (eforall (esort (lvar (lis liz))) ([y] (esort (lmax (lmax (lsucc lzero) (lvar liz)) (lvar (lis liz))))))))
   = (ends-in-sort/forall ([x] (ends-in-sort/forall ([y] ends-in-sort/sort)))).

PProd/rec-name : name "PProd.rec" (is-rec-for "PProd").

PProd/clf : count-leading-foralls (eforall (esort (lvar liz)) ([x] (eforall (esort (lvar (lis liz))) ([y] (esort (lmax (lmax (lsucc lzero) (lvar liz)) (lvar (lis liz)))))))) (lis (lis liz))
   = (count-leading-foralls/succ
       ([x]
         (count-leading-foralls/succ
           ([y] (count-leading-foralls/zero not-forall/sort))))).

PProd/cnd : cnames-distinct (ccons "PProd.mk" cnil)
   = (cnames-distinct/cons cnames-distinct/nil all-string-neq/nil).

PProd/name : name "PProd" (is-decl
  (eforall (esort (lvar liz)) ([x] (eforall (esort (lvar (lis liz))) ([y] (esort (lmax (lmax (lsucc lzero) (lvar liz)) (lvar (lis liz))))))))
  (indt (ccons "PProd.mk" cnil) (lis (lis liz)))).

PProd/decl : declared "PProd"
  (eforall (esort (lvar liz)) ([x] (eforall (esort (lvar (lis liz))) ([y] (esort (lmax (lmax (lsucc lzero) (lvar liz)) (lvar (lis liz))))))))
  (indt (ccons "PProd.mk" cnil) (lis (lis liz)))
   = declared/ok-indt PProd/name PProd/rec-name PProd/clf PProd/cnd (dkind-ok/indt PProd/type-wf PProd/ends-in-sort).

%% ctor PProd.mk (of PProd)
PProd_mk/type-wf-sort : lvl
   = (limax
       (lsucc (lvar liz))
       (limax
         (lsucc (lvar (lis liz)))
         (limax
           (lvar liz)
           (limax
             (lvar (lis liz))
             (lmax (lmax (lsucc lzero) (lvar liz)) (lvar (lis liz))))))).

PProd_mk/type-wf : of
  (eforall (esort (lvar liz)) ([x] (eforall (esort (lvar (lis liz))) ([y] (eforall x ([z] (eforall y ([w] (eapp (eapp (econst "PProd" (lcons (lvar liz) (lcons (lvar (lis liz)) lnil))) x) y)))))))))
  (esort PProd_mk/type-wf-sort)
   = (defeq/forall
       defeq/sort-refl
       ([x]
         ([h]
           (defeq/forall
             defeq/sort-refl
             ([y]
               ([h1]
                 (defeq/forall
                   h
                   ([z]
                     ([h2]
                       (defeq/forall
                         h1
                         ([w]
                           ([h3]
                             (defeq/app
                               (defeq/app
                                 (defeq/const
                                   PProd/decl
                                   (inst-expr/forall
                                     (inst-expr/sort
                                       (lvl-inst/var lvl-nth/zero))
                                     ([x]
                                       ([h]
                                         (inst-expr/forall
                                           (inst-expr/sort
                                             (lvl-inst/var
                                               (lvl-nth/succ lvl-nth/zero)))
                                           ([y]
                                             ([h1]
                                               (inst-expr/sort
                                                 (lvl-inst/max
                                                   (lvl-inst/max
                                                     (lvl-inst/succ
                                                       lvl-inst/zero)
                                                     (lvl-inst/var
                                                       lvl-nth/zero))
                                                   (lvl-inst/var
                                                     (lvl-nth/succ
                                                       lvl-nth/zero)))))))))))
                                 h)
                               h1))))))))))))).

PProd_mk/positivity : ctor-positive "PProd" (lcons (lvar liz) (lcons (lvar (lis liz)) lnil)) (eforall (esort (lvar liz)) ([x] (eforall (esort (lvar (lis liz))) ([y] (eforall x ([z] (eforall y ([w] (eapp (eapp (econst "PProd" (lcons (lvar liz) (lcons (lvar (lis liz)) lnil))) x) y)))))))))
   = (ctor-positive/intro ([S] (eforall (esort (lvar liz)) ([x] (eforall (esort (lvar (lis liz))) ([y] (eforall x ([z] (eforall y ([w] (eapp (eapp S x) y)))))))))) (ctor-spine/arg
       (strict-pos/no-occur (esort (lvar liz)) no-self-ref/sort)
       ([x]
         ([y]
           (ctor-spine/arg
             (strict-pos/no-occur (esort (lvar (lis liz))) no-self-ref/sort)
             ([z]
               ([w]
                 (ctor-spine/arg
                   (strict-pos/no-occur x y)
                   ([x1]
                     ([y1]
                       (ctor-spine/arg
                         (strict-pos/no-occur z w)
                         ([z1]
                           ([w1]
                             (ctor-spine/result
                               (applies-self/app
                                 (applies-self/app
                                   applies-self/refl)))))))))))))))).

PProd_mk/eisl : ends-in-sort-with-level (eforall (esort (lvar liz)) ([x] (eforall (esort (lvar (lis liz))) ([y] (esort (lmax (lmax (lsucc lzero) (lvar liz)) (lvar (lis liz)))))))) (lmax (lmax (lsucc lzero) (lvar liz)) (lvar (lis liz)))
   = (ends-in-sort-with-level/forall
       ([x]
         (ends-in-sort-with-level/forall ([y] ends-in-sort-with-level/sort)))).

PProd_mk/cmem : cmem "PProd.mk" (ccons "PProd.mk" cnil)
   = cmem/here.

