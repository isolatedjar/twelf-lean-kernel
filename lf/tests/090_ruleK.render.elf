Bool_false/name : name "Bool.false" (is-decl lnil (econst "Bool" lnil) ctor).

Bool_false/decl : declared "Bool.false" lnil (econst "Bool" lnil) ctor
   = declared/ok Bool_false/name (dkind-ok/ctor Bool_false/type-wf Bool_false/positivity).

