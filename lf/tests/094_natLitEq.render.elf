%%% Render-only view of: 094_natLitEq
%%% Reducing Nat literals
%solve nonneg_3 : 3 >= 0.

%% inductive Eq (numParams=2, numIndices=1)
Eq/render-type : {u_1 : lvl} expr =
   [u_1] (eforall (esort u_1) ([x] (eforall x ([y] (eforall x ([z] (esort lzero))))))).

%% ctor Eq.refl (induct=Eq, numFields=0)
Eq_refl/render-type : {u_1 : lvl} expr =
   [u_1] (eforall (esort u_1) ([x] (eforall x ([y] (eapp (eapp (eapp (econst "Eq" (lcons u_1 lnil)) x) y) y))))).

%% recursor Eq.rec (numMotives=1, numMinors=1, k=true)
Eq_rec/render-type : {u : lvl} {u_1 : lvl} expr =
   [u] [u_1] (eforall (esort u_1) ([x] (eforall x ([y] (eforall (eforall x ([z] (eforall (eapp (eapp (eapp (econst "Eq" (lcons u_1 lnil)) x) y) z) ([w] (esort u))))) ([z] (eforall (eapp (eapp z y) (eapp (eapp (econst "Eq.refl" (lcons u_1 lnil)) x) y)) ([w] (eforall x ([x1] (eforall (eapp (eapp (eapp (econst "Eq" (lcons u_1 lnil)) x) y) x1) ([y1] (eapp (eapp z x1) y1))))))))))))).
%%   rec-rule for Eq.refl (nfields=0)
Eq_rec/render-rule0-rhs : {u : lvl} {u_1 : lvl} expr =
   [u] [u_1] (elam (esort u_1) ([x] (elam x ([y] (elam (eforall x ([z] (eforall (eapp (eapp (eapp (econst "Eq" (lcons u_1 lnil)) x) y) z) ([w] (esort u))))) ([z] (elam (eapp (eapp z y) (eapp (eapp (econst "Eq.refl" (lcons u_1 lnil)) x) y)) ([w] w)))))))).

%% inductive Nat (numParams=0, numIndices=0)
Nat/render-type : expr =
   (esort (lsucc lzero)).

%% ctor Nat.zero (induct=Nat, numFields=0)
Nat_zero/render-type : expr =
   (econst "Nat" lnil).

%% ctor Nat.succ (induct=Nat, numFields=1)
Nat_succ/render-type : expr =
   (eforall (econst "Nat" lnil) ([x] (econst "Nat" lnil))).

%% recursor Nat.rec (numMotives=1, numMinors=2, k=false)
Nat_rec/render-type : {u : lvl} expr =
   [u] (eforall (eforall (econst "Nat" lnil) ([x] (esort u))) ([x] (eforall (eapp x (econst "Nat.zero" lnil)) ([y] (eforall (eforall (econst "Nat" lnil) ([z] (eforall (eapp x z) ([w] (eapp x (eapp (econst "Nat.succ" lnil) z)))))) ([z] (eforall (econst "Nat" lnil) ([w] (eapp x w))))))))).
%%   rec-rule for Nat.zero (nfields=0)
Nat_rec/render-rule0-rhs : {u : lvl} expr =
   [u] (elam (eforall (econst "Nat" lnil) ([x] (esort u))) ([x] (elam (eapp x (econst "Nat.zero" lnil)) ([y] (elam (eforall (econst "Nat" lnil) ([z] (eforall (eapp x z) ([w] (eapp x (eapp (econst "Nat.succ" lnil) z)))))) ([z] y)))))).
%%   rec-rule for Nat.succ (nfields=1)
Nat_rec/render-rule1-rhs : {u : lvl} expr =
   [u] (elam (eforall (econst "Nat" lnil) ([x] (esort u))) ([x] (elam (eapp x (econst "Nat.zero" lnil)) ([y] (elam (eforall (econst "Nat" lnil) ([z] (eforall (eapp x z) ([w] (eapp x (eapp (econst "Nat.succ" lnil) z)))))) ([z] (elam (econst "Nat" lnil) ([w] (eapp (eapp z w) (eapp (eapp (eapp (eapp (econst "Nat.rec" (lcons u lnil)) x) y) z) w)))))))))).

%% thm natLitEq
natLitEq/render-type : expr =
   (eapp (eapp (eapp (econst "Eq" (lcons (lsucc lzero) lnil)) (econst "Nat" lnil)) (enatlit 3 nonneg_3)) (eapp (econst "Nat.succ" lnil) (eapp (econst "Nat.succ" lnil) (eapp (econst "Nat.succ" lnil) (econst "Nat.zero" lnil))))).
natLitEq/render-value : expr =
   (eapp (eapp (econst "Eq.refl" (lcons (lsucc lzero) lnil)) (econst "Nat" lnil)) (enatlit 3 nonneg_3)).

