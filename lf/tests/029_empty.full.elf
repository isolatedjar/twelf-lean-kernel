%%% Expected outcome: accept
%%% A simple empty inductive type
%% inductive Empty
Empty/type-wf-sort : lvl
   = (lsucc (lsucc lzero)).

Empty/type-wf : defeq (esort (lsucc lzero)) (esort (lsucc lzero)) (esort Empty/type-wf-sort)
   = defeq/sort-refl.

%%% HOLE
Empty/ends-in-sort : ends-in-sort (esort (lsucc lzero)).

Empty/name : name "Empty" (is-decl (esort (lsucc lzero)) indt).

Empty/decl : declared "Empty" (esort (lsucc lzero)) indt
   = declared/ok Empty/name (dkind-ok/indt Empty/type-wf Empty/ends-in-sort).

%% recursor Empty.rec
%%% HOLE
Empty_rec/type-wf-sort : lvl.

%%% HOLE
Empty_rec/type-wf : defeq (eforall (eforall (econst "Empty" lnil) ([x] (esort (lvar liz)))) ([x] (eforall (econst "Empty" lnil) ([y] (eapp x y))))) (eforall (eforall (econst "Empty" lnil) ([x] (esort (lvar liz)))) ([x] (eforall (econst "Empty" lnil) ([y] (eapp x y))))) (esort Empty_rec/type-wf-sort).

Empty_rec/name : name "Empty.rec" (is-decl (eforall (eforall (econst "Empty" lnil) ([x] (esort (lvar liz)))) ([x] (eforall (econst "Empty" lnil) ([y] (eapp x y))))) irec).

Empty_rec/decl : declared "Empty.rec" (eforall (eforall (econst "Empty" lnil) ([x] (esort (lvar liz)))) ([x] (eforall (econst "Empty" lnil) ([y] (eapp x y))))) irec
   = declared/ok Empty_rec/name (dkind-ok/irec Empty_rec/type-wf).

%% def empty
empty/type-wf-sort : lvl
   = (lsucc (lsucc lzero)).

empty/type-wf : defeq (esort (lsucc lzero)) (esort (lsucc lzero)) (esort empty/type-wf-sort)
   = defeq/sort-refl.

%%% HOLE
empty/value-typed : defeq (econst "Empty" lnil) (econst "Empty" lnil) (esort (lsucc lzero)).

empty/name : name "empty" (is-decl (esort (lsucc lzero)) (defn (econst "Empty" lnil))).

empty/decl : declared "empty" (esort (lsucc lzero)) (defn (econst "Empty" lnil))
   = declared/ok empty/name (dkind-ok/defn empty/type-wf empty/value-typed).

