%% def prodType
%%% HOLE
prodType/type-wf : defeq (eforall (esort (lsucc lzero)) ([x] (eforall (esort (lsucc lzero)) ([y] (esort (lsucc lzero)))))) (eforall (esort (lsucc lzero)) ([x] (eforall (esort (lsucc lzero)) ([y] (esort (lsucc lzero)))))) (esort lzero).

%%% HOLE
prodType/value-typed : defeq (econst "Prod" (lcons lzero (lcons lzero lnil))) (econst "Prod" (lcons lzero (lcons lzero lnil))) (eforall (esort (lsucc lzero)) ([x] (eforall (esort (lsucc lzero)) ([y] (esort (lsucc lzero)))))).

