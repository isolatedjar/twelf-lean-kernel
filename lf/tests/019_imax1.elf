%%% Expected outcome: accept
%%% Type inference for forall using imax
%% def imax1
imax1/type-wf :
   defeq (eforall (esort lzero) ([x] (esort lzero))) (eforall (esort lzero) ([x] (esort lzero))) (esort (limax (lsucc lzero) (lsucc lzero)))
   = (defeq/forall (defeq/sort-refl-at lzero) ([x] [y] (defeq/sort-refl-at lzero))).

imax1/value-typed :
   defeq (elam (esort lzero) ([x] (eforall (esort (lsucc lzero)) ([y] x)))) (elam (esort lzero) ([x] (eforall (esort (lsucc lzero)) ([y] x)))) (eforall (esort lzero) ([x] (esort lzero)))
   = (defeq/conv (defeq/forall defeq/sort-refl ([x] [y] (defeq/sort-eq (lvl-eq/trans lvl-eq/imax-zero lvl-eq/refl)))) (defeq/lam (defeq/sort-refl-at lzero) ([x] [y] (defeq/forall (defeq/sort-refl-at (lsucc lzero)) ([z] [w] y))))).

imax1/decl : declared "imax1" lnil
   (eforall (esort lzero) ([x] (esort lzero)))
   (defn (elam (esort lzero) ([x] (eforall (esort (lsucc lzero)) ([y] x)))))
   (dkind-ok/defn imax1/type-wf imax1/value-typed).

%mode declared +N +LS -T -DK -W.
%worlds () (declared _ _ _ _ _).
%unique declared +N +LS -1T -1DK *W.
