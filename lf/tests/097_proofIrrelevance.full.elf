%% def proofIrrelevance
proofIrrelevance/type-wf-sort : lvl
   = (limax (lsucc lzero) (limax lzero (limax lzero lzero))).

proofIrrelevance/type-wf : defeq (eforall (esort lzero) ([x] (eforall x ([y] (eforall x ([z] (eapp (eapp (eapp (econst "Eq" (lcons lzero lnil)) x) y) z))))))) (eforall (esort lzero) ([x] (eforall x ([y] (eforall x ([z] (eapp (eapp (eapp (econst "Eq" (lcons lzero lnil)) x) y) z))))))) (esort proofIrrelevance/type-wf-sort)
   = (defeq/forall defeq/sort-refl ([x] ([h] (defeq/forall h ([y] ([h1] (defeq/forall h ([z] ([h2] (defeq/app (defeq/app (defeq/app (defeq/const Eq/decl (inst-expr/forall (inst-expr/sort (lvl-inst/var lvl-nth/zero)) ([x] ([h] (inst-expr/forall h ([y] ([h1] (inst-expr/forall h ([z] ([h2] (inst-expr/sort lvl-inst/zero))))))))))) h) h1) h2)))))))))).

