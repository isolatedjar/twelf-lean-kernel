proofIrrelevance/value-typed : defeq (elam (esort lzero) ([x] (elam x ([y] (elam x ([z] (eapp (eapp (econst "rfl" (lcons lzero lnil)) x) y))))))) (elam (esort lzero) ([x] (elam x ([y] (elam x ([z] (eapp (eapp (econst "rfl" (lcons lzero lnil)) x) y))))))) (eforall (esort lzero) ([x] (eforall x ([y] (eforall x ([z] (eapp (eapp (eapp (econst "Eq" (lcons lzero lnil)) x) y) z))))))).

