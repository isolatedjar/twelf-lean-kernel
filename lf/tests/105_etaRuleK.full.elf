%%% Expected outcome: reject
%%% Corner case for function eta:
%%% Does a defeq between a partially applied recursor with rule k and a free
%%% variable trigger eta expansion?
%%% 
%%% Taking the official kernel as the specification, the answer is no.
%%% See <https://github.com/leanprover/lean4/issues/12520> for a discussion.
%solve nonneg_1 : 1 >= 0.
%solve nonneg_0 : 0 >= 0.

sneq/0 : string-neq "Bool.false" "Bool.true".

%% inductive Eq
Eq/type-wf-sort : lvl
   = (limax
       (lsucc (lvar liz))
       (limax (lvar liz) (limax (lvar liz) (lsucc lzero)))).

Eq/type-wf : of (eforall (esort (lvar liz)) ([x] (eforall x ([y] (eforall x ([z] (esort lzero))))))) (esort Eq/type-wf-sort)
   = (defeq/forall
       defeq/sort-refl
       ([x]
         ([h]
           (defeq/forall
             h
             ([y] ([h1] (defeq/forall h ([z] ([h2] defeq/sort-refl))))))))).

Eq/ends-in-sort : ends-in-sort (eforall (esort (lvar liz)) ([x] (eforall x ([y] (eforall x ([z] (esort lzero)))))))
   = (ends-in-sort/forall
       ([x]
         (ends-in-sort/forall
           ([y] (ends-in-sort/forall ([z] ends-in-sort/sort)))))).

Eq/rec-name : name "Eq.rec" (is-rec-for "Eq").

Eq/clf : count-leading-foralls (eforall (esort (lvar liz)) ([x] (eforall x ([y] (eforall x ([z] (esort lzero))))))) (lis (lis (lis liz)))
   = (count-leading-foralls/succ
       ([x]
         (count-leading-foralls/succ
           ([y]
             (count-leading-foralls/succ
               ([z] (count-leading-foralls/zero not-forall/sort))))))).

Eq/cnd : cnames-distinct (ccons "Eq.refl" cnil)
   = (cnames-distinct/cons cnames-distinct/nil all-string-neq/nil).

Eq/name : name "Eq" (is-decl (eforall (esort (lvar liz)) ([x] (eforall x ([y] (eforall x ([z] (esort lzero))))))) (indt (ccons "Eq.refl" cnil) (lis (lis (lis liz))))).

Eq/decl : declared "Eq" (eforall (esort (lvar liz)) ([x] (eforall x ([y] (eforall x ([z] (esort lzero))))))) (indt (ccons "Eq.refl" cnil) (lis (lis (lis liz))))
   = declared/ok-indt Eq/name Eq/rec-name Eq/clf Eq/cnd (dkind-ok/indt Eq/type-wf Eq/ends-in-sort).

%% ctor Eq.refl (of Eq)
Eq_refl/type-wf-sort : lvl
   = (limax (lsucc (lvar liz)) (limax (lvar liz) lzero)).

Eq_refl/type-wf : of (eforall (esort (lvar liz)) ([x] (eforall x ([y] (eapp (eapp (eapp (econst "Eq" (lcons (lvar liz) lnil)) x) y) y))))) (esort Eq_refl/type-wf-sort)
   = (defeq/forall
       defeq/sort-refl
       ([x]
         ([h]
           (defeq/forall
             h
             ([y]
               ([h1]
                 (defeq/app
                   (defeq/app
                     (defeq/app
                       (defeq/const
                         Eq/decl
                         (inst-expr/forall
                           (inst-expr/sort (lvl-inst/var lvl-nth/zero))
                           ([x]
                             ([h]
                               (inst-expr/forall
                                 h
                                 ([y]
                                   ([h1]
                                     (inst-expr/forall
                                       h
                                       ([z]
                                         ([h2]
                                           (inst-expr/sort
                                             lvl-inst/zero)))))))))))
                       h)
                     h1)
                   h1))))))).

Eq_refl/positivity : ctor-positive "Eq" (lcons (lvar liz) lnil) (eforall (esort (lvar liz)) ([x] (eforall x ([y] (eapp (eapp (eapp (econst "Eq" (lcons (lvar liz) lnil)) x) y) y)))))
   = (ctor-positive/intro ([S] (eforall (esort (lvar liz)) ([x] (eforall x ([y] (eapp (eapp (eapp S x) y) y)))))) (ctor-spine/arg
       (strict-pos/no-occur (esort (lvar liz)) no-self-ref/sort)
       ([x]
         ([y]
           (ctor-spine/arg
             (strict-pos/no-occur x y)
             ([z]
               ([w]
                 (ctor-spine/result
                   (applies-self/app
                     (applies-self/app
                       (applies-self/app applies-self/refl))))))))))).

Eq_refl/eisl : ends-in-sort-with-level (eforall (esort (lvar liz)) ([x] (eforall x ([y] (eforall x ([z] (esort lzero))))))) lzero
   = (ends-in-sort-with-level/forall
       ([x]
         (ends-in-sort-with-level/forall
           ([y]
             (ends-in-sort-with-level/forall
               ([z] ends-in-sort-with-level/sort)))))).

Eq_refl/cmem : cmem "Eq.refl" (ccons "Eq.refl" cnil)
   = cmem/here.

%%% HOLE: Eq_refl/fuo — prover for field-universes-ok-skip-params not yet implemented
Eq_refl/fuo : field-universes-ok-skip-params (lis (lis (lis liz))) (eforall (esort (lvar liz)) ([x] (eforall x ([y] (eapp (eapp (eapp (econst "Eq" (lcons (lvar liz) lnil)) x) y) y))))) lzero.

Eq_refl/name : name "Eq.refl" (is-decl (eforall (esort (lvar liz)) ([x] (eforall x ([y] (eapp (eapp (eapp (econst "Eq" (lcons (lvar liz) lnil)) x) y) y))))) (ctor "Eq" liz)).

Eq_refl/decl : declared "Eq.refl" (eforall (esort (lvar liz)) ([x] (eforall x ([y] (eapp (eapp (eapp (econst "Eq" (lcons (lvar liz) lnil)) x) y) y))))) (ctor "Eq" liz)
   = declared/ok-ctor Eq_refl/name Eq/name Eq_refl/cmem Eq_refl/eisl Eq_refl/fuo (dkind-ok/ctor Eq_refl/type-wf Eq_refl/positivity).

%% recursor Eq.rec
Eq_rec/type-wf-sort : lvl
   = (limax
       (lsucc (lvar (lis liz)))
       (limax
         (lvar (lis liz))
         (limax
           (limax (lvar (lis liz)) (limax lzero (lsucc (lvar liz))))
           (limax
             (lvar liz)
             (limax (lvar (lis liz)) (limax lzero (lvar liz))))))).

Eq_rec/type-wf : of
  (eforall (esort (lvar (lis liz)))
    ([x]
      (eforall x
        ([y]
          (eforall (eforall x ([z] (eforall (eapp (eapp (eapp (econst "Eq" (lcons (lvar (lis liz)) lnil)) x) y) z) ([w] (esort (lvar liz))))))
            ([z]
              (eforall (eapp (eapp z y) (eapp (eapp (econst "Eq.refl" (lcons (lvar (lis liz)) lnil)) x) y))
                ([w] (eforall x ([x1] (eforall (eapp (eapp (eapp (econst "Eq" (lcons (lvar (lis liz)) lnil)) x) y) x1) ([y1] (eapp (eapp z x1) y1)))))))))))))
  (esort Eq_rec/type-wf-sort)
   = (defeq/forall
       defeq/sort-refl
       ([x]
         ([h]
           (defeq/forall
             h
             ([y]
               ([h1]
                 (defeq/forall
                   (defeq/forall
                     h
                     ([z]
                       ([h2]
                         (defeq/forall
                           (defeq/app
                             (defeq/app
                               (defeq/app
                                 (defeq/const
                                   Eq/decl
                                   (inst-expr/forall
                                     (inst-expr/sort
                                       (lvl-inst/var lvl-nth/zero))
                                     ([x]
                                       ([h]
                                         (inst-expr/forall
                                           h
                                           ([y]
                                             ([h1]
                                               (inst-expr/forall
                                                 h
                                                 ([z]
                                                   ([h2]
                                                     (inst-expr/sort
                                                       lvl-inst/zero)))))))))))
                                 h)
                               h1)
                             h2)
                           ([w] ([h3] defeq/sort-refl))))))
                   ([z]
                     ([h2]
                       (defeq/forall
                         (defeq/app
                           (defeq/app h2 h1)
                           (defeq/app
                             (defeq/app
                               (defeq/const
                                 Eq_refl/decl
                                 (inst-expr/forall
                                   (inst-expr/sort (lvl-inst/var lvl-nth/zero))
                                   ([x]
                                     ([h]
                                       (inst-expr/forall
                                         h
                                         ([y]
                                           ([h1]
                                             (inst-expr/app
                                               (inst-expr/app
                                                 (inst-expr/app
                                                   (inst-expr/const
                                                     (lvls-inst/cons
                                                       (lvl-inst/var
                                                         lvl-nth/zero)
                                                       lvls-inst/nil))
                                                   h)
                                                 h1)
                                               h1))))))))
                               h)
                             h1))
                         ([w]
                           ([h3]
                             (defeq/forall
                               h
                               ([x1]
                                 ([h4]
                                   (defeq/forall
                                     (defeq/app
                                       (defeq/app
                                         (defeq/app
                                           (defeq/const
                                             Eq/decl
                                             (inst-expr/forall
                                               (inst-expr/sort
                                                 (lvl-inst/var lvl-nth/zero))
                                               ([x]
                                                 ([h]
                                                   (inst-expr/forall
                                                     h
                                                     ([y]
                                                       ([h1]
                                                         (inst-expr/forall
                                                           h
                                                           ([z]
                                                             ([h2]
                                                               (inst-expr/sort
                                                                 lvl-inst/zero)))))))))))
                                           h)
                                         h1)
                                       h4)
                                     ([y1]
                                       ([h5]
                                         (defeq/app
                                           (defeq/app h2 h4)
                                           h5))))))))))))))))))).

Eq_rec/decl : declared "Eq.rec"
  (eforall (esort (lvar (lis liz)))
    ([x]
      (eforall x
        ([y]
          (eforall (eforall x ([z] (eforall (eapp (eapp (eapp (econst "Eq" (lcons (lvar (lis liz)) lnil)) x) y) z) ([w] (esort (lvar liz))))))
            ([z]
              (eforall (eapp (eapp z y) (eapp (eapp (econst "Eq.refl" (lcons (lvar (lis liz)) lnil)) x) y))
                ([w] (eforall x ([x1] (eforall (eapp (eapp (eapp (econst "Eq" (lcons (lvar (lis liz)) lnil)) x) y) x1) ([y1] (eapp (eapp z x1) y1)))))))))))))
  (irec "Eq")
   = declared/ok-irec Eq/rec-name (dkind-ok/irec Eq_rec/type-wf).

%% inductive Bool
Bool/type-wf-sort : lvl
   = (lsucc (lsucc lzero)).

Bool/type-wf : of (esort (lsucc lzero)) (esort Bool/type-wf-sort)
   = defeq/sort-refl.

Bool/ends-in-sort : ends-in-sort (esort (lsucc lzero))
   = ends-in-sort/sort.

Bool/rec-name : name "Bool.rec" (is-rec-for "Bool").

Bool/clf : count-leading-foralls (esort (lsucc lzero)) liz
   = (count-leading-foralls/zero not-forall/sort).

Bool/cnd : cnames-distinct (ccons "Bool.false" (ccons "Bool.true" cnil))
   = (cnames-distinct/cons
       (cnames-distinct/cons cnames-distinct/nil all-string-neq/nil)
       (all-string-neq/cons sneq/0 all-string-neq/nil)).

Bool/name : name "Bool" (is-decl (esort (lsucc lzero)) (indt (ccons "Bool.false" (ccons "Bool.true" cnil)) liz)).

Bool/decl : declared "Bool" (esort (lsucc lzero)) (indt (ccons "Bool.false" (ccons "Bool.true" cnil)) liz)
   = declared/ok-indt Bool/name Bool/rec-name Bool/clf Bool/cnd (dkind-ok/indt Bool/type-wf Bool/ends-in-sort).

%% ctor Bool.false (of Bool)
Bool_false/type-wf-sort : lvl
   = (lsucc lzero).

Bool_false/type-wf : of (econst "Bool" lnil) (esort Bool_false/type-wf-sort)
   = (defeq/const Bool/decl (inst-expr/sort (lvl-inst/succ lvl-inst/zero))).

Bool_false/positivity : ctor-positive "Bool" lnil (econst "Bool" lnil)
   = (ctor-positive/intro ([S] S) (ctor-spine/result applies-self/refl)).

Bool_false/eisl : ends-in-sort-with-level (esort (lsucc lzero)) (lsucc lzero)
   = ends-in-sort-with-level/sort.

Bool_false/cmem : cmem "Bool.false" (ccons "Bool.false" (ccons "Bool.true" cnil))
   = cmem/here.

%%% HOLE: Bool_false/fuo — prover for field-universes-ok-skip-params not yet implemented
Bool_false/fuo : field-universes-ok-skip-params liz (econst "Bool" lnil) (lsucc lzero).

Bool_false/name : name "Bool.false" (is-decl (econst "Bool" lnil) (ctor "Bool" liz)).

Bool_false/decl : declared "Bool.false" (econst "Bool" lnil) (ctor "Bool" liz)
   = declared/ok-ctor Bool_false/name Bool/name Bool_false/cmem Bool_false/eisl Bool_false/fuo (dkind-ok/ctor Bool_false/type-wf Bool_false/positivity).

%% ctor Bool.true (of Bool)
Bool_true/type-wf-sort : lvl
   = (lsucc lzero).

Bool_true/type-wf : of (econst "Bool" lnil) (esort Bool_true/type-wf-sort)
   = (defeq/const Bool/decl (inst-expr/sort (lvl-inst/succ lvl-inst/zero))).

Bool_true/positivity : ctor-positive "Bool" lnil (econst "Bool" lnil)
   = (ctor-positive/intro ([S] S) (ctor-spine/result applies-self/refl)).

Bool_true/eisl : ends-in-sort-with-level (esort (lsucc lzero)) (lsucc lzero)
   = ends-in-sort-with-level/sort.

Bool_true/cmem : cmem "Bool.true" (ccons "Bool.false" (ccons "Bool.true" cnil))
   = (cmem/there cmem/here).

%%% HOLE: Bool_true/fuo — prover for field-universes-ok-skip-params not yet implemented
Bool_true/fuo : field-universes-ok-skip-params liz (econst "Bool" lnil) (lsucc lzero).

Bool_true/name : name "Bool.true" (is-decl (econst "Bool" lnil) (ctor "Bool" (lis liz))).

Bool_true/decl : declared "Bool.true" (econst "Bool" lnil) (ctor "Bool" (lis liz))
   = declared/ok-ctor Bool_true/name Bool/name Bool_true/cmem Bool_true/eisl Bool_true/fuo (dkind-ok/ctor Bool_true/type-wf Bool_true/positivity).

%% recursor Bool.rec
Bool_rec/type-wf-sort : lvl
   = (limax
       (limax (lsucc lzero) (lsucc (lvar liz)))
       (limax (lvar liz) (limax (lvar liz) (limax (lsucc lzero) (lvar liz))))).

Bool_rec/type-wf : of
  (eforall (eforall (econst "Bool" lnil) ([x] (esort (lvar liz))))
    ([x] (eforall (eapp x (econst "Bool.false" lnil)) ([y] (eforall (eapp x (econst "Bool.true" lnil)) ([z] (eforall (econst "Bool" lnil) ([w] (eapp x w)))))))))
  (esort Bool_rec/type-wf-sort)
   = (defeq/forall
       (defeq/forall
         (defeq/const Bool/decl (inst-expr/sort (lvl-inst/succ lvl-inst/zero)))
         ([x] ([h] defeq/sort-refl)))
       ([x]
         ([h]
           (defeq/forall
             (defeq/app
               h
               (defeq/const Bool_false/decl (inst-expr/const lvls-inst/nil)))
             ([y]
               ([h1]
                 (defeq/forall
                   (defeq/app
                     h
                     (defeq/const
                       Bool_true/decl
                       (inst-expr/const lvls-inst/nil)))
                   ([z]
                     ([h2]
                       (defeq/forall
                         (defeq/const
                           Bool/decl
                           (inst-expr/sort (lvl-inst/succ lvl-inst/zero)))
                         ([w] ([h3] (defeq/app h h3))))))))))))).

Bool_rec/decl : declared "Bool.rec"
  (eforall (eforall (econst "Bool" lnil) ([x] (esort (lvar liz))))
    ([x] (eforall (eapp x (econst "Bool.false" lnil)) ([y] (eforall (eapp x (econst "Bool.true" lnil)) ([z] (eforall (econst "Bool" lnil) ([w] (eapp x w)))))))))
  (irec "Bool")
   = declared/ok-irec Bool/rec-name (dkind-ok/irec Bool_rec/type-wf).

%% def etaRuleK
etaRuleK/type-wf-sort : lvl
   = (limax (limax lzero (lsucc lzero)) lzero).

etaRuleK/type-wf : of
  (eforall (eforall (eapp (eapp (eapp (econst "Eq" (lcons (lsucc lzero) lnil)) (econst "Bool" lnil)) (econst "Bool.true" lnil)) (econst "Bool.true" lnil)) ([x] (econst "Bool" lnil)))
    ([x]
      (eapp (eapp (eapp (econst "Eq" (lcons (lsucc lzero) lnil))
        (eforall (eapp (eapp (eapp (econst "Eq" (lcons (lsucc lzero) lnil)) (econst "Bool" lnil)) (econst "Bool.true" lnil)) (econst "Bool.true" lnil)) ([y] (econst "Bool" lnil))))
        (eapp (eapp (eapp (eapp (eapp (econst "Eq.rec" (lcons (lsucc lzero) (lcons (lsucc lzero) lnil))) (econst "Bool" lnil)) (econst "Bool.true" lnil))
          (elam (econst "Bool" lnil) ([y] (elam (eapp (eapp (eapp (econst "Eq" (lcons (lsucc lzero) lnil)) (econst "Bool" lnil)) (econst "Bool.true" lnil)) y) ([z] (econst "Bool" lnil))))))
          (eapp x (eapp (eapp (econst "Eq.refl" (lcons (lsucc lzero) lnil)) (econst "Bool" lnil)) (econst "Bool.true" lnil))))
          (econst "Bool.true" lnil)))
        x)))
  (esort etaRuleK/type-wf-sort)
   = (defeq/forall
       (defeq/forall
         (defeq/app
           (defeq/app
             (defeq/app
               (defeq/const
                 Eq/decl
                 (inst-expr/forall
                   (inst-expr/sort (lvl-inst/var lvl-nth/zero))
                   ([x]
                     ([h]
                       (inst-expr/forall
                         h
                         ([y]
                           ([h1]
                             (inst-expr/forall
                               h
                               ([z]
                                 ([h2] (inst-expr/sort lvl-inst/zero)))))))))))
               (defeq/const
                 Bool/decl
                 (inst-expr/sort (lvl-inst/succ lvl-inst/zero))))
             (defeq/const Bool_true/decl (inst-expr/const lvls-inst/nil)))
           (defeq/const Bool_true/decl (inst-expr/const lvls-inst/nil)))
         ([x]
           ([h]
             (defeq/const
               Bool/decl
               (inst-expr/sort (lvl-inst/succ lvl-inst/zero))))))
       ([x]
         ([h]
           (defeq/app
             (defeq/app
               (defeq/app
                 (defeq/const
                   Eq/decl
                   (inst-expr/forall
                     (inst-expr/sort (lvl-inst/var lvl-nth/zero))
                     ([x]
                       ([h]
                         (inst-expr/forall
                           h
                           ([y]
                             ([h1]
                               (inst-expr/forall
                                 h
                                 ([z]
                                   ([h2]
                                     (inst-expr/sort lvl-inst/zero)))))))))))
                 (defeq/conv
                   (defeq/sort-eq
                     (lvl-eq/le
                       (mleq/imax-lsL
                         (mleq/sR
                           (mleq/maxL
                             (mleq/self nonneg_1)
                             (mleq/sL (mleq/self nonneg_0)))))
                       (mleq/sL
                         (mleq/imax-lsR
                           (mleq/maxR-r (mleq/sR (mleq/self nonneg_0)))))))
                   (defeq/forall
                     (defeq/app
                       (defeq/app
                         (defeq/app
                           (defeq/const
                             Eq/decl
                             (inst-expr/forall
                               (inst-expr/sort (lvl-inst/var lvl-nth/zero))
                               ([x]
                                 ([h]
                                   (inst-expr/forall
                                     h
                                     ([y]
                                       ([h1]
                                         (inst-expr/forall
                                           h
                                           ([z]
                                             ([h2]
                                               (inst-expr/sort
                                                 lvl-inst/zero)))))))))))
                           (defeq/const
                             Bool/decl
                             (inst-expr/sort (lvl-inst/succ lvl-inst/zero))))
                         (defeq/const
                           Bool_true/decl
                           (inst-expr/const lvls-inst/nil)))
                       (defeq/const
                         Bool_true/decl
                         (inst-expr/const lvls-inst/nil)))
                     ([y]
                       ([h1]
                         (defeq/const
                           Bool/decl
                           (inst-expr/sort (lvl-inst/succ lvl-inst/zero))))))))
               (defeq/conv
                 (defeq/forall
                   (defeq/app
                     (defeq/app
                       (defeq/app
                         (defeq/const
                           Eq/decl
                           (inst-expr/forall
                             (inst-expr/sort (lvl-inst/var lvl-nth/zero))
                             ([x]
                               ([h]
                                 (inst-expr/forall
                                   h
                                   ([y]
                                     ([h1]
                                       (inst-expr/forall
                                         h
                                         ([z]
                                           ([h2]
                                             (inst-expr/sort
                                               lvl-inst/zero)))))))))))
                         (defeq/const
                           Bool/decl
                           (inst-expr/sort (lvl-inst/succ lvl-inst/zero))))
                       (defeq/const
                         Bool_true/decl
                         (inst-expr/const lvls-inst/nil)))
                     (defeq/const
                       Bool_true/decl
                       (inst-expr/const lvls-inst/nil)))
                   ([y]
                     ([h1]
                       (defeq/trans
                         (defeq/app
                           (defeq/beta
                             ([z]
                               ([h2]
                                 (defeq/lam
                                   (defeq/app
                                     (defeq/app
                                       (defeq/app
                                         (defeq/const
                                           Eq/decl
                                           (inst-expr/forall
                                             (inst-expr/sort
                                               (lvl-inst/var lvl-nth/zero))
                                             ([x]
                                               ([h]
                                                 (inst-expr/forall
                                                   h
                                                   ([y]
                                                     ([h1]
                                                       (inst-expr/forall
                                                         h
                                                         ([z]
                                                           ([h2]
                                                             (inst-expr/sort
                                                               lvl-inst/zero)))))))))))
                                         (defeq/const
                                           Bool/decl
                                           (inst-expr/sort
                                             (lvl-inst/succ lvl-inst/zero))))
                                       (defeq/const
                                         Bool_true/decl
                                         (inst-expr/const lvls-inst/nil)))
                                     h2)
                                   ([w]
                                     ([h3]
                                       (defeq/const
                                         Bool/decl
                                         (inst-expr/sort
                                           (lvl-inst/succ lvl-inst/zero))))))))
                             (defeq/const
                               Bool_true/decl
                               (inst-expr/const lvls-inst/nil)))
                           h1)
                         (defeq/trans
                           (defeq/beta
                             ([z]
                               ([h2]
                                 (defeq/const
                                   Bool/decl
                                   (inst-expr/sort
                                     (lvl-inst/succ lvl-inst/zero)))))
                             h1)
                           (defeq/const
                             Bool/decl
                             (inst-expr/sort
                               (lvl-inst/succ lvl-inst/zero))))))))
                 (defeq/app
                   (defeq/app
                     (defeq/app
                       (defeq/app
                         (defeq/app
                           (defeq/const
                             Eq_rec/decl
                             (inst-expr/forall
                               (inst-expr/sort
                                 (lvl-inst/var (lvl-nth/succ lvl-nth/zero)))
                               ([x]
                                 ([h]
                                   (inst-expr/forall
                                     h
                                     ([y]
                                       ([h1]
