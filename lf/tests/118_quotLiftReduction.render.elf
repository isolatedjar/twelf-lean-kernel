%% thm quotLiftReduction
quotLiftReduction/render-type : {u : lvl} {v : lvl} expr =
   [u] [v] (eforall (esort u) ([x] (eforall (eforall x ([y] (eforall x ([z] (esort lzero))))) ([y] (eforall (esort v) ([z] (eforall (eforall x ([w] z)) ([w] (eforall (eforall x ([x1] (eforall x ([y1] (eforall (eapp (eapp y x1) y1) ([z1] (eapp (eapp (eapp (econst "Eq" (lcons v lnil)) z) (eapp w x1)) (eapp w y1)))))))) ([x1] (eforall x ([y1] (eapp (eapp (eapp (econst "Eq" (lcons v lnil)) z) (eapp (eapp (eapp (eapp (eapp (eapp (econst "Quot.lift" (lcons u (lcons v lnil))) x) y) z) w) x1) (eapp (eapp (eapp (econst "Quot.mk" (lcons u lnil)) x) y) y1))) (eapp w y1)))))))))))))).
quotLiftReduction/render-value : {u : lvl} {v : lvl} expr =
   [u] [v] (elam (esort u) ([x] (elam (eforall x ([y] (eforall x ([z] (esort lzero))))) ([y] (elam (esort v) ([z] (elam (eforall x ([w] z)) ([w] (elam (eforall x ([x1] (eforall x ([y1] (eforall (eapp (eapp y x1) y1) ([z1] (eapp (eapp (eapp (econst "Eq" (lcons v lnil)) z) (eapp w x1)) (eapp w y1)))))))) ([x1] (elam x ([y1] (eapp (eapp (econst "Eq.refl" (lcons v lnil)) z) (eapp (eapp (eapp (eapp (eapp (eapp (econst "Quot.lift" (lcons u (lcons v lnil))) x) y) z) w) x1) (eapp (eapp (eapp (econst "Quot.mk" (lcons u lnil)) x) y) y1))))))))))))))).

