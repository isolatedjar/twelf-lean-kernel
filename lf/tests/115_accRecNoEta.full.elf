%% inductive Acc
Acc/type-wf-sort : lvl
   = (limax
       (lsucc (lvar liz))
       (limax
         (limax (lvar liz) (limax (lvar liz) (lsucc lzero)))
         (limax (lvar liz) (lsucc lzero)))).

Acc/type-wf : of (eforall (esort (lvar liz)) ([x] (eforall (eforall x ([y] (eforall x ([z] (esort lzero))))) ([y] (eforall x ([z] (esort lzero))))))) (esort Acc/type-wf-sort)
   = (defeq/forall
       defeq/sort-refl
       ([x]
         ([h]
           (defeq/forall
             (defeq/forall
               h
               ([y] ([h1] (defeq/forall h ([z] ([h2] defeq/sort-refl))))))
             ([y] ([h1] (defeq/forall h ([z] ([h2] defeq/sort-refl))))))))).

Acc/ends-in-sort : ends-in-sort (eforall (esort (lvar liz)) ([x] (eforall (eforall x ([y] (eforall x ([z] (esort lzero))))) ([y] (eforall x ([z] (esort lzero)))))))
   = (ends-in-sort/forall
       ([x]
         (ends-in-sort/forall
           ([y] (ends-in-sort/forall ([z] ends-in-sort/sort)))))).

Acc/rec-name : name "Acc.rec" (is-rec-for "Acc").

Acc/eisl : ends-in-sort-with-level (eforall (esort (lvar liz)) ([x] (eforall (eforall x ([y] (eforall x ([z] (esort lzero))))) ([y] (eforall x ([z] (esort lzero))))))) lzero
   = (ends-in-sort-with-level/forall
       ([x]
         (ends-in-sort-with-level/forall
           ([y]
             (ends-in-sort-with-level/forall
               ([z] ends-in-sort-with-level/sort)))))).

Acc/cnd : cnames-distinct (ccons "Acc.intro" cnil)
   = (cnames-distinct/cons cnames-distinct/nil all-string-neq/nil).

Acc/name : name "Acc" (is-decl
  (eforall (esort (lvar liz)) ([x] (eforall (eforall x ([y] (eforall x ([z] (esort lzero))))) ([y] (eforall x ([z] (esort lzero)))))))
  (indt (ccons "Acc.intro" cnil) (lis (lis liz)))).

Acc/decl : declared "Acc" (eforall (esort (lvar liz)) ([x] (eforall (eforall x ([y] (eforall x ([z] (esort lzero))))) ([y] (eforall x ([z] (esort lzero))))))) (indt (ccons "Acc.intro" cnil) (lis (lis liz)))
