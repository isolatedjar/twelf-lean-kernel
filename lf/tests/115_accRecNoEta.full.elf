            ([z]
              (eforall (eapp (eapp (eapp (econst "Acc" (lcons (lsucc lzero) lnil)) x) y) z)
                ([w]
                  (eforall (econst "Bool" lnil)
                    ([x1]
                      (eapp (eapp (eapp (econst "Eq" (lcons (lsucc lzero) lnil)) (econst "Bool" lnil))
                        (eapp (eapp (eapp (eapp (eapp (eapp (econst "Acc.rec" (lcons (lsucc lzero) (lcons (lsucc lzero) lnil))) x) y)
                          (elam x ([y1] (elam (eapp (eapp (eapp (econst "Acc" (lcons (lsucc lzero) lnil)) x) y) y1) ([z1] (econst "Bool" lnil))))))
                          (elam x
