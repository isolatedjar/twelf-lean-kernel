%% inductive Acc
Acc/type-wf : of
  (eforall (esort (lvar z)) ([x] (eforall (eforall x ([y] (eforall x ([w] (esort lzero))))) ([y] (eforall x ([w] (esort lzero)))))))
  (esort (limax (lsucc (lvar z)) (limax (limax (lvar z) (limax (lvar z) (lsucc lzero))) (limax (lvar z) (lsucc lzero)))))
   = (defeq/forall
       defeq/sort-refl
       ([x]
         ([h]
           (defeq/forall
             (defeq/forall
               h
               ([y] ([h1] (defeq/forall h ([w] ([h2] defeq/sort-refl))))))
             ([y] ([h1] (defeq/forall h ([w] ([h2] defeq/sort-refl))))))))).

Acc/ends-in-sort : ends-in-sort (eforall (esort (lvar z)) ([x] (eforall (eforall x ([y] (eforall x ([w] (esort lzero))))) ([y] (eforall x ([w] (esort lzero)))))))
   = (ends-in-sort/forall
       ([x]
         (ends-in-sort/forall
           ([y] (ends-in-sort/forall ([w] ends-in-sort/sort)))))).

Acc/rec-name : name "Acc.rec" (is-rec-for "Acc").

Acc/eisl : ends-in-sort-with-level (eforall (esort (lvar z)) ([x] (eforall (eforall x ([y] (eforall x ([w] (esort lzero))))) ([y] (eforall x ([w] (esort lzero))))))) lzero
   = (ends-in-sort-with-level/forall
       ([x]
         (ends-in-sort-with-level/forall
           ([y]
             (ends-in-sort-with-level/forall
               ([w] ends-in-sort-with-level/sort)))))).

Acc/cnd : cnames-distinct (ccons "Acc.intro" cnil)
   = (cnames-distinct/cons cnames-distinct/nil all-string-neq/nil).

Acc/name : name "Acc" (is-decl (eforall (esort (lvar z)) ([x] (eforall (eforall x ([y] (eforall x ([w] (esort lzero))))) ([y] (eforall x ([w] (esort lzero))))))) (indt (ccons "Acc.intro" cnil) (s (s z)))).

Acc/decl : declared "Acc" (eforall (esort (lvar z)) ([x] (eforall (eforall x ([y] (eforall x ([w] (esort lzero))))) ([y] (eforall x ([w] (esort lzero))))))) (indt (ccons "Acc.intro" cnil) (s (s z)))
