%% axiom Quot.sound
Quot_sound/render-type : {u : lvl} expr =
   [u] (eforall (esort u) ([x] (eforall (eforall x ([y] (eforall x ([z] (esort lzero))))) ([y] (eforall x ([z] (eforall x ([w] (eforall (eapp (eapp y z) w) ([x1] (eapp (eapp (eapp (econst "Eq" (lcons u lnil)) (eapp (eapp (econst "Quot" (lcons u lnil)) x) y)) (eapp (eapp (eapp (econst "Quot.mk" (lcons u lnil)) x) y) z)) (eapp (eapp (eapp (econst "Quot.mk" (lcons u lnil)) x) y) w)))))))))))).

%% def quotSoundType
quotSoundType/render-type : {u : lvl} expr =
   [u] (eforall (esort u) ([x] (eforall (eforall x ([y] (eforall x ([z] (esort lzero))))) ([y] (eforall x ([z] (eforall x ([w] (eforall (eapp (eapp y z) w) ([x1] (eapp (eapp (eapp (econst "Eq" (lcons u lnil)) (eapp (eapp (econst "Quot" (lcons u lnil)) x) y)) (eapp (eapp (eapp (econst "Quot.mk" (lcons u lnil)) x) y) z)) (eapp (eapp (eapp (econst "Quot.mk" (lcons u lnil)) x) y) w)))))))))))).
quotSoundType/render-value : {u : lvl} expr =
   [u] (econst "Quot.sound" (lcons u lnil)).

