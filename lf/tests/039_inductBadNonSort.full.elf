%%% Expected outcome: reject
%%% An inductive type with a non-sort type
%% def constType
constType/type-wf-sort : lvl
   = (limax
       (lsucc (lsucc lzero))
       (limax (lsucc (lsucc lzero)) (lsucc (lsucc lzero)))).

constType/type-wf : of (eforall (esort (lsucc lzero)) ([x] (eforall (esort (lsucc lzero)) ([y] (esort (lsucc lzero)))))) (esort constType/type-wf-sort)
   = (defeq/forall
       defeq/sort-refl
       ([x] ([h] (defeq/forall defeq/sort-refl ([y] ([h1] defeq/sort-refl)))))).

constType/value-typed : of (elam (esort (lsucc lzero)) ([x] (elam (esort (lsucc lzero)) ([y] x)))) (eforall (esort (lsucc lzero)) ([x] (eforall (esort (lsucc lzero)) ([y] (esort (lsucc lzero))))))
   = (defeq/lam
       defeq/sort-refl
       ([x] ([h] (defeq/lam defeq/sort-refl ([y] ([h1] h)))))).

constType/name : name "constType" (is-decl
  (eforall (esort (lsucc lzero)) ([x] (eforall (esort (lsucc lzero)) ([y] (esort (lsucc lzero))))))
  (defn (elam (esort (lsucc lzero)) ([x] (elam (esort (lsucc lzero)) ([y] x)))))).

constType/decl : declared "constType" (eforall (esort (lsucc lzero)) ([x] (eforall (esort (lsucc lzero)) ([y] (esort (lsucc lzero)))))) (defn (elam (esort (lsucc lzero)) ([x] (elam (esort (lsucc lzero)) ([y] x)))))
   = declared/ok constType/name (dkind-ok/defn constType/type-wf constType/value-typed).

%% inductive inductBadNonSort
%%% HOLE
inductBadNonSort/type-wf-sort : lvl.

%%% HOLE
inductBadNonSort/type-wf : of (econst "constType" lnil) (esort inductBadNonSort/type-wf-sort).

%%% HOLE
inductBadNonSort/ends-in-sort : ends-in-sort (econst "constType" lnil).

inductBadNonSort/rec-name : name "inductBadNonSort.rec" (is-rec-for "inductBadNonSort").

inductBadNonSort/clf : count-leading-foralls (econst "constType" lnil) liz
   = (count-leading-foralls/zero not-forall/const).

inductBadNonSort/cnd : cnames-distinct cnil
   = cnames-distinct/nil.

inductBadNonSort/name : name "inductBadNonSort" (is-decl (econst "constType" lnil) (indt cnil liz)).

inductBadNonSort/decl : declared "inductBadNonSort" (econst "constType" lnil) (indt cnil liz)
   = declared/ok-indt inductBadNonSort/name inductBadNonSort/rec-name inductBadNonSort/clf inductBadNonSort/cnd (dkind-ok/indt inductBadNonSort/type-wf inductBadNonSort/ends-in-sort).
