%%% Expected outcome: accept
%%% Definitional equality between lambdas
%% def defEqLambda
defEqLambda/type-wf : of
  (eforall (eforall (eforall (esort lzero) ([x] (esort lzero))) ([x] (esort lzero)))
    ([x] (eforall (eforall (eforall (esort lzero) ([y] (esort lzero))) ([y] (eapp x y))) ([y] (eapp x (elam (esort lzero) ([w] (eforall w ([v] w)))))))))
  (esort (limax (limax (limax (lsucc lzero) (lsucc lzero)) (lsucc lzero)) (limax (limax (limax (lsucc lzero) (lsucc lzero)) lzero) lzero)))
   = (defeq/forall
       (defeq/forall
         (defeq/forall defeq/sort-refl ([x] ([h] defeq/sort-refl)))
         ([x] ([h] defeq/sort-refl)))
       ([x]
         ([h]
           (defeq/forall
             (defeq/forall
               (defeq/forall defeq/sort-refl ([y] ([h1] defeq/sort-refl)))
               ([y] ([h1] (defeq/app h h1))))
             ([y]
               ([h1]
                 (defeq/app
                   h
                   (defeq/conv
                     (defeq/forall
                       (defeq/sort-eq eq-lvl/refl)
                       ([w]
                         ([h2]
                           (defeq/sort-eq
                             (eq-lvl/le
                               leq-lvl/lz
                               (leq-lvl/imaxLz leq-lvl/self))))))
                     (defeq/lam
                       defeq/sort-refl
                       ([w] ([h2] (defeq/forall h2 ([v] ([h3] h2)))))))))))))).

defEqLambda/value-typed : of
  (elam (eforall (eforall (esort lzero) ([x] (esort lzero))) ([x] (esort lzero)))
    ([x] (elam (eforall (eforall (esort lzero) ([y] (esort lzero))) ([y] (eapp x y))) ([y] (eapp y (elam (esort lzero) ([w] (eforall w ([v] w)))))))))
  (eforall (eforall (eforall (esort lzero) ([x] (esort lzero))) ([x] (esort lzero)))
    ([x] (eforall (eforall (eforall (esort lzero) ([y] (esort lzero))) ([y] (eapp x y))) ([y] (eapp x (elam (esort lzero) ([w] (eforall w ([v] w)))))))))
   = (defeq/lam
       (defeq/forall
         (defeq/forall defeq/sort-refl ([x] ([h] defeq/sort-refl)))
         ([x] ([h] defeq/sort-refl)))
       ([x]
         ([h]
           (defeq/lam
             (defeq/forall
               (defeq/forall defeq/sort-refl ([y] ([h1] defeq/sort-refl)))
               ([y] ([h1] (defeq/app h h1))))
             ([y]
               ([h1]
                 (defeq/app
                   h1
                   (defeq/conv
                     (defeq/forall
                       (defeq/sort-eq eq-lvl/refl)
                       ([w]
                         ([h2]
                           (defeq/sort-eq
                             (eq-lvl/le
                               leq-lvl/lz
                               (leq-lvl/imaxLz leq-lvl/self))))))
                     (defeq/lam
                       defeq/sort-refl
                       ([w] ([h2] (defeq/forall h2 ([v] ([h3] h2)))))))))))))).

defEqLambda/name : name "defEqLambda" (is-decl
  (eforall (eforall (eforall (esort lzero) ([x] (esort lzero))) ([x] (esort lzero)))
    ([x] (eforall (eforall (eforall (esort lzero) ([y] (esort lzero))) ([y] (eapp x y))) ([y] (eapp x (elam (esort lzero) ([w] (eforall w ([v] w)))))))))
  (defn (elam (eforall (eforall (esort lzero) ([x] (esort lzero))) ([x] (esort lzero))) ([x] (elam (eforall (eforall (esort lzero) ([y] (esort lzero))) ([y] (eapp x y))) ([y] (eapp y (elam (esort lzero) ([w] (eforall w ([v] w))))))))))).

defEqLambda/decl : declared "defEqLambda"
  (eforall (eforall (eforall (esort lzero) ([x] (esort lzero))) ([x] (esort lzero)))
    ([x] (eforall (eforall (eforall (esort lzero) ([y] (esort lzero))) ([y] (eapp x y))) ([y] (eapp x (elam (esort lzero) ([w] (eforall w ([v] w)))))))))
  (defn (elam (eforall (eforall (esort lzero) ([x] (esort lzero))) ([x] (esort lzero))) ([x] (elam (eforall (eforall (esort lzero) ([y] (esort lzero))) ([y] (eapp x y))) ([y] (eapp y (elam (esort lzero) ([w] (eforall w ([v] w))))))))))
   = declared/ok defEqLambda/name dkind-non-inductive/defn (dkind-ok/defn defEqLambda/type-wf defEqLambda/value-typed).
