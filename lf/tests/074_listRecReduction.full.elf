                ([w]
                  (eforall (eapp (econst "List" (lcons (lvar (lis liz)) lnil)) x)
                    ([x1] (eforall (eapp y x1) ([y1] (eapp y (eapp (eapp (eapp (econst "List.cons" (lcons (lvar (lis liz)) lnil)) x) w) x1))))))))
                ([w] (eforall (eapp (econst "List" (lcons (lvar (lis liz)) lnil)) x) ([x1] (eapp y x1)))))))))))
  (irec "List").

