%%   level params: u_1 u
%%   type:   (eforall (esort (lsucc (lvar (s z)))) ([x] (eforall (eforall (eapp (econst "List" (lcons (lvar (s z)) lnil)) x) ([y] (esort (lvar z)))) ([y] (eforall (eapp y (eapp (econst "List.nil" (lcons (lvar (s z)) lnil)) x)) ([w] (eforall (eforall x ([v] (eforall (eapp (econst "List" (lcons (lvar (s z)) lnil)) x) ([x1] (eforall (eapp y x1) ([y1] (eapp y (eapp (eapp (eapp (econst "List.cons" (lcons (lvar (s z)) lnil)) x) v) x1)))))))) ([v] (eforall (eapp (econst "List" (lcons (lvar (s z)) lnil)) x) ([x1] (eapp y x1)))))))))))
