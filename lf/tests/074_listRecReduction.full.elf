%% inductive And
And/type-wf : of (eforall (esort lzero) ([x] (eforall (esort lzero) ([y] (esort lzero))))) (esort (limax (lsucc lzero) (limax (lsucc lzero) (lsucc lzero))))
   = (defeq/forall
       defeq/sort-refl
       ([x] ([h] (defeq/forall defeq/sort-refl ([y] ([h1] defeq/sort-refl)))))).

And/ends-in-sort : ends-in-sort (eforall (esort lzero) ([x] (eforall (esort lzero) ([y] (esort lzero)))))
   = (ends-in-sort/forall ([x] (ends-in-sort/forall ([y] ends-in-sort/sort)))).

And/rec-name : name "And.rec" (is-rec-for "And").

And/eisl : ends-in-sort-with-level (eforall (esort lzero) ([x] (eforall (esort lzero) ([y] (esort lzero))))) lzero
   = (ends-in-sort-with-level/forall
       ([x]
         (ends-in-sort-with-level/forall ([y] ends-in-sort-with-level/sort)))).

And/cnd : cnames-distinct (ccons "And.intro" cnil)
   = (cnames-distinct/cons cnames-distinct/nil all-string-neq/nil).

And/name : name "And" (is-decl (eforall (esort lzero) ([x] (eforall (esort lzero) ([y] (esort lzero))))) (indt (ccons "And.intro" cnil) (s (s z)))).

And/decl : declared "And" (eforall (esort lzero) ([x] (eforall (esort lzero) ([y] (esort lzero))))) (indt (ccons "And.intro" cnil) (s (s z)))
   = declared/ok-indt And/name And/rec-name And/cnd (dkind-ok/indt And/type-wf And/ends-in-sort).

%% ctor And.intro (of And)
And_intro/type-wf : of
  (eforall (esort lzero) ([x] (eforall (esort lzero) ([y] (eforall x ([w] (eforall y ([v] (eapp (eapp (econst "And" lnil) x) y)))))))))
  (esort (limax (lsucc lzero) (limax (lsucc lzero) (limax lzero (limax lzero lzero)))))
   = (defeq/forall
       defeq/sort-refl
       ([x]
         ([h]
           (defeq/forall
             defeq/sort-refl
             ([y]
               ([h1]
                 (defeq/forall
                   h
                   ([w]
                     ([h2]
                       (defeq/forall
                         h1
                         ([v]
                           ([h3]
                             (defeq/app
                               (defeq/app
                                 (defeq/const
                                   And/decl
                                   (inst-expr/forall
                                     (inst-expr/sort inst-lvl/zero)
                                     ([x]
                                       ([h]
                                         (inst-expr/forall
                                           (inst-expr/sort inst-lvl/zero)
                                           ([y]
                                             ([h1]
                                               (inst-expr/sort
                                                 inst-lvl/zero))))))))
                                 h)
                               h1))))))))))))).

And_intro/positivity : ctor-positive "And" lnil (eforall (esort lzero) ([x] (eforall (esort lzero) ([y] (eforall x ([w] (eforall y ([v] (eapp (eapp (econst "And" lnil) x) y)))))))))
   = (ctor-positive/intro ([S] (eforall (esort lzero) ([x] (eforall (esort lzero) ([y] (eforall x ([w] (eforall y ([v] (eapp (eapp S x) y)))))))))) (ctor-spine/arg
       (strict-pos/no-occur (esort lzero) no-self-ref/sort)
       ([x]
         ([y]
           (ctor-spine/arg
             (strict-pos/no-occur (esort lzero) no-self-ref/sort)
             ([w]
               ([v]
                 (ctor-spine/arg
                   (strict-pos/no-occur x y)
                   ([x1]
                     ([y1]
                       (ctor-spine/arg
                         (strict-pos/no-occur w v)
                         ([w1]
                           ([v1]
                             (ctor-spine/result
                               (applies-self/app
                                 (applies-self/app
                                   applies-self/refl)))))))))))))))).

And_intro/cmem : cmem "And.intro" (ccons "And.intro" cnil)
   = cmem/here.

And_intro/fuo : field-universes-ok (eforall (esort lzero) ([x] (eforall (esort lzero) ([y] (eforall x ([w] (eforall y ([v] (eapp (eapp (econst "And" lnil) x) y))))))))) lzero
   = (field-universes-ok/forall
       defeq/sort-refl
       (leq-lvl/imaxLz leq-lvl/self)
       ([x]
         ([h]
           (field-universes-ok/forall
             defeq/sort-refl
             (leq-lvl/imaxLz leq-lvl/self)
             ([y]
               ([h1]
                 (field-universes-ok/forall
                   h
                   (leq-lvl/imaxLz leq-lvl/self)
                   ([w]
                     ([h2]
                       (field-universes-ok/forall
                         h1
                         (leq-lvl/imaxLz leq-lvl/self)
                         ([v]
                           ([h3]
                             (field-universes-ok/done
                               not-forall/app))))))))))))).

And_intro/name : name "And.intro" (is-decl (eforall (esort lzero) ([x] (eforall (esort lzero) ([y] (eforall x ([w] (eforall y ([v] (eapp (eapp (econst "And" lnil) x) y))))))))) (ctor "And" z)).

And_intro/decl : declared "And.intro" (eforall (esort lzero) ([x] (eforall (esort lzero) ([y] (eforall x ([w] (eforall y ([v] (eapp (eapp (econst "And" lnil) x) y))))))))) (ctor "And" z)
