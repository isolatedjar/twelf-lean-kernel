List_nil/fuo : field-universes-ok-skip-params (lis liz) (eforall (esort (lsucc (lvar liz))) ([x] (eapp (econst "List" (lcons (lvar liz) lnil)) x))) (lsucc (lvar liz))
   = (field-universes-ok-skip-params/skip
       ([x]
