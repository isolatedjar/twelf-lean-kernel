%%   K-like reduction: yes

%% def List.recOn
List_recOn/type-wf : of
  (eforall (esort (lsucc (lvar (s z))))
    ([x]
      (eforall (eforall (eapp (econst "List" (lcons (lvar (s z)) lnil)) x) ([y] (esort (lvar z))))
        ([y]
          (eforall (eapp (econst "List" (lcons (lvar (s z)) lnil)) x)
            ([w]
              (eforall (eapp y (eapp (econst "List.nil" (lcons (lvar (s z)) lnil)) x))
                ([v]
                  (eforall (eforall x
                    ([x1]
                      (eforall (eapp (econst "List" (lcons (lvar (s z)) lnil)) x)
                        ([y1] (eforall (eapp y y1) ([w1] (eapp y (eapp (eapp (eapp (econst "List.cons" (lcons (lvar (s z)) lnil)) x) x1) y1))))))))
