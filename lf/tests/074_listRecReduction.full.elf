%%% Expected outcome: accept
%%% Reduction behavior of `List.rec`
%solve nonneg_0 : 0 >= 0.

sneq/0 : string-neq "List.nil" "List.cons".

%% inductive List
List/type-wf-sort : lvl
   = (limax (lsucc (lsucc (lvar liz))) (lsucc (lsucc (lvar liz)))).

List/type-wf : of (eforall (esort (lsucc (lvar liz))) ([x] (esort (lsucc (lvar liz))))) (esort List/type-wf-sort)
   = (defeq/forall defeq/sort-refl ([x] ([h] defeq/sort-refl))).

List/ends-in-sort : ends-in-sort (eforall (esort (lsucc (lvar liz))) ([x] (esort (lsucc (lvar liz)))))
   = (ends-in-sort/forall ([x] ends-in-sort/sort)).

List/rec-name : name "List.rec" (is-rec-for "List").

List/eisl : ends-in-sort-with-level (eforall (esort (lsucc (lvar liz))) ([x] (esort (lsucc (lvar liz))))) (lsucc (lvar liz))
   = (ends-in-sort-with-level/forall ([x] ends-in-sort-with-level/sort)).

List/clf : count-leading-foralls (eforall (esort (lsucc (lvar liz))) ([x] (esort (lsucc (lvar liz))))) (lis liz)
   = (count-leading-foralls/succ ([x] count-leading-foralls/zero)).

List/cnd : cnames-distinct (ccons "List.nil" (ccons "List.cons" cnil))
   = (cnames-distinct/cons
       (cnames-distinct/cons cnames-distinct/nil all-string-neq/nil)
       (all-string-neq/cons sneq/0 all-string-neq/nil)).

List/name : name "List" (is-decl (eforall (esort (lsucc (lvar liz))) ([x] (esort (lsucc (lvar liz))))) (indt (ccons "List.nil" (ccons "List.cons" cnil)) (lis liz))).

List/decl : declared "List" (eforall (esort (lsucc (lvar liz))) ([x] (esort (lsucc (lvar liz))))) (indt (ccons "List.nil" (ccons "List.cons" cnil)) (lis liz))
   = declared/ok-indt List/name List/rec-name List/clf List/cnd (dkind-ok/indt List/type-wf List/ends-in-sort).

%% ctor List.nil (of List)
List_nil/type-wf-sort : lvl
   = (limax (lsucc (lsucc (lvar liz))) (lsucc (lvar liz))).

List_nil/type-wf : of (eforall (esort (lsucc (lvar liz))) ([x] (eapp (econst "List" (lcons (lvar liz) lnil)) x))) (esort List_nil/type-wf-sort)
   = (defeq/forall
       defeq/sort-refl
       ([x]
         ([h]
           (defeq/app
             (defeq/const
               List/decl
               (inst-expr/forall
                 (inst-expr/sort (lvl-inst/succ (lvl-inst/var lvl-nth/zero)))
                 ([x]
                   ([h]
                     (inst-expr/sort
                       (lvl-inst/succ (lvl-inst/var lvl-nth/zero)))))))
             h)))).

List_nil/positivity : ctor-positive "List" (lcons (lvar liz) lnil) (eforall (esort (lsucc (lvar liz))) ([x] (eapp (econst "List" (lcons (lvar liz) lnil)) x)))
   = (ctor-positive/intro ([S] (eforall (esort (lsucc (lvar liz))) ([x] (eapp S x)))) (ctor-spine/arg
       (strict-pos/no-occur (esort (lsucc (lvar liz))) no-self-ref/sort)
       ([x] ([y] (ctor-spine/result (applies-self/app applies-self/refl)))))).

List_nil/cmem : cmem "List.nil" (ccons "List.nil" (ccons "List.cons" cnil))
