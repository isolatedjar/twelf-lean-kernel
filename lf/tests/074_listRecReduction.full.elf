%%% Expected outcome: accept
%%% Reduction behavior of `List.rec`
sneq/0 : string-neq "List.nil" "List.cons".

%% inductive List
List/type-wf : of (eforall (esort (lsucc (lvar z))) ([x] (esort (lsucc (lvar z))))) (esort (limax (lsucc (lsucc (lvar z))) (lsucc (lsucc (lvar z)))))
   = (defeq/forall defeq/sort-refl ([x] ([h] defeq/sort-refl))).

List/ends-in-sort : ends-in-sort (eforall (esort (lsucc (lvar z))) ([x] (esort (lsucc (lvar z)))))
   = (ends-in-sort/forall ([x] ends-in-sort/sort)).

List/rec-name : name "List.rec" (is-rec-for "List").

List/eisl : ends-in-sort-with-level (eforall (esort (lsucc (lvar z))) ([x] (esort (lsucc (lvar z))))) (lsucc (lvar z))
   = (ends-in-sort-with-level/forall ([x] ends-in-sort-with-level/sort)).

List/cnd : cnames-distinct (ccons "List.nil" (ccons "List.cons" cnil))
   = (cnames-distinct/cons
       (cnames-distinct/cons cnames-distinct/nil all-string-neq/nil)
       (all-string-neq/cons sneq/0 all-string-neq/nil)).

List/name : name "List" (is-decl (eforall (esort (lsucc (lvar z))) ([x] (esort (lsucc (lvar z))))) (indt (ccons "List.nil" (ccons "List.cons" cnil)) (s z))).

List/decl : declared "List" (eforall (esort (lsucc (lvar z))) ([x] (esort (lsucc (lvar z))))) (indt (ccons "List.nil" (ccons "List.cons" cnil)) (s z))
   = declared/ok-indt List/name List/rec-name List/cnd (dkind-ok/indt List/type-wf List/ends-in-sort).

%% ctor List.nil (of List)
List_nil/type-wf : of (eforall (esort (lsucc (lvar z))) ([x] (eapp (econst "List" (lcons (lvar z) lnil)) x))) (esort (limax (lsucc (lsucc (lvar z))) (lsucc (lvar z))))
   = (defeq/forall
       defeq/sort-refl
       ([x]
         ([h]
           (defeq/app
             (defeq/const
               List/decl
               (inst-expr/forall
                 (inst-expr/sort (inst-lvl/succ (inst-lvl/var nth-lvl/z)))
                 ([x]
                   ([h]
                     (inst-expr/sort
                       (inst-lvl/succ (inst-lvl/var nth-lvl/z)))))))
             h)))).

List_nil/positivity : ctor-positive "List" (lcons (lvar z) lnil) (eforall (esort (lsucc (lvar z))) ([x] (eapp (econst "List" (lcons (lvar z) lnil)) x)))
   = (ctor-positive/intro ([S] (eforall (esort (lsucc (lvar z))) ([x] (eapp S x)))) (ctor-spine/arg
       (strict-pos/no-occur (esort (lsucc (lvar z))) no-self-ref/sort)
       ([x] ([y] (ctor-spine/result (applies-self/app applies-self/refl)))))).

List_nil/cmem : cmem "List.nil" (ccons "List.nil" (ccons "List.cons" cnil))
   = cmem/here.

%%% HOLE: List_nil/fuo
List_nil/fuo : field-universes-ok (eforall (esort (lsucc (lvar z))) ([x] (eapp (econst "List" (lcons (lvar z) lnil)) x))) (lsucc (lvar z)).

List_nil/name : name "List.nil" (is-decl (eforall (esort (lsucc (lvar z))) ([x] (eapp (econst "List" (lcons (lvar z) lnil)) x))) (ctor "List" z)).

List_nil/decl : declared "List.nil" (eforall (esort (lsucc (lvar z))) ([x] (eapp (econst "List" (lcons (lvar z) lnil)) x))) (ctor "List" z)
   = declared/ok-ctor List_nil/name List/name List_nil/cmem List/eisl List_nil/fuo (dkind-ok/ctor List_nil/type-wf List_nil/positivity).

%% ctor List.cons (of List)
List_cons/type-wf : of
  (eforall (esort (lsucc (lvar z))) ([x] (eforall x ([y] (eforall (eapp (econst "List" (lcons (lvar z) lnil)) x) ([w] (eapp (econst "List" (lcons (lvar z) lnil)) x)))))))
  (esort (limax (lsucc (lsucc (lvar z))) (limax (lsucc (lvar z)) (limax (lsucc (lvar z)) (lsucc (lvar z))))))
   = (defeq/forall
       defeq/sort-refl
       ([x]
         ([h]
           (defeq/forall
             h
             ([y]
               ([h1]
                 (defeq/forall
                   (defeq/app
                     (defeq/const
                       List/decl
                       (inst-expr/forall
                         (inst-expr/sort
                           (inst-lvl/succ (inst-lvl/var nth-lvl/z)))
                         ([x]
                           ([h]
                             (inst-expr/sort
                               (inst-lvl/succ (inst-lvl/var nth-lvl/z)))))))
                     h)
                   ([w]
                     ([h2]
                       (defeq/app
                         (defeq/const
                           List/decl
                           (inst-expr/forall
                             (inst-expr/sort
                               (inst-lvl/succ (inst-lvl/var nth-lvl/z)))
                             ([x]
                               ([h]
                                 (inst-expr/sort
                                   (inst-lvl/succ (inst-lvl/var nth-lvl/z)))))))
                         h)))))))))).

List_cons/positivity : ctor-positive "List" (lcons (lvar z) lnil) (eforall (esort (lsucc (lvar z))) ([x] (eforall x ([y] (eforall (eapp (econst "List" (lcons (lvar z) lnil)) x) ([w] (eapp (econst "List" (lcons (lvar z) lnil)) x)))))))
   = (ctor-positive/intro ([S] (eforall (esort (lsucc (lvar z))) ([x] (eforall x ([y] (eforall (eapp S x) ([w] (eapp S x)))))))) (ctor-spine/arg
       (strict-pos/no-occur (esort (lsucc (lvar z))) no-self-ref/sort)
       ([x]
         ([y]
           (ctor-spine/arg
             (strict-pos/no-occur x y)
             ([w]
               ([v]
                 (ctor-spine/arg
                   (strict-pos/head (applies-self/app applies-self/refl))
                   ([x1]
                     ([y1]
                       (ctor-spine/result
                         (applies-self/app applies-self/refl)))))))))))).

List_cons/cmem : cmem "List.cons" (ccons "List.nil" (ccons "List.cons" cnil))
   = (cmem/there cmem/here).

%%% HOLE: List_cons/fuo
List_cons/fuo : field-universes-ok (eforall (esort (lsucc (lvar z))) ([x] (eforall x ([y] (eforall (eapp (econst "List" (lcons (lvar z) lnil)) x) ([w] (eapp (econst "List" (lcons (lvar z) lnil)) x))))))) (lsucc (lvar z)).

List_cons/name : name "List.cons" (is-decl
  (eforall (esort (lsucc (lvar z))) ([x] (eforall x ([y] (eforall (eapp (econst "List" (lcons (lvar z) lnil)) x) ([w] (eapp (econst "List" (lcons (lvar z) lnil)) x)))))))
  (ctor "List" (s z))).

List_cons/decl : declared "List.cons"
  (eforall (esort (lsucc (lvar z))) ([x] (eforall x ([y] (eforall (eapp (econst "List" (lcons (lvar z) lnil)) x) ([w] (eapp (econst "List" (lcons (lvar z) lnil)) x)))))))
  (ctor "List" (s z))
   = declared/ok-ctor List_cons/name List/name List_cons/cmem List/eisl List_cons/fuo (dkind-ok/ctor List_cons/type-wf List_cons/positivity).

