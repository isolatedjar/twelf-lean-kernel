       (limax (lsucc lzero) (lsucc (lsucc (lvar liz))))).

OfNat/type-wf : of (eforall (esort (lsucc (lvar liz))) ([x] (eforall (econst "Nat" lnil) ([y] (esort (lsucc (lvar liz))))))) (esort OfNat/type-wf-sort)
   = (defeq/forall
       defeq/sort-refl
       ([x]
         ([h]
           (defeq/forall
             (defeq/const
               Nat/decl
               (inst-expr/sort (lvl-inst/succ lvl-inst/zero)))
             ([y] ([h1] defeq/sort-refl)))))).

OfNat/ends-in-sort : ends-in-sort (eforall (esort (lsucc (lvar liz))) ([x] (eforall (econst "Nat" lnil) ([y] (esort (lsucc (lvar liz)))))))
   = (ends-in-sort/forall ([x] (ends-in-sort/forall ([y] ends-in-sort/sort)))).

OfNat/rec-name : name "OfNat.rec" (is-rec-for "OfNat").

OfNat/name : name "OfNat" (is-decl (eforall (esort (lsucc (lvar liz))) ([x] (eforall (econst "Nat" lnil) ([y] (esort (lsucc (lvar liz))))))) indt).

OfNat/decl : declared "OfNat" (eforall (esort (lsucc (lvar liz))) ([x] (eforall (econst "Nat" lnil) ([y] (esort (lsucc (lvar liz))))))) indt
