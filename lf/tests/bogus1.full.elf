                               (inst-expr/forall
                                 h
                                 ([w]
                                   ([h2]
                                     (inst-expr/app
                                       (inst-expr/app
                                         (inst-expr/const
                                           (inst-lvls/cons
                                             inst-lvls/nil
                                             (inst-lvl/var nth-lvl/z)))
                                         h)
                                       h1)))))))))))
                 (defeq/const
                   Nat/decl
                   (inst-expr/sort (inst-lvl/succ inst-lvl/zero))))
               h)
             h)))).

instOfNatNat/name : name "instOfNatNat" (is-decl
  (eforall (econst "Nat" lnil) ([x] (eapp (eapp (econst "OfNat" (lcons lzero lnil)) (econst "Nat" lnil)) x)))
  (defn (elam (econst "Nat" lnil) ([x] (eapp (eapp (eapp (econst "OfNat.mk" (lcons lzero lnil)) (econst "Nat" lnil)) x) x))))).

instOfNatNat/decl : declared "instOfNatNat"
  (eforall (econst "Nat" lnil) ([x] (eapp (eapp (econst "OfNat" (lcons lzero lnil)) (econst "Nat" lnil)) x)))
  (defn (elam (econst "Nat" lnil) ([x] (eapp (eapp (eapp (econst "OfNat.mk" (lcons lzero lnil)) (econst "Nat" lnil)) x) x))))
   = declared/ok instOfNatNat/name dkind-non-inductive/defn (dkind-ok/defn instOfNatNat/type-wf instOfNatNat/value-typed).

%% inductive True
True/type-wf : of (esort lzero) (esort (lsucc lzero))
   = defeq/sort-refl.

True/ends-in-sort : ends-in-sort (esort lzero)
   = ends-in-sort/sort.

True/rec-name : name "True.rec" (is-rec-for "True").

True/eisl : ends-in-sort-with-level (esort lzero) lzero
   = ends-in-sort-with-level/sort.

True/cnd : cnames-distinct (ccons "True.intro" cnil)
   = (cnames-distinct/cons cnames-distinct/nil all-string-neq/nil).

True/name : name "True" (is-decl (esort lzero) (indt (ccons "True.intro" cnil) z)).

True/decl : declared "True" (esort lzero) (indt (ccons "True.intro" cnil) z)
   = declared/ok-indt True/name True/rec-name True/cnd (dkind-ok/indt True/type-wf True/ends-in-sort).

%% ctor True.intro (of True)
True_intro/type-wf : of (econst "True" lnil) (esort lzero)
   = (defeq/const True/decl (inst-expr/sort inst-lvl/zero)).

True_intro/positivity : ctor-positive "True" lnil (econst "True" lnil)
   = (ctor-positive/intro ([S] S) (ctor-spine/result applies-self/refl)).

True_intro/cmem : cmem "True.intro" (ccons "True.intro" cnil)
   = cmem/here.

True_intro/fuo : field-universes-ok (econst "True" lnil) lzero
   = (field-universes-ok/done not-forall/const).

True_intro/name : name "True.intro" (is-decl (econst "True" lnil) (ctor "True" z)).

True_intro/decl : declared "True.intro" (econst "True" lnil) (ctor "True" z)
   = declared/ok-ctor True_intro/name True/name True_intro/cmem True/eisl True_intro/fuo (dkind-ok/ctor True_intro/type-wf True_intro/positivity).

%% recursor True.rec (TCB-derived; informational only)
%%   level params: u
%%   type:   (eforall (eforall (econst "True" lnil) ([x] (esort (lvar z)))) ([x] (eforall (eapp x (econst "True.intro" lnil)) ([y] (eforall (econst "True" lnil) ([w] (eapp x w)))))))
%%   rules:
%%     True.rec … True.intro … = (elam (eforall (econst "True" lnil) ([x] (esort (lvar z)))) ([x] (elam (eapp x (econst "True.intro" lnil)) ([y] y))))   (0 fields)
%%   K-like reduction: yes

