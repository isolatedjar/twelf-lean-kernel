thm/name : name "thm" (is-decl
  (eapp (eapp (eapp (econst "Eq" (lcons (lsucc lzero) lnil)) (econst "Nat" lnil))
    (eapp (eapp (eapp (econst "OfNat.ofNat" (lcons lzero lnil)) (econst "Nat" lnil)) (enatlit 0 nonneg_0)) (eapp (econst "instOfNatNat" lnil) (enatlit 0 nonneg_0))))
    (eapp (eapp (eapp (econst "OfNat.ofNat" (lcons lzero lnil)) (econst "Nat" lnil)) (enatlit 1 nonneg_1)) (eapp (econst "instOfNatNat" lnil) (enatlit 1 nonneg_1))))
  (thm (econst "True.intro" lnil))).

thm/decl : declared "thm"
  (eapp (eapp (eapp (econst "Eq" (lcons (lsucc lzero) lnil)) (econst "Nat" lnil))
    (eapp (eapp (eapp (econst "OfNat.ofNat" (lcons lzero lnil)) (econst "Nat" lnil)) (enatlit 0 nonneg_0)) (eapp (econst "instOfNatNat" lnil) (enatlit 0 nonneg_0))))
    (eapp (eapp (eapp (econst "OfNat.ofNat" (lcons lzero lnil)) (econst "Nat" lnil)) (enatlit 1 nonneg_1)) (eapp (econst "instOfNatNat" lnil) (enatlit 1 nonneg_1))))
  (thm (econst "True.intro" lnil))
