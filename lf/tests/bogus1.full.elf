    (eapp (eapp (eapp (econst "OfNat.ofNat" (lcons lzero lnil)) (econst "Nat" lnil)) (enatlit 1 nonneg_1)) (eapp (econst "instOfNatNat" lnil) (enatlit 1 nonneg_1))))
