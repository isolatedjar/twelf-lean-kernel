%%% Expected outcome: accept
%%% Type checking Nat literals
%solve nonneg_0 : 0 >= 0.

sneq/0 : string-neq "Nat.zero" "Nat.succ".

%% inductive Nat
Nat/type-wf-sort : lvl
   = (lsucc (lsucc lzero)).

Nat/type-wf : of (esort (lsucc lzero)) (esort Nat/type-wf-sort)
   = defeq/sort-refl.

Nat/ends-in-sort : ends-in-sort (esort (lsucc lzero))
   = ends-in-sort/sort.

Nat/rec-name : name "Nat.rec" (is-rec-for "Nat").

Nat/eisl : ends-in-sort-with-level (esort (lsucc lzero)) (lsucc lzero)
   = ends-in-sort-with-level/sort.

Nat/cnd : cnames-distinct (ccons "Nat.zero" (ccons "Nat.succ" cnil))
   = (cnames-distinct/cons
       (cnames-distinct/cons cnames-distinct/nil all-string-neq/nil)
       (all-string-neq/cons sneq/0 all-string-neq/nil)).

Nat/name : name "Nat" (is-decl (esort (lsucc lzero)) (indt (ccons "Nat.zero" (ccons "Nat.succ" cnil)) liz)).

Nat/decl : declared "Nat" (esort (lsucc lzero)) (indt (ccons "Nat.zero" (ccons "Nat.succ" cnil)) liz)
   = declared/ok-indt Nat/name Nat/rec-name Nat/cnd (dkind-ok/indt Nat/type-wf Nat/ends-in-sort).

%% ctor Nat.zero (of Nat)
Nat_zero/type-wf-sort : lvl
   = (lsucc lzero).

Nat_zero/type-wf : of (econst "Nat" lnil) (esort Nat_zero/type-wf-sort)
   = (defeq/const Nat/decl (inst-expr/sort (lvl-inst/succ lvl-inst/zero))).

Nat_zero/positivity : ctor-positive "Nat" lnil (econst "Nat" lnil)
   = (ctor-positive/intro ([S] S) (ctor-spine/result applies-self/refl)).

Nat_zero/cmem : cmem "Nat.zero" (ccons "Nat.zero" (ccons "Nat.succ" cnil))
   = cmem/here.

Nat_zero/fuo : field-universes-ok (econst "Nat" lnil) (lsucc lzero)
   = (field-universes-ok/done not-forall/const).

Nat_zero/name : name "Nat.zero" (is-decl (econst "Nat" lnil) (ctor "Nat" liz)).

Nat_zero/decl : declared "Nat.zero" (econst "Nat" lnil) (ctor "Nat" liz)
   = declared/ok-ctor Nat_zero/name Nat/name Nat_zero/cmem Nat/eisl Nat_zero/fuo (dkind-ok/ctor Nat_zero/type-wf Nat_zero/positivity).

%% ctor Nat.succ (of Nat)
Nat_succ/type-wf-sort : lvl
   = (limax (lsucc lzero) (lsucc lzero)).

Nat_succ/type-wf : of (eforall (econst "Nat" lnil) ([x] (econst "Nat" lnil))) (esort Nat_succ/type-wf-sort)
   = (defeq/forall
       (defeq/const Nat/decl (inst-expr/sort (lvl-inst/succ lvl-inst/zero)))
       ([x]
         ([h]
           (defeq/const
             Nat/decl
             (inst-expr/sort (lvl-inst/succ lvl-inst/zero)))))).

Nat_succ/positivity : ctor-positive "Nat" lnil (eforall (econst "Nat" lnil) ([x] (econst "Nat" lnil)))
   = (ctor-positive/intro ([S] (eforall S ([x] S))) (ctor-spine/arg
       (strict-pos/head applies-self/refl)
       ([x] ([y] (ctor-spine/result applies-self/refl))))).

Nat_succ/cmem : cmem "Nat.succ" (ccons "Nat.zero" (ccons "Nat.succ" cnil))
   = (cmem/there cmem/here).

Nat_succ/fuo : field-universes-ok (eforall (econst "Nat" lnil) ([x] (econst "Nat" lnil))) (lsucc lzero)
   = (field-universes-ok/forall
       (defeq/const Nat/decl (inst-expr/sort (lvl-inst/succ lvl-inst/zero)))
       (mleq/imax-lsL
         (mleq/sR
           (mleq/maxL
             (mleq/sL (mleq/self nonneg_0))
             (mleq/sL (mleq/self nonneg_0)))))
       ([x] ([h] (field-universes-ok/done not-forall/const)))).

Nat_succ/name : name "Nat.succ" (is-decl (eforall (econst "Nat" lnil) ([x] (econst "Nat" lnil))) (ctor "Nat" (lis liz))).

Nat_succ/decl : declared "Nat.succ" (eforall (econst "Nat" lnil) ([x] (econst "Nat" lnil))) (ctor "Nat" (lis liz))
   = declared/ok-ctor Nat_succ/name Nat/name Nat_succ/cmem Nat/eisl Nat_succ/fuo (dkind-ok/ctor Nat_succ/type-wf Nat_succ/positivity).

%% recursor Nat.rec (TCB-derived; informational only)
%%   level params: u
%%   type:   (eforall (eforall (econst "Nat" lnil) ([x] (esort (lvar liz)))) ([x] (eforall (eapp x (econst "Nat.zero" lnil)) ([y] (eforall (eforall (econst "Nat" lnil) ([z] (eforall (eapp x z) ([w] (eapp x (eapp (econst "Nat.succ" lnil) z)))))) ([z] (eforall (econst "Nat" lnil) ([w] (eapp x w)))))))))
%%   rules:
%%     Nat.rec … Nat.zero … = (elam (eforall (econst "Nat" lnil) ([x] (esort (lvar liz)))) ([x] (elam (eapp x (econst "Nat.zero" lnil)) ([y] (elam (eforall (econst "Nat" lnil) ([z] (eforall (eapp x z) ([w] (eapp x (eapp (econst "Nat.succ" lnil) z)))))) ([z] y))))))   (0 fields)
%%     Nat.rec … Nat.succ … = (elam (eforall (econst "Nat" lnil) ([x] (esort (lvar liz)))) ([x] (elam (eapp x (econst "Nat.zero" lnil)) ([y] (elam (eforall (econst "Nat" lnil) ([z] (eforall (eapp x z) ([w] (eapp x (eapp (econst "Nat.succ" lnil) z)))))) ([z] (elam (econst "Nat" lnil) ([w] (eapp (eapp z w) (eapp (eapp (eapp (eapp (econst "Nat.rec" (lcons (lvar liz) lnil)) x) y) z) w))))))))))   (1 fields)

%% def aNatLit
aNatLit/type-wf-sort : lvl
   = (lsucc lzero).

aNatLit/type-wf : of (econst "Nat" lnil) (esort aNatLit/type-wf-sort)
   = (defeq/const Nat/decl (inst-expr/sort (lvl-inst/succ lvl-inst/zero))).

%%% HOLE
aNatLit/value-typed : of (enatlit 0 nonneg_0) (econst "Nat" lnil).

aNatLit/name : name "aNatLit" (is-decl (econst "Nat" lnil) (defn (enatlit 0 nonneg_0))).

aNatLit/decl : declared "aNatLit" (econst "Nat" lnil) (defn (enatlit 0 nonneg_0))
   = declared/ok aNatLit/name dkind-non-inductive/defn (dkind-ok/defn aNatLit/type-wf aNatLit/value-typed).
