%%% Expected outcome: accept
%%% Arrow type (function type)
%% def arrowType
arrowType/type-wf-sort : lvl
   = (lsucc (lsucc lzero)).

arrowType/type-wf : defeq (esort (lsucc lzero)) (esort (lsucc lzero)) (esort arrowType/type-wf-sort)
   = defeq/sort-refl.

arrowType/value-typed : defeq (eforall (esort lzero) ([x] (esort lzero))) (eforall (esort lzero) ([x] (esort lzero))) (esort (lsucc lzero))
   = (defeq/conv (defeq/sort-eq lvl-eq/imax-idem) (defeq/forall defeq/sort-refl ([x] ([h] defeq/sort-refl)))).

arrowType/name : name "arrowType" (is-decl (esort (lsucc lzero)) (defn (eforall (esort lzero) ([x] (esort lzero))))).

arrowType/decl : declared "arrowType" (esort (lsucc lzero)) (defn (eforall (esort lzero) ([x] (esort lzero))))
   = declared/ok arrowType/name (dkind-ok/defn arrowType/type-wf arrowType/value-typed).

