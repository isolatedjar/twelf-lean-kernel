%%% Expected outcome: reject
%%% A definition and a constructor with the same name
%% def dup_ctor_def.mk
dup_ctor_def_mk/type-wf-sort : lvl
   = (lsucc (lsucc lzero)).

dup_ctor_def_mk/type-wf : of (esort (lsucc lzero)) (esort dup_ctor_def_mk/type-wf-sort)
   = defeq/sort-refl.

dup_ctor_def_mk/value-typed : of (esort lzero) (esort (lsucc lzero))
   = defeq/sort-refl.

dup_ctor_def_mk/name : name "dup_ctor_def.mk" (is-decl (esort (lsucc lzero)) (defn (esort lzero))).

dup_ctor_def_mk/decl : declared "dup_ctor_def.mk" (esort (lsucc lzero)) (defn (esort lzero))
   = declared/ok dup_ctor_def_mk/name (dkind-ok/defn dup_ctor_def_mk/type-wf dup_ctor_def_mk/value-typed).

%% inductive dup_ctor_def
dup_ctor_def/type-wf-sort : lvl
   = (lsucc (lsucc lzero)).

dup_ctor_def/type-wf : of (esort (lsucc lzero)) (esort dup_ctor_def/type-wf-sort)
   = defeq/sort-refl.

dup_ctor_def/ends-in-sort : ends-in-sort (esort (lsucc lzero))
   = ends-in-sort/sort.

dup_ctor_def/rec-name : name "dup_ctor_def.rec" (is-rec-for "dup_ctor_def").

dup_ctor_def/name : name "dup_ctor_def" (is-decl (esort (lsucc lzero)) indt).

dup_ctor_def/decl : declared "dup_ctor_def" (esort (lsucc lzero)) indt
   = declared/ok dup_ctor_def/name (dkind-ok/indt dup_ctor_def/type-wf dup_ctor_def/ends-in-sort).

%% ctor dup_ctor_def.mk (of dup_ctor_def)
dup_ctor_def_mk/type-wf-sort : lvl
   = (lsucc lzero).

dup_ctor_def_mk/type-wf : of (econst "dup_ctor_def" lnil) (esort dup_ctor_def_mk/type-wf-sort)
   = (defeq/const
       dup_ctor_def/decl
       (inst-expr/sort (lvl-inst/succ lvl-inst/zero))).

dup_ctor_def_mk/positivity : ctor-positive "dup_ctor_def" lnil (econst "dup_ctor_def" lnil)
   = (ctor-positive/intro ([S] S) (ctor-spine/result applies-self/refl)).

dup_ctor_def_mk/eisl : ends-in-sort-with-level (esort (lsucc lzero)) (lsucc lzero)
   = ends-in-sort-with-level/sort.

%%% HOLE: dup_ctor_def_mk/fuo — prover for field-universes-ok-skip-params not yet implemented
dup_ctor_def_mk/fuo : field-universes-ok-skip-params liz (econst "dup_ctor_def" lnil) (lsucc lzero).

dup_ctor_def_mk/name : name "dup_ctor_def.mk" (is-decl (econst "dup_ctor_def" lnil) ctor).

dup_ctor_def_mk/decl : declared "dup_ctor_def.mk" (econst "dup_ctor_def" lnil) ctor
   = declared/ok dup_ctor_def_mk/name (dkind-ok/ctor dup_ctor_def_mk/type-wf dup_ctor_def_mk/positivity dup_ctor_def/decl dup_ctor_def_mk/eisl dup_ctor_def_mk/fuo).

%% recursor dup_ctor_def.rec
dup_ctor_def_rec/type-wf-sort : lvl
   = (limax
       (limax (lsucc lzero) (lsucc (lvar liz)))
       (limax (lvar liz) (limax (lsucc lzero) (lvar liz)))).

dup_ctor_def_rec/type-wf : of (eforall (eforall (econst "dup_ctor_def" lnil) ([x] (esort (lvar liz))))
                             ([x] (eforall (eapp x (econst "dup_ctor_def.mk" lnil)) ([y] (eforall (econst "dup_ctor_def" lnil) ([z] (eapp x z))))))) (esort dup_ctor_def_rec/type-wf-sort)
   = (defeq/forall
       (defeq/forall
         (defeq/const
           dup_ctor_def/decl
           (inst-expr/sort (lvl-inst/succ lvl-inst/zero)))
         ([x] ([h] defeq/sort-refl)))
       ([x]
         ([h]
           (defeq/forall
             (defeq/app
               h
               (defeq/const
                 dup_ctor_def_mk/decl
                 (inst-expr/const lvls-inst/nil)))
             ([y]
               ([h1]
                 (defeq/forall
                   (defeq/const
                     dup_ctor_def/decl
                     (inst-expr/sort (lvl-inst/succ lvl-inst/zero)))
                   ([z] ([h2] (defeq/app h h2)))))))))).

dup_ctor_def_rec/decl : declared "dup_ctor_def.rec" (eforall (eforall (econst "dup_ctor_def" lnil) ([x] (esort (lvar liz)))) ([x] (eforall (eapp x (econst "dup_ctor_def.mk" lnil)) ([y] (eforall (econst "dup_ctor_def" lnil) ([z] (eapp x z))))))) irec
   = declared/ok-irec dup_ctor_def/rec-name (dkind-ok/irec dup_ctor_def_rec/type-wf).
