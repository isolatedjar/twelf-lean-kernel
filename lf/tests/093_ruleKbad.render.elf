            (eapp (eapp (eapp (eapp (eapp (eapp (econst "Eq.rec" (lcons (lsucc lzero) (lcons (lsucc lzero) lnil))) (econst "Bool" lnil)) (econst "Bool.true" lnil))
              (elam (econst "Bool" lnil) ([z] (elam (eapp (eapp (eapp (econst "Eq" (lcons (lsucc lzero) lnil)) (econst "Bool" lnil)) (econst "Bool.true" lnil)) z) ([w] (econst "Bool" lnil))))))
              y)
              (econst "Bool.false" lnil))
              x))
            y))))).

ruleKbad/name : name "ruleKbad" (is-decl
  (eforall (eapp (eapp (eapp (econst "Eq" (lcons (lsucc lzero) lnil)) (econst "Bool" lnil)) (econst "Bool.true" lnil)) (econst "Bool.false" lnil))
