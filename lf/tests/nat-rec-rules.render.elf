%% recursor Nat.rec (TCB-derived; informational only)
%%   level params: u_1
%%   type:   (eforall (eforall (econst "Nat" lnil) ([x] (esort (lvar z)))) ([x] (eforall (eapp x (econst "Nat.zero" lnil)) ([y] (eforall (eforall (econst "Nat" lnil) ([w] (eforall (eapp x w) ([v] (eapp x (eapp (econst "Nat.succ" lnil) w)))))) ([w] (eforall (econst "Nat" lnil) ([v] (eapp x v)))))))))
%%   rules:
%%     Nat.rec … Nat.zero … = (elam (eforall (econst "Nat" lnil) ([x] (esort (lvar z)))) ([x] (elam (eapp x (econst "Nat.zero" lnil)) ([y] (elam (eforall (econst "Nat" lnil) ([w] (eforall (eapp x w) ([v] (eapp x (eapp (econst "Nat.succ" lnil) w)))))) ([w] y))))))   (0 fields)
%%     Nat.rec … Nat.succ … = (elam (eforall (econst "Nat" lnil) ([x] (esort (lvar z)))) ([x] (elam (eapp x (econst "Nat.zero" lnil)) ([y] (elam (eforall (econst "Nat" lnil) ([w] (eforall (eapp x w) ([v] (eapp x (eapp (econst "Nat.succ" lnil) w)))))) ([w] (elam (econst "Nat" lnil) ([v] y))))))))   (1 fields)

%% def Nat.beq
%%% HOLE
Nat_beq/type-wf : of (eforall (econst "Nat" lnil) ([x] (eforall (econst "Nat" lnil) ([y] (econst "Bool" lnil))))) (esort _).

%%% HOLE
Nat_beq/value-typed : of
  (elam (econst "Nat" lnil)
    ([x]
      (elam (econst "Nat" lnil)
        ([y]
          (eapp (eapp (eapp (eapp (econst "Nat.rec" (lcons (lsucc lzero) lnil)) (elam (econst "Nat" lnil) ([w] (econst "Bool" lnil)))) (econst "Bool.true" lnil))
            (elam (econst "Nat" lnil) ([w] (elam (econst "Bool" lnil) ([v] (econst "Bool.false" lnil))))))
            x)))))
  (eforall (econst "Nat" lnil) ([x] (eforall (econst "Nat" lnil) ([y] (econst "Bool" lnil))))).

Nat_beq/name : name "Nat.beq" (is-decl
  (eforall (econst "Nat" lnil) ([x] (eforall (econst "Nat" lnil) ([y] (econst "Bool" lnil)))))
  (defn (elam (econst "Nat" lnil) ([x] (elam (econst "Nat" lnil) ([y] (eapp (eapp (eapp (eapp (econst "Nat.rec" (lcons (lsucc lzero) lnil)) (elam (econst "Nat" lnil) ([w] (econst "Bool" lnil)))) (econst "Bool.true" lnil)) (elam (econst "Nat" lnil) ([w] (elam (econst "Bool" lnil) ([v] (econst "Bool.false" lnil)))))) x))))))).

Nat_beq/decl : declared "Nat.beq"
  (eforall (econst "Nat" lnil) ([x] (eforall (econst "Nat" lnil) ([y] (econst "Bool" lnil)))))
  (defn (elam (econst "Nat" lnil) ([x] (elam (econst "Nat" lnil) ([y] (eapp (eapp (eapp (eapp (econst "Nat.rec" (lcons (lsucc lzero) lnil)) (elam (econst "Nat" lnil) ([w] (econst "Bool" lnil)))) (econst "Bool.true" lnil)) (elam (econst "Nat" lnil) ([w] (elam (econst "Bool" lnil) ([v] (econst "Bool.false" lnil)))))) x))))))
   = declared/ok Nat_beq/name dkind-non-inductive/defn (dkind-ok/defn Nat_beq/type-wf Nat_beq/value-typed).

%% def proof_of_false
%%% HOLE
proof_of_false/type-wf : of (econst "False" lnil) (esort _).

%%% HOLE
proof_of_false/value-typed : of
  (eapp (eapp (eapp (eapp (econst "Nat.rec" (lcons lzero lnil))
    (elam (econst "Nat" lnil)
      ([x]
        (eapp (eapp (eapp (eapp (econst "Bool.rec" (lcons (lsucc lzero) lnil)) (elam (econst "Bool" lnil) ([y] (esort lzero)))) (econst "False" lnil)) (econst "True" lnil))
          (eapp (eapp (econst "Nat.beq" lnil) x) (enatlit 0 nonneg_0))))))
    (econst "True.intro" lnil))
    (elam (econst "Nat" lnil)
      ([x]
        (elam (eapp (elam (econst "Nat" lnil)
          ([y]
            (eapp (eapp (eapp (eapp (econst "Bool.rec" (lcons (lsucc lzero) lnil)) (elam (econst "Bool" lnil) ([w] (esort lzero)))) (econst "False" lnil)) (econst "True" lnil))
              (eapp (eapp (econst "Nat.beq" lnil) y) (enatlit 0 nonneg_0)))))
          x)
          ([y] (econst "True.intro" lnil))))))
    (enatlit 1 nonneg_1))
  (econst "False" lnil).

proof_of_false/name : name "proof_of_false" (is-decl
  (econst "False" lnil)
  (defn (eapp (eapp (eapp (eapp (econst "Nat.rec" (lcons lzero lnil)) (elam (econst "Nat" lnil) ([x] (eapp (eapp (eapp (eapp (econst "Bool.rec" (lcons (lsucc lzero) lnil)) (elam (econst "Bool" lnil) ([y] (esort lzero)))) (econst "False" lnil)) (econst "True" lnil)) (eapp (eapp (econst "Nat.beq" lnil) x) (enatlit 0 nonneg_0)))))) (econst "True.intro" lnil)) (elam (econst "Nat" lnil) ([x] (elam (eapp (elam (econst "Nat" lnil) ([y] (eapp (eapp (eapp (eapp (econst "Bool.rec" (lcons (lsucc lzero) lnil)) (elam (econst "Bool" lnil) ([w] (esort lzero)))) (econst "False" lnil)) (econst "True" lnil)) (eapp (eapp (econst "Nat.beq" lnil) y) (enatlit 0 nonneg_0))))) x) ([y] (econst "True.intro" lnil)))))) (enatlit 1 nonneg_1)))).

proof_of_false/decl : declared "proof_of_false"
  (econst "False" lnil)
  (defn (eapp (eapp (eapp (eapp (econst "Nat.rec" (lcons lzero lnil)) (elam (econst "Nat" lnil) ([x] (eapp (eapp (eapp (eapp (econst "Bool.rec" (lcons (lsucc lzero) lnil)) (elam (econst "Bool" lnil) ([y] (esort lzero)))) (econst "False" lnil)) (econst "True" lnil)) (eapp (eapp (econst "Nat.beq" lnil) x) (enatlit 0 nonneg_0)))))) (econst "True.intro" lnil)) (elam (econst "Nat" lnil) ([x] (elam (eapp (elam (econst "Nat" lnil) ([y] (eapp (eapp (eapp (eapp (econst "Bool.rec" (lcons (lsucc lzero) lnil)) (elam (econst "Bool" lnil) ([w] (esort lzero)))) (econst "False" lnil)) (econst "True" lnil)) (eapp (eapp (econst "Nat.beq" lnil) y) (enatlit 0 nonneg_0))))) x) ([y] (econst "True.intro" lnil)))))) (enatlit 1 nonneg_1)))
   = declared/ok proof_of_false/name dkind-non-inductive/defn (dkind-ok/defn proof_of_false/type-wf proof_of_false/value-typed).
