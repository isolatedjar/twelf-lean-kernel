%% recursor Nat.rec
%%% HOLE
Nat_rec/type-wf-sort : lvl.

%%% HOLE
Nat_rec/type-wf : of
  (eforall (eforall (econst "Nat" lnil) ([x] (esort (lvar liz))))
    ([x]
      (eforall (eapp x (econst "Nat.zero" lnil))
        ([y] (eforall (eforall (econst "Nat" lnil) ([z] (eforall (eapp x z) ([w] (eapp x (eapp (econst "Nat.succ" lnil) z)))))) ([z] (eforall (econst "Nat" lnil) ([w] (eapp x w)))))))))
  (esort Nat_rec/type-wf-sort).

Nat_rec/decl : declared "Nat.rec"
  (eforall (eforall (econst "Nat" lnil) ([x] (esort (lvar liz))))
    ([x]
      (eforall (eapp x (econst "Nat.zero" lnil))
        ([y] (eforall (eforall (econst "Nat" lnil) ([z] (eforall (eapp x z) ([w] (eapp x (eapp (econst "Nat.succ" lnil) z)))))) ([z] (eforall (econst "Nat" lnil) ([w] (eapp x w)))))))))
  irec
   = declared/ok-irec Nat/rec-name (dkind-ok/irec Nat_rec/type-wf).

%% def Nat.beq
%%% HOLE
Nat_beq/type-wf-sort : lvl.

%%% HOLE
Nat_beq/type-wf : of (eforall (econst "Nat" lnil) ([x] (eforall (econst "Nat" lnil) ([y] (econst "Bool" lnil))))) (esort Nat_beq/type-wf-sort).

%%% HOLE
Nat_beq/value-typed : of
  (elam (econst "Nat" lnil)
    ([x]
      (elam (econst "Nat" lnil)
        ([y]
          (eapp (eapp (eapp (eapp (econst "Nat.rec" (lcons (lsucc lzero) lnil)) (elam (econst "Nat" lnil) ([z] (econst "Bool" lnil)))) (econst "Bool.true" lnil))
            (elam (econst "Nat" lnil) ([z] (elam (econst "Bool" lnil) ([w] (econst "Bool.false" lnil))))))
            x)))))
  (eforall (econst "Nat" lnil) ([x] (eforall (econst "Nat" lnil) ([y] (econst "Bool" lnil))))).

Nat_beq/name : name "Nat.beq" (is-decl
  (eforall (econst "Nat" lnil) ([x] (eforall (econst "Nat" lnil) ([y] (econst "Bool" lnil)))))
  (defn (elam (econst "Nat" lnil) ([x] (elam (econst "Nat" lnil) ([y] (eapp (eapp (eapp (eapp (econst "Nat.rec" (lcons (lsucc lzero) lnil)) (elam (econst "Nat" lnil) ([z] (econst "Bool" lnil)))) (econst "Bool.true" lnil)) (elam (econst "Nat" lnil) ([z] (elam (econst "Bool" lnil) ([w] (econst "Bool.false" lnil)))))) x))))))).

Nat_beq/decl : declared "Nat.beq"
  (eforall (econst "Nat" lnil) ([x] (eforall (econst "Nat" lnil) ([y] (econst "Bool" lnil)))))
  (defn (elam (econst "Nat" lnil) ([x] (elam (econst "Nat" lnil) ([y] (eapp (eapp (eapp (eapp (econst "Nat.rec" (lcons (lsucc lzero) lnil)) (elam (econst "Nat" lnil) ([z] (econst "Bool" lnil)))) (econst "Bool.true" lnil)) (elam (econst "Nat" lnil) ([z] (elam (econst "Bool" lnil) ([w] (econst "Bool.false" lnil)))))) x))))))
   = declared/ok Nat_beq/name (dkind-ok/defn Nat_beq/type-wf Nat_beq/value-typed).

%% def proof_of_false
%%% HOLE
proof_of_false/type-wf-sort : lvl.

%%% HOLE
proof_of_false/type-wf : of (econst "False" lnil) (esort proof_of_false/type-wf-sort).

%%% HOLE
proof_of_false/value-typed : of
  (eapp (eapp (eapp (eapp (econst "Nat.rec" (lcons lzero lnil))
    (elam (econst "Nat" lnil)
      ([x]
        (eapp (eapp (eapp (eapp (econst "Bool.rec" (lcons (lsucc lzero) lnil)) (elam (econst "Bool" lnil) ([y] (esort lzero)))) (econst "False" lnil)) (econst "True" lnil))
          (eapp (eapp (econst "Nat.beq" lnil) x) (enatlit 0 nonneg_0))))))
    (econst "True.intro" lnil))
    (elam (econst "Nat" lnil)
      ([x]
        (elam (eapp (elam (econst "Nat" lnil)
          ([y]
            (eapp (eapp (eapp (eapp (econst "Bool.rec" (lcons (lsucc lzero) lnil)) (elam (econst "Bool" lnil) ([z] (esort lzero)))) (econst "False" lnil)) (econst "True" lnil))
              (eapp (eapp (econst "Nat.beq" lnil) y) (enatlit 0 nonneg_0)))))
          x)
          ([y] (econst "True.intro" lnil))))))
    (enatlit 1 nonneg_1))
  (econst "False" lnil).

proof_of_false/name : name "proof_of_false" (is-decl
  (econst "False" lnil)
  (defn (eapp (eapp (eapp (eapp (econst "Nat.rec" (lcons lzero lnil)) (elam (econst "Nat" lnil) ([x] (eapp (eapp (eapp (eapp (econst "Bool.rec" (lcons (lsucc lzero) lnil)) (elam (econst "Bool" lnil) ([y] (esort lzero)))) (econst "False" lnil)) (econst "True" lnil)) (eapp (eapp (econst "Nat.beq" lnil) x) (enatlit 0 nonneg_0)))))) (econst "True.intro" lnil)) (elam (econst "Nat" lnil) ([x] (elam (eapp (elam (econst "Nat" lnil) ([y] (eapp (eapp (eapp (eapp (econst "Bool.rec" (lcons (lsucc lzero) lnil)) (elam (econst "Bool" lnil) ([z] (esort lzero)))) (econst "False" lnil)) (econst "True" lnil)) (eapp (eapp (econst "Nat.beq" lnil) y) (enatlit 0 nonneg_0))))) x) ([y] (econst "True.intro" lnil)))))) (enatlit 1 nonneg_1)))).

proof_of_false/decl : declared "proof_of_false"
  (econst "False" lnil)
  (defn (eapp (eapp (eapp (eapp (econst "Nat.rec" (lcons lzero lnil)) (elam (econst "Nat" lnil) ([x] (eapp (eapp (eapp (eapp (econst "Bool.rec" (lcons (lsucc lzero) lnil)) (elam (econst "Bool" lnil) ([y] (esort lzero)))) (econst "False" lnil)) (econst "True" lnil)) (eapp (eapp (econst "Nat.beq" lnil) x) (enatlit 0 nonneg_0)))))) (econst "True.intro" lnil)) (elam (econst "Nat" lnil) ([x] (elam (eapp (elam (econst "Nat" lnil) ([y] (eapp (eapp (eapp (eapp (econst "Bool.rec" (lcons (lsucc lzero) lnil)) (elam (econst "Bool" lnil) ([z] (esort lzero)))) (econst "False" lnil)) (econst "True" lnil)) (eapp (eapp (econst "Nat.beq" lnil) y) (enatlit 0 nonneg_0))))) x) ([y] (econst "True.intro" lnil)))))) (enatlit 1 nonneg_1)))
   = declared/ok proof_of_false/name (dkind-ok/defn proof_of_false/type-wf proof_of_false/value-typed).
