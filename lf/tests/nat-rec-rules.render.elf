%%% HOLE
True_intro/positivity : ctor-positive "True" lnil (econst "True" lnil).

True_intro/eisl : ends-in-sort-with-level (esort lzero) lzero
   = ends-in-sort-with-level/sort.

%%% HOLE: True_intro/fuo — prover for field-universes-ok-skip-params not yet implemented
True_intro/fuo : field-universes-ok-skip-params liz (econst "True" lnil) lzero.

True_intro/name : name "True.intro" (is-decl (econst "True" lnil) ctor).

True_intro/decl : declared "True.intro" (econst "True" lnil) ctor
   = declared/ok True_intro/name (dkind-ok/ctor True_intro/type-wf True_intro/positivity True/decl True_intro/eisl True_intro/fuo).

%% recursor True.rec
%%% HOLE
True_rec/type-wf-sort : lvl.

%%% HOLE
True_rec/type-wf : of
  (eforall (eforall (econst "True" lnil) ([x] (esort (lvar liz)))) ([x] (eforall (eapp x (econst "True.intro" lnil)) ([y] (eforall (econst "True" lnil) ([z] (eapp x z)))))))
  (esort True_rec/type-wf-sort).

True_rec/decl : declared "True.rec" (eforall (eforall (econst "True" lnil) ([x] (esort (lvar liz)))) ([x] (eforall (eapp x (econst "True.intro" lnil)) ([y] (eforall (econst "True" lnil) ([z] (eapp x z))))))) irec
   = declared/ok-irec True/rec-name (dkind-ok/irec True_rec/type-wf).

