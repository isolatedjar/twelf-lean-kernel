%%% Expected outcome: accept
%%% Unit eta
%% inductive PUnit
PUnit/type-wf : of (esort (lvar z)) (esort (lsucc (lvar z)))
   = defeq/sort-refl.

PUnit/ends-in-sort : ends-in-sort (esort (lvar z))
   = ends-in-sort/sort.

PUnit/rec-name : name "PUnit.rec" (is-rec-for "PUnit").

PUnit/eisl : ends-in-sort-with-level (esort (lvar z)) (lvar z)
   = ends-in-sort-with-level/sort.

PUnit/cnd : cnames-distinct (ccons "PUnit.unit" cnil)
   = (cnames-distinct/cons cnames-distinct/nil all-string-neq/nil).

PUnit/name : name "PUnit" (is-decl (esort (lvar z)) (indt (ccons "PUnit.unit" cnil) z)).

PUnit/decl : declared "PUnit" (esort (lvar z)) (indt (ccons "PUnit.unit" cnil) z)
   = declared/ok-indt PUnit/name PUnit/rec-name PUnit/cnd (dkind-ok/indt PUnit/type-wf PUnit/ends-in-sort).

%% ctor PUnit.unit (of PUnit)
PUnit_unit/type-wf : of (econst "PUnit" (lcons (lvar z) lnil)) (esort (lvar z))
   = (defeq/const PUnit/decl (inst-expr/sort (inst-lvl/var nth-lvl/z))).

PUnit_unit/positivity : ctor-positive "PUnit" (lcons (lvar z) lnil) (econst "PUnit" (lcons (lvar z) lnil))
   = (ctor-positive/intro ([S] S) (ctor-spine/result applies-self/refl)).

PUnit_unit/cmem : cmem "PUnit.unit" (ccons "PUnit.unit" cnil)
   = cmem/here.

PUnit_unit/fuo : field-universes-ok (econst "PUnit" (lcons (lvar z) lnil)) (lvar z)
   = (field-universes-ok/done not-forall/const).

PUnit_unit/name : name "PUnit.unit" (is-decl (econst "PUnit" (lcons (lvar z) lnil)) (ctor "PUnit" z)).

PUnit_unit/decl : declared "PUnit.unit" (econst "PUnit" (lcons (lvar z) lnil)) (ctor "PUnit" z)
   = declared/ok-ctor PUnit_unit/name PUnit/name PUnit_unit/cmem PUnit/eisl PUnit_unit/fuo (dkind-ok/ctor PUnit_unit/type-wf PUnit_unit/positivity).

%% recursor PUnit.rec (TCB-derived; informational only)
%%   level params: u_1 u
%%   type:   (eforall (eforall (econst "PUnit" (lcons (lvar (s z)) lnil)) ([x] (esort (lvar z)))) ([x] (eforall (eapp x (econst "PUnit.unit" (lcons (lvar (s z)) lnil))) ([y] (eforall (econst "PUnit" (lcons (lvar (s z)) lnil)) ([w] (eapp x w)))))))
%%   rules:
%%     PUnit.rec … PUnit.unit … = (elam (eforall (econst "PUnit" (lcons (lvar (s z)) lnil)) ([x] (esort (lvar z)))) ([x] (elam (eapp x (econst "PUnit.unit" (lcons (lvar (s z)) lnil))) ([y] y))))   (0 fields)

%% def Unit
Unit/type-wf : of (esort (lsucc lzero)) (esort (lsucc (lsucc lzero)))
   = defeq/sort-refl.

Unit/value-typed : of (econst "PUnit" (lcons (lsucc lzero) lnil)) (esort (lsucc lzero))
   = (defeq/const PUnit/decl (inst-expr/sort (inst-lvl/var nth-lvl/z))).

Unit/name : name "Unit" (is-decl (esort (lsucc lzero)) (defn (econst "PUnit" (lcons (lsucc lzero) lnil)))).

Unit/decl : declared "Unit" (esort (lsucc lzero)) (defn (econst "PUnit" (lcons (lsucc lzero) lnil)))
   = declared/ok Unit/name dkind-non-inductive/defn (dkind-ok/defn Unit/type-wf Unit/value-typed).

%% inductive Eq
Eq/type-wf : of (eforall (esort (lvar z)) ([x] (eforall x ([y] (eforall x ([w] (esort lzero))))))) (esort (limax (lsucc (lvar z)) (limax (lvar z) (limax (lvar z) (lsucc lzero)))))
   = (defeq/forall
       defeq/sort-refl
       ([x]
         ([h]
           (defeq/forall
             h
             ([y] ([h1] (defeq/forall h ([w] ([h2] defeq/sort-refl))))))))).

Eq/ends-in-sort : ends-in-sort (eforall (esort (lvar z)) ([x] (eforall x ([y] (eforall x ([w] (esort lzero)))))))
   = (ends-in-sort/forall
       ([x]
         (ends-in-sort/forall
           ([y] (ends-in-sort/forall ([w] ends-in-sort/sort)))))).

Eq/rec-name : name "Eq.rec" (is-rec-for "Eq").

Eq/eisl : ends-in-sort-with-level (eforall (esort (lvar z)) ([x] (eforall x ([y] (eforall x ([w] (esort lzero))))))) lzero
   = (ends-in-sort-with-level/forall
       ([x]
         (ends-in-sort-with-level/forall
           ([y]
             (ends-in-sort-with-level/forall
               ([w] ends-in-sort-with-level/sort)))))).

Eq/cnd : cnames-distinct (ccons "Eq.refl" cnil)
   = (cnames-distinct/cons cnames-distinct/nil all-string-neq/nil).

Eq/name : name "Eq" (is-decl (eforall (esort (lvar z)) ([x] (eforall x ([y] (eforall x ([w] (esort lzero))))))) (indt (ccons "Eq.refl" cnil) (s (s z)))).

Eq/decl : declared "Eq" (eforall (esort (lvar z)) ([x] (eforall x ([y] (eforall x ([w] (esort lzero))))))) (indt (ccons "Eq.refl" cnil) (s (s z)))
   = declared/ok-indt Eq/name Eq/rec-name Eq/cnd (dkind-ok/indt Eq/type-wf Eq/ends-in-sort).

%% ctor Eq.refl (of Eq)
Eq_refl/type-wf : of (eforall (esort (lvar z)) ([x] (eforall x ([y] (eapp (eapp (eapp (econst "Eq" (lcons (lvar z) lnil)) x) y) y))))) (esort (limax (lsucc (lvar z)) (limax (lvar z) lzero)))
   = (defeq/forall
       defeq/sort-refl
       ([x]
         ([h]
           (defeq/forall
             h
             ([y]
               ([h1]
                 (defeq/app
                   (defeq/app
                     (defeq/app
                       (defeq/const
                         Eq/decl
                         (inst-expr/forall
                           (inst-expr/sort (inst-lvl/var nth-lvl/z))
                           ([x]
                             ([h]
                               (inst-expr/forall
                                 h
                                 ([y]
                                   ([h1]
                                     (inst-expr/forall
                                       h
                                       ([w]
                                         ([h2]
                                           (inst-expr/sort
                                             inst-lvl/zero)))))))))))
                       h)
                     h1)
                   h1))))))).

Eq_refl/positivity : ctor-positive "Eq" (lcons (lvar z) lnil) (eforall (esort (lvar z)) ([x] (eforall x ([y] (eapp (eapp (eapp (econst "Eq" (lcons (lvar z) lnil)) x) y) y)))))
   = (ctor-positive/intro ([S] (eforall (esort (lvar z)) ([x] (eforall x ([y] (eapp (eapp (eapp S x) y) y)))))) (ctor-spine/arg
       (strict-pos/no-occur (esort (lvar z)) no-self-ref/sort)
       ([x]
         ([y]
           (ctor-spine/arg
             (strict-pos/no-occur x y)
             ([w]
               ([v]
                 (ctor-spine/result
                   (applies-self/app
                     (applies-self/app
                       (applies-self/app applies-self/refl))))))))))).

Eq_refl/cmem : cmem "Eq.refl" (ccons "Eq.refl" cnil)
   = cmem/here.

Eq_refl/fuo : field-universes-ok (eforall (esort (lvar z)) ([x] (eforall x ([y] (eapp (eapp (eapp (econst "Eq" (lcons (lvar z) lnil)) x) y) y))))) lzero
   = (field-universes-ok/forall
       defeq/sort-refl
       (leq-lvl/imaxLz leq-lvl/self)
       ([x]
         ([h]
           (field-universes-ok/forall
             h
             (leq-lvl/imaxLz leq-lvl/self)
             ([y] ([h1] (field-universes-ok/done not-forall/app))))))).

Eq_refl/name : name "Eq.refl" (is-decl (eforall (esort (lvar z)) ([x] (eforall x ([y] (eapp (eapp (eapp (econst "Eq" (lcons (lvar z) lnil)) x) y) y))))) (ctor "Eq" z)).

Eq_refl/decl : declared "Eq.refl" (eforall (esort (lvar z)) ([x] (eforall x ([y] (eapp (eapp (eapp (econst "Eq" (lcons (lvar z) lnil)) x) y) y))))) (ctor "Eq" z)
   = declared/ok-ctor Eq_refl/name Eq/name Eq_refl/cmem Eq/eisl Eq_refl/fuo (dkind-ok/ctor Eq_refl/type-wf Eq_refl/positivity).

%% recursor Eq.rec (TCB-derived; informational only)
%%   level params: u u_1
%%   type:   (eforall (esort (lvar (s z))) ([x] (eforall x ([y] (eforall (eforall x ([w] (eforall (eapp (eapp (eapp (econst "Eq" (lcons (lvar (s z)) lnil)) x) y) w) ([v] (esort (lvar z)))))) ([w] (eforall (eapp (eapp w y) (eapp (eapp (econst "Eq.refl" (lcons (lvar (s z)) lnil)) x) y)) ([v] (eforall x ([x1] (eforall (eapp (eapp (eapp (econst "Eq" (lcons (lvar (s z)) lnil)) x) y) x1) ([y1] (eapp (eapp w x1) y1)))))))))))))
%%   rules:
%%     Eq.rec … Eq.refl … = (elam (esort (lvar (s z))) ([x] (elam x ([y] (elam (eforall x ([w] (eforall (eapp (eapp (eapp (econst "Eq" (lcons (lvar (s z)) lnil)) x) y) w) ([v] (esort (lvar z)))))) ([w] (elam (eapp (eapp w y) (eapp (eapp (econst "Eq.refl" (lcons (lvar (s z)) lnil)) x) y)) ([v] v))))))))   (0 fields)
%%   K-like reduction: yes

%% def rfl
rfl/type-wf : of (eforall (esort (lvar z)) ([x] (eforall x ([y] (eapp (eapp (eapp (econst "Eq" (lcons (lvar z) lnil)) x) y) y))))) (esort (limax (lsucc (lvar z)) (limax (lvar z) lzero)))
   = (defeq/forall
       defeq/sort-refl
       ([x]
         ([h]
           (defeq/forall
             h
             ([y]
               ([h1]
                 (defeq/app
                   (defeq/app
                     (defeq/app
                       (defeq/const
                         Eq/decl
                         (inst-expr/forall
                           (inst-expr/sort (inst-lvl/var nth-lvl/z))
                           ([x]
                             ([h]
                               (inst-expr/forall
                                 h
                                 ([y]
                                   ([h1]
                                     (inst-expr/forall
                                       h
                                       ([w]
                                         ([h2]
                                           (inst-expr/sort
                                             inst-lvl/zero)))))))))))
                       h)
                     h1)
                   h1))))))).

rfl/value-typed : of
  (elam (esort (lvar z)) ([x] (elam x ([y] (eapp (eapp (econst "Eq.refl" (lcons (lvar z) lnil)) x) y)))))
  (eforall (esort (lvar z)) ([x] (eforall x ([y] (eapp (eapp (eapp (econst "Eq" (lcons (lvar z) lnil)) x) y) y)))))
   = (defeq/lam
       defeq/sort-refl
       ([x]
         ([h]
           (defeq/lam
             h
             ([y]
               ([h1]
                 (defeq/app
                   (defeq/app
                     (defeq/const
                       Eq_refl/decl
                       (inst-expr/forall
                         (inst-expr/sort (inst-lvl/var nth-lvl/z))
                         ([x]
                           ([h]
                             (inst-expr/forall
                               h
                               ([y]
                                 ([h1]
                                   (inst-expr/app
                                     (inst-expr/app
                                       (inst-expr/app
                                         (inst-expr/const
                                           (inst-lvls/cons
                                             inst-lvls/nil
                                             (inst-lvl/var nth-lvl/z)))
                                         h)
                                       h1)
                                     h1))))))))
                     h)
                   h1))))))).

rfl/name : name "rfl" (is-decl
  (eforall (esort (lvar z)) ([x] (eforall x ([y] (eapp (eapp (eapp (econst "Eq" (lcons (lvar z) lnil)) x) y) y)))))
  (defn (elam (esort (lvar z)) ([x] (elam x ([y] (eapp (eapp (econst "Eq.refl" (lcons (lvar z) lnil)) x) y))))))).

rfl/decl : declared "rfl"
  (eforall (esort (lvar z)) ([x] (eforall x ([y] (eapp (eapp (eapp (econst "Eq" (lcons (lvar z) lnil)) x) y) y)))))
  (defn (elam (esort (lvar z)) ([x] (elam x ([y] (eapp (eapp (econst "Eq.refl" (lcons (lvar z) lnil)) x) y))))))
   = declared/ok rfl/name dkind-non-inductive/defn (dkind-ok/defn rfl/type-wf rfl/value-typed).

%% def unitEta1
unitEta1/type-wf : of
  (eforall (econst "Unit" lnil) ([x] (eforall (econst "Unit" lnil) ([y] (eapp (eapp (eapp (econst "Eq" (lcons (lsucc lzero) lnil)) (econst "Unit" lnil)) x) y)))))
  (esort (limax (lsucc lzero) (limax (lsucc lzero) lzero)))
   = (defeq/forall
       (defeq/const Unit/decl (inst-expr/sort (inst-lvl/succ inst-lvl/zero)))
       ([x]
         ([h]
           (defeq/forall
             (defeq/const
               Unit/decl
               (inst-expr/sort (inst-lvl/succ inst-lvl/zero)))
             ([y]
               ([h1]
                 (defeq/app
                   (defeq/app
                     (defeq/app
                       (defeq/const
                         Eq/decl
                         (inst-expr/forall
                           (inst-expr/sort (inst-lvl/var nth-lvl/z))
                           ([x]
                             ([h]
                               (inst-expr/forall
                                 h
                                 ([y]
                                   ([h1]
                                     (inst-expr/forall
                                       h
                                       ([w]
                                         ([h2]
                                           (inst-expr/sort
                                             inst-lvl/zero)))))))))))
                       (defeq/const
                         Unit/decl
                         (inst-expr/sort (inst-lvl/succ inst-lvl/zero))))
                     h)
                   h1))))))).

%%% HOLE
unitEta1/value-typed : of
  (elam (econst "Unit" lnil) ([x] (elam (econst "Unit" lnil) ([y] (eapp (eapp (econst "rfl" (lcons (lsucc lzero) lnil)) (econst "Unit" lnil)) x)))))
  (eforall (econst "Unit" lnil) ([x] (eforall (econst "Unit" lnil) ([y] (eapp (eapp (eapp (econst "Eq" (lcons (lsucc lzero) lnil)) (econst "Unit" lnil)) x) y))))).

unitEta1/name : name "unitEta1" (is-decl
  (eforall (econst "Unit" lnil) ([x] (eforall (econst "Unit" lnil) ([y] (eapp (eapp (eapp (econst "Eq" (lcons (lsucc lzero) lnil)) (econst "Unit" lnil)) x) y)))))
  (defn (elam (econst "Unit" lnil) ([x] (elam (econst "Unit" lnil) ([y] (eapp (eapp (econst "rfl" (lcons (lsucc lzero) lnil)) (econst "Unit" lnil)) x))))))).

unitEta1/decl : declared "unitEta1"
  (eforall (econst "Unit" lnil) ([x] (eforall (econst "Unit" lnil) ([y] (eapp (eapp (eapp (econst "Eq" (lcons (lsucc lzero) lnil)) (econst "Unit" lnil)) x) y)))))
  (defn (elam (econst "Unit" lnil) ([x] (elam (econst "Unit" lnil) ([y] (eapp (eapp (econst "rfl" (lcons (lsucc lzero) lnil)) (econst "Unit" lnil)) x))))))
   = declared/ok unitEta1/name dkind-non-inductive/defn (dkind-ok/defn unitEta1/type-wf unitEta1/value-typed).
