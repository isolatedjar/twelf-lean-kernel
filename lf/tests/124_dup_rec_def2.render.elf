dup_rec_def2_original_rec/render-type : {u : lvl} expr =
   [u] (eforall (eforall (econst "dup_rec_def2" lnil) ([x] (esort u))) ([x] (eforall (eapp x (econst "dup_rec_def2.mk" lnil)) ([y] (eforall (econst "dup_rec_def2" lnil) ([z] (eapp x z))))))).
%%   rec-rule for dup_rec_def2.mk (nfields=0)
dup_rec_def2_original_rec/render-rule0-rhs : {u : lvl} expr =
