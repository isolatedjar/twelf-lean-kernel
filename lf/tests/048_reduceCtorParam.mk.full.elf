                               ([x] ([h] (inst-expr/lam h ([y] ([h1] h1)))))))
                           defeq/sort-refl)
                         defeq/sort-refl)
                       (defeq/trans
                         (defeq/app
                           (defeq/beta
                             ([z] ([h2] (defeq/lam h2 ([w] ([h3] h3)))))
                             defeq/sort-refl)
                           defeq/sort-refl)
                         (defeq/trans
