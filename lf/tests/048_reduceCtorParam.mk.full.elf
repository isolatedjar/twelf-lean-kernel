                             ([x] ([h] (inst-expr/forall h ([y] ([h1] h))))))
                           (inst-expr/lam
                             (inst-expr/sort (lvl-inst/var lvl-nth/zero))
                             ([x] ([h] (inst-expr/lam h ([y] ([h1] h1)))))))
                         defeq/sort-refl)
                       defeq/sort-refl)
                     (defeq/trans
                       (defeq/app
                         (defeq/beta
                           ([y] ([h1] (defeq/lam h1 ([z] ([h2] h2)))))
