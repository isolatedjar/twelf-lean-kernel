%%% Expected outcome: accept
%%% When checking inductives, we expect the kernel to reduce the types of constructor arguments.
sneq/0 : string-neq "id" "reduceCtorParam".

%% def id
id/type-wf : of (eforall (esort (lvar z)) ([x] (eforall x ([y] x)))) (esort (limax (lsucc (lvar z)) (limax (lvar z) (lvar z))))
   = (defeq/forall defeq/sort-refl ([x] ([h] (defeq/forall h ([y] ([h1] h)))))).

id/value-typed : of (elam (esort (lvar z)) ([x] (elam x ([y] y)))) (eforall (esort (lvar z)) ([x] (eforall x ([y] x))))
   = (defeq/lam defeq/sort-refl ([x] ([h] (defeq/lam h ([y] ([h1] h1)))))).

id/name : name "id" (is-decl (eforall (esort (lvar z)) ([x] (eforall x ([y] x)))) (defn (elam (esort (lvar z)) ([x] (elam x ([y] y)))))).

id/decl : declared "id" (eforall (esort (lvar z)) ([x] (eforall x ([y] x)))) (defn (elam (esort (lvar z)) ([x] (elam x ([y] y)))))
   = declared/ok id/name dkind-non-inductive/defn (dkind-ok/defn id/type-wf id/value-typed).

%% def constType
constType/type-wf : of (eforall (esort (lsucc lzero)) ([x] (eforall (esort (lsucc lzero)) ([y] (esort (lsucc lzero)))))) (esort (limax (lsucc (lsucc lzero)) (limax (lsucc (lsucc lzero)) (lsucc (lsucc lzero)))))
   = (defeq/forall
       defeq/sort-refl
       ([x] ([h] (defeq/forall defeq/sort-refl ([y] ([h1] defeq/sort-refl)))))).

constType/value-typed : of (elam (esort (lsucc lzero)) ([x] (elam (esort (lsucc lzero)) ([y] x)))) (eforall (esort (lsucc lzero)) ([x] (eforall (esort (lsucc lzero)) ([y] (esort (lsucc lzero))))))
   = (defeq/lam
       defeq/sort-refl
       ([x] ([h] (defeq/lam defeq/sort-refl ([y] ([h1] h)))))).

constType/name : name "constType" (is-decl
  (eforall (esort (lsucc lzero)) ([x] (eforall (esort (lsucc lzero)) ([y] (esort (lsucc lzero))))))
  (defn (elam (esort (lsucc lzero)) ([x] (elam (esort (lsucc lzero)) ([y] x)))))).

constType/decl : declared "constType" (eforall (esort (lsucc lzero)) ([x] (eforall (esort (lsucc lzero)) ([y] (esort (lsucc lzero)))))) (defn (elam (esort (lsucc lzero)) ([x] (elam (esort (lsucc lzero)) ([y] x)))))
   = declared/ok constType/name dkind-non-inductive/defn (dkind-ok/defn constType/type-wf constType/value-typed).

%% inductive reduceCtorParam
reduceCtorParam/type-wf : of (eforall (esort (lsucc lzero)) ([x] (esort (lsucc lzero)))) (esort (limax (lsucc (lsucc lzero)) (lsucc (lsucc lzero))))
   = (defeq/forall defeq/sort-refl ([x] ([h] defeq/sort-refl))).

reduceCtorParam/ends-in-sort : ends-in-sort (eforall (esort (lsucc lzero)) ([x] (esort (lsucc lzero))))
   = (ends-in-sort/forall ([x] ends-in-sort/sort)).

reduceCtorParam/rec-name : name "reduceCtorParam.rec" (is-rec-for "reduceCtorParam").

reduceCtorParam/eisl : ends-in-sort-with-level (eforall (esort (lsucc lzero)) ([x] (esort (lsucc lzero)))) (lsucc lzero)
   = (ends-in-sort-with-level/forall ([x] ends-in-sort-with-level/sort)).

reduceCtorParam/cnd : cnames-distinct (ccons "reduceCtorParam.mk" cnil)
   = (cnames-distinct/cons cnames-distinct/nil all-string-neq/nil).

reduceCtorParam/name : name "reduceCtorParam" (is-decl (eforall (esort (lsucc lzero)) ([x] (esort (lsucc lzero)))) (indt (ccons "reduceCtorParam.mk" cnil) (s z))).

reduceCtorParam/decl : declared "reduceCtorParam" (eforall (esort (lsucc lzero)) ([x] (esort (lsucc lzero)))) (indt (ccons "reduceCtorParam.mk" cnil) (s z))
   = declared/ok-indt reduceCtorParam/name reduceCtorParam/rec-name reduceCtorParam/cnd (dkind-ok/indt reduceCtorParam/type-wf reduceCtorParam/ends-in-sort).

%% ctor reduceCtorParam.mk (of reduceCtorParam)
reduceCtorParam_mk/type-wf : of
  (eforall (eapp (eapp (econst "id" (lcons (lsucc (lsucc (lsucc lzero))) lnil)) (esort (lsucc (lsucc lzero)))) (esort (lsucc lzero)))
    ([x] (eforall (eapp (eapp (econst "constType" lnil) (eapp (econst "reduceCtorParam" lnil) x)) (eapp (econst "reduceCtorParam" lnil) x)) ([y] (eapp (econst "reduceCtorParam" lnil) x)))))
  (esort (limax (lsucc (lsucc lzero)) (limax (lsucc lzero) (lsucc lzero))))
   = (defeq/forall
       (defeq/app
         (defeq/app
           (defeq/const
             id/decl
             (inst-expr/forall
               (inst-expr/sort (inst-lvl/var nth-lvl/z))
               ([x] ([h] (inst-expr/forall h ([y] ([h1] h)))))))
           defeq/sort-refl)
         defeq/sort-refl)
       ([x]
         ([h]
           (defeq/forall
             (defeq/app
               (defeq/app
                 (defeq/const
                   constType/decl
                   (inst-expr/forall
                     (inst-expr/sort (inst-lvl/succ inst-lvl/zero))
                     ([x]
                       ([h]
                         (inst-expr/forall
                           (inst-expr/sort (inst-lvl/succ inst-lvl/zero))
                           ([y]
                             ([h1]
                               (inst-expr/sort
                                 (inst-lvl/succ inst-lvl/zero)))))))))
                 (defeq/app
                   (defeq/const
                     reduceCtorParam/decl
                     (inst-expr/forall
                       (inst-expr/sort (inst-lvl/succ inst-lvl/zero))
                       ([x]
                         ([h] (inst-expr/sort (inst-lvl/succ inst-lvl/zero))))))
                   (defeq/conv
                     (defeq/trans
                       (defeq/app
                         (defeq/app
                           (defeq/delta
                             id/decl
                             (inst-expr/forall
                               (inst-expr/sort (inst-lvl/var nth-lvl/z))
                               ([x] ([h] (inst-expr/forall h ([y] ([h1] h))))))
                             (inst-expr/lam
                               (inst-expr/sort (inst-lvl/var nth-lvl/z))
                               ([x] ([h] (inst-expr/lam h ([y] ([h1] h1)))))))
                           defeq/sort-refl)
                         defeq/sort-refl)
                       (defeq/trans
                         (defeq/app
                           (defeq/beta
                             ([y] ([h1] (defeq/lam h1 ([w] ([h2] h2)))))
                             defeq/sort-refl)
                           defeq/sort-refl)
                         (defeq/trans
                           (defeq/beta ([y] ([h1] h1)) defeq/sort-refl)
                           defeq/sort-refl)))
                     h)))
               (defeq/app
                 (defeq/const
                   reduceCtorParam/decl
                   (inst-expr/forall
                     (inst-expr/sort (inst-lvl/succ inst-lvl/zero))
                     ([x]
                       ([h] (inst-expr/sort (inst-lvl/succ inst-lvl/zero))))))
                 (defeq/conv
                   (defeq/trans
                     (defeq/app
                       (defeq/app
                         (defeq/delta
                           id/decl
                           (inst-expr/forall
                             (inst-expr/sort (inst-lvl/var nth-lvl/z))
                             ([x] ([h] (inst-expr/forall h ([y] ([h1] h))))))
                           (inst-expr/lam
                             (inst-expr/sort (inst-lvl/var nth-lvl/z))
                             ([x] ([h] (inst-expr/lam h ([y] ([h1] h1)))))))
                         defeq/sort-refl)
                       defeq/sort-refl)
                     (defeq/trans
                       (defeq/app
                         (defeq/beta
                           ([y] ([h1] (defeq/lam h1 ([w] ([h2] h2)))))
                           defeq/sort-refl)
                         defeq/sort-refl)
                       (defeq/trans
                         (defeq/beta ([y] ([h1] h1)) defeq/sort-refl)
                         defeq/sort-refl)))
                   h)))
             ([y]
               ([h1]
                 (defeq/app
                   (defeq/const
                     reduceCtorParam/decl
                     (inst-expr/forall
                       (inst-expr/sort (inst-lvl/succ inst-lvl/zero))
                       ([x]
                         ([h] (inst-expr/sort (inst-lvl/succ inst-lvl/zero))))))
                   (defeq/conv
                     (defeq/trans
                       (defeq/app
                         (defeq/app
                           (defeq/delta
                             id/decl
                             (inst-expr/forall
                               (inst-expr/sort (inst-lvl/var nth-lvl/z))
                               ([x] ([h] (inst-expr/forall h ([y] ([h1] h))))))
                             (inst-expr/lam
                               (inst-expr/sort (inst-lvl/var nth-lvl/z))
                               ([x] ([h] (inst-expr/lam h ([y] ([h1] h1)))))))
                           defeq/sort-refl)
                         defeq/sort-refl)
                       (defeq/trans
                         (defeq/app
                           (defeq/beta
                             ([w] ([h2] (defeq/lam h2 ([v] ([h3] h3)))))
                             defeq/sort-refl)
                           defeq/sort-refl)
                         (defeq/trans
                           (defeq/beta ([w] ([h2] h2)) defeq/sort-refl)
                           defeq/sort-refl)))
                     h)))))))).

%%% HOLE
reduceCtorParam_mk/positivity : ctor-positive "reduceCtorParam" lnil (eforall (eapp (eapp (econst "id" (lcons (lsucc (lsucc (lsucc lzero))) lnil)) (esort (lsucc (lsucc lzero)))) (esort (lsucc lzero))) ([x] (eforall (eapp (eapp (econst "constType" lnil) (eapp (econst "reduceCtorParam" lnil) x)) (eapp (econst "reduceCtorParam" lnil) x)) ([y] (eapp (econst "reduceCtorParam" lnil) x))))).

reduceCtorParam_mk/cmem : cmem "reduceCtorParam.mk" (ccons "reduceCtorParam.mk" cnil)
   = cmem/here.

%%% HOLE: reduceCtorParam_mk/fuo
reduceCtorParam_mk/fuo : field-universes-ok (eforall (eapp (eapp (econst "id" (lcons (lsucc (lsucc (lsucc lzero))) lnil)) (esort (lsucc (lsucc lzero)))) (esort (lsucc lzero))) ([x] (eforall (eapp (eapp (econst "constType" lnil) (eapp (econst "reduceCtorParam" lnil) x)) (eapp (econst "reduceCtorParam" lnil) x)) ([y] (eapp (econst "reduceCtorParam" lnil) x))))) (lsucc lzero).

reduceCtorParam_mk/name : name "reduceCtorParam.mk" (is-decl
  (eforall (eapp (eapp (econst "id" (lcons (lsucc (lsucc (lsucc lzero))) lnil)) (esort (lsucc (lsucc lzero)))) (esort (lsucc lzero)))
    ([x] (eforall (eapp (eapp (econst "constType" lnil) (eapp (econst "reduceCtorParam" lnil) x)) (eapp (econst "reduceCtorParam" lnil) x)) ([y] (eapp (econst "reduceCtorParam" lnil) x)))))
  (ctor "reduceCtorParam" z)).

reduceCtorParam_mk/decl : declared "reduceCtorParam.mk"
  (eforall (eapp (eapp (econst "id" (lcons (lsucc (lsucc (lsucc lzero))) lnil)) (esort (lsucc (lsucc lzero)))) (esort (lsucc lzero)))
    ([x] (eforall (eapp (eapp (econst "constType" lnil) (eapp (econst "reduceCtorParam" lnil) x)) (eapp (econst "reduceCtorParam" lnil) x)) ([y] (eapp (econst "reduceCtorParam" lnil) x)))))
  (ctor "reduceCtorParam" z)
   = declared/ok-ctor reduceCtorParam_mk/name reduceCtorParam/name reduceCtorParam_mk/cmem reduceCtorParam/eisl reduceCtorParam_mk/fuo (dkind-ok/ctor reduceCtorParam_mk/type-wf reduceCtorParam_mk/positivity).

%% recursor reduceCtorParam.rec (TCB-derived; informational only)
%%   level params: u
%%   type:   (eforall (esort (lsucc lzero)) ([x] (eforall (eforall (eapp (econst "reduceCtorParam" lnil) x) ([y] (esort (lvar z)))) ([y] (eforall (eforall (eapp (eapp (econst "constType" lnil) (eapp (econst "reduceCtorParam" lnil) x)) (eapp (econst "reduceCtorParam" lnil) x)) ([w] (eforall (eapp y w) ([v] (eapp y (eapp (eapp (econst "reduceCtorParam.mk" lnil) x) w)))))) ([w] (eforall (eapp (econst "reduceCtorParam" lnil) x) ([v] (eapp y v)))))))))
%%   rules:
%%     reduceCtorParam.rec … reduceCtorParam.mk … = (elam (esort (lsucc lzero)) ([x] (elam (eforall (eapp (econst "reduceCtorParam" lnil) x) ([y] (esort (lvar z)))) ([y] (elam (eforall (eapp (eapp (econst "constType" lnil) (eapp (econst "reduceCtorParam" lnil) x)) (eapp (econst "reduceCtorParam" lnil) x)) ([w] (eforall (eapp y w) ([v] (eapp y (eapp (eapp (econst "reduceCtorParam.mk" lnil) x) w)))))) ([w] (elam (eapp (eapp (econst "constType" lnil) (eapp (econst "reduceCtorParam" lnil) x)) (eapp (econst "reduceCtorParam" lnil) x)) ([v] (eapp (eapp w v) (eapp (eapp (eapp (eapp (econst "reduceCtorParam.rec" (lcons (lvar z) lnil)) x) y) w) v))))))))))   (1 fields)
