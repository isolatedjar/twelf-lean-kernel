reduceCtorParam_rec/decl : declared "reduceCtorParam.rec"
  (eforall (esort (lsucc lzero))
    ([x]
      (eforall (eforall (eapp (econst "reduceCtorParam" lnil) x) ([y] (esort (lvar liz))))
