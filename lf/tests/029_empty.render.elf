%%% Render-only view of: 029_empty
%%% A simple empty inductive type
%% inductive Empty
%%% HOLE
Empty/type-wf-sort : lvl.

%%% HOLE
Empty/type-wf : of (esort (lsucc lzero)) (esort Empty/type-wf-sort).

%%% HOLE
Empty/ends-in-sort : ends-in-sort (esort (lsucc lzero)).

Empty/rec-name : name "Empty.rec" (is-rec-for "Empty").

Empty/eisl : ends-in-sort-with-level (esort (lsucc lzero)) (lsucc lzero)
   = ends-in-sort-with-level/sort.

Empty/cnd : cnames-distinct cnil
   = cnames-distinct/nil.

Empty/name : name "Empty" (is-decl (esort (lsucc lzero)) (indt cnil liz)).

Empty/decl : declared "Empty" (esort (lsucc lzero)) (indt cnil liz)
   = declared/ok-indt Empty/name Empty/rec-name Empty/cnd (dkind-ok/indt Empty/type-wf Empty/ends-in-sort).

%% recursor Empty.rec (TCB-derived; informational only)
%%   level params: u
%%   type:   (eforall (eforall (econst "Empty" lnil) ([x] (esort (lvar liz)))) ([x] (eforall (econst "Empty" lnil) ([y] (eapp x y)))))

%% def empty
%%% HOLE
empty/type-wf-sort : lvl.

%%% HOLE
empty/type-wf : of (esort (lsucc lzero)) (esort empty/type-wf-sort).

%%% HOLE
empty/value-typed : of (econst "Empty" lnil) (esort (lsucc lzero)).

empty/name : name "empty" (is-decl (esort (lsucc lzero)) (defn (econst "Empty" lnil))).

empty/decl : declared "empty" (esort (lsucc lzero)) (defn (econst "Empty" lnil))
   = declared/ok empty/name dkind-non-inductive/defn (dkind-ok/defn empty/type-wf empty/value-typed).
