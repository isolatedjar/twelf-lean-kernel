%%% Render-only view of: 029_empty
%%% A simple empty inductive type
%% inductive Empty
%%% HOLE
Empty/type-wf-sort : lvl.

%%% HOLE
Empty/type-wf : defeq (esort (lsucc lzero)) (esort (lsucc lzero)) (esort Empty/type-wf-sort).

%%% HOLE
Empty/ends-in-sort : ends-in-sort (esort (lsucc lzero)).

Empty/name : name "Empty" (is-decl lnil (esort (lsucc lzero)) indt).

Empty/decl : declared "Empty" lnil (esort (lsucc lzero)) indt
   = declared/ok Empty/name (dkind-ok/indt Empty/type-wf Empty/ends-in-sort).

%% recursor Empty.rec
%%% HOLE
Empty_rec/type-wf-sort : {u : lvl} lvl.

%%% HOLE
Empty_rec/type-wf : {u : lvl} defeq (eforall (eforall (econst "Empty" lnil) ([x] (esort u))) ([x] (eforall (econst "Empty" lnil) ([y] (eapp x y))))) (eforall (eforall (econst "Empty" lnil) ([x] (esort u))) ([x] (eforall (econst "Empty" lnil) ([y] (eapp x y))))) (esort (Empty_rec/type-wf-sort u)).

Empty_rec/name : {u : lvl} name "Empty.rec" (is-decl (lcons u lnil) (eforall (eforall (econst "Empty" lnil) ([x] (esort u))) ([x] (eforall (econst "Empty" lnil) ([y] (eapp x y))))) irec).

Empty_rec/decl : {u : lvl} declared "Empty.rec" (lcons u lnil) (eforall (eforall (econst "Empty" lnil) ([x] (esort u))) ([x] (eforall (econst "Empty" lnil) ([y] (eapp x y))))) irec
   = [u] declared/ok (Empty_rec/name u) (dkind-ok/irec (Empty_rec/type-wf u)).

%% def empty
%%% HOLE
empty/type-wf-sort : lvl.

%%% HOLE
empty/type-wf : defeq (esort (lsucc lzero)) (esort (lsucc lzero)) (esort empty/type-wf-sort).

%%% HOLE
empty/value-typed : defeq (econst "Empty" lnil) (econst "Empty" lnil) (esort (lsucc lzero)).

empty/name : name "empty" (is-decl lnil (esort (lsucc lzero)) (defn (econst "Empty" lnil))).

empty/decl : declared "empty" lnil (esort (lsucc lzero)) (defn (econst "Empty" lnil))
   = declared/ok empty/name (dkind-ok/defn empty/type-wf empty/value-typed).

