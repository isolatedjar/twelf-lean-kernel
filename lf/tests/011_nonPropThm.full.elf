%%% Expected outcome: reject
%%% The type of a theorem has to be a proposition
%solve nonneg_0 : 0 >= 0.

%% thm nonPropThm
%%% HOLE
nonPropThm/type-wf : of (esort lzero) (esort lzero).

nonPropThm/value-typed : of (eforall (esort lzero) ([x] x)) (esort lzero)
   = (defeq/conv (defeq/sort-eq (lvl-eq/le (mleq/imax-lzL (mleq/self nonneg_0)) (mleq/lz nonneg_0))) (defeq/forall defeq/sort-refl ([x] ([h] h)))).

nonPropThm/name : name "nonPropThm" (is-decl (esort lzero) (thm (eforall (esort lzero) ([x] x)))).

nonPropThm/decl : declared "nonPropThm" (esort lzero) (thm (eforall (esort lzero) ([x] x)))
   = declared/ok nonPropThm/name (dkind-ok/thm nonPropThm/type-wf nonPropThm/value-typed).
