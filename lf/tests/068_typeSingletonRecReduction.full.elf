%%% Expected outcome: accept
%%% Because `NewSingleton` is a singleton, `NewSingleton.rec true x` reduces to
%%% `true` even though `x` is a variable.
%% inductive NewSingleton
NewSingleton/type-wf-sort : lvl
   = (lsucc (lsucc lzero)).

NewSingleton/type-wf : of (esort (lsucc lzero)) (esort NewSingleton/type-wf-sort)
   = defeq/sort-refl.

NewSingleton/ends-in-sort : ends-in-sort (esort (lsucc lzero))
   = ends-in-sort/sort.

NewSingleton/rec-name : name "NewSingleton.rec" (is-rec-for "NewSingleton").

NewSingleton/name : name "NewSingleton" (is-decl (esort (lsucc lzero)) indt).

NewSingleton/decl : declared "NewSingleton" (esort (lsucc lzero)) indt
   = declared/ok NewSingleton/name (dkind-ok/indt NewSingleton/type-wf NewSingleton/ends-in-sort).

%% ctor NewSingleton.mk (of NewSingleton)
NewSingleton_mk/type-wf-sort : lvl
   = (lsucc lzero).

NewSingleton_mk/type-wf : of (econst "NewSingleton" lnil) (esort NewSingleton_mk/type-wf-sort)
   = (defeq/const NewSingleton/decl (inst-expr/sort (lvl-inst/succ lvl-inst/zero))).

NewSingleton_mk/positivity : ctor-positive "NewSingleton" lnil (econst "NewSingleton" lnil)
   = (ctor-positive/intro ([S] S) (ctor-spine/result applies-self/refl)).

NewSingleton_mk/name : name "NewSingleton.mk" (is-decl (econst "NewSingleton" lnil) ctor).

NewSingleton_mk/decl : declared "NewSingleton.mk" (econst "NewSingleton" lnil) ctor
   = declared/ok NewSingleton_mk/name (dkind-ok/ctor NewSingleton_mk/type-wf NewSingleton_mk/positivity).

%% recursor NewSingleton.rec
NewSingleton_rec/type-wf-sort : lvl
   = (limax (limax (lsucc lzero) (lsucc (lvar liz))) (limax (lvar liz) (limax (lsucc lzero) (lvar liz)))).

NewSingleton_rec/type-wf : of (eforall (eforall (econst "NewSingleton" lnil) ([x] (esort (lvar liz)))) ([x] (eforall (eapp x (econst "NewSingleton.mk" lnil)) ([y] (eforall (econst "NewSingleton" lnil) ([z] (eapp x z))))))) (esort NewSingleton_rec/type-wf-sort)
   = (defeq/forall (defeq/forall (defeq/const NewSingleton/decl (inst-expr/sort (lvl-inst/succ lvl-inst/zero))) ([x] ([h] defeq/sort-refl))) ([x] ([h] (defeq/forall (defeq/app h (defeq/const NewSingleton_mk/decl (inst-expr/const lvls-inst/nil))) ([y] ([h1] (defeq/forall (defeq/const NewSingleton/decl (inst-expr/sort (lvl-inst/succ lvl-inst/zero))) ([z] ([h2] (defeq/app h h2)))))))))).

NewSingleton_rec/decl : declared "NewSingleton.rec" (eforall (eforall (econst "NewSingleton" lnil) ([x] (esort (lvar liz)))) ([x] (eforall (eapp x (econst "NewSingleton.mk" lnil)) ([y] (eforall (econst "NewSingleton" lnil) ([z] (eapp x z))))))) irec
   = declared/ok-irec NewSingleton/rec-name (dkind-ok/irec NewSingleton_rec/type-wf).

%% inductive Eq
Eq/type-wf-sort : lvl
   = (limax (lsucc (lvar liz)) (limax (lvar liz) (limax (lvar liz) (lsucc lzero)))).

Eq/type-wf : of (eforall (esort (lvar liz)) ([x] (eforall x ([y] (eforall x ([z] (esort lzero))))))) (esort Eq/type-wf-sort)
   = (defeq/forall defeq/sort-refl ([x] ([h] (defeq/forall h ([y] ([h1] (defeq/forall h ([z] ([h2] defeq/sort-refl))))))))).

Eq/ends-in-sort : ends-in-sort (eforall (esort (lvar liz)) ([x] (eforall x ([y] (eforall x ([z] (esort lzero)))))))
   = (ends-in-sort/forall ([x] (ends-in-sort/forall ([y] (ends-in-sort/forall ([z] ends-in-sort/sort)))))).

Eq/rec-name : name "Eq.rec" (is-rec-for "Eq").

Eq/name : name "Eq" (is-decl (eforall (esort (lvar liz)) ([x] (eforall x ([y] (eforall x ([z] (esort lzero))))))) indt).

Eq/decl : declared "Eq" (eforall (esort (lvar liz)) ([x] (eforall x ([y] (eforall x ([z] (esort lzero))))))) indt
   = declared/ok Eq/name (dkind-ok/indt Eq/type-wf Eq/ends-in-sort).

%% ctor Eq.refl (of Eq)
Eq_refl/type-wf-sort : lvl
   = (limax (lsucc (lvar liz)) (limax (lvar liz) lzero)).

Eq_refl/type-wf : of (eforall (esort (lvar liz)) ([x] (eforall x ([y] (eapp (eapp (eapp (econst "Eq" (lcons (lvar liz) lnil)) x) y) y))))) (esort Eq_refl/type-wf-sort)
