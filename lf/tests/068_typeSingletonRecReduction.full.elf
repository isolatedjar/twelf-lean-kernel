%%% Expected outcome: accept
%%% Because `NewSingleton` is a singleton, `NewSingleton.rec true x` reduces to
%%% `true` even though `x` is a variable.
%solve nonneg_0 : 0 >= 0.

sneq/0 : string-neq "Bool.false" "Bool.true".

%% inductive NewSingleton
NewSingleton/type-wf-sort : lvl
   = (lsucc (lsucc lzero)).

NewSingleton/type-wf : of (esort (lsucc lzero)) (esort NewSingleton/type-wf-sort)
   = defeq/sort-refl.

NewSingleton/ends-in-sort : ends-in-sort (esort (lsucc lzero))
   = ends-in-sort/sort.

NewSingleton/rec-name : name "NewSingleton.rec" (is-rec-for "NewSingleton").

NewSingleton/eisl : ends-in-sort-with-level (esort (lsucc lzero)) (lsucc lzero)
   = ends-in-sort-with-level/sort.

NewSingleton/cnd : cnames-distinct (ccons "NewSingleton.mk" cnil)
   = (cnames-distinct/cons cnames-distinct/nil all-string-neq/nil).

NewSingleton/name : name "NewSingleton" (is-decl (esort (lsucc lzero)) (indt (ccons "NewSingleton.mk" cnil) liz)).

NewSingleton/decl : declared "NewSingleton" (esort (lsucc lzero)) (indt (ccons "NewSingleton.mk" cnil) liz)
   = declared/ok-indt NewSingleton/name NewSingleton/rec-name NewSingleton/cnd (dkind-ok/indt NewSingleton/type-wf NewSingleton/ends-in-sort).

%% ctor NewSingleton.mk (of NewSingleton)
NewSingleton_mk/type-wf-sort : lvl
   = (lsucc lzero).

NewSingleton_mk/type-wf : of (econst "NewSingleton" lnil) (esort NewSingleton_mk/type-wf-sort)
   = (defeq/const
       NewSingleton/decl
       (inst-expr/sort (lvl-inst/succ lvl-inst/zero))).

NewSingleton_mk/positivity : ctor-positive "NewSingleton" lnil (econst "NewSingleton" lnil)
   = (ctor-positive/intro ([S] S) (ctor-spine/result applies-self/refl)).

NewSingleton_mk/cmem : cmem "NewSingleton.mk" (ccons "NewSingleton.mk" cnil)
   = cmem/here.

NewSingleton_mk/fuo : field-universes-ok (econst "NewSingleton" lnil) (lsucc lzero)
   = (field-universes-ok/done not-forall/const).

NewSingleton_mk/name : name "NewSingleton.mk" (is-decl (econst "NewSingleton" lnil) (ctor "NewSingleton" liz)).

NewSingleton_mk/decl : declared "NewSingleton.mk" (econst "NewSingleton" lnil) (ctor "NewSingleton" liz)
   = declared/ok-ctor NewSingleton_mk/name NewSingleton/name NewSingleton_mk/cmem NewSingleton/eisl NewSingleton_mk/fuo (dkind-ok/ctor NewSingleton_mk/type-wf NewSingleton_mk/positivity).

%% recursor NewSingleton.rec (TCB-derived; informational only)
%%   level params: u
%%   type:   (eforall (eforall (econst "NewSingleton" lnil) ([x] (esort (lvar liz)))) ([x] (eforall (eapp x (econst "NewSingleton.mk" lnil)) ([y] (eforall (econst "NewSingleton" lnil) ([z] (eapp x z)))))))
%%   rules:
%%     NewSingleton.rec … NewSingleton.mk … = (elam (eforall (econst "NewSingleton" lnil) ([x] (esort (lvar liz)))) ([x] (elam (eapp x (econst "NewSingleton.mk" lnil)) ([y] y))))   (0 fields)

%% inductive Eq
Eq/type-wf-sort : lvl
   = (limax
       (lsucc (lvar liz))
       (limax (lvar liz) (limax (lvar liz) (lsucc lzero)))).

Eq/type-wf : of (eforall (esort (lvar liz)) ([x] (eforall x ([y] (eforall x ([z] (esort lzero))))))) (esort Eq/type-wf-sort)
   = (defeq/forall
       defeq/sort-refl
       ([x]
         ([h]
           (defeq/forall
             h
             ([y] ([h1] (defeq/forall h ([z] ([h2] defeq/sort-refl))))))))).

Eq/ends-in-sort : ends-in-sort (eforall (esort (lvar liz)) ([x] (eforall x ([y] (eforall x ([z] (esort lzero)))))))
   = (ends-in-sort/forall
       ([x]
         (ends-in-sort/forall
           ([y] (ends-in-sort/forall ([z] ends-in-sort/sort)))))).

Eq/rec-name : name "Eq.rec" (is-rec-for "Eq").

Eq/eisl : ends-in-sort-with-level (eforall (esort (lvar liz)) ([x] (eforall x ([y] (eforall x ([z] (esort lzero))))))) lzero
   = (ends-in-sort-with-level/forall
       ([x]
         (ends-in-sort-with-level/forall
           ([y]
             (ends-in-sort-with-level/forall
               ([z] ends-in-sort-with-level/sort)))))).

Eq/cnd : cnames-distinct (ccons "Eq.refl" cnil)
   = (cnames-distinct/cons cnames-distinct/nil all-string-neq/nil).

Eq/name : name "Eq" (is-decl (eforall (esort (lvar liz)) ([x] (eforall x ([y] (eforall x ([z] (esort lzero))))))) (indt (ccons "Eq.refl" cnil) (lis (lis liz)))).

Eq/decl : declared "Eq" (eforall (esort (lvar liz)) ([x] (eforall x ([y] (eforall x ([z] (esort lzero))))))) (indt (ccons "Eq.refl" cnil) (lis (lis liz)))
   = declared/ok-indt Eq/name Eq/rec-name Eq/cnd (dkind-ok/indt Eq/type-wf Eq/ends-in-sort).

%% ctor Eq.refl (of Eq)
Eq_refl/type-wf-sort : lvl
   = (limax (lsucc (lvar liz)) (limax (lvar liz) lzero)).

Eq_refl/type-wf : of (eforall (esort (lvar liz)) ([x] (eforall x ([y] (eapp (eapp (eapp (econst "Eq" (lcons (lvar liz) lnil)) x) y) y))))) (esort Eq_refl/type-wf-sort)
   = (defeq/forall
       defeq/sort-refl
       ([x]
         ([h]
           (defeq/forall
             h
             ([y]
               ([h1]
                 (defeq/app
                   (defeq/app
                     (defeq/app
                       (defeq/const
                         Eq/decl
                         (inst-expr/forall
                           (inst-expr/sort (lvl-inst/var lvl-nth/zero))
                           ([x]
                             ([h]
                               (inst-expr/forall
                                 h
                                 ([y]
                                   ([h1]
                                     (inst-expr/forall
                                       h
                                       ([z]
                                         ([h2]
                                           (inst-expr/sort
                                             lvl-inst/zero)))))))))))
                       h)
                     h1)
                   h1))))))).

Eq_refl/positivity : ctor-positive "Eq" (lcons (lvar liz) lnil) (eforall (esort (lvar liz)) ([x] (eforall x ([y] (eapp (eapp (eapp (econst "Eq" (lcons (lvar liz) lnil)) x) y) y)))))
   = (ctor-positive/intro ([S] (eforall (esort (lvar liz)) ([x] (eforall x ([y] (eapp (eapp (eapp S x) y) y)))))) (ctor-spine/arg
       (strict-pos/no-occur (esort (lvar liz)) no-self-ref/sort)
       ([x]
         ([y]
           (ctor-spine/arg
             (strict-pos/no-occur x y)
             ([z]
               ([w]
                 (ctor-spine/result
                   (applies-self/app
                     (applies-self/app
                       (applies-self/app applies-self/refl))))))))))).

Eq_refl/cmem : cmem "Eq.refl" (ccons "Eq.refl" cnil)
   = cmem/here.

Eq_refl/fuo : field-universes-ok (eforall (esort (lvar liz)) ([x] (eforall x ([y] (eapp (eapp (eapp (econst "Eq" (lcons (lvar liz) lnil)) x) y) y))))) lzero
   = (field-universes-ok/forall
       defeq/sort-refl
       (mleq/imax-lzL (mleq/self nonneg_0))
       ([x]
         ([h]
           (field-universes-ok/forall
             h
             (mleq/imax-lzL (mleq/self nonneg_0))
             ([y] ([h1] (field-universes-ok/done not-forall/app))))))).

Eq_refl/name : name "Eq.refl" (is-decl (eforall (esort (lvar liz)) ([x] (eforall x ([y] (eapp (eapp (eapp (econst "Eq" (lcons (lvar liz) lnil)) x) y) y))))) (ctor "Eq" liz)).

Eq_refl/decl : declared "Eq.refl" (eforall (esort (lvar liz)) ([x] (eforall x ([y] (eapp (eapp (eapp (econst "Eq" (lcons (lvar liz) lnil)) x) y) y))))) (ctor "Eq" liz)
   = declared/ok-ctor Eq_refl/name Eq/name Eq_refl/cmem Eq/eisl Eq_refl/fuo (dkind-ok/ctor Eq_refl/type-wf Eq_refl/positivity).

%% recursor Eq.rec (TCB-derived; informational only)
%%   level params: u u_1
%%   type:   (eforall (esort (lvar (lis liz))) ([x] (eforall x ([y] (eforall (eforall x ([z] (eforall (eapp (eapp (eapp (econst "Eq" (lcons (lvar (lis liz)) lnil)) x) y) z) ([w] (esort (lvar liz)))))) ([z] (eforall (eapp (eapp z y) (eapp (eapp (econst "Eq.refl" (lcons (lvar (lis liz)) lnil)) x) y)) ([w] (eforall x ([x1] (eforall (eapp (eapp (eapp (econst "Eq" (lcons (lvar (lis liz)) lnil)) x) y) x1) ([y1] (eapp (eapp z x1) y1)))))))))))))
%%   rules:
%%     Eq.rec … Eq.refl … = (elam (esort (lvar (lis liz))) ([x] (elam x ([y] (elam (eforall x ([z] (eforall (eapp (eapp (eapp (econst "Eq" (lcons (lvar (lis liz)) lnil)) x) y) z) ([w] (esort (lvar liz)))))) ([z] (elam (eapp (eapp z y) (eapp (eapp (econst "Eq.refl" (lcons (lvar (lis liz)) lnil)) x) y)) ([w] w))))))))   (0 fields)
%%   K-like reduction: yes

%% inductive Bool
Bool/type-wf-sort : lvl
   = (lsucc (lsucc lzero)).

Bool/type-wf : of (esort (lsucc lzero)) (esort Bool/type-wf-sort)
   = defeq/sort-refl.

Bool/ends-in-sort : ends-in-sort (esort (lsucc lzero))
   = ends-in-sort/sort.

Bool/rec-name : name "Bool.rec" (is-rec-for "Bool").

Bool/eisl : ends-in-sort-with-level (esort (lsucc lzero)) (lsucc lzero)
   = ends-in-sort-with-level/sort.

Bool/cnd : cnames-distinct (ccons "Bool.false" (ccons "Bool.true" cnil))
   = (cnames-distinct/cons
       (cnames-distinct/cons cnames-distinct/nil all-string-neq/nil)
       (all-string-neq/cons sneq/0 all-string-neq/nil)).

Bool/name : name "Bool" (is-decl (esort (lsucc lzero)) (indt (ccons "Bool.false" (ccons "Bool.true" cnil)) liz)).

Bool/decl : declared "Bool" (esort (lsucc lzero)) (indt (ccons "Bool.false" (ccons "Bool.true" cnil)) liz)
   = declared/ok-indt Bool/name Bool/rec-name Bool/cnd (dkind-ok/indt Bool/type-wf Bool/ends-in-sort).

%% ctor Bool.false (of Bool)
Bool_false/type-wf-sort : lvl
   = (lsucc lzero).

Bool_false/type-wf : of (econst "Bool" lnil) (esort Bool_false/type-wf-sort)
   = (defeq/const Bool/decl (inst-expr/sort (lvl-inst/succ lvl-inst/zero))).

Bool_false/positivity : ctor-positive "Bool" lnil (econst "Bool" lnil)
   = (ctor-positive/intro ([S] S) (ctor-spine/result applies-self/refl)).

Bool_false/cmem : cmem "Bool.false" (ccons "Bool.false" (ccons "Bool.true" cnil))
   = cmem/here.

Bool_false/fuo : field-universes-ok (econst "Bool" lnil) (lsucc lzero)
   = (field-universes-ok/done not-forall/const).

Bool_false/name : name "Bool.false" (is-decl (econst "Bool" lnil) (ctor "Bool" liz)).

Bool_false/decl : declared "Bool.false" (econst "Bool" lnil) (ctor "Bool" liz)
   = declared/ok-ctor Bool_false/name Bool/name Bool_false/cmem Bool/eisl Bool_false/fuo (dkind-ok/ctor Bool_false/type-wf Bool_false/positivity).

%% ctor Bool.true (of Bool)
Bool_true/type-wf-sort : lvl
   = (lsucc lzero).

Bool_true/type-wf : of (econst "Bool" lnil) (esort Bool_true/type-wf-sort)
   = (defeq/const Bool/decl (inst-expr/sort (lvl-inst/succ lvl-inst/zero))).

Bool_true/positivity : ctor-positive "Bool" lnil (econst "Bool" lnil)
   = (ctor-positive/intro ([S] S) (ctor-spine/result applies-self/refl)).

Bool_true/cmem : cmem "Bool.true" (ccons "Bool.false" (ccons "Bool.true" cnil))
   = (cmem/there cmem/here).

Bool_true/fuo : field-universes-ok (econst "Bool" lnil) (lsucc lzero)
   = (field-universes-ok/done not-forall/const).

Bool_true/name : name "Bool.true" (is-decl (econst "Bool" lnil) (ctor "Bool" (lis liz))).

Bool_true/decl : declared "Bool.true" (econst "Bool" lnil) (ctor "Bool" (lis liz))
   = declared/ok-ctor Bool_true/name Bool/name Bool_true/cmem Bool/eisl Bool_true/fuo (dkind-ok/ctor Bool_true/type-wf Bool_true/positivity).

%% recursor Bool.rec (TCB-derived; informational only)
%%   level params: u
%%   type:   (eforall (eforall (econst "Bool" lnil) ([x] (esort (lvar liz)))) ([x] (eforall (eapp x (econst "Bool.false" lnil)) ([y] (eforall (eapp x (econst "Bool.true" lnil)) ([z] (eforall (econst "Bool" lnil) ([w] (eapp x w)))))))))
%%   rules:
%%     Bool.rec … Bool.false … = (elam (eforall (econst "Bool" lnil) ([x] (esort (lvar liz)))) ([x] (elam (eapp x (econst "Bool.false" lnil)) ([y] (elam (eapp x (econst "Bool.true" lnil)) ([z] y))))))   (0 fields)
%%     Bool.rec … Bool.true … = (elam (eforall (econst "Bool" lnil) ([x] (esort (lvar liz)))) ([x] (elam (eapp x (econst "Bool.false" lnil)) ([y] (elam (eapp x (econst "Bool.true" lnil)) ([z] z))))))   (0 fields)

%% def rfl
rfl/type-wf-sort : lvl
   = (limax (lsucc (lvar liz)) (limax (lvar liz) lzero)).

rfl/type-wf : of (eforall (esort (lvar liz)) ([x] (eforall x ([y] (eapp (eapp (eapp (econst "Eq" (lcons (lvar liz) lnil)) x) y) y))))) (esort rfl/type-wf-sort)
   = (defeq/forall
       defeq/sort-refl
       ([x]
         ([h]
           (defeq/forall
             h
             ([y]
               ([h1]
                 (defeq/app
                   (defeq/app
                     (defeq/app
                       (defeq/const
                         Eq/decl
                         (inst-expr/forall
                           (inst-expr/sort (lvl-inst/var lvl-nth/zero))
                           ([x]
                             ([h]
                               (inst-expr/forall
                                 h
                                 ([y]
                                   ([h1]
                                     (inst-expr/forall
                                       h
                                       ([z]
                                         ([h2]
                                           (inst-expr/sort
                                             lvl-inst/zero)))))))))))
                       h)
                     h1)
                   h1))))))).

rfl/value-typed : of
  (elam (esort (lvar liz)) ([x] (elam x ([y] (eapp (eapp (econst "Eq.refl" (lcons (lvar liz) lnil)) x) y)))))
  (eforall (esort (lvar liz)) ([x] (eforall x ([y] (eapp (eapp (eapp (econst "Eq" (lcons (lvar liz) lnil)) x) y) y)))))
   = (defeq/lam
       defeq/sort-refl
       ([x]
         ([h]
           (defeq/lam
             h
             ([y]
               ([h1]
                 (defeq/app
                   (defeq/app
                     (defeq/const
                       Eq_refl/decl
                       (inst-expr/forall
                         (inst-expr/sort (lvl-inst/var lvl-nth/zero))
                         ([x]
                           ([h]
                             (inst-expr/forall
                               h
                               ([y]
                                 ([h1]
                                   (inst-expr/app
                                     (inst-expr/app
                                       (inst-expr/app
                                         (inst-expr/const
                                           (lvls-inst/cons
                                             (lvl-inst/var lvl-nth/zero)
                                             lvls-inst/nil))
                                         h)
                                       h1)
                                     h1))))))))
                     h)
                   h1))))))).

rfl/name : name "rfl" (is-decl
  (eforall (esort (lvar liz)) ([x] (eforall x ([y] (eapp (eapp (eapp (econst "Eq" (lcons (lvar liz) lnil)) x) y) y)))))
  (defn (elam (esort (lvar liz)) ([x] (elam x ([y] (eapp (eapp (econst "Eq.refl" (lcons (lvar liz) lnil)) x) y))))))).

rfl/decl : declared "rfl"
  (eforall (esort (lvar liz)) ([x] (eforall x ([y] (eapp (eapp (eapp (econst "Eq" (lcons (lvar liz) lnil)) x) y) y)))))
  (defn (elam (esort (lvar liz)) ([x] (elam x ([y] (eapp (eapp (econst "Eq.refl" (lcons (lvar liz) lnil)) x) y))))))
   = declared/ok rfl/name dkind-non-inductive/defn (dkind-ok/defn rfl/type-wf rfl/value-typed).

%% def typeSingletonRecReduction
typeSingletonRecReduction/type-wf-sort : lvl
   = (limax (lsucc lzero) lzero).

typeSingletonRecReduction/type-wf : of
  (eforall (econst "NewSingleton" lnil)
    ([x]
      (eapp (eapp (eapp (econst "Eq" (lcons (lsucc lzero) lnil)) (econst "Bool" lnil))
        (eapp (eapp (eapp (econst "NewSingleton.rec" (lcons (lsucc lzero) lnil)) (elam (econst "NewSingleton" lnil) ([y] (econst "Bool" lnil)))) (econst "Bool.true" lnil)) x))
        (econst "Bool.true" lnil))))
  (esort typeSingletonRecReduction/type-wf-sort)
   = (defeq/forall
       (defeq/const
         NewSingleton/decl
         (inst-expr/sort (lvl-inst/succ lvl-inst/zero)))
       ([x]
         ([h]
           (defeq/app
             (defeq/app
               (defeq/app
                 (defeq/const
                   Eq/decl
                   (inst-expr/forall
                     (inst-expr/sort (lvl-inst/var lvl-nth/zero))
                     ([x]
                       ([h]
                         (inst-expr/forall
                           h
                           ([y]
                             ([h1]
                               (inst-expr/forall
                                 h
                                 ([z]
                                   ([h2]
                                     (inst-expr/sort lvl-inst/zero)))))))))))
                 (defeq/const
                   Bool/decl
                   (inst-expr/sort (lvl-inst/succ lvl-inst/zero))))
               (defeq/conv
                 (defeq/trans
                   (defeq/beta
                     ([y]
                       ([h1]
                         (defeq/const
                           Bool/decl
                           (inst-expr/sort (lvl-inst/succ lvl-inst/zero)))))
                     h)
                   (defeq/const
                     Bool/decl
                     (inst-expr/sort (lvl-inst/succ lvl-inst/zero))))
                 (defeq/app
                   (defeq/app
                     (defeq/app
                       (defeq/const
                         (rec-derived-declared
                           (rec-derived/enum
                             NewSingleton/decl
                             NewSingleton/rec-name
                             (enum-rec-type/intro
                               ([x]
                                 ([h]
                                   (enum-rec-body/minor
                                     ([y] ([h1] enum-rec-body/done))))))
                             NewSingleton/eisl
                             le-eligible/csingle)
                           NewSingleton/rec-name)
                         (inst-expr/forall
                           (inst-expr/forall
                             (inst-expr/const lvls-inst/nil)
                             ([x]
                               ([h]
                                 (inst-expr/sort (lvl-inst/var lvl-nth/zero)))))
                           ([x]
                             ([h]
                               (inst-expr/forall
                                 (inst-expr/app
                                   h
                                   (inst-expr/const lvls-inst/nil))
                                 ([y]
                                   ([h1]
                                     (inst-expr/forall
                                       (inst-expr/const lvls-inst/nil)
                                       ([z] ([h2] (inst-expr/app h h2)))))))))))
                       (defeq/lam
                         (defeq/const
                           NewSingleton/decl
                           (inst-expr/sort (lvl-inst/succ lvl-inst/zero)))
                         ([y]
                           ([h1]
                             (defeq/const
                               Bool/decl
                               (inst-expr/sort
                                 (lvl-inst/succ lvl-inst/zero)))))))
                     (defeq/conv
                       (defeq/trans
                         (defeq/const
                           Bool/decl
                           (inst-expr/sort (lvl-inst/succ lvl-inst/zero)))
                         (defeq/symm
                           (defeq/beta
                             ([y]
                               ([h1]
                                 (defeq/const
                                   Bool/decl
                                   (inst-expr/sort
                                     (lvl-inst/succ lvl-inst/zero)))))
                             (defeq/const
                               NewSingleton_mk/decl
                               (inst-expr/const lvls-inst/nil)))))
                       (defeq/const
                         Bool_true/decl
                         (inst-expr/const lvls-inst/nil))))
                   h)))
             (defeq/const Bool_true/decl (inst-expr/const lvls-inst/nil)))))).

%%% HOLE
typeSingletonRecReduction/value-typed : of
  (elam (econst "NewSingleton" lnil)
    ([x]
      (eapp (eapp (econst "rfl" (lcons (lsucc lzero) lnil)) (econst "Bool" lnil))
        (eapp (eapp (eapp (econst "NewSingleton.rec" (lcons (lsucc lzero) lnil)) (elam (econst "NewSingleton" lnil) ([y] (econst "Bool" lnil)))) (econst "Bool.true" lnil)) x))))
  (eforall (econst "NewSingleton" lnil)
    ([x]
      (eapp (eapp (eapp (econst "Eq" (lcons (lsucc lzero) lnil)) (econst "Bool" lnil))
        (eapp (eapp (eapp (econst "NewSingleton.rec" (lcons (lsucc lzero) lnil)) (elam (econst "NewSingleton" lnil) ([y] (econst "Bool" lnil)))) (econst "Bool.true" lnil)) x))
        (econst "Bool.true" lnil)))).

typeSingletonRecReduction/name : name "typeSingletonRecReduction" (is-decl
  (eforall (econst "NewSingleton" lnil)
    ([x]
      (eapp (eapp (eapp (econst "Eq" (lcons (lsucc lzero) lnil)) (econst "Bool" lnil))
        (eapp (eapp (eapp (econst "NewSingleton.rec" (lcons (lsucc lzero) lnil)) (elam (econst "NewSingleton" lnil) ([y] (econst "Bool" lnil)))) (econst "Bool.true" lnil)) x))
        (econst "Bool.true" lnil))))
  (defn (elam (econst "NewSingleton" lnil) ([x] (eapp (eapp (econst "rfl" (lcons (lsucc lzero) lnil)) (econst "Bool" lnil)) (eapp (eapp (eapp (econst "NewSingleton.rec" (lcons (lsucc lzero) lnil)) (elam (econst "NewSingleton" lnil) ([y] (econst "Bool" lnil)))) (econst "Bool.true" lnil)) x)))))).

typeSingletonRecReduction/decl : declared "typeSingletonRecReduction"
  (eforall (econst "NewSingleton" lnil)
    ([x]
      (eapp (eapp (eapp (econst "Eq" (lcons (lsucc lzero) lnil)) (econst "Bool" lnil))
