%%% Render-only view of: 009_forallSortBad
%%% The binding domain of a forall has to be a sort
%% def id
id/render-type : {u : lvl} expr =
   [u] (eforall (esort u) ([x] (eforall x ([y] x)))).
id/render-value : {u : lvl} expr =
   [u] (elam (esort u) ([x] (elam x ([y] y)))).

%% def forallSortBad
forallSortBad/render-type : expr =
   (esort lzero).
forallSortBad/render-value : expr =
   (eforall (eapp (eapp (econst "id" (lcons (lsucc (lsucc lzero)) lnil)) (esort (lsucc lzero))) (esort lzero)) ([x] (eforall x ([y] (eforall y ([z] y)))))).

