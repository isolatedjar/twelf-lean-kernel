%%% Render-only view of: 107_reduceCtorParamRefl.mk
%%% When checking inductives, we expect the kernel to reduce the types of constructor arguments in all
%%% positive positions.
%% def id
id/render-type : {u : lvl} expr =
   [u] (eforall (esort u) ([x] (eforall x ([y] x)))).
id/render-value : {u : lvl} expr =
   [u] (elam (esort u) ([x] (elam x ([y] y)))).

%% def constType
constType/render-type : expr =
   (eforall (esort (lsucc lzero)) ([x] (eforall (esort (lsucc lzero)) ([y] (esort (lsucc lzero)))))).
constType/render-value : expr =
   (elam (esort (lsucc lzero)) ([x] (elam (esort (lsucc lzero)) ([y] x)))).

%% inductive reduceCtorParamRefl (numParams=1, numIndices=0)
reduceCtorParamRefl/render-type : expr =
   (eforall (esort (lsucc lzero)) ([x] (esort (lsucc lzero)))).

%% ctor reduceCtorParamRefl.mk (induct=reduceCtorParamRefl, numFields=1)
reduceCtorParamRefl_mk/render-type : expr =
   (eforall (eapp (eapp (econst "id" (lcons (lsucc (lsucc (lsucc lzero))) lnil)) (esort (lsucc (lsucc lzero)))) (esort (lsucc lzero))) ([x] (eforall (eforall x ([y] (eapp (eapp (econst "constType" lnil) (eapp (econst "reduceCtorParamRefl" lnil) x)) (eapp (econst "reduceCtorParamRefl" lnil) x)))) ([y] (eapp (econst "reduceCtorParamRefl" lnil) x))))).

%% recursor reduceCtorParamRefl.rec (numMotives=1, numMinors=1, k=false)
reduceCtorParamRefl_rec/render-type : {u : lvl} expr =
   [u] (eforall (esort (lsucc lzero)) ([x] (eforall (eforall (eapp (econst "reduceCtorParamRefl" lnil) x) ([y] (esort u))) ([y] (eforall (eforall (eforall x ([z] (eapp (eapp (econst "constType" lnil) (eapp (econst "reduceCtorParamRefl" lnil) x)) (eapp (econst "reduceCtorParamRefl" lnil) x)))) ([z] (eforall (eforall x ([w] (eapp y (eapp z w)))) ([w] (eapp y (eapp (eapp (econst "reduceCtorParamRefl.mk" lnil) x) z)))))) ([z] (eforall (eapp (econst "reduceCtorParamRefl" lnil) x) ([w] (eapp y w))))))))).
%%   rec-rule for reduceCtorParamRefl.mk (nfields=1)
reduceCtorParamRefl_rec/render-rule0-rhs : {u : lvl} expr =
   [u] (elam (esort (lsucc lzero)) ([x] (elam (eforall (eapp (econst "reduceCtorParamRefl" lnil) x) ([y] (esort u))) ([y] (elam (eforall (eforall x ([z] (eapp (eapp (econst "constType" lnil) (eapp (econst "reduceCtorParamRefl" lnil) x)) (eapp (econst "reduceCtorParamRefl" lnil) x)))) ([z] (eforall (eforall x ([w] (eapp y (eapp z w)))) ([w] (eapp y (eapp (eapp (econst "reduceCtorParamRefl.mk" lnil) x) z)))))) ([z] (elam (eforall x ([w] (eapp (eapp (econst "constType" lnil) (eapp (econst "reduceCtorParamRefl" lnil) x)) (eapp (econst "reduceCtorParamRefl" lnil) x)))) ([w] (eapp (eapp z w) (elam x ([x1] (eapp (eapp (eapp (eapp (econst "reduceCtorParamRefl.rec" (lcons u lnil)) x) y) z) (eapp w x1))))))))))))).

