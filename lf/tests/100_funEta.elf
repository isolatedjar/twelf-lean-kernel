%% thm funEta
funEta/type-wf :
   defeq (eforall (esort (lsucc lzero)) ([x] (eforall (esort (lsucc lzero)) ([y] (eforall (eforall x ([z] y)) ([z] (eapp (eapp (eapp (econst "Eq" (lcons (lsucc lzero) lnil)) (eforall x ([w] y))) (elam x ([w] (eapp z w)))) z))))))) (eforall (esort (lsucc lzero)) ([x] (eforall (esort (lsucc lzero)) ([y] (eforall (eforall x ([z] y)) ([z] (eapp (eapp (eapp (econst "Eq" (lcons (lsucc lzero) lnil)) (eforall x ([w] y))) (elam x ([w] (eapp z w)))) z))))))) (esort (limax (lsucc (lsucc lzero)) (limax (lsucc (lsucc lzero)) (limax (limax (lsucc lzero) (lsucc lzero)) lzero))))
   = (defeq/forall (defeq/sort-refl-at (lsucc lzero)) ([x] [y] (defeq/forall (defeq/sort-refl-at (lsucc lzero)) ([z] [w] (defeq/forall (defeq/forall y ([x1] [y1] w)) ([x1] [y1] (defeq/app (defeq/app (defeq/app (defeq/const (Eq/decl (lsucc lzero))) (defeq/conv (defeq/sort-eq (lvl-eq/trans lvl-eq/imax-succ (lvl-eq/trans lvl-eq/max-idem lvl-eq/refl))) (defeq/forall y ([z1] [w1] w)))) (defeq/lam y ([z1] [w1] (defeq/app y1 w1)))) y1))))))).

funEta/value-typed :
   defeq (elam (esort (lsucc lzero)) ([x] (elam (esort (lsucc lzero)) ([y] (elam (eforall x ([z] y)) ([z] (eapp (eapp (econst "rfl" (lcons (lsucc lzero) lnil)) (eforall x ([w] y))) (elam x ([w] (eapp z w)))))))))) (elam (esort (lsucc lzero)) ([x] (elam (esort (lsucc lzero)) ([y] (elam (eforall x ([z] y)) ([z] (eapp (eapp (econst "rfl" (lcons (lsucc lzero) lnil)) (eforall x ([w] y))) (elam x ([w] (eapp z w)))))))))) (eforall (esort (lsucc lzero)) ([x] (eforall (esort (lsucc lzero)) ([y] (eforall (eforall x ([z] y)) ([z] (eapp (eapp (eapp (econst "Eq" (lcons (lsucc lzero) lnil)) (eforall x ([w] y))) (elam x ([w] (eapp z w)))) z)))))))
   = (defeq/lam (defeq/sort-refl-at (lsucc lzero)) ([x] [y] (defeq/lam (defeq/sort-refl-at (lsucc lzero)) ([z] [w] (defeq/lam (defeq/forall y ([x1] [y1] w)) ([x1] [y1] (defeq/app (defeq/app (defeq/const (rfl/decl (lsucc lzero))) (defeq/conv (defeq/sort-eq (lvl-eq/trans lvl-eq/imax-succ (lvl-eq/trans lvl-eq/max-idem lvl-eq/refl))) (defeq/forall y ([z1] [w1] w)))) (defeq/lam y ([z1] [w1] (defeq/app y1 w1)))))))))).

funEta/decl : declared "funEta" lnil
   (eforall (esort (lsucc lzero)) ([x] (eforall (esort (lsucc lzero)) ([y] (eforall (eforall x ([z] y)) ([z] (eapp (eapp (eapp (econst "Eq" (lcons (lsucc lzero) lnil)) (eforall x ([w] y))) (elam x ([w] (eapp z w)))) z)))))))
   (thm (elam (esort (lsucc lzero)) ([x] (elam (esort (lsucc lzero)) ([y] (elam (eforall x ([z] y)) ([z] (eapp (eapp (econst "rfl" (lcons (lsucc lzero) lnil)) (eforall x ([w] y))) (elam x ([w] (eapp z w)))))))))))
   (dkind-ok/thm funEta/type-wf funEta/value-typed).

