%%% Expected outcome: accept
%%% Unit eta
%% inductive PUnit
%%% HOLE
PUnit/type-wf-sort : {u : lvl} lvl.

%%% HOLE
PUnit/type-wf : {u : lvl} defeq (esort u) (esort u) (esort (PUnit/type-wf-sort u)).

%%% HOLE
PUnit/ends-in-sort : {u : lvl} ends-in-sort (esort u).

PUnit/name : {u : lvl} name "PUnit" (is-decl (lcons u lnil) (esort u) indt).

PUnit/decl : {u : lvl} declared "PUnit" (lcons u lnil) (esort u) indt
   = [u] declared/ok (PUnit/name u) (dkind-ok/indt (PUnit/type-wf u) (PUnit/ends-in-sort u)).

%% ctor PUnit.unit (of PUnit)
%%% HOLE
PUnit_unit/type-wf-sort : {u : lvl} lvl.

%%% HOLE
PUnit_unit/type-wf : {u : lvl} defeq (econst "PUnit" (lcons u lnil)) (econst "PUnit" (lcons u lnil)) (esort (PUnit_unit/type-wf-sort u)).

%%% HOLE
PUnit_unit/positivity : {u : lvl} ctor-positive "PUnit" (lcons u lnil) (econst "PUnit" (lcons u lnil)).

PUnit_unit/name : {u : lvl} name "PUnit.unit" (is-decl (lcons u lnil) (econst "PUnit" (lcons u lnil)) ctor).

PUnit_unit/decl : {u : lvl} declared "PUnit.unit" (lcons u lnil) (econst "PUnit" (lcons u lnil)) ctor
   = [u] declared/ok (PUnit_unit/name u) (dkind-ok/ctor (PUnit_unit/type-wf u) (PUnit_unit/positivity u)).

%% recursor PUnit.rec
%%% HOLE
PUnit_rec/type-wf-sort : {u_1 : lvl} {u : lvl} lvl.

%%% HOLE
PUnit_rec/type-wf : {u_1 : lvl} {u : lvl} defeq (eforall (eforall (econst "PUnit" (lcons u lnil)) ([x] (esort u_1))) ([x] (eforall (eapp x (econst "PUnit.unit" (lcons u lnil))) ([y] (eforall (econst "PUnit" (lcons u lnil)) ([z] (eapp x z))))))) (eforall (eforall (econst "PUnit" (lcons u lnil)) ([x] (esort u_1))) ([x] (eforall (eapp x (econst "PUnit.unit" (lcons u lnil))) ([y] (eforall (econst "PUnit" (lcons u lnil)) ([z] (eapp x z))))))) (esort (PUnit_rec/type-wf-sort u_1 u)).

PUnit_rec/name : {u_1 : lvl} {u : lvl} name "PUnit.rec" (is-decl (lcons u_1 (lcons u lnil)) (eforall (eforall (econst "PUnit" (lcons u lnil)) ([x] (esort u_1))) ([x] (eforall (eapp x (econst "PUnit.unit" (lcons u lnil))) ([y] (eforall (econst "PUnit" (lcons u lnil)) ([z] (eapp x z))))))) irec).

PUnit_rec/decl : {u_1 : lvl} {u : lvl} declared "PUnit.rec" (lcons u_1 (lcons u lnil)) (eforall (eforall (econst "PUnit" (lcons u lnil)) ([x] (esort u_1))) ([x] (eforall (eapp x (econst "PUnit.unit" (lcons u lnil))) ([y] (eforall (econst "PUnit" (lcons u lnil)) ([z] (eapp x z))))))) irec
   = [u_1] [u] declared/ok (PUnit_rec/name u_1 u) (dkind-ok/irec (PUnit_rec/type-wf u_1 u)).

%% def Unit
%%% HOLE
Unit/type-wf-sort : lvl.

%%% HOLE
Unit/type-wf : defeq (esort (lsucc lzero)) (esort (lsucc lzero)) (esort Unit/type-wf-sort).

%%% HOLE
Unit/value-typed : defeq (econst "PUnit" (lcons (lsucc lzero) lnil)) (econst "PUnit" (lcons (lsucc lzero) lnil)) (esort (lsucc lzero)).

Unit/name : name "Unit" (is-decl lnil (esort (lsucc lzero)) (defn (econst "PUnit" (lcons (lsucc lzero) lnil)))).

Unit/decl : declared "Unit" lnil (esort (lsucc lzero)) (defn (econst "PUnit" (lcons (lsucc lzero) lnil)))
   = declared/ok Unit/name (dkind-ok/defn Unit/type-wf Unit/value-typed).

%% inductive Eq
%%% HOLE
Eq/type-wf-sort : {u_1 : lvl} lvl.

%%% HOLE
Eq/type-wf : {u_1 : lvl} defeq (eforall (esort u_1) ([x] (eforall x ([y] (eforall x ([z] (esort lzero))))))) (eforall (esort u_1) ([x] (eforall x ([y] (eforall x ([z] (esort lzero))))))) (esort (Eq/type-wf-sort u_1)).

%%% HOLE
Eq/ends-in-sort : {u_1 : lvl} ends-in-sort (eforall (esort u_1) ([x] (eforall x ([y] (eforall x ([z] (esort lzero))))))).

Eq/name : {u_1 : lvl} name "Eq" (is-decl (lcons u_1 lnil) (eforall (esort u_1) ([x] (eforall x ([y] (eforall x ([z] (esort lzero))))))) indt).

Eq/decl : {u_1 : lvl} declared "Eq" (lcons u_1 lnil) (eforall (esort u_1) ([x] (eforall x ([y] (eforall x ([z] (esort lzero))))))) indt
   = [u_1] declared/ok (Eq/name u_1) (dkind-ok/indt (Eq/type-wf u_1) (Eq/ends-in-sort u_1)).

%% ctor Eq.refl (of Eq)
%%% HOLE
Eq_refl/type-wf-sort : {u_1 : lvl} lvl.

%%% HOLE
Eq_refl/type-wf : {u_1 : lvl} defeq (eforall (esort u_1) ([x] (eforall x ([y] (eapp (eapp (eapp (econst "Eq" (lcons u_1 lnil)) x) y) y))))) (eforall (esort u_1) ([x] (eforall x ([y] (eapp (eapp (eapp (econst "Eq" (lcons u_1 lnil)) x) y) y))))) (esort (Eq_refl/type-wf-sort u_1)).

%%% HOLE
Eq_refl/positivity : {u_1 : lvl} ctor-positive "Eq" (lcons u_1 lnil) (eforall (esort u_1) ([x] (eforall x ([y] (eapp (eapp (eapp (econst "Eq" (lcons u_1 lnil)) x) y) y))))).

Eq_refl/name : {u_1 : lvl} name "Eq.refl" (is-decl (lcons u_1 lnil) (eforall (esort u_1) ([x] (eforall x ([y] (eapp (eapp (eapp (econst "Eq" (lcons u_1 lnil)) x) y) y))))) ctor).

Eq_refl/decl : {u_1 : lvl} declared "Eq.refl" (lcons u_1 lnil) (eforall (esort u_1) ([x] (eforall x ([y] (eapp (eapp (eapp (econst "Eq" (lcons u_1 lnil)) x) y) y))))) ctor
   = [u_1] declared/ok (Eq_refl/name u_1) (dkind-ok/ctor (Eq_refl/type-wf u_1) (Eq_refl/positivity u_1)).

%% recursor Eq.rec
%%% HOLE
Eq_rec/type-wf-sort : {u : lvl} {u_1 : lvl} lvl.

%%% HOLE
Eq_rec/type-wf : {u : lvl} {u_1 : lvl} defeq (eforall (esort u_1) ([x] (eforall x ([y] (eforall (eforall x ([z] (eforall (eapp (eapp (eapp (econst "Eq" (lcons u_1 lnil)) x) y) z) ([w] (esort u))))) ([z] (eforall (eapp (eapp z y) (eapp (eapp (econst "Eq.refl" (lcons u_1 lnil)) x) y)) ([w] (eforall x ([x1] (eforall (eapp (eapp (eapp (econst "Eq" (lcons u_1 lnil)) x) y) x1) ([y1] (eapp (eapp z x1) y1))))))))))))) (eforall (esort u_1) ([x] (eforall x ([y] (eforall (eforall x ([z] (eforall (eapp (eapp (eapp (econst "Eq" (lcons u_1 lnil)) x) y) z) ([w] (esort u))))) ([z] (eforall (eapp (eapp z y) (eapp (eapp (econst "Eq.refl" (lcons u_1 lnil)) x) y)) ([w] (eforall x ([x1] (eforall (eapp (eapp (eapp (econst "Eq" (lcons u_1 lnil)) x) y) x1) ([y1] (eapp (eapp z x1) y1))))))))))))) (esort (Eq_rec/type-wf-sort u u_1)).

Eq_rec/name : {u : lvl} {u_1 : lvl} name "Eq.rec" (is-decl (lcons u (lcons u_1 lnil)) (eforall (esort u_1) ([x] (eforall x ([y] (eforall (eforall x ([z] (eforall (eapp (eapp (eapp (econst "Eq" (lcons u_1 lnil)) x) y) z) ([w] (esort u))))) ([z] (eforall (eapp (eapp z y) (eapp (eapp (econst "Eq.refl" (lcons u_1 lnil)) x) y)) ([w] (eforall x ([x1] (eforall (eapp (eapp (eapp (econst "Eq" (lcons u_1 lnil)) x) y) x1) ([y1] (eapp (eapp z x1) y1))))))))))))) irec).

Eq_rec/decl : {u : lvl} {u_1 : lvl} declared "Eq.rec" (lcons u (lcons u_1 lnil)) (eforall (esort u_1) ([x] (eforall x ([y] (eforall (eforall x ([z] (eforall (eapp (eapp (eapp (econst "Eq" (lcons u_1 lnil)) x) y) z) ([w] (esort u))))) ([z] (eforall (eapp (eapp z y) (eapp (eapp (econst "Eq.refl" (lcons u_1 lnil)) x) y)) ([w] (eforall x ([x1] (eforall (eapp (eapp (eapp (econst "Eq" (lcons u_1 lnil)) x) y) x1) ([y1] (eapp (eapp z x1) y1))))))))))))) irec
   = [u] [u_1] declared/ok (Eq_rec/name u u_1) (dkind-ok/irec (Eq_rec/type-wf u u_1)).

%% def rfl
%%% HOLE
rfl/type-wf-sort : {u : lvl} lvl.

%%% HOLE
rfl/type-wf : {u : lvl} defeq (eforall (esort u) ([x] (eforall x ([y] (eapp (eapp (eapp (econst "Eq" (lcons u lnil)) x) y) y))))) (eforall (esort u) ([x] (eforall x ([y] (eapp (eapp (eapp (econst "Eq" (lcons u lnil)) x) y) y))))) (esort (rfl/type-wf-sort u)).

%%% HOLE
rfl/value-typed : {u : lvl} defeq (elam (esort u) ([x] (elam x ([y] (eapp (eapp (econst "Eq.refl" (lcons u lnil)) x) y))))) (elam (esort u) ([x] (elam x ([y] (eapp (eapp (econst "Eq.refl" (lcons u lnil)) x) y))))) (eforall (esort u) ([x] (eforall x ([y] (eapp (eapp (eapp (econst "Eq" (lcons u lnil)) x) y) y))))).

rfl/name : {u : lvl} name "rfl" (is-decl (lcons u lnil) (eforall (esort u) ([x] (eforall x ([y] (eapp (eapp (eapp (econst "Eq" (lcons u lnil)) x) y) y))))) (defn (elam (esort u) ([x] (elam x ([y] (eapp (eapp (econst "Eq.refl" (lcons u lnil)) x) y))))))).

rfl/decl : {u : lvl} declared "rfl" (lcons u lnil) (eforall (esort u) ([x] (eforall x ([y] (eapp (eapp (eapp (econst "Eq" (lcons u lnil)) x) y) y))))) (defn (elam (esort u) ([x] (elam x ([y] (eapp (eapp (econst "Eq.refl" (lcons u lnil)) x) y))))))
   = [u] declared/ok (rfl/name u) (dkind-ok/defn (rfl/type-wf u) (rfl/value-typed u)).

%% def unitEta1
%%% HOLE
unitEta1/type-wf-sort : lvl.

%%% HOLE
unitEta1/type-wf : defeq (eforall (econst "Unit" lnil) ([x] (eforall (econst "Unit" lnil) ([y] (eapp (eapp (eapp (econst "Eq" (lcons (lsucc lzero) lnil)) (econst "Unit" lnil)) x) y))))) (eforall (econst "Unit" lnil) ([x] (eforall (econst "Unit" lnil) ([y] (eapp (eapp (eapp (econst "Eq" (lcons (lsucc lzero) lnil)) (econst "Unit" lnil)) x) y))))) (esort unitEta1/type-wf-sort).

%%% HOLE
unitEta1/value-typed : defeq (elam (econst "Unit" lnil) ([x] (elam (econst "Unit" lnil) ([y] (eapp (eapp (econst "rfl" (lcons (lsucc lzero) lnil)) (econst "Unit" lnil)) x))))) (elam (econst "Unit" lnil) ([x] (elam (econst "Unit" lnil) ([y] (eapp (eapp (econst "rfl" (lcons (lsucc lzero) lnil)) (econst "Unit" lnil)) x))))) (eforall (econst "Unit" lnil) ([x] (eforall (econst "Unit" lnil) ([y] (eapp (eapp (eapp (econst "Eq" (lcons (lsucc lzero) lnil)) (econst "Unit" lnil)) x) y))))).

unitEta1/name : name "unitEta1" (is-decl lnil (eforall (econst "Unit" lnil) ([x] (eforall (econst "Unit" lnil) ([y] (eapp (eapp (eapp (econst "Eq" (lcons (lsucc lzero) lnil)) (econst "Unit" lnil)) x) y))))) (defn (elam (econst "Unit" lnil) ([x] (elam (econst "Unit" lnil) ([y] (eapp (eapp (econst "rfl" (lcons (lsucc lzero) lnil)) (econst "Unit" lnil)) x))))))).

unitEta1/decl : declared "unitEta1" lnil (eforall (econst "Unit" lnil) ([x] (eforall (econst "Unit" lnil) ([y] (eapp (eapp (eapp (econst "Eq" (lcons (lsucc lzero) lnil)) (econst "Unit" lnil)) x) y))))) (defn (elam (econst "Unit" lnil) ([x] (elam (econst "Unit" lnil) ([y] (eapp (eapp (econst "rfl" (lcons (lsucc lzero) lnil)) (econst "Unit" lnil)) x))))))
   = declared/ok unitEta1/name (dkind-ok/defn unitEta1/type-wf unitEta1/value-typed).

