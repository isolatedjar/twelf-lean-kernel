%%% Expected outcome: accept
%%% Lambda reduction under binder
%solve nonneg_0 : 0 >= 0.

%% def constType
constType/type-wf-sort : lvl
   = (limax
       (lsucc (lsucc lzero))
       (limax (lsucc (lsucc lzero)) (lsucc (lsucc lzero)))).

constType/type-wf : of (eforall (esort (lsucc lzero)) ([x] (eforall (esort (lsucc lzero)) ([y] (esort (lsucc lzero)))))) (esort constType/type-wf-sort)
   = (defeq/forall
       defeq/sort-refl
       ([x] ([h] (defeq/forall defeq/sort-refl ([y] ([h1] defeq/sort-refl)))))).

constType/value-typed : of (elam (esort (lsucc lzero)) ([x] (elam (esort (lsucc lzero)) ([y] x)))) (eforall (esort (lsucc lzero)) ([x] (eforall (esort (lsucc lzero)) ([y] (esort (lsucc lzero))))))
   = (defeq/lam
       defeq/sort-refl
       ([x] ([h] (defeq/lam defeq/sort-refl ([y] ([h1] h)))))).

constType/name : name "constType" (is-decl
  (eforall (esort (lsucc lzero)) ([x] (eforall (esort (lsucc lzero)) ([y] (esort (lsucc lzero))))))
  (defn (elam (esort (lsucc lzero)) ([x] (elam (esort (lsucc lzero)) ([y] x)))))).

constType/decl : declared "constType" (eforall (esort (lsucc lzero)) ([x] (eforall (esort (lsucc lzero)) ([y] (esort (lsucc lzero)))))) (defn (elam (esort (lsucc lzero)) ([x] (elam (esort (lsucc lzero)) ([y] x)))))
   = declared/ok constType/name dkind-non-inductive/defn (dkind-ok/defn constType/type-wf constType/value-typed).

%% def betaReduction2
betaReduction2/type-wf-sort : lvl
   = (limax (lsucc lzero) (lsucc lzero)).

betaReduction2/type-wf : of (eforall (esort lzero) ([x] (eapp (eapp (econst "constType" lnil) (esort lzero)) (eforall (esort lzero) ([y] (esort lzero)))))) (esort betaReduction2/type-wf-sort)
   = (defeq/forall
       defeq/sort-refl
       ([x]
         ([h]
           (defeq/app
             (defeq/app
               (defeq/const
                 constType/decl
                 (inst-expr/forall
                   (inst-expr/sort (lvl-inst/succ lvl-inst/zero))
                   ([x]
                     ([h]
                       (inst-expr/forall
                         (inst-expr/sort (lvl-inst/succ lvl-inst/zero))
                         ([y]
                           ([h1]
                             (inst-expr/sort
                               (lvl-inst/succ lvl-inst/zero)))))))))
               defeq/sort-refl)
             (defeq/conv
               (defeq/sort-eq
                 (lvl-eq/le
                   (mleq/imax-lsL
                     (mleq/sR
                       (mleq/maxL
                         (mleq/sL (mleq/self nonneg_0))
                         (mleq/sL (mleq/self nonneg_0)))))
                   (mleq/sL
                     (mleq/imax-lsR
                       (mleq/maxR-l (mleq/sR (mleq/self nonneg_0)))))))
               (defeq/forall defeq/sort-refl ([y] ([h1] defeq/sort-refl)))))))).

betaReduction2/value-typed : of (elam (esort lzero) ([x] x)) (eforall (esort lzero) ([x] (eapp (eapp (econst "constType" lnil) (esort lzero)) (eforall (esort lzero) ([y] (esort lzero))))))
   = (defeq/conv
       (defeq/forall
         (defeq/sort-eq lvl-eq/refl)
         ([x]
           ([h]
             (defeq/trans
               (defeq/trans
                 (defeq/trans
                   defeq/sort-refl
                   (defeq/symm
                     (defeq/beta
                       ([y] ([h1] defeq/sort-refl))
                       (defeq/conv
                         (defeq/sort-eq
                           (lvl-eq/le
                             (mleq/imax-lsL
                               (mleq/sR
                                 (mleq/maxL
                                   (mleq/sL (mleq/self nonneg_0))
                                   (mleq/sL (mleq/self nonneg_0)))))
                             (mleq/sL
                               (mleq/imax-lsR
                                 (mleq/maxR-l
                                   (mleq/sR (mleq/self nonneg_0)))))))
                         (defeq/forall
                           defeq/sort-refl
                           ([y] ([h1] defeq/sort-refl)))))))
                 (defeq/symm
                   (defeq/app
                     (defeq/beta
                       ([y] ([h1] (defeq/lam defeq/sort-refl ([z] ([h2] h1)))))
                       defeq/sort-refl)
                     (defeq/conv
                       (defeq/sort-eq
                         (lvl-eq/le
                           (mleq/imax-lsL
                             (mleq/sR
                               (mleq/maxL
                                 (mleq/sL (mleq/self nonneg_0))
                                 (mleq/sL (mleq/self nonneg_0)))))
                           (mleq/sL
                             (mleq/imax-lsR
                               (mleq/maxR-l (mleq/sR (mleq/self nonneg_0)))))))
                       (defeq/forall
                         defeq/sort-refl
                         ([y] ([h1] defeq/sort-refl)))))))
               (defeq/symm
                 (defeq/app
                   (defeq/app
                     (defeq/delta
                       constType/decl
                       (inst-expr/forall
                         (inst-expr/sort (lvl-inst/succ lvl-inst/zero))
                         ([x]
                           ([h]
                             (inst-expr/forall
                               (inst-expr/sort (lvl-inst/succ lvl-inst/zero))
                               ([y]
                                 ([h1]
                                   (inst-expr/sort
                                     (lvl-inst/succ lvl-inst/zero))))))))
                       (inst-expr/lam
                         (inst-expr/sort (lvl-inst/succ lvl-inst/zero))
                         ([x]
                           ([h]
                             (inst-expr/lam
                               (inst-expr/sort (lvl-inst/succ lvl-inst/zero))
                               ([y] ([h1] h)))))))
                     defeq/sort-refl)
                   (defeq/conv
                     (defeq/sort-eq
                       (lvl-eq/le
                         (mleq/imax-lsL
                           (mleq/sR
                             (mleq/maxL
                               (mleq/sL (mleq/self nonneg_0))
                               (mleq/sL (mleq/self nonneg_0)))))
                         (mleq/sL
                           (mleq/imax-lsR
                             (mleq/maxR-l (mleq/sR (mleq/self nonneg_0)))))))
                     (defeq/forall
                       defeq/sort-refl
                       ([y] ([h1] defeq/sort-refl))))))))))
       (defeq/lam defeq/sort-refl ([x] ([h] h)))).

betaReduction2/name : name "betaReduction2" (is-decl (eforall (esort lzero) ([x] (eapp (eapp (econst "constType" lnil) (esort lzero)) (eforall (esort lzero) ([y] (esort lzero)))))) (defn (elam (esort lzero) ([x] x)))).

betaReduction2/decl : declared "betaReduction2" (eforall (esort lzero) ([x] (eapp (eapp (econst "constType" lnil) (esort lzero)) (eforall (esort lzero) ([y] (esort lzero)))))) (defn (elam (esort lzero) ([x] x)))
   = declared/ok betaReduction2/name dkind-non-inductive/defn (dkind-ok/defn betaReduction2/type-wf betaReduction2/value-typed).
