%%% Expected outcome: reject
%%% Mismatched types
%% TRANSLATOR: could not bridge inferred type to declared type
%%   inferred type kind: sort
%%   declared type kind: sort
%%   emitting valTy.proof; Twelf will likely reject.
%% def badDef
badDef/type-wf :
   defeq (esort lzero) (esort lzero) (esort (lsucc lzero))
   = defeq/sort-refl.

badDef/value-typed :
   defeq (esort (lsucc lzero)) (esort (lsucc lzero)) (esort lzero)
   = defeq/sort-refl.

badDef/decl : declared "badDef" lnil
   (esort lzero)
   (defn (esort (lsucc lzero)))
   (dkind-ok/defn badDef/type-wf badDef/value-typed).

%mode declared +N -LS -T -DK -W.
%worlds () (declared _ _ _ _ _).
%unique declared +N -1LS -1T -1DK *W.
