%%% Expected outcome: accept
%%% Type checking Nat literals
%solve nonneg_0 : 0 >= 0.

%% inductive Nat
%%% HOLE
Nat/type-wf-sort : lvl.

%%% HOLE
Nat/type-wf : defeq (esort (lsucc lzero)) (esort (lsucc lzero)) (esort Nat/type-wf-sort).

%%% HOLE
Nat/ends-in-sort : ends-in-sort (esort (lsucc lzero)).

Nat/decl : declared "Nat" lnil
   (esort (lsucc lzero))
   indt
   (dkind-ok/indt Nat/type-wf Nat/ends-in-sort).

%% ctor Nat.zero (of Nat)
%%% HOLE
Nat_zero/type-wf-sort : lvl.

%%% HOLE
Nat_zero/type-wf : defeq (econst "Nat" lnil) (econst "Nat" lnil) (esort Nat_zero/type-wf-sort).

%%% HOLE
Nat_zero/positivity : ctor-positive "Nat" lnil (econst "Nat" lnil).

Nat_zero/decl : declared "Nat.zero" lnil
   (econst "Nat" lnil)
   ctor
   (dkind-ok/ctor Nat_zero/type-wf Nat_zero/positivity).

%% ctor Nat.succ (of Nat)
%%% HOLE
Nat_succ/type-wf-sort : lvl.

%%% HOLE
Nat_succ/type-wf : defeq (eforall (econst "Nat" lnil) ([x] (econst "Nat" lnil))) (eforall (econst "Nat" lnil) ([x] (econst "Nat" lnil))) (esort Nat_succ/type-wf-sort).

%%% HOLE
Nat_succ/positivity : ctor-positive "Nat" lnil (eforall (econst "Nat" lnil) ([x] (econst "Nat" lnil))).

Nat_succ/decl : declared "Nat.succ" lnil
   (eforall (econst "Nat" lnil) ([x] (econst "Nat" lnil)))
   ctor
   (dkind-ok/ctor Nat_succ/type-wf Nat_succ/positivity).

%% recursor Nat.rec
%%% HOLE
Nat_rec/type-wf-sort : {u : lvl} lvl.

%%% HOLE
Nat_rec/type-wf : {u : lvl} defeq (eforall (eforall (econst "Nat" lnil) ([x] (esort u))) ([x] (eforall (eapp x (econst "Nat.zero" lnil)) ([y] (eforall (eforall (econst "Nat" lnil) ([z] (eforall (eapp x z) ([w] (eapp x (eapp (econst "Nat.succ" lnil) z)))))) ([z] (eforall (econst "Nat" lnil) ([w] (eapp x w))))))))) (eforall (eforall (econst "Nat" lnil) ([x] (esort u))) ([x] (eforall (eapp x (econst "Nat.zero" lnil)) ([y] (eforall (eforall (econst "Nat" lnil) ([z] (eforall (eapp x z) ([w] (eapp x (eapp (econst "Nat.succ" lnil) z)))))) ([z] (eforall (econst "Nat" lnil) ([w] (eapp x w))))))))) (esort (Nat_rec/type-wf-sort u)).

Nat_rec/decl : {u : lvl} declared "Nat.rec" (lcons u lnil)
   (eforall (eforall (econst "Nat" lnil) ([x] (esort u))) ([x] (eforall (eapp x (econst "Nat.zero" lnil)) ([y] (eforall (eforall (econst "Nat" lnil) ([z] (eforall (eapp x z) ([w] (eapp x (eapp (econst "Nat.succ" lnil) z)))))) ([z] (eforall (econst "Nat" lnil) ([w] (eapp x w)))))))))
   irec
   (dkind-ok/irec (Nat_rec/type-wf u)).

%% def aNatLit
%%% HOLE
aNatLit/type-wf-sort : lvl.

%%% HOLE
aNatLit/type-wf : defeq (econst "Nat" lnil) (econst "Nat" lnil) (esort aNatLit/type-wf-sort).

%%% HOLE
aNatLit/value-typed : defeq (enatlit 0 nonneg_0) (enatlit 0 nonneg_0) (econst "Nat" lnil).

aNatLit/decl : declared "aNatLit" lnil
   (econst "Nat" lnil)
   (defn (enatlit 0 nonneg_0))
   (dkind-ok/defn aNatLit/type-wf aNatLit/value-typed).

