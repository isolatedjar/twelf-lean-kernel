  (eforall (esort (lsucc lzero))
    ([x]
      (eforall (esort (lsucc lzero))
        ([y]
          (eforall (eforall (eapp (eapp (econst "Prod" (lcons lzero (lcons lzero lnil))) x) y) ([z] (esort (lvar liz))))
            ([z]
