                      (eforall y
                        ([y1]
                          (eapp (eapp (eapp (econst "Eq" (lcons (lvar z) lnil)) (eapp w (eapp (eapp (eapp (eapp (econst "Prod.mk" (lcons lzero (lcons lzero lnil))) x) y) x1) y1)))
                            (eapp (eapp (eapp (eapp (eapp (econst "Prod.rec" (lcons (lvar z) (lcons lzero (lcons lzero lnil)))) x) y)
                              (elam (eapp (eapp (econst "Prod" (lcons lzero (lcons lzero lnil))) x) y) ([w1] (eapp w w1))))
                              v)
