%%% Expected outcome: accept
%%% Reduction behavior of `Prod.rec`
%% inductive Prod
Prod/type-wf : of
  (eforall (esort (lsucc (lvar z))) ([x] (eforall (esort (lsucc (lvar (s z)))) ([y] (esort (lmax (lsucc (lvar z)) (lsucc (lvar (s z)))))))))
  (esort (limax (lsucc (lsucc (lvar z))) (limax (lsucc (lsucc (lvar (s z)))) (lsucc (lmax (lsucc (lvar z)) (lsucc (lvar (s z))))))))
   = (defeq/forall
       defeq/sort-refl
       ([x] ([h] (defeq/forall defeq/sort-refl ([y] ([h1] defeq/sort-refl)))))).

Prod/ends-in-sort : ends-in-sort (eforall (esort (lsucc (lvar z))) ([x] (eforall (esort (lsucc (lvar (s z)))) ([y] (esort (lmax (lsucc (lvar z)) (lsucc (lvar (s z)))))))))
   = (ends-in-sort/forall ([x] (ends-in-sort/forall ([y] ends-in-sort/sort)))).

Prod/rec-name : name "Prod.rec" (is-rec-for "Prod").

Prod/eisl : ends-in-sort-with-level (eforall (esort (lsucc (lvar z))) ([x] (eforall (esort (lsucc (lvar (s z)))) ([y] (esort (lmax (lsucc (lvar z)) (lsucc (lvar (s z))))))))) (lmax (lsucc (lvar z)) (lsucc (lvar (s z))))
   = (ends-in-sort-with-level/forall
       ([x]
         (ends-in-sort-with-level/forall ([y] ends-in-sort-with-level/sort)))).

Prod/cnd : cnames-distinct (ccons "Prod.mk" cnil)
   = (cnames-distinct/cons cnames-distinct/nil all-string-neq/nil).

Prod/name : name "Prod" (is-decl (eforall (esort (lsucc (lvar z))) ([x] (eforall (esort (lsucc (lvar (s z)))) ([y] (esort (lmax (lsucc (lvar z)) (lsucc (lvar (s z))))))))) (indt (ccons "Prod.mk" cnil) (s (s z)))).

Prod/decl : declared "Prod" (eforall (esort (lsucc (lvar z))) ([x] (eforall (esort (lsucc (lvar (s z)))) ([y] (esort (lmax (lsucc (lvar z)) (lsucc (lvar (s z))))))))) (indt (ccons "Prod.mk" cnil) (s (s z)))
   = declared/ok-indt Prod/name Prod/rec-name Prod/cnd (dkind-ok/indt Prod/type-wf Prod/ends-in-sort).

%% ctor Prod.mk (of Prod)
Prod_mk/type-wf : of
  (eforall (esort (lsucc (lvar z))) ([x] (eforall (esort (lsucc (lvar (s z)))) ([y] (eforall x ([w] (eforall y ([v] (eapp (eapp (econst "Prod" (lcons (lvar z) (lcons (lvar (s z)) lnil))) x) y)))))))))
  (esort (limax (lsucc (lsucc (lvar z))) (limax (lsucc (lsucc (lvar (s z)))) (limax (lsucc (lvar z)) (limax (lsucc (lvar (s z))) (lmax (lsucc (lvar z)) (lsucc (lvar (s z)))))))))
   = (defeq/forall
       defeq/sort-refl
       ([x]
         ([h]
           (defeq/forall
             defeq/sort-refl
             ([y]
               ([h1]
                 (defeq/forall
                   h
                   ([w]
                     ([h2]
                       (defeq/forall
                         h1
                         ([v]
                           ([h3]
                             (defeq/app
                               (defeq/app
                                 (defeq/const
                                   Prod/decl
                                   (inst-expr/forall
                                     (inst-expr/sort
                                       (inst-lvl/succ (inst-lvl/var nth-lvl/z)))
                                     ([x]
                                       ([h]
                                         (inst-expr/forall
                                           (inst-expr/sort
                                             (inst-lvl/succ
                                               (inst-lvl/var
                                                 (nth-lvl/s nth-lvl/z))))
                                           ([y]
                                             ([h1]
                                               (inst-expr/sort
                                                 (inst-lvl/max
                                                   (inst-lvl/succ
                                                     (inst-lvl/var
                                                       (nth-lvl/s nth-lvl/z)))
                                                   (inst-lvl/succ
                                                     (inst-lvl/var
                                                       nth-lvl/z)))))))))))
                                 h)
                               h1))))))))))))).

Prod_mk/positivity : ctor-positive "Prod" (lcons (lvar z) (lcons (lvar (s z)) lnil)) (eforall (esort (lsucc (lvar z))) ([x] (eforall (esort (lsucc (lvar (s z)))) ([y] (eforall x ([w] (eforall y ([v] (eapp (eapp (econst "Prod" (lcons (lvar z) (lcons (lvar (s z)) lnil))) x) y)))))))))
   = (ctor-positive/intro ([S] (eforall (esort (lsucc (lvar z))) ([x] (eforall (esort (lsucc (lvar (s z)))) ([y] (eforall x ([w] (eforall y ([v] (eapp (eapp S x) y)))))))))) (ctor-spine/arg
       (strict-pos/no-occur (esort (lsucc (lvar z))) no-self-ref/sort)
       ([x]
         ([y]
           (ctor-spine/arg
             (strict-pos/no-occur (esort (lsucc (lvar (s z)))) no-self-ref/sort)
             ([w]
               ([v]
                 (ctor-spine/arg
                   (strict-pos/no-occur x y)
                   ([x1]
                     ([y1]
                       (ctor-spine/arg
                         (strict-pos/no-occur w v)
                         ([w1]
                           ([v1]
                             (ctor-spine/result
                               (applies-self/app
                                 (applies-self/app
                                   applies-self/refl)))))))))))))))).

Prod_mk/cmem : cmem "Prod.mk" (ccons "Prod.mk" cnil)
   = cmem/here.

%%% HOLE: Prod_mk/fuo
Prod_mk/fuo : field-universes-ok (eforall (esort (lsucc (lvar z))) ([x] (eforall (esort (lsucc (lvar (s z)))) ([y] (eforall x ([w] (eforall y ([v] (eapp (eapp (econst "Prod" (lcons (lvar z) (lcons (lvar (s z)) lnil))) x) y))))))))) (lmax (lsucc (lvar z)) (lsucc (lvar (s z)))).

Prod_mk/name : name "Prod.mk" (is-decl
  (eforall (esort (lsucc (lvar z))) ([x] (eforall (esort (lsucc (lvar (s z)))) ([y] (eforall x ([w] (eforall y ([v] (eapp (eapp (econst "Prod" (lcons (lvar z) (lcons (lvar (s z)) lnil))) x) y)))))))))
  (ctor "Prod" z)).

Prod_mk/decl : declared "Prod.mk"
  (eforall (esort (lsucc (lvar z))) ([x] (eforall (esort (lsucc (lvar (s z)))) ([y] (eforall x ([w] (eforall y ([v] (eapp (eapp (econst "Prod" (lcons (lvar z) (lcons (lvar (s z)) lnil))) x) y)))))))))
  (ctor "Prod" z)
   = declared/ok-ctor Prod_mk/name Prod/name Prod_mk/cmem Prod/eisl Prod_mk/fuo (dkind-ok/ctor Prod_mk/type-wf Prod_mk/positivity).

%% recursor Prod.rec (TCB-derived; informational only)
%%   level params: u_1 u v
%%   type:   (eforall (esort (lsucc (lvar (s z)))) ([x] (eforall (esort (lsucc (lvar (s (s z))))) ([y] (eforall (eforall (eapp (eapp (econst "Prod" (lcons (lvar (s z)) (lcons (lvar (s (s z))) lnil))) x) y) ([w] (esort (lvar z)))) ([w] (eforall (eforall x ([v] (eforall y ([x1] (eapp w (eapp (eapp (eapp (eapp (econst "Prod.mk" (lcons (lvar (s z)) (lcons (lvar (s (s z))) lnil))) x) y) v) x1)))))) ([v] (eforall (eapp (eapp (econst "Prod" (lcons (lvar (s z)) (lcons (lvar (s (s z))) lnil))) x) y) ([x1] (eapp w x1)))))))))))
%%   rules:
%%     Prod.rec … Prod.mk … = (elam (esort (lsucc (lvar (s z)))) ([x] (elam (esort (lsucc (lvar (s (s z))))) ([y] (elam (eforall (eapp (eapp (econst "Prod" (lcons (lvar (s z)) (lcons (lvar (s (s z))) lnil))) x) y) ([w] (esort (lvar z)))) ([w] (elam (eforall x ([v] (eforall y ([x1] (eapp w (eapp (eapp (eapp (eapp (econst "Prod.mk" (lcons (lvar (s z)) (lcons (lvar (s (s z))) lnil))) x) y) v) x1)))))) ([v] (elam x ([x1] (elam y ([y1] (eapp (eapp v x1) y1)))))))))))))   (2 fields)

%% inductive Eq
Eq/type-wf : of (eforall (esort (lvar z)) ([x] (eforall x ([y] (eforall x ([w] (esort lzero))))))) (esort (limax (lsucc (lvar z)) (limax (lvar z) (limax (lvar z) (lsucc lzero)))))
   = (defeq/forall
       defeq/sort-refl
       ([x]
         ([h]
           (defeq/forall
             h
             ([y] ([h1] (defeq/forall h ([w] ([h2] defeq/sort-refl))))))))).

Eq/ends-in-sort : ends-in-sort (eforall (esort (lvar z)) ([x] (eforall x ([y] (eforall x ([w] (esort lzero)))))))
   = (ends-in-sort/forall
       ([x]
         (ends-in-sort/forall
           ([y] (ends-in-sort/forall ([w] ends-in-sort/sort)))))).

Eq/rec-name : name "Eq.rec" (is-rec-for "Eq").

Eq/eisl : ends-in-sort-with-level (eforall (esort (lvar z)) ([x] (eforall x ([y] (eforall x ([w] (esort lzero))))))) lzero
   = (ends-in-sort-with-level/forall
       ([x]
         (ends-in-sort-with-level/forall
           ([y]
             (ends-in-sort-with-level/forall
               ([w] ends-in-sort-with-level/sort)))))).

Eq/cnd : cnames-distinct (ccons "Eq.refl" cnil)
   = (cnames-distinct/cons cnames-distinct/nil all-string-neq/nil).

Eq/name : name "Eq" (is-decl (eforall (esort (lvar z)) ([x] (eforall x ([y] (eforall x ([w] (esort lzero))))))) (indt (ccons "Eq.refl" cnil) (s (s z)))).

Eq/decl : declared "Eq" (eforall (esort (lvar z)) ([x] (eforall x ([y] (eforall x ([w] (esort lzero))))))) (indt (ccons "Eq.refl" cnil) (s (s z)))
   = declared/ok-indt Eq/name Eq/rec-name Eq/cnd (dkind-ok/indt Eq/type-wf Eq/ends-in-sort).

%% ctor Eq.refl (of Eq)
Eq_refl/type-wf : of (eforall (esort (lvar z)) ([x] (eforall x ([y] (eapp (eapp (eapp (econst "Eq" (lcons (lvar z) lnil)) x) y) y))))) (esort (limax (lsucc (lvar z)) (limax (lvar z) lzero)))
   = (defeq/forall
       defeq/sort-refl
       ([x]
         ([h]
           (defeq/forall
             h
             ([y]
               ([h1]
                 (defeq/app
                   (defeq/app
                     (defeq/app
                       (defeq/const
                         Eq/decl
                         (inst-expr/forall
                           (inst-expr/sort (inst-lvl/var nth-lvl/z))
                           ([x]
                             ([h]
                               (inst-expr/forall
                                 h
                                 ([y]
                                   ([h1]
                                     (inst-expr/forall
                                       h
                                       ([w]
                                         ([h2]
                                           (inst-expr/sort
                                             inst-lvl/zero)))))))))))
                       h)
                     h1)
                   h1))))))).

Eq_refl/positivity : ctor-positive "Eq" (lcons (lvar z) lnil) (eforall (esort (lvar z)) ([x] (eforall x ([y] (eapp (eapp (eapp (econst "Eq" (lcons (lvar z) lnil)) x) y) y)))))
   = (ctor-positive/intro ([S] (eforall (esort (lvar z)) ([x] (eforall x ([y] (eapp (eapp (eapp S x) y) y)))))) (ctor-spine/arg
       (strict-pos/no-occur (esort (lvar z)) no-self-ref/sort)
       ([x]
         ([y]
           (ctor-spine/arg
             (strict-pos/no-occur x y)
             ([w]
               ([v]
                 (ctor-spine/result
                   (applies-self/app
                     (applies-self/app
                       (applies-self/app applies-self/refl))))))))))).

Eq_refl/cmem : cmem "Eq.refl" (ccons "Eq.refl" cnil)
   = cmem/here.

Eq_refl/fuo : field-universes-ok (eforall (esort (lvar z)) ([x] (eforall x ([y] (eapp (eapp (eapp (econst "Eq" (lcons (lvar z) lnil)) x) y) y))))) lzero
   = (field-universes-ok/forall
       defeq/sort-refl
       (leq-lvl/imaxLz leq-lvl/self)
       ([x]
         ([h]
           (field-universes-ok/forall
             h
             (leq-lvl/imaxLz leq-lvl/self)
             ([y] ([h1] (field-universes-ok/done not-forall/app))))))).

Eq_refl/name : name "Eq.refl" (is-decl (eforall (esort (lvar z)) ([x] (eforall x ([y] (eapp (eapp (eapp (econst "Eq" (lcons (lvar z) lnil)) x) y) y))))) (ctor "Eq" z)).

Eq_refl/decl : declared "Eq.refl" (eforall (esort (lvar z)) ([x] (eforall x ([y] (eapp (eapp (eapp (econst "Eq" (lcons (lvar z) lnil)) x) y) y))))) (ctor "Eq" z)
   = declared/ok-ctor Eq_refl/name Eq/name Eq_refl/cmem Eq/eisl Eq_refl/fuo (dkind-ok/ctor Eq_refl/type-wf Eq_refl/positivity).

%% recursor Eq.rec (TCB-derived; informational only)
%%   level params: u u_1
%%   type:   (eforall (esort (lvar (s z))) ([x] (eforall x ([y] (eforall (eforall x ([w] (eforall (eapp (eapp (eapp (econst "Eq" (lcons (lvar (s z)) lnil)) x) y) w) ([v] (esort (lvar z)))))) ([w] (eforall (eapp (eapp w y) (eapp (eapp (econst "Eq.refl" (lcons (lvar (s z)) lnil)) x) y)) ([v] (eforall x ([x1] (eforall (eapp (eapp (eapp (econst "Eq" (lcons (lvar (s z)) lnil)) x) y) x1) ([y1] (eapp (eapp w x1) y1)))))))))))))
%%   rules:
%%     Eq.rec … Eq.refl … = (elam (esort (lvar (s z))) ([x] (elam x ([y] (elam (eforall x ([w] (eforall (eapp (eapp (eapp (econst "Eq" (lcons (lvar (s z)) lnil)) x) y) w) ([v] (esort (lvar z)))))) ([w] (elam (eapp (eapp w y) (eapp (eapp (econst "Eq.refl" (lcons (lvar (s z)) lnil)) x) y)) ([v] v))))))))   (0 fields)
%%   K-like reduction: yes

%% thm prodRecEqns
%%% HOLE
prodRecEqns/type-wf : of
  (eforall (esort (lsucc lzero))
    ([x]
      (eforall (esort (lsucc lzero))
        ([y]
          (eforall (eforall (eapp (eapp (econst "Prod" (lcons lzero (lcons lzero lnil))) x) y) ([w] (esort (lvar z))))
            ([w]
              (eforall (eforall x ([v] (eforall y ([x1] (eapp w (eapp (eapp (eapp (eapp (econst "Prod.mk" (lcons lzero (lcons lzero lnil))) x) y) v) x1))))))
                ([v]
