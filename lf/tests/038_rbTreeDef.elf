%% def rbTreeDef
rbTreeDef/type-wf :
   {u : lvl} defeq (eforall (esort (lsucc u)) ([x] (eforall (econst "Color" lnil) ([y] (eforall (econst "N" lnil) ([z] (esort (lsucc u)))))))) (eforall (esort (lsucc u)) ([x] (eforall (econst "Color" lnil) ([y] (eforall (econst "N" lnil) ([z] (esort (lsucc u)))))))) (esort (limax (lsucc (lsucc u)) (limax (lsucc lzero) (limax (lsucc lzero) (lsucc (lsucc u))))))
   = [u] (defeq/forall (defeq/sort-refl-at (lsucc u)) ([x] [y] (defeq/forall (defeq/const Color/decl) ([z] [w] (defeq/forall (defeq/const N/decl) ([x1] [y1] (defeq/sort-refl-at (lsucc u)))))))).

rbTreeDef/value-typed :
   {u : lvl} defeq (econst "RBTree" (lcons u lnil)) (econst "RBTree" (lcons u lnil)) (eforall (esort (lsucc u)) ([x] (eforall (econst "Color" lnil) ([y] (eforall (econst "N" lnil) ([z] (esort (lsucc u))))))))
   = [u] (defeq/const (RBTree/decl u)).

rbTreeDef/decl : {u : lvl} declared "rbTreeDef" (lcons u lnil)
   (eforall (esort (lsucc u)) ([x] (eforall (econst "Color" lnil) ([y] (eforall (econst "N" lnil) ([z] (esort (lsucc u))))))))
   (defn (econst "RBTree" (lcons u lnil)))
   (dkind-ok/defn (rbTreeDef/type-wf u) (rbTreeDef/value-typed u)).

