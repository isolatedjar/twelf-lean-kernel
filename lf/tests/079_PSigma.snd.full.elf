%%% Expected outcome: accept
%%% Type-checking dependent projection functions
%% inductive PSigma
PSigma/type-wf : of
  (eforall (esort (lvar z)) ([x] (eforall (eforall x ([y] (esort (lvar (s z))))) ([y] (esort (lmax (lmax (lsucc lzero) (lvar z)) (lvar (s z))))))))
  (esort (limax (lsucc (lvar z)) (limax (limax (lvar z) (lsucc (lvar (s z)))) (lsucc (lmax (lmax (lsucc lzero) (lvar z)) (lvar (s z)))))))
   = (defeq/forall
       defeq/sort-refl
       ([x]
         ([h]
           (defeq/forall
             (defeq/forall h ([y] ([h1] defeq/sort-refl)))
             ([y] ([h1] defeq/sort-refl)))))).

PSigma/ends-in-sort : ends-in-sort (eforall (esort (lvar z)) ([x] (eforall (eforall x ([y] (esort (lvar (s z))))) ([y] (esort (lmax (lmax (lsucc lzero) (lvar z)) (lvar (s z))))))))
   = (ends-in-sort/forall ([x] (ends-in-sort/forall ([y] ends-in-sort/sort)))).

PSigma/rec-name : name "PSigma.rec" (is-rec-for "PSigma").

PSigma/eisl : ends-in-sort-with-level (eforall (esort (lvar z)) ([x] (eforall (eforall x ([y] (esort (lvar (s z))))) ([y] (esort (lmax (lmax (lsucc lzero) (lvar z)) (lvar (s z)))))))) (lmax (lmax (lsucc lzero) (lvar z)) (lvar (s z)))
   = (ends-in-sort-with-level/forall
       ([x]
         (ends-in-sort-with-level/forall ([y] ends-in-sort-with-level/sort)))).

PSigma/cnd : cnames-distinct (ccons "PSigma.mk" cnil)
   = (cnames-distinct/cons cnames-distinct/nil all-string-neq/nil).

PSigma/name : name "PSigma" (is-decl
  (eforall (esort (lvar z)) ([x] (eforall (eforall x ([y] (esort (lvar (s z))))) ([y] (esort (lmax (lmax (lsucc lzero) (lvar z)) (lvar (s z))))))))
  (indt (ccons "PSigma.mk" cnil) (s (s z)))).

PSigma/decl : declared "PSigma"
  (eforall (esort (lvar z)) ([x] (eforall (eforall x ([y] (esort (lvar (s z))))) ([y] (esort (lmax (lmax (lsucc lzero) (lvar z)) (lvar (s z))))))))
  (indt (ccons "PSigma.mk" cnil) (s (s z)))
   = declared/ok-indt PSigma/name PSigma/rec-name PSigma/cnd (dkind-ok/indt PSigma/type-wf PSigma/ends-in-sort).

%% ctor PSigma.mk (of PSigma)
PSigma_mk/type-wf : of
  (eforall (esort (lvar z))
    ([x] (eforall (eforall x ([y] (esort (lvar (s z))))) ([y] (eforall x ([w] (eforall (eapp y w) ([v] (eapp (eapp (econst "PSigma" (lcons (lvar z) (lcons (lvar (s z)) lnil))) x) y)))))))))
  (esort (limax (lsucc (lvar z)) (limax (limax (lvar z) (lsucc (lvar (s z)))) (limax (lvar z) (limax (lvar (s z)) (lmax (lmax (lsucc lzero) (lvar z)) (lvar (s z))))))))
   = (defeq/forall
       defeq/sort-refl
       ([x]
         ([h]
           (defeq/forall
             (defeq/forall h ([y] ([h1] defeq/sort-refl)))
             ([y]
               ([h1]
                 (defeq/forall
                   h
                   ([w]
                     ([h2]
                       (defeq/forall
                         (defeq/app h1 h2)
                         ([v]
                           ([h3]
                             (defeq/app
                               (defeq/app
                                 (defeq/const
                                   PSigma/decl
                                   (inst-expr/forall
                                     (inst-expr/sort (inst-lvl/var nth-lvl/z))
                                     ([x]
                                       ([h]
                                         (inst-expr/forall
                                           (inst-expr/forall
                                             h
                                             ([y]
                                               ([h1]
                                                 (inst-expr/sort
                                                   (inst-lvl/var
                                                     (nth-lvl/s nth-lvl/z))))))
                                           ([y]
                                             ([h1]
                                               (inst-expr/sort
                                                 (inst-lvl/max
                                                   (inst-lvl/var
                                                     (nth-lvl/s nth-lvl/z))
                                                   (inst-lvl/max
                                                     (inst-lvl/var nth-lvl/z)
                                                     (inst-lvl/succ
                                                       inst-lvl/zero)))))))))))
                                 h)
                               h1))))))))))))).

PSigma_mk/positivity : ctor-positive "PSigma" (lcons (lvar z) (lcons (lvar (s z)) lnil)) (eforall (esort (lvar z)) ([x] (eforall (eforall x ([y] (esort (lvar (s z))))) ([y] (eforall x ([w] (eforall (eapp y w) ([v] (eapp (eapp (econst "PSigma" (lcons (lvar z) (lcons (lvar (s z)) lnil))) x) y)))))))))
   = (ctor-positive/intro ([S] (eforall (esort (lvar z)) ([x] (eforall (eforall x ([y] (esort (lvar (s z))))) ([y] (eforall x ([w] (eforall (eapp y w) ([v] (eapp (eapp S x) y)))))))))) (ctor-spine/arg
       (strict-pos/no-occur (esort (lvar z)) no-self-ref/sort)
       ([x]
         ([y]
           (ctor-spine/arg
             (strict-pos/no-occur
               (eforall x ([y] (esort (lvar (s z)))))
               (no-self-ref/forall y ([w] ([v] no-self-ref/sort))))
             ([w]
               ([v]
                 (ctor-spine/arg
                   (strict-pos/no-occur x y)
                   ([x1]
                     ([y1]
                       (ctor-spine/arg
                         (strict-pos/no-occur
                           (eapp w x1)
                           (no-self-ref/app v y1))
                         ([w1]
                           ([v1]
                             (ctor-spine/result
                               (applies-self/app
                                 (applies-self/app
                                   applies-self/refl)))))))))))))))).

PSigma_mk/cmem : cmem "PSigma.mk" (ccons "PSigma.mk" cnil)
   = cmem/here.

%%% HOLE: PSigma_mk/fuo
PSigma_mk/fuo : field-universes-ok (eforall (esort (lvar z)) ([x] (eforall (eforall x ([y] (esort (lvar (s z))))) ([y] (eforall x ([w] (eforall (eapp y w) ([v] (eapp (eapp (econst "PSigma" (lcons (lvar z) (lcons (lvar (s z)) lnil))) x) y))))))))) (lmax (lmax (lsucc lzero) (lvar z)) (lvar (s z))).

PSigma_mk/name : name "PSigma.mk" (is-decl
  (eforall (esort (lvar z))
    ([x] (eforall (eforall x ([y] (esort (lvar (s z))))) ([y] (eforall x ([w] (eforall (eapp y w) ([v] (eapp (eapp (econst "PSigma" (lcons (lvar z) (lcons (lvar (s z)) lnil))) x) y)))))))))
  (ctor "PSigma" z)).

PSigma_mk/decl : declared "PSigma.mk"
  (eforall (esort (lvar z))
    ([x] (eforall (eforall x ([y] (esort (lvar (s z))))) ([y] (eforall x ([w] (eforall (eapp y w) ([v] (eapp (eapp (econst "PSigma" (lcons (lvar z) (lcons (lvar (s z)) lnil))) x) y)))))))))
  (ctor "PSigma" z)
   = declared/ok-ctor PSigma_mk/name PSigma/name PSigma_mk/cmem PSigma/eisl PSigma_mk/fuo (dkind-ok/ctor PSigma_mk/type-wf PSigma_mk/positivity).

%% recursor PSigma.rec (TCB-derived; informational only)
%%   level params: u_1 u v
%%   type:   (eforall (esort (lvar (s z))) ([x] (eforall (eforall x ([y] (esort (lvar (s (s z)))))) ([y] (eforall (eforall (eapp (eapp (econst "PSigma" (lcons (lvar (s z)) (lcons (lvar (s (s z))) lnil))) x) y) ([w] (esort (lvar z)))) ([w] (eforall (eforall x ([v] (eforall (eapp y v) ([x1] (eapp w (eapp (eapp (eapp (eapp (econst "PSigma.mk" (lcons (lvar (s z)) (lcons (lvar (s (s z))) lnil))) x) y) v) x1)))))) ([v] (eforall (eapp (eapp (econst "PSigma" (lcons (lvar (s z)) (lcons (lvar (s (s z))) lnil))) x) y) ([x1] (eapp w x1)))))))))))
%%   rules:
%%     PSigma.rec … PSigma.mk … = (elam (esort (lvar (s z))) ([x] (elam (eforall x ([y] (esort (lvar (s (s z)))))) ([y] (elam (eforall (eapp (eapp (econst "PSigma" (lcons (lvar (s z)) (lcons (lvar (s (s z))) lnil))) x) y) ([w] (esort (lvar z)))) ([w] (elam (eforall x ([v] (eforall (eapp y v) ([x1] (eapp w (eapp (eapp (eapp (eapp (econst "PSigma.mk" (lcons (lvar (s z)) (lcons (lvar (s (s z))) lnil))) x) y) v) x1)))))) ([v] (elam x ([x1] (elam (eapp y x1) ([y1] (eapp (eapp v x1) y1)))))))))))))   (2 fields)

%% def PSigma.fst
PSigma_fst/type-wf : of
  (eforall (esort (lvar z)) ([x] (eforall (eforall x ([y] (esort (lvar (s z))))) ([y] (eforall (eapp (eapp (econst "PSigma" (lcons (lvar z) (lcons (lvar (s z)) lnil))) x) y) ([w] x))))))
  (esort (limax (lsucc (lvar z)) (limax (limax (lvar z) (lsucc (lvar (s z)))) (limax (lmax (lmax (lsucc lzero) (lvar z)) (lvar (s z))) (lvar z)))))
   = (defeq/forall
       defeq/sort-refl
       ([x]
         ([h]
           (defeq/forall
             (defeq/forall h ([y] ([h1] defeq/sort-refl)))
             ([y]
               ([h1]
                 (defeq/forall
                   (defeq/app
                     (defeq/app
                       (defeq/const
                         PSigma/decl
                         (inst-expr/forall
                           (inst-expr/sort (inst-lvl/var nth-lvl/z))
                           ([x]
                             ([h]
                               (inst-expr/forall
                                 (inst-expr/forall
                                   h
                                   ([y]
                                     ([h1]
                                       (inst-expr/sort
                                         (inst-lvl/var
                                           (nth-lvl/s nth-lvl/z))))))
                                 ([y]
                                   ([h1]
                                     (inst-expr/sort
                                       (inst-lvl/max
                                         (inst-lvl/var (nth-lvl/s nth-lvl/z))
                                         (inst-lvl/max
                                           (inst-lvl/var nth-lvl/z)
                                           (inst-lvl/succ
                                             inst-lvl/zero)))))))))))
                       h)
                     h1)
                   ([w] ([h2] h))))))))).

