%% def PSigma.snd
PSigma_snd/type-wf : of
  (eforall (esort (lvar z))
    ([x]
      (eforall (eforall x ([y] (esort (lvar (s z)))))
        ([y]
          (eforall (eapp (eapp (econst "PSigma" (lcons (lvar z) (lcons (lvar (s z)) lnil))) x) y)
            ([w] (eapp y (eapp (eapp (eapp (econst "PSigma.fst" (lcons (lvar z) (lcons (lvar (s z)) lnil))) x) y) w))))))))
  (esort (limax (lsucc (lvar z)) (limax (limax (lvar z) (lsucc (lvar (s z)))) (limax (lmax (lmax (lsucc lzero) (lvar z)) (lvar (s z))) (lvar (s z))))))
   = (defeq/forall
       defeq/sort-refl
       ([x]
         ([h]
           (defeq/forall
             (defeq/forall h ([y] ([h1] defeq/sort-refl)))
             ([y]
               ([h1]
                 (defeq/forall
                   (defeq/app
                     (defeq/app
                       (defeq/const
                         PSigma/decl
                         (inst-expr/forall
                           (inst-expr/sort (inst-lvl/var nth-lvl/z))
                           ([x]
                             ([h]
                               (inst-expr/forall
                                 (inst-expr/forall
                                   h
                                   ([y]
                                     ([h1]
                                       (inst-expr/sort
                                         (inst-lvl/var
                                           (nth-lvl/s nth-lvl/z))))))
                                 ([y]
                                   ([h1]
                                     (inst-expr/sort
                                       (inst-lvl/max
                                         (inst-lvl/var (nth-lvl/s nth-lvl/z))
                                         (inst-lvl/max
                                           (inst-lvl/var nth-lvl/z)
                                           (inst-lvl/succ
                                             inst-lvl/zero)))))))))))
                       h)
                     h1)
                   ([w]
                     ([h2]
                       (defeq/app
                         h1
                         (defeq/app
                           (defeq/app
                             (defeq/app
                               (defeq/const
                                 PSigma_fst/decl
                                 (inst-expr/forall
                                   (inst-expr/sort (inst-lvl/var nth-lvl/z))
                                   ([x]
                                     ([h]
                                       (inst-expr/forall
                                         (inst-expr/forall
                                           h
                                           ([y]
                                             ([h1]
                                               (inst-expr/sort
                                                 (inst-lvl/var
                                                   (nth-lvl/s nth-lvl/z))))))
                                         ([y]
                                           ([h1]
                                             (inst-expr/forall
                                               (inst-expr/app
                                                 (inst-expr/app
                                                   (inst-expr/const
                                                     (inst-lvls/cons
                                                       (inst-lvls/cons
                                                         inst-lvls/nil
                                                         (inst-lvl/var
                                                           (nth-lvl/s
                                                             nth-lvl/z)))
                                                       (inst-lvl/var
                                                         nth-lvl/z)))
                                                   h)
                                                 h1)
                                               ([w] ([h2] h))))))))))
                               h)
                             h1)
                           h2))))))))))).

