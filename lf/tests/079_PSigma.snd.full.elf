%%% Expected outcome: accept
%%% Type-checking dependent projection functions
%solve nonneg_0 : 0 >= 0.
%solve nonneg_1 : 1 >= 0.

%% inductive PSigma
PSigma/type-wf-sort : lvl
   = (limax
       (lsucc (lvar liz))
       (limax
         (limax (lvar liz) (lsucc (lvar (lis liz))))
         (lsucc (lmax (lmax (lsucc lzero) (lvar liz)) (lvar (lis liz)))))).

PSigma/type-wf : of (eforall (esort (lvar liz)) ([x] (eforall (eforall x ([y] (esort (lvar (lis liz))))) ([y] (esort (lmax (lmax (lsucc lzero) (lvar liz)) (lvar (lis liz)))))))) (esort PSigma/type-wf-sort)
   = (defeq/forall
       defeq/sort-refl
       ([x]
         ([h]
           (defeq/forall
             (defeq/forall h ([y] ([h1] defeq/sort-refl)))
             ([y] ([h1] defeq/sort-refl)))))).

PSigma/ends-in-sort : ends-in-sort (eforall (esort (lvar liz)) ([x] (eforall (eforall x ([y] (esort (lvar (lis liz))))) ([y] (esort (lmax (lmax (lsucc lzero) (lvar liz)) (lvar (lis liz))))))))
   = (ends-in-sort/forall ([x] (ends-in-sort/forall ([y] ends-in-sort/sort)))).

PSigma/rec-name : name "PSigma.rec" (is-rec-for "PSigma").

PSigma/eisl : ends-in-sort-with-level (eforall (esort (lvar liz)) ([x] (eforall (eforall x ([y] (esort (lvar (lis liz))))) ([y] (esort (lmax (lmax (lsucc lzero) (lvar liz)) (lvar (lis liz)))))))) (lmax (lmax (lsucc lzero) (lvar liz)) (lvar (lis liz)))
   = (ends-in-sort-with-level/forall
       ([x]
         (ends-in-sort-with-level/forall ([y] ends-in-sort-with-level/sort)))).

PSigma/cnd : cnames-distinct (ccons "PSigma.mk" cnil)
   = (cnames-distinct/cons cnames-distinct/nil all-string-neq/nil).

PSigma/name : name "PSigma" (is-decl
  (eforall (esort (lvar liz)) ([x] (eforall (eforall x ([y] (esort (lvar (lis liz))))) ([y] (esort (lmax (lmax (lsucc lzero) (lvar liz)) (lvar (lis liz))))))))
  (indt (ccons "PSigma.mk" cnil) (lis (lis liz)))).

PSigma/decl : declared "PSigma"
  (eforall (esort (lvar liz)) ([x] (eforall (eforall x ([y] (esort (lvar (lis liz))))) ([y] (esort (lmax (lmax (lsucc lzero) (lvar liz)) (lvar (lis liz))))))))
  (indt (ccons "PSigma.mk" cnil) (lis (lis liz)))
   = declared/ok-indt PSigma/name PSigma/rec-name PSigma/cnd (dkind-ok/indt PSigma/type-wf PSigma/ends-in-sort).

%% ctor PSigma.mk (of PSigma)
PSigma_mk/type-wf-sort : lvl
   = (limax
       (lsucc (lvar liz))
       (limax
         (limax (lvar liz) (lsucc (lvar (lis liz))))
         (limax
           (lvar liz)
           (limax
             (lvar (lis liz))
             (lmax (lmax (lsucc lzero) (lvar liz)) (lvar (lis liz))))))).

PSigma_mk/type-wf : of
  (eforall (esort (lvar liz))
    ([x] (eforall (eforall x ([y] (esort (lvar (lis liz))))) ([y] (eforall x ([z] (eforall (eapp y z) ([w] (eapp (eapp (econst "PSigma" (lcons (lvar liz) (lcons (lvar (lis liz)) lnil))) x) y)))))))))
  (esort PSigma_mk/type-wf-sort)
   = (defeq/forall
       defeq/sort-refl
       ([x]
         ([h]
           (defeq/forall
             (defeq/forall h ([y] ([h1] defeq/sort-refl)))
             ([y]
               ([h1]
                 (defeq/forall
                   h
                   ([z]
                     ([h2]
                       (defeq/forall
                         (defeq/app h1 h2)
                         ([w]
                           ([h3]
                             (defeq/app
                               (defeq/app
                                 (defeq/const
                                   PSigma/decl
                                   (inst-expr/forall
                                     (inst-expr/sort
                                       (lvl-inst/var lvl-nth/zero))
                                     ([x]
                                       ([h]
                                         (inst-expr/forall
                                           (inst-expr/forall
                                             h
                                             ([y]
                                               ([h1]
                                                 (inst-expr/sort
                                                   (lvl-inst/var
                                                     (lvl-nth/succ
                                                       lvl-nth/zero))))))
                                           ([y]
                                             ([h1]
                                               (inst-expr/sort
                                                 (lvl-inst/max
                                                   (lvl-inst/max
                                                     (lvl-inst/succ
                                                       lvl-inst/zero)
                                                     (lvl-inst/var
                                                       lvl-nth/zero))
                                                   (lvl-inst/var
                                                     (lvl-nth/succ
                                                       lvl-nth/zero)))))))))))
                                 h)
                               h1))))))))))))).

PSigma_mk/positivity : ctor-positive "PSigma" (lcons (lvar liz) (lcons (lvar (lis liz)) lnil)) (eforall (esort (lvar liz)) ([x] (eforall (eforall x ([y] (esort (lvar (lis liz))))) ([y] (eforall x ([z] (eforall (eapp y z) ([w] (eapp (eapp (econst "PSigma" (lcons (lvar liz) (lcons (lvar (lis liz)) lnil))) x) y)))))))))
   = (ctor-positive/intro ([S] (eforall (esort (lvar liz)) ([x] (eforall (eforall x ([y] (esort (lvar (lis liz))))) ([y] (eforall x ([z] (eforall (eapp y z) ([w] (eapp (eapp S x) y)))))))))) (ctor-spine/arg
       (strict-pos/no-occur (esort (lvar liz)) no-self-ref/sort)
       ([x]
         ([y]
           (ctor-spine/arg
             (strict-pos/no-occur
               (eforall x ([y] (esort (lvar (lis liz)))))
               (no-self-ref/forall y ([z] ([w] no-self-ref/sort))))
             ([z]
               ([w]
                 (ctor-spine/arg
                   (strict-pos/no-occur x y)
                   ([x1]
                     ([y1]
                       (ctor-spine/arg
                         (strict-pos/no-occur
                           (eapp z x1)
                           (no-self-ref/app w y1))
                         ([z1]
                           ([w1]
                             (ctor-spine/result
                               (applies-self/app
                                 (applies-self/app
                                   applies-self/refl)))))))))))))))).

PSigma_mk/cmem : cmem "PSigma.mk" (ccons "PSigma.mk" cnil)
   = cmem/here.

%%% HOLE: PSigma_mk/fuo
PSigma_mk/fuo : field-universes-ok (eforall (esort (lvar liz)) ([x] (eforall (eforall x ([y] (esort (lvar (lis liz))))) ([y] (eforall x ([z] (eforall (eapp y z) ([w] (eapp (eapp (econst "PSigma" (lcons (lvar liz) (lcons (lvar (lis liz)) lnil))) x) y))))))))) (lmax (lmax (lsucc lzero) (lvar liz)) (lvar (lis liz))).

PSigma_mk/name : name "PSigma.mk" (is-decl
  (eforall (esort (lvar liz))
    ([x] (eforall (eforall x ([y] (esort (lvar (lis liz))))) ([y] (eforall x ([z] (eforall (eapp y z) ([w] (eapp (eapp (econst "PSigma" (lcons (lvar liz) (lcons (lvar (lis liz)) lnil))) x) y)))))))))
  (ctor "PSigma" liz)).

PSigma_mk/decl : declared "PSigma.mk"
  (eforall (esort (lvar liz))
    ([x] (eforall (eforall x ([y] (esort (lvar (lis liz))))) ([y] (eforall x ([z] (eforall (eapp y z) ([w] (eapp (eapp (econst "PSigma" (lcons (lvar liz) (lcons (lvar (lis liz)) lnil))) x) y)))))))))
  (ctor "PSigma" liz)
   = declared/ok-ctor PSigma_mk/name PSigma/name PSigma_mk/cmem PSigma/eisl PSigma_mk/fuo (dkind-ok/ctor PSigma_mk/type-wf PSigma_mk/positivity).

