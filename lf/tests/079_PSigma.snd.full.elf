%%   type:   (eforall (esort (lvar (lis liz))) ([x] (eforall (eforall x ([y] (esort (lvar (lis (lis liz)))))) ([y] (eforall (eforall (eapp (eapp (econst "PSigma" (lcons (lvar (lis liz)) (lcons (lvar (lis (lis liz))) lnil))) x) y) ([z] (esort (lvar liz)))) ([z] (eforall (eforall x ([w] (eforall (eapp y w) ([x1] (eapp z (eapp (eapp (eapp (eapp (econst "PSigma.mk" (lcons (lvar (lis liz)) (lcons (lvar (lis (lis liz))) lnil))) x) y) w) x1)))))) ([w] (eforall (eapp (eapp (econst "PSigma" (lcons (lvar (lis liz)) (lcons (lvar (lis (lis liz))) lnil))) x) y) ([x1] (eapp z x1)))))))))))
%%   rules:
%%     PSigma.rec … PSigma.mk … = (elam (esort (lvar (lis liz))) ([x] (elam (eforall x ([y] (esort (lvar (lis (lis liz)))))) ([y] (elam (eforall (eapp (eapp (econst "PSigma" (lcons (lvar (lis liz)) (lcons (lvar (lis (lis liz))) lnil))) x) y) ([z] (esort (lvar liz)))) ([z] (elam (eforall x ([w] (eforall (eapp y w) ([x1] (eapp z (eapp (eapp (eapp (eapp (econst "PSigma.mk" (lcons (lvar (lis liz)) (lcons (lvar (lis (lis liz))) lnil))) x) y) w) x1)))))) ([w] (elam x ([x1] (elam (eapp y x1) ([y1] (eapp (eapp w x1) y1)))))))))))))   (2 fields)

%% def PSigma.fst
PSigma_fst/type-wf-sort : lvl
   = (limax
       (lsucc (lvar liz))
       (limax
         (limax (lvar liz) (lsucc (lvar (lis liz))))
         (limax
           (lmax (lmax (lsucc lzero) (lvar liz)) (lvar (lis liz)))
           (lvar liz)))).

