%%% Expected outcome: reject
%%% Two definitions with the same name
%% def dup_defs
dup_defs/type-wf : of (esort (lsucc lzero)) (esort (lsucc (lsucc lzero)))
   = defeq/sort-refl.

dup_defs/value-typed : of (esort lzero) (esort (lsucc lzero))
   = defeq/sort-refl.

dup_defs/name : name "dup_defs" (is-decl (esort (lsucc lzero)) (defn (esort lzero))).

dup_defs/decl : declared "dup_defs" (esort (lsucc lzero)) (defn (esort lzero))
   = declared/ok dup_defs/name dkind-non-inductive/defn (dkind-ok/defn dup_defs/type-wf dup_defs/value-typed).

