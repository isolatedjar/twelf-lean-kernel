%%% Expected outcome: reject
%%% Two definitions with the same name
%% def dup_defs
dup_defs/type-wf-sort : lvl
   = (lsucc (lsucc lzero)).

dup_defs/type-wf : defeq (esort (lsucc lzero)) (esort (lsucc lzero)) (esort dup_defs/type-wf-sort)
   = defeq/sort-refl.

dup_defs/value-typed : defeq (esort lzero) (esort lzero) (esort (lsucc lzero))
   = defeq/sort-refl.

dup_defs/name : name "dup_defs" (is-decl (esort (lsucc lzero)) (defn (esort lzero))).

dup_defs/decl : declared "dup_defs" (esort (lsucc lzero)) (defn (esort lzero))
   = declared/ok dup_defs/name (dkind-ok/defn dup_defs/type-wf dup_defs/value-typed).

%% def dup_defs
dup_defs/type-wf-sort : lvl
   = (lsucc (lsucc lzero)).

dup_defs/type-wf : defeq (esort (lsucc lzero)) (esort (lsucc lzero)) (esort dup_defs/type-wf-sort)
   = defeq/sort-refl.

dup_defs/value-typed : defeq (esort lzero) (esort lzero) (esort (lsucc lzero))
   = defeq/sort-refl.

dup_defs/name : name "dup_defs" (is-decl (esort (lsucc lzero)) (defn (esort lzero))).

dup_defs/decl : declared "dup_defs" (esort (lsucc lzero)) (defn (esort lzero))
