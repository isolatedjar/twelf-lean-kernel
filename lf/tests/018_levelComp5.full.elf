%%% Expected outcome: accept
%%% Some level computation
%% def levelComp5
levelComp5/type-wf-sort : lvl
   = (lsucc (lsucc (lvar liz))).

levelComp5/type-wf : of (esort (lsucc (lvar liz))) (esort levelComp5/type-wf-sort)
   = defeq/sort-refl.

levelComp5/value-typed : of (esort (lvar liz)) (esort (lsucc (lvar liz)))
   = defeq/sort-refl.

levelComp5/name : name "levelComp5" (is-decl (esort (lsucc (lvar liz))) (defn (esort (lvar liz)))).

levelComp5/decl : declared "levelComp5" (esort (lsucc (lvar liz))) (defn (esort (lvar liz)))
   = declared/ok levelComp5/name dkind-non-inductive/defn (dkind-ok/defn levelComp5/type-wf levelComp5/value-typed).
