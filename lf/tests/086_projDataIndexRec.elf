projDataIndexRec/decl : {u_1 : lvl} declared "projDataIndexRec" (lcons u_1 lnil)
   (eforall (econst "N" lnil) ([x] (eforall (eforall (eapp (econst "ProjDataIndex" lnil) x) ([y] (esort u_1))) ([y] (eforall (eforall (econst "True" lnil) ([z] (eapp y (eapp (eapp (econst "ProjDataIndex.mk" lnil) x) z)))) ([z] (eforall (eapp (econst "ProjDataIndex" lnil) x) ([w] (eapp y w)))))))))
   (defn (econst "ProjDataIndex.rec" (lcons u_1 lnil)))
   (dkind-ok/defn (projDataIndexRec/type-wf u_1) (projDataIndexRec/value-typed u_1)).

%mode declared +N +LS -T -DK -W.
%worlds () (declared _ _ _ _ _).
%unique declared +N +LS -1T -1DK *W.
