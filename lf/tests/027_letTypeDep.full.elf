%%% Expected outcome: accept
%%% Type checking a dependent let
%% axiom aDepProp
aDepProp/type-wf : of (eforall (esort (lsucc lzero)) ([x] (esort lzero))) (esort (limax (lsucc (lsucc lzero)) (lsucc lzero)))
   = (defeq/forall defeq/sort-refl ([x] ([h] defeq/sort-refl))).

aDepProp/name : name "aDepProp" (is-decl (eforall (esort (lsucc lzero)) ([x] (esort lzero))) ax).

aDepProp/decl : declared "aDepProp" (eforall (esort (lsucc lzero)) ([x] (esort lzero))) ax
   = declared/ok aDepProp/name dkind-non-inductive/ax (dkind-ok/ax aDepProp/type-wf).

%% axiom mkADepProp
mkADepProp/type-wf : of (eforall (esort (lsucc lzero)) ([x] (eapp (econst "aDepProp" lnil) x))) (esort (limax (lsucc (lsucc lzero)) lzero))
   = (defeq/forall
       defeq/sort-refl
       ([x]
         ([h]
           (defeq/app
             (defeq/const
               aDepProp/decl
               (inst-expr/forall
                 (inst-expr/sort (inst-lvl/succ inst-lvl/zero))
                 ([x] ([h] (inst-expr/sort inst-lvl/zero)))))
             h)))).

mkADepProp/name : name "mkADepProp" (is-decl (eforall (esort (lsucc lzero)) ([x] (eapp (econst "aDepProp" lnil) x))) ax).

mkADepProp/decl : declared "mkADepProp" (eforall (esort (lsucc lzero)) ([x] (eapp (econst "aDepProp" lnil) x))) ax
   = declared/ok mkADepProp/name dkind-non-inductive/ax (dkind-ok/ax mkADepProp/type-wf).

%% def letTypeDep
letTypeDep/type-wf : of (eapp (econst "aDepProp" lnil) (esort lzero)) (esort lzero)
   = (defeq/app
       (defeq/const
         aDepProp/decl
         (inst-expr/forall
           (inst-expr/sort (inst-lvl/succ inst-lvl/zero))
           ([x] ([h] (inst-expr/sort inst-lvl/zero)))))
       defeq/sort-refl).

letTypeDep/value-typed : of (eapp (elam (esort (lsucc lzero)) ([x] (eapp (econst "mkADepProp" lnil) x))) (esort lzero)) (eapp (econst "aDepProp" lnil) (esort lzero))
   = (defeq/app
       (defeq/lam
         defeq/sort-refl
         ([x]
           ([h]
             (defeq/app
               (defeq/const
                 mkADepProp/decl
                 (inst-expr/forall
                   (inst-expr/sort (inst-lvl/succ inst-lvl/zero))
                   ([x]
                     ([h] (inst-expr/app (inst-expr/const inst-lvls/nil) h)))))
               h))))
       defeq/sort-refl).

letTypeDep/name : name "letTypeDep" (is-decl (eapp (econst "aDepProp" lnil) (esort lzero)) (defn (eapp (elam (esort (lsucc lzero)) ([x] (eapp (econst "mkADepProp" lnil) x))) (esort lzero)))).

letTypeDep/decl : declared "letTypeDep" (eapp (econst "aDepProp" lnil) (esort lzero)) (defn (eapp (elam (esort (lsucc lzero)) ([x] (eapp (econst "mkADepProp" lnil) x))) (esort lzero)))
   = declared/ok letTypeDep/name dkind-non-inductive/defn (dkind-ok/defn letTypeDep/type-wf letTypeDep/value-typed).
