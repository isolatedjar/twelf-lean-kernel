%%% Expected outcome: accept
%%% Type checking a dependent let
%% axiom aDepProp
aDepProp/type-wf-sort : lvl
   = (limax (lsucc (lsucc lzero)) (lsucc lzero)).

aDepProp/type-wf : defeq (eforall (esort (lsucc lzero)) ([x] (esort lzero))) (eforall (esort (lsucc lzero)) ([x] (esort lzero))) (esort aDepProp/type-wf-sort)
   = (defeq/forall defeq/sort-refl ([x] ([h] defeq/sort-refl))).

aDepProp/name : name "aDepProp" (is-decl (eforall (esort (lsucc lzero)) ([x] (esort lzero))) ax).

aDepProp/decl : declared "aDepProp" (eforall (esort (lsucc lzero)) ([x] (esort lzero))) ax
   = declared/ok aDepProp/name (dkind-ok/ax aDepProp/type-wf).

%% axiom mkADepProp
mkADepProp/type-wf-sort : lvl
   = (limax (lsucc (lsucc lzero)) lzero).

mkADepProp/type-wf : defeq (eforall (esort (lsucc lzero)) ([x] (eapp (econst "aDepProp" lnil) x))) (eforall (esort (lsucc lzero)) ([x] (eapp (econst "aDepProp" lnil) x))) (esort mkADepProp/type-wf-sort)
   = (defeq/forall defeq/sort-refl ([x] ([h] (defeq/app (defeq/const aDepProp/decl (inst-expr/forall (inst-expr/sort (lvl-inst/succ lvl-inst/zero)) ([x] ([h] (inst-expr/sort lvl-inst/zero))))) h)))).

mkADepProp/name : name "mkADepProp" (is-decl (eforall (esort (lsucc lzero)) ([x] (eapp (econst "aDepProp" lnil) x))) ax).

mkADepProp/decl : declared "mkADepProp" (eforall (esort (lsucc lzero)) ([x] (eapp (econst "aDepProp" lnil) x))) ax
   = declared/ok mkADepProp/name (dkind-ok/ax mkADepProp/type-wf).

%% def letTypeDep
letTypeDep/type-wf-sort : lvl
   = lzero.

letTypeDep/type-wf : defeq (eapp (econst "aDepProp" lnil) (esort lzero)) (eapp (econst "aDepProp" lnil) (esort lzero)) (esort letTypeDep/type-wf-sort)
   = (defeq/app (defeq/const aDepProp/decl (inst-expr/forall (inst-expr/sort (lvl-inst/succ lvl-inst/zero)) ([x] ([h] (inst-expr/sort lvl-inst/zero))))) defeq/sort-refl).

letTypeDep/value-typed : defeq (eapp (elam (esort (lsucc lzero)) ([x] (eapp (econst "mkADepProp" lnil) x))) (esort lzero)) (eapp (elam (esort (lsucc lzero)) ([x] (eapp (econst "mkADepProp" lnil) x))) (esort lzero)) (eapp (econst "aDepProp" lnil) (esort lzero))
   = (defeq/app (defeq/lam defeq/sort-refl ([x] ([h] (defeq/app (defeq/const mkADepProp/decl (inst-expr/forall (inst-expr/sort (lvl-inst/succ lvl-inst/zero)) ([x] ([h] (inst-expr/app (inst-expr/const lvls-inst/nil) h))))) h)))) defeq/sort-refl).

letTypeDep/name : name "letTypeDep" (is-decl (eapp (econst "aDepProp" lnil) (esort lzero)) (defn (eapp (elam (esort (lsucc lzero)) ([x] (eapp (econst "mkADepProp" lnil) x))) (esort lzero)))).

letTypeDep/decl : declared "letTypeDep" (eapp (econst "aDepProp" lnil) (esort lzero)) (defn (eapp (elam (esort (lsucc lzero)) ([x] (eapp (econst "mkADepProp" lnil) x))) (esort lzero)))
   = declared/ok letTypeDep/name (dkind-ok/defn letTypeDep/type-wf letTypeDep/value-typed).

