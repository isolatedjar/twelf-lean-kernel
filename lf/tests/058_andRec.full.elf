%%% Expected outcome: accept
%%% Asserting the type of the generated recursor
%% inductive And
And/type-wf-sort : lvl
   = (limax (lsucc lzero) (limax (lsucc lzero) (lsucc lzero))).

And/type-wf : of (eforall (esort lzero) ([x] (eforall (esort lzero) ([y] (esort lzero))))) (esort And/type-wf-sort)
   = (defeq/forall
       defeq/sort-refl
       ([x] ([h] (defeq/forall defeq/sort-refl ([y] ([h1] defeq/sort-refl)))))).

And/ends-in-sort : ends-in-sort (eforall (esort lzero) ([x] (eforall (esort lzero) ([y] (esort lzero)))))
   = (ends-in-sort/forall ([x] (ends-in-sort/forall ([y] ends-in-sort/sort)))).

And/rec-name : name "And.rec" (is-rec-for "And").

And/name : name "And" (is-decl (eforall (esort lzero) ([x] (eforall (esort lzero) ([y] (esort lzero))))) indt).

And/decl : declared "And" (eforall (esort lzero) ([x] (eforall (esort lzero) ([y] (esort lzero))))) indt
   = declared/ok And/name (dkind-ok/indt And/type-wf And/ends-in-sort).

%% ctor And.intro (of And)
And_intro/type-wf-sort : lvl
   = (limax
       (lsucc lzero)
       (limax (lsucc lzero) (limax lzero (limax lzero lzero)))).

And_intro/type-wf : of (eforall (esort lzero) ([x] (eforall (esort lzero) ([y] (eforall x ([z] (eforall y ([w] (eapp (eapp (econst "And" lnil) x) y))))))))) (esort And_intro/type-wf-sort)
   = (defeq/forall
       defeq/sort-refl
       ([x]
         ([h]
           (defeq/forall
             defeq/sort-refl
             ([y]
               ([h1]
                 (defeq/forall
                   h
                   ([z]
                     ([h2]
                       (defeq/forall
                         h1
                         ([w]
                           ([h3]
                             (defeq/app
                               (defeq/app
                                 (defeq/const
                                   And/decl
                                   (inst-expr/forall
                                     (inst-expr/sort lvl-inst/zero)
                                     ([x]
                                       ([h]
                                         (inst-expr/forall
                                           (inst-expr/sort lvl-inst/zero)
                                           ([y]
                                             ([h1]
                                               (inst-expr/sort
                                                 lvl-inst/zero))))))))
                                 h)
                               h1))))))))))))).

And_intro/positivity : ctor-positive "And" lnil (eforall (esort lzero) ([x] (eforall (esort lzero) ([y] (eforall x ([z] (eforall y ([w] (eapp (eapp (econst "And" lnil) x) y)))))))))
   = (ctor-positive/intro ([S] (eforall (esort lzero) ([x] (eforall (esort lzero) ([y] (eforall x ([z] (eforall y ([w] (eapp (eapp S x) y)))))))))) (ctor-spine/arg
       (strict-pos/no-occur (esort lzero) no-self-ref/sort)
       ([x]
         ([y]
           (ctor-spine/arg
             (strict-pos/no-occur (esort lzero) no-self-ref/sort)
             ([z]
               ([w]
                 (ctor-spine/arg
                   (strict-pos/no-occur x y)
                   ([x1]
                     ([y1]
                       (ctor-spine/arg
                         (strict-pos/no-occur z w)
                         ([z1]
                           ([w1]
                             (ctor-spine/result
                               (applies-self/app
                                 (applies-self/app
                                   applies-self/refl)))))))))))))))).

And_intro/name : name "And.intro" (is-decl (eforall (esort lzero) ([x] (eforall (esort lzero) ([y] (eforall x ([z] (eforall y ([w] (eapp (eapp (econst "And" lnil) x) y))))))))) ctor).

And_intro/decl : declared "And.intro" (eforall (esort lzero) ([x] (eforall (esort lzero) ([y] (eforall x ([z] (eforall y ([w] (eapp (eapp (econst "And" lnil) x) y))))))))) ctor
   = declared/ok And_intro/name (dkind-ok/ctor And_intro/type-wf And_intro/positivity).

%% recursor And.rec
And_rec/type-wf-sort : lvl
   = (limax
       (lsucc lzero)
       (limax
         (lsucc lzero)
         (limax
           (limax lzero (lsucc (lvar liz)))
           (limax
             (limax lzero (limax lzero (lvar liz)))
             (limax lzero (lvar liz)))))).

