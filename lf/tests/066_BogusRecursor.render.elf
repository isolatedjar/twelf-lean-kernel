%%% Render-only view of: 066_BogusRecursor
%%% A kernel must validate the recursors it is handed. If we write
%%% 
%%% ```
%%% inductive BogusRecursor : Type where
%%%   | mk : BogusRecursor
%%% ```
%%% 
%%% then the recursor `BogusRecursor.rec` will be correctly derived with type
%%% `{motive : BogusRecursor → Sort u} → motive .mk → (t : BogusRecursor) → motive t`.
%%% 
%%% This test claims the recursor for `BogusRecursor` should be a trivial constant
%%% of type `Prop`. A correct kernel notices the discrepancy and rejects.
%% inductive BogusRecursor
%%% HOLE
BogusRecursor/type-wf-sort : lvl.

%%% HOLE
BogusRecursor/type-wf : defeq (esort (lsucc lzero)) (esort (lsucc lzero)) (esort BogusRecursor/type-wf-sort).

%%% HOLE
BogusRecursor/ends-in-sort : ends-in-sort (esort (lsucc lzero)).

BogusRecursor/rec-name : name "BogusRecursor.rec" (is-rec-for "BogusRecursor").

BogusRecursor/name : name "BogusRecursor" (is-decl (esort (lsucc lzero)) indt).

BogusRecursor/decl : declared "BogusRecursor" (esort (lsucc lzero)) indt
   = declared/ok BogusRecursor/name (dkind-ok/indt BogusRecursor/type-wf BogusRecursor/ends-in-sort).

%% ctor BogusRecursor.mk (of BogusRecursor)
%%% HOLE
BogusRecursor_mk/type-wf-sort : lvl.

%%% HOLE
BogusRecursor_mk/type-wf : defeq (econst "BogusRecursor" lnil) (econst "BogusRecursor" lnil) (esort BogusRecursor_mk/type-wf-sort).

%%% HOLE
BogusRecursor_mk/positivity : ctor-positive "BogusRecursor" lnil (econst "BogusRecursor" lnil).

BogusRecursor_mk/name : name "BogusRecursor.mk" (is-decl (econst "BogusRecursor" lnil) ctor).

BogusRecursor_mk/decl : declared "BogusRecursor.mk" (econst "BogusRecursor" lnil) ctor
   = declared/ok BogusRecursor_mk/name (dkind-ok/ctor BogusRecursor_mk/type-wf BogusRecursor_mk/positivity).

%% recursor BogusRecursor.rec
%%% HOLE
BogusRecursor_rec/type-wf-sort : lvl.

%%% HOLE
BogusRecursor_rec/type-wf : defeq (esort lzero) (esort lzero) (esort BogusRecursor_rec/type-wf-sort).

BogusRecursor_rec/decl : declared "BogusRecursor.rec" (esort lzero) irec
   = declared/ok-irec BogusRecursor/rec-name (dkind-ok/irec BogusRecursor_rec/type-wf).
