%%% Expected outcome: accept
%%% Some level computation
%% def levelComp4
%%% HOLE
levelComp4/type-wf : {u : lvl} defeq (esort (lsucc lzero)) (esort (lsucc lzero)) (esort lzero).

%%% HOLE
levelComp4/value-typed : {u : lvl} defeq (esort lzero) (esort lzero) (esort (lsucc lzero)).

levelComp4/decl : {u : lvl} declared "levelComp4" (lcons u lnil)
   (esort (lsucc lzero))
   (defn (esort lzero))
   (dkind-ok/defn (levelComp4/type-wf u) (levelComp4/value-typed u)).

