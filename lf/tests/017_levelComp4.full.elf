%%% Expected outcome: accept
%%% Some level computation
%% def levelComp4
levelComp4/type-wf-sort : lvl
   = (lsucc (lsucc lzero)).

levelComp4/type-wf : defeq (esort (lsucc lzero)) (esort (lsucc lzero)) (esort levelComp4/type-wf-sort)
   = defeq/sort-refl.

levelComp4/value-typed : defeq (esort lzero) (esort lzero) (esort (lsucc lzero))
   = defeq/sort-refl.

levelComp4/name : name "levelComp4" (is-decl (esort (lsucc lzero)) (defn (esort lzero))).

levelComp4/decl : declared "levelComp4" (esort (lsucc lzero)) (defn (esort lzero))
   = declared/ok levelComp4/name (dkind-ok/defn levelComp4/type-wf levelComp4/value-typed).

