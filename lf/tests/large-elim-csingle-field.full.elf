%%% Expected outcome: reject
%%% Large elimination of a single-constructor `Prop` that carries a DATA field.
%%% 
%%% `inductive Box : Prop | mk (a : Bool)` is a valid Lean inductive (Prop
%%% impredicativity admits the `Bool` field), but Box is NOT a subsingleton, so
%%% Lean forbids large elimination of it.  We inject (bypassing the kernel) a
%%% large-elim `Box.rec.{u}` and a use `extract : Box → Bool := Box.rec (fun _ =>
%%% Bool) (fun a => a)`.
%%% 
%%% A sound checker must reject (the recursor is not the canonical one Lean would
%%% regenerate; large-elim of a non-subsingleton Prop is illegal).  This targets
%%% the Twelf kernel's `le-eligible/csingle`, which admits large elimination of
%%% ANY single-ctor inductive regardless of field structure.
sneq/0 : string-neq "Bool.false" "Bool.true".
sneq/1 : string-neq "Bool" "Box".

%% inductive Bool
Bool/type-wf : of (esort (lsucc lzero)) (esort (lsucc (lsucc lzero)))
   = defeq/sort-refl.

Bool/ends-in-sort : ends-in-sort (esort (lsucc lzero))
   = ends-in-sort/sort.

Bool/rec-name : name "Bool.rec" (is-rec-for "Bool").

Bool/eisl : ends-in-sort-with-level (esort (lsucc lzero)) (lsucc lzero)
   = ends-in-sort-with-level/sort.

Bool/cnd : cnames-distinct (ccons "Bool.false" (ccons "Bool.true" cnil))
   = (cnames-distinct/cons
       (cnames-distinct/cons cnames-distinct/nil all-string-neq/nil)
       (all-string-neq/cons sneq/0 all-string-neq/nil)).

Bool/name : name "Bool" (is-decl (esort (lsucc lzero)) (indt (ccons "Bool.false" (ccons "Bool.true" cnil)) z)).

Bool/decl : declared "Bool" (esort (lsucc lzero)) (indt (ccons "Bool.false" (ccons "Bool.true" cnil)) z)
   = declared/ok-indt Bool/name Bool/rec-name Bool/cnd (dkind-ok/indt Bool/type-wf Bool/ends-in-sort).

%% ctor Bool.false (of Bool)
Bool_false/type-wf : of (econst "Bool" lnil) (esort (lsucc lzero))
   = (defeq/const Bool/decl (inst-expr/sort (inst-lvl/succ inst-lvl/zero))).

Bool_false/positivity : ctor-positive "Bool" lnil (econst "Bool" lnil)
   = (ctor-positive/intro ([S] S) (ctor-spine/result applies-self/refl)).

Bool_false/cmem : cmem "Bool.false" (ccons "Bool.false" (ccons "Bool.true" cnil))
   = cmem/here.

Bool_false/fuo : field-universes-ok (econst "Bool" lnil) (lsucc lzero)
   = (field-universes-ok/done not-forall/const).

Bool_false/name : name "Bool.false" (is-decl (econst "Bool" lnil) (ctor "Bool" z)).

Bool_false/decl : declared "Bool.false" (econst "Bool" lnil) (ctor "Bool" z)
   = declared/ok-ctor Bool_false/name Bool/name Bool_false/cmem Bool/eisl Bool_false/fuo (dkind-ok/ctor Bool_false/type-wf Bool_false/positivity).

%% ctor Bool.true (of Bool)
Bool_true/type-wf : of (econst "Bool" lnil) (esort (lsucc lzero))
   = (defeq/const Bool/decl (inst-expr/sort (inst-lvl/succ inst-lvl/zero))).

Bool_true/positivity : ctor-positive "Bool" lnil (econst "Bool" lnil)
   = (ctor-positive/intro ([S] S) (ctor-spine/result applies-self/refl)).

Bool_true/cmem : cmem "Bool.true" (ccons "Bool.false" (ccons "Bool.true" cnil))
   = (cmem/there cmem/here).

Bool_true/fuo : field-universes-ok (econst "Bool" lnil) (lsucc lzero)
   = (field-universes-ok/done not-forall/const).

Bool_true/name : name "Bool.true" (is-decl (econst "Bool" lnil) (ctor "Bool" (s z))).

Bool_true/decl : declared "Bool.true" (econst "Bool" lnil) (ctor "Bool" (s z))
   = declared/ok-ctor Bool_true/name Bool/name Bool_true/cmem Bool/eisl Bool_true/fuo (dkind-ok/ctor Bool_true/type-wf Bool_true/positivity).

%% recursor Bool.rec (TCB-derived; informational only)
%%   level params: u
%%   type:   (eforall (eforall (econst "Bool" lnil) ([x] (esort (lvar z)))) ([x] (eforall (eapp x (econst "Bool.false" lnil)) ([y] (eforall (eapp x (econst "Bool.true" lnil)) ([w] (eforall (econst "Bool" lnil) ([v] (eapp x v)))))))))
%%   rules:
%%     Bool.rec … Bool.false … = (elam (eforall (econst "Bool" lnil) ([x] (esort (lvar z)))) ([x] (elam (eapp x (econst "Bool.false" lnil)) ([y] (elam (eapp x (econst "Bool.true" lnil)) ([w] y))))))   (0 fields)
%%     Bool.rec … Bool.true … = (elam (eforall (econst "Bool" lnil) ([x] (esort (lvar z)))) ([x] (elam (eapp x (econst "Bool.false" lnil)) ([y] (elam (eapp x (econst "Bool.true" lnil)) ([w] w))))))   (0 fields)

%% inductive Box
Box/type-wf : of (esort lzero) (esort (lsucc lzero))
   = defeq/sort-refl.

Box/ends-in-sort : ends-in-sort (esort lzero)
   = ends-in-sort/sort.

Box/rec-name : name "Box.rec" (is-rec-for "Box").

Box/eisl : ends-in-sort-with-level (esort lzero) lzero
   = ends-in-sort-with-level/sort.

Box/cnd : cnames-distinct (ccons "Box.mk" cnil)
   = (cnames-distinct/cons cnames-distinct/nil all-string-neq/nil).

Box/name : name "Box" (is-decl (esort lzero) (indt (ccons "Box.mk" cnil) z)).

Box/decl : declared "Box" (esort lzero) (indt (ccons "Box.mk" cnil) z)
   = declared/ok-indt Box/name Box/rec-name Box/cnd (dkind-ok/indt Box/type-wf Box/ends-in-sort).

%% ctor Box.mk (of Box)
Box_mk/type-wf : of (eforall (econst "Bool" lnil) ([x] (econst "Box" lnil))) (esort (limax (lsucc lzero) lzero))
   = (defeq/forall
       (defeq/const Bool/decl (inst-expr/sort (inst-lvl/succ inst-lvl/zero)))
       ([x] ([h] (defeq/const Box/decl (inst-expr/sort inst-lvl/zero))))).

Box_mk/positivity : ctor-positive "Box" lnil (eforall (econst "Bool" lnil) ([x] (econst "Box" lnil)))
   = (ctor-positive/intro ([S] (eforall (econst "Bool" lnil) ([x] S))) (ctor-spine/arg
       (strict-pos/no-occur (econst "Bool" lnil) (no-self-ref/const sneq/1))
       ([x] ([y] (ctor-spine/result applies-self/refl))))).

Box_mk/cmem : cmem "Box.mk" (ccons "Box.mk" cnil)
   = cmem/here.

Box_mk/fuo : field-universes-ok (eforall (econst "Bool" lnil) ([x] (econst "Box" lnil))) lzero
   = (field-universes-ok/forall
       (defeq/const Bool/decl (inst-expr/sort (inst-lvl/succ inst-lvl/zero)))
       (leq-lvl/imaxLz leq-lvl/self)
       ([x] ([h] (field-universes-ok/done not-forall/const)))).

Box_mk/name : name "Box.mk" (is-decl (eforall (econst "Bool" lnil) ([x] (econst "Box" lnil))) (ctor "Box" z)).

Box_mk/decl : declared "Box.mk" (eforall (econst "Bool" lnil) ([x] (econst "Box" lnil))) (ctor "Box" z)
   = declared/ok-ctor Box_mk/name Box/name Box_mk/cmem Box/eisl Box_mk/fuo (dkind-ok/ctor Box_mk/type-wf Box_mk/positivity).

%% recursor Box.rec (TCB-derived; informational only)
%%   level params: u
%%   type:   (eforall (eforall (econst "Box" lnil) ([x] (esort (lvar z)))) ([x] (eforall (eforall (econst "Bool" lnil) ([y] (eapp x (eapp (econst "Box.mk" lnil) y)))) ([y] (eforall (econst "Box" lnil) ([w] (eapp x w)))))))
%%   rules:
%%     Box.rec … Box.mk … = (elam (eforall (econst "Box" lnil) ([x] (esort (lvar z)))) ([x] (elam (eforall (econst "Bool" lnil) ([y] (eapp x (eapp (econst "Box.mk" lnil) y)))) ([y] (elam (econst "Bool" lnil) ([w] (eapp y w)))))))   (1 fields)

%% def extract
extract/type-wf : of (eforall (econst "Box" lnil) ([x] (econst "Bool" lnil))) (esort (limax lzero (lsucc lzero)))
   = (defeq/forall
       (defeq/const Box/decl (inst-expr/sort inst-lvl/zero))
       ([x]
         ([h]
           (defeq/const
             Bool/decl
             (inst-expr/sort (inst-lvl/succ inst-lvl/zero)))))).

extract/value-typed : of
  (eapp (eapp (econst "Box.rec" (lcons (lsucc lzero) lnil)) (elam (econst "Box" lnil) ([x] (econst "Bool" lnil)))) (elam (econst "Bool" lnil) ([x] x)))
  (eforall (econst "Box" lnil) ([x] (econst "Bool" lnil)))
   = (defeq/conv
       (defeq/forall
         (defeq/const Box/decl (inst-expr/sort inst-lvl/zero))
         ([x]
           ([h]
             (defeq/trans
               (defeq/beta
                 ([y]
                   ([h1]
                     (defeq/const
                       Bool/decl
                       (inst-expr/sort (inst-lvl/succ inst-lvl/zero)))))
                 h)
               (defeq/const
                 Bool/decl
                 (inst-expr/sort (inst-lvl/succ inst-lvl/zero)))))))
       (defeq/app
         (defeq/app
           (defeq/const
             (rec-derived-declared
               (rec-derived/enum
                 Box/decl
                 Box/rec-name
                 (enum-rec-type/intro
                   ([x]
                     ([h]
                       (enum-rec-body/minor-1f
                         (defeq/const
                           Bool/decl
                           (inst-expr/sort (inst-lvl/succ inst-lvl/zero)))
                         ([y] ([h1] enum-rec-body/done))))))
                 Box/eisl
                 le-eligible/csingle)
               Box/rec-name)
             (inst-expr/forall
               (inst-expr/forall
                 (inst-expr/const inst-lvls/nil)
                 ([x] ([h] (inst-expr/sort (inst-lvl/var nth-lvl/z)))))
               ([x]
                 ([h]
                   (inst-expr/forall
                     (inst-expr/forall
                       (inst-expr/const inst-lvls/nil)
                       ([y]
                         ([h1]
                           (inst-expr/app
                             h
                             (inst-expr/app
                               (inst-expr/const inst-lvls/nil)
                               h1)))))
                     ([y]
                       ([h1]
                         (inst-expr/forall
                           (inst-expr/const inst-lvls/nil)
                           ([w] ([h2] (inst-expr/app h h2)))))))))))
           (defeq/lam
             (defeq/const Box/decl (inst-expr/sort inst-lvl/zero))
             ([x]
               ([h]
                 (defeq/const
                   Bool/decl
                   (inst-expr/sort (inst-lvl/succ inst-lvl/zero)))))))
         (defeq/conv
           (defeq/forall
             (defeq/const
               Bool/decl
               (inst-expr/sort (inst-lvl/succ inst-lvl/zero)))
             ([x]
               ([h]
                 (defeq/trans
                   (defeq/const
                     Bool/decl
                     (inst-expr/sort (inst-lvl/succ inst-lvl/zero)))
                   (defeq/symm
                     (defeq/beta
                       ([y]
                         ([h1]
                           (defeq/const
                             Bool/decl
                             (inst-expr/sort (inst-lvl/succ inst-lvl/zero)))))
                       (defeq/app
                         (defeq/const
                           Box_mk/decl
                           (inst-expr/forall
                             (inst-expr/const inst-lvls/nil)
                             ([x] ([h] (inst-expr/const inst-lvls/nil)))))
                         h)))))))
           (defeq/lam
             (defeq/const
               Bool/decl
               (inst-expr/sort (inst-lvl/succ inst-lvl/zero)))
             ([x] ([h] h)))))).

extract/name : name "extract" (is-decl
  (eforall (econst "Box" lnil) ([x] (econst "Bool" lnil)))
  (defn (eapp (eapp (econst "Box.rec" (lcons (lsucc lzero) lnil)) (elam (econst "Box" lnil) ([x] (econst "Bool" lnil)))) (elam (econst "Bool" lnil) ([x] x))))).

extract/decl : declared "extract"
  (eforall (econst "Box" lnil) ([x] (econst "Bool" lnil)))
  (defn (eapp (eapp (econst "Box.rec" (lcons (lsucc lzero) lnil)) (elam (econst "Box" lnil) ([x] (econst "Bool" lnil)))) (elam (econst "Bool" lnil) ([x] x))))
   = declared/ok extract/name dkind-non-inductive/defn (dkind-ok/defn extract/type-wf extract/value-typed).
