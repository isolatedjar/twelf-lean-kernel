%%% Expected outcome: reject
%%% Proof of False via incorrect large elimination restriction.
%%% 
%%% If the check for whether a level is surely not zero is implemented wrong, in
%%% particular if it incorrectly returns true for params, we can create a
%%% universe-polymorphic
%%% ```
%%% inductive MyBool.{u} : Sort u | tt | ff
%%% ```
%%% where the recursor `MyBool.rec.{1,0}` can do large elimination of a `Prop`.
%%% Because of proof irrelevance we have `tt = ff`, so we can derive a
%%% contradiction.
%%% 
%%% Found by Anthony Wang using Aristotle.
sneq/0 : string-neq "MyBool.tt" "MyBool.ff".

%% inductive False
False/type-wf-sort : lvl
   = (lsucc lzero).

False/type-wf : of (esort lzero) (esort False/type-wf-sort)
   = defeq/sort-refl.

False/ends-in-sort : ends-in-sort (esort lzero)
   = ends-in-sort/sort.

False/rec-name : name "False.rec" (is-rec-for "False").

False/clf : count-leading-foralls (esort lzero) liz
   = (count-leading-foralls/zero not-forall/sort).

False/cnd : cnames-distinct cnil
   = cnames-distinct/nil.

False/name : name "False" (is-decl (esort lzero) (indt cnil liz)).

False/decl : declared "False" (esort lzero) (indt cnil liz)
   = declared/ok-indt False/name False/rec-name False/clf False/cnd (dkind-ok/indt False/type-wf False/ends-in-sort).

%% inductive True
True/type-wf-sort : lvl
   = (lsucc lzero).

True/type-wf : of (esort lzero) (esort True/type-wf-sort)
   = defeq/sort-refl.

True/ends-in-sort : ends-in-sort (esort lzero)
   = ends-in-sort/sort.

True/rec-name : name "True.rec" (is-rec-for "True").

True/clf : count-leading-foralls (esort lzero) liz
   = (count-leading-foralls/zero not-forall/sort).

True/cnd : cnames-distinct (ccons "True.intro" cnil)
   = (cnames-distinct/cons cnames-distinct/nil all-string-neq/nil).

True/name : name "True" (is-decl (esort lzero) (indt (ccons "True.intro" cnil) liz)).

True/decl : declared "True" (esort lzero) (indt (ccons "True.intro" cnil) liz)
   = declared/ok-indt True/name True/rec-name True/clf True/cnd (dkind-ok/indt True/type-wf True/ends-in-sort).

%% ctor True.intro (of True)
True_intro/type-wf-sort : lvl
   = lzero.

True_intro/type-wf : of (econst "True" lnil) (esort True_intro/type-wf-sort)
   = (defeq/const True/decl (inst-expr/sort lvl-inst/zero)).

True_intro/positivity : ctor-positive "True" lnil (econst "True" lnil)
   = (ctor-positive/intro ([S] S) (ctor-spine/result applies-self/refl)).

True_intro/eisl : ends-in-sort-with-level (esort lzero) lzero
   = ends-in-sort-with-level/sort.

True_intro/cmem : cmem "True.intro" (ccons "True.intro" cnil)
   = cmem/here.

%%% HOLE: True_intro/fuo — prover for field-universes-ok-skip-params not yet implemented
True_intro/fuo : field-universes-ok-skip-params liz (econst "True" lnil) lzero.

True_intro/name : name "True.intro" (is-decl (econst "True" lnil) (ctor "True" liz)).

True_intro/decl : declared "True.intro" (econst "True" lnil) (ctor "True" liz)
   = declared/ok-ctor True_intro/name True/name True_intro/cmem True_intro/eisl True_intro/fuo (dkind-ok/ctor True_intro/type-wf True_intro/positivity).

%% inductive MyBool
MyBool/type-wf-sort : lvl
   = (lsucc (lvar liz)).

MyBool/type-wf : of (esort (lvar liz)) (esort MyBool/type-wf-sort)
   = defeq/sort-refl.

MyBool/ends-in-sort : ends-in-sort (esort (lvar liz))
   = ends-in-sort/sort.

MyBool/rec-name : name "MyBool.rec" (is-rec-for "MyBool").

MyBool/clf : count-leading-foralls (esort (lvar liz)) liz
   = (count-leading-foralls/zero not-forall/sort).

MyBool/cnd : cnames-distinct (ccons "MyBool.tt" (ccons "MyBool.ff" cnil))
   = (cnames-distinct/cons
       (cnames-distinct/cons cnames-distinct/nil all-string-neq/nil)
       (all-string-neq/cons sneq/0 all-string-neq/nil)).

MyBool/name : name "MyBool" (is-decl (esort (lvar liz)) (indt (ccons "MyBool.tt" (ccons "MyBool.ff" cnil)) liz)).

MyBool/decl : declared "MyBool" (esort (lvar liz)) (indt (ccons "MyBool.tt" (ccons "MyBool.ff" cnil)) liz)
   = declared/ok-indt MyBool/name MyBool/rec-name MyBool/clf MyBool/cnd (dkind-ok/indt MyBool/type-wf MyBool/ends-in-sort).

%% ctor MyBool.tt (of MyBool)
MyBool_tt/type-wf-sort : lvl
   = (lvar liz).

MyBool_tt/type-wf : of (econst "MyBool" (lcons (lvar liz) lnil)) (esort MyBool_tt/type-wf-sort)
   = (defeq/const MyBool/decl (inst-expr/sort (lvl-inst/var lvl-nth/zero))).

MyBool_tt/positivity : ctor-positive "MyBool" (lcons (lvar liz) lnil) (econst "MyBool" (lcons (lvar liz) lnil))
   = (ctor-positive/intro ([S] S) (ctor-spine/result applies-self/refl)).

MyBool_tt/eisl : ends-in-sort-with-level (esort (lvar liz)) (lvar liz)
   = ends-in-sort-with-level/sort.

MyBool_tt/cmem : cmem "MyBool.tt" (ccons "MyBool.tt" (ccons "MyBool.ff" cnil))
   = cmem/here.

%%% HOLE: MyBool_tt/fuo — prover for field-universes-ok-skip-params not yet implemented
MyBool_tt/fuo : field-universes-ok-skip-params liz (econst "MyBool" (lcons (lvar liz) lnil)) (lvar liz).

MyBool_tt/name : name "MyBool.tt" (is-decl (econst "MyBool" (lcons (lvar liz) lnil)) (ctor "MyBool" liz)).

MyBool_tt/decl : declared "MyBool.tt" (econst "MyBool" (lcons (lvar liz) lnil)) (ctor "MyBool" liz)
   = declared/ok-ctor MyBool_tt/name MyBool/name MyBool_tt/cmem MyBool_tt/eisl MyBool_tt/fuo (dkind-ok/ctor MyBool_tt/type-wf MyBool_tt/positivity).

%% ctor MyBool.ff (of MyBool)
MyBool_ff/type-wf-sort : lvl
   = (lvar liz).

MyBool_ff/type-wf : of (econst "MyBool" (lcons (lvar liz) lnil)) (esort MyBool_ff/type-wf-sort)
   = (defeq/const MyBool/decl (inst-expr/sort (lvl-inst/var lvl-nth/zero))).

MyBool_ff/positivity : ctor-positive "MyBool" (lcons (lvar liz) lnil) (econst "MyBool" (lcons (lvar liz) lnil))
   = (ctor-positive/intro ([S] S) (ctor-spine/result applies-self/refl)).

MyBool_ff/eisl : ends-in-sort-with-level (esort (lvar liz)) (lvar liz)
   = ends-in-sort-with-level/sort.

MyBool_ff/cmem : cmem "MyBool.ff" (ccons "MyBool.tt" (ccons "MyBool.ff" cnil))
   = (cmem/there cmem/here).

%%% HOLE: MyBool_ff/fuo — prover for field-universes-ok-skip-params not yet implemented
MyBool_ff/fuo : field-universes-ok-skip-params liz (econst "MyBool" (lcons (lvar liz) lnil)) (lvar liz).

MyBool_ff/name : name "MyBool.ff" (is-decl (econst "MyBool" (lcons (lvar liz) lnil)) (ctor "MyBool" (lis liz))).

MyBool_ff/decl : declared "MyBool.ff" (econst "MyBool" (lcons (lvar liz) lnil)) (ctor "MyBool" (lis liz))
   = declared/ok-ctor MyBool_ff/name MyBool/name MyBool_ff/cmem MyBool_ff/eisl MyBool_ff/fuo (dkind-ok/ctor MyBool_ff/type-wf MyBool_ff/positivity).

%% def cast
cast/type-wf-sort : lvl
   = (limax (limax lzero (lsucc lzero)) (limax lzero lzero)).

cast/type-wf : of
  (eforall (eforall (econst "MyBool" (lcons lzero lnil)) ([x] (esort lzero))) ([x] (eforall (eapp x (econst "MyBool.tt" (lcons lzero lnil))) ([y] (eapp x (econst "MyBool.ff" (lcons lzero lnil)))))))
  (esort cast/type-wf-sort)
   = (defeq/forall
       (defeq/forall
         (defeq/const MyBool/decl (inst-expr/sort (lvl-inst/var lvl-nth/zero)))
         ([x] ([h] defeq/sort-refl)))
       ([x]
         ([h]
           (defeq/forall
             (defeq/app
               h
               (defeq/const
                 MyBool_tt/decl
                 (inst-expr/const
                   (lvls-inst/cons (lvl-inst/var lvl-nth/zero) lvls-inst/nil))))
             ([y]
               ([h1]
                 (defeq/app
                   h
                   (defeq/const
                     MyBool_ff/decl
                     (inst-expr/const
                       (lvls-inst/cons
                         (lvl-inst/var lvl-nth/zero)
                         lvls-inst/nil)))))))))).

%%% HOLE
cast/value-typed : of
  (elam (eforall (econst "MyBool" (lcons lzero lnil)) ([x] (esort lzero))) ([x] (elam (eapp x (econst "MyBool.tt" (lcons lzero lnil))) ([y] y))))
  (eforall (eforall (econst "MyBool" (lcons lzero lnil)) ([x] (esort lzero))) ([x] (eforall (eapp x (econst "MyBool.tt" (lcons lzero lnil))) ([y] (eapp x (econst "MyBool.ff" (lcons lzero lnil))))))).

cast/name : name "cast" (is-decl
  (eforall (eforall (econst "MyBool" (lcons lzero lnil)) ([x] (esort lzero))) ([x] (eforall (eapp x (econst "MyBool.tt" (lcons lzero lnil))) ([y] (eapp x (econst "MyBool.ff" (lcons lzero lnil)))))))
  (defn (elam (eforall (econst "MyBool" (lcons lzero lnil)) ([x] (esort lzero))) ([x] (elam (eapp x (econst "MyBool.tt" (lcons lzero lnil))) ([y] y)))))).

cast/decl : declared "cast"
  (eforall (eforall (econst "MyBool" (lcons lzero lnil)) ([x] (esort lzero))) ([x] (eforall (eapp x (econst "MyBool.tt" (lcons lzero lnil))) ([y] (eapp x (econst "MyBool.ff" (lcons lzero lnil)))))))
  (defn (elam (eforall (econst "MyBool" (lcons lzero lnil)) ([x] (esort lzero))) ([x] (elam (eapp x (econst "MyBool.tt" (lcons lzero lnil))) ([y] y)))))
   = declared/ok cast/name (dkind-ok/defn cast/type-wf cast/value-typed).

%% thm false_proof
false_proof/type-wf : of (econst "False" lnil) (esort lzero)
   = (defeq/const False/decl (inst-expr/sort lvl-inst/zero)).

%%% HOLE
false_proof/value-typed : of
  (eapp (eapp (econst "cast" lnil)
    (eapp (eapp (eapp (econst "MyBool.rec" (lcons (lsucc lzero) (lcons lzero lnil))) (elam (econst "MyBool" (lcons lzero lnil)) ([x] (esort lzero)))) (econst "True" lnil)) (econst "False" lnil)))
    (econst "True.intro" lnil))
  (econst "False" lnil).

false_proof/name : name "false_proof" (is-decl
  (econst "False" lnil)
  (thm (eapp (eapp (econst "cast" lnil) (eapp (eapp (eapp (econst "MyBool.rec" (lcons (lsucc lzero) (lcons lzero lnil))) (elam (econst "MyBool" (lcons lzero lnil)) ([x] (esort lzero)))) (econst "True" lnil)) (econst "False" lnil))) (econst "True.intro" lnil)))).

false_proof/decl : declared "false_proof"
  (econst "False" lnil)
  (thm (eapp (eapp (econst "cast" lnil) (eapp (eapp (eapp (econst "MyBool.rec" (lcons (lsucc lzero) (lcons lzero lnil))) (elam (econst "MyBool" (lcons lzero lnil)) ([x] (esort lzero)))) (econst "True" lnil)) (econst "False" lnil))) (econst "True.intro" lnil)))
   = declared/ok false_proof/name (dkind-ok/thm false_proof/type-wf false_proof/value-typed).
