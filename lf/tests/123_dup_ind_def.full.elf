dup_ind_def/name : name "dup_ind_def" (is-decl (esort (lsucc lzero)) (indt (ccons "dup_ind_def.mk" cnil) z)).

dup_ind_def/decl : declared "dup_ind_def" (esort (lsucc lzero)) (indt (ccons "dup_ind_def.mk" cnil) z)
   = declared/ok-indt dup_ind_def/name dup_ind_def/rec-name dup_ind_def/cnd (dkind-ok/indt dup_ind_def/type-wf dup_ind_def/ends-in-sort).

%% ctor dup_ind_def.mk (of dup_ind_def)
dup_ind_def_mk/type-wf : of (econst "dup_ind_def" lnil) (esort (lsucc lzero))
   = (defeq/const
       dup_ind_def/decl
       (inst-expr/sort (inst-lvl/succ inst-lvl/zero))).

dup_ind_def_mk/positivity : ctor-positive "dup_ind_def" lnil (econst "dup_ind_def" lnil)
   = (ctor-positive/intro ([S] S) (ctor-spine/result applies-self/refl)).

dup_ind_def_mk/cmem : cmem "dup_ind_def.mk" (ccons "dup_ind_def.mk" cnil)
   = cmem/here.

dup_ind_def_mk/fuo : field-universes-ok (econst "dup_ind_def" lnil) (lsucc lzero)
   = (field-universes-ok/done not-forall/const).

dup_ind_def_mk/name : name "dup_ind_def.mk" (is-decl (econst "dup_ind_def" lnil) (ctor "dup_ind_def" z)).

dup_ind_def_mk/decl : declared "dup_ind_def.mk" (econst "dup_ind_def" lnil) (ctor "dup_ind_def" z)
   = declared/ok-ctor dup_ind_def_mk/name dup_ind_def/name dup_ind_def_mk/cmem dup_ind_def/eisl dup_ind_def_mk/fuo (dkind-ok/ctor dup_ind_def_mk/type-wf dup_ind_def_mk/positivity).

