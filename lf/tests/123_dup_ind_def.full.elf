%%% A definition and a constructor with the same name
%% def dup_ind_def
dup_ind_def/type-wf : of (esort (lsucc lzero)) (esort (lsucc (lsucc lzero)))
   = defeq/sort-refl.

dup_ind_def/value-typed : of (esort lzero) (esort (lsucc lzero))
   = defeq/sort-refl.

dup_ind_def/name : name "dup_ind_def" (is-decl (esort (lsucc lzero)) (defn (esort lzero))).

dup_ind_def/decl : declared "dup_ind_def" (esort (lsucc lzero)) (defn (esort lzero))
   = declared/ok dup_ind_def/name dkind-non-inductive/defn (dkind-ok/defn dup_ind_def/type-wf dup_ind_def/value-typed).

%% inductive dup_ind_def
dup_ind_def/type-wf : of (esort (lsucc lzero)) (esort (lsucc (lsucc lzero)))
