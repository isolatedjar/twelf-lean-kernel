dup_ind_def/rec-name : name "dup_ind_def.rec" (is-rec-for "dup_ind_def").

dup_ind_def/eisl : ends-in-sort-with-level (esort (lsucc lzero)) (lsucc lzero)
   = ends-in-sort-with-level/sort.

dup_ind_def/cnd : cnames-distinct (ccons "dup_ind_def.mk" cnil)
