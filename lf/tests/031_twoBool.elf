%%% Expected outcome: accept
%%% A simple product type
%% inductive Bool
Bool/type-wf :
   defeq (esort (lsucc lzero)) (esort (lsucc lzero)) (esort (lsucc (lsucc lzero)))
   = (defeq/sort-refl-at (lsucc lzero)).

Bool/ends-in-sort :
   ends-in-sort (esort (lsucc lzero))
   = ends-in-sort/sort.

Bool/decl : declared "Bool" lnil
   (esort (lsucc lzero))
   indt
   (dkind-ok/indt Bool/type-wf Bool/ends-in-sort).

%% inductive ctor Bool.false
Bool_false/type-wf :
   defeq (econst "Bool" lnil) (econst "Bool" lnil) (esort (lsucc lzero))
   = (defeq/const Bool/decl).

Bool_false/positivity :
   ctor-positive "Bool" lnil (econst "Bool" lnil)
   = (ctor-positive/intro ([S] S) (ctor-spine/result applies-self/refl)).

Bool_false/decl : declared "Bool.false" lnil
   (econst "Bool" lnil)
   ctor
   (dkind-ok/ctor Bool_false/type-wf Bool_false/positivity).

%% inductive ctor Bool.true
Bool_true/type-wf :
   defeq (econst "Bool" lnil) (econst "Bool" lnil) (esort (lsucc lzero))
   = (defeq/const Bool/decl).

Bool_true/positivity :
   ctor-positive "Bool" lnil (econst "Bool" lnil)
   = (ctor-positive/intro ([S] S) (ctor-spine/result applies-self/refl)).

Bool_true/decl : declared "Bool.true" lnil
   (econst "Bool" lnil)
   ctor
   (dkind-ok/ctor Bool_true/type-wf Bool_true/positivity).

%% inductive recursor Bool.rec
Bool_rec/type-wf :
   {u : lvl} defeq (eforall (eforall (econst "Bool" lnil) ([x] (esort u))) ([x] (eforall (eapp x (econst "Bool.false" lnil)) ([y] (eforall (eapp x (econst "Bool.true" lnil)) ([z] (eforall (econst "Bool" lnil) ([w] (eapp x w))))))))) (eforall (eforall (econst "Bool" lnil) ([x] (esort u))) ([x] (eforall (eapp x (econst "Bool.false" lnil)) ([y] (eforall (eapp x (econst "Bool.true" lnil)) ([z] (eforall (econst "Bool" lnil) ([w] (eapp x w))))))))) (esort (limax (limax (lsucc lzero) (lsucc u)) (limax u (limax u (limax (lsucc lzero) u)))))
   = [u] (defeq/forall (defeq/forall (defeq/const Bool/decl) ([x] [y] (defeq/sort-refl-at u))) ([x] [y] (defeq/forall (defeq/app y (defeq/const Bool_false/decl)) ([z] [w] (defeq/forall (defeq/app y (defeq/const Bool_true/decl)) ([x1] [y1] (defeq/forall (defeq/const Bool/decl) ([z1] [w1] (defeq/app y w1))))))))).

Bool_rec/decl : {u : lvl} declared "Bool.rec" (lcons u lnil)
   (eforall (eforall (econst "Bool" lnil) ([x] (esort u))) ([x] (eforall (eapp x (econst "Bool.false" lnil)) ([y] (eforall (eapp x (econst "Bool.true" lnil)) ([z] (eforall (econst "Bool" lnil) ([w] (eapp x w)))))))))
   irec
   (dkind-ok/irec (Bool_rec/type-wf u)).

%% inductive TwoBool
TwoBool/type-wf :
   defeq (esort (lsucc lzero)) (esort (lsucc lzero)) (esort (lsucc (lsucc lzero)))
   = (defeq/sort-refl-at (lsucc lzero)).

TwoBool/ends-in-sort :
   ends-in-sort (esort (lsucc lzero))
   = ends-in-sort/sort.

TwoBool/decl : declared "TwoBool" lnil
   (esort (lsucc lzero))
   indt
   (dkind-ok/indt TwoBool/type-wf TwoBool/ends-in-sort).

%% inductive ctor TwoBool.mk
TwoBool_mk/type-wf :
   defeq (eforall (econst "Bool" lnil) ([x] (eforall (econst "Bool" lnil) ([y] (econst "TwoBool" lnil))))) (eforall (econst "Bool" lnil) ([x] (eforall (econst "Bool" lnil) ([y] (econst "TwoBool" lnil))))) (esort (limax (lsucc lzero) (limax (lsucc lzero) (lsucc lzero))))
   = (defeq/forall (defeq/const Bool/decl) ([x] [y] (defeq/forall (defeq/const Bool/decl) ([z] [w] (defeq/const TwoBool/decl))))).

TwoBool_mk/positivity :
   ctor-positive "TwoBool" lnil (eforall (econst "Bool" lnil) ([x] (eforall (econst "Bool" lnil) ([y] (econst "TwoBool" lnil)))))
   = (ctor-positive/intro ([S] (eforall (econst "Bool" lnil) ([x] (eforall (econst "Bool" lnil) ([y] S))))) (ctor-spine/arg (strict-pos/no-occur (econst "Bool" lnil)) ([_y0] (ctor-spine/arg (strict-pos/no-occur (econst "Bool" lnil)) ([_y1] (ctor-spine/result applies-self/refl)))))).

TwoBool_mk/decl : declared "TwoBool.mk" lnil
   (eforall (econst "Bool" lnil) ([x] (eforall (econst "Bool" lnil) ([y] (econst "TwoBool" lnil)))))
   ctor
   (dkind-ok/ctor TwoBool_mk/type-wf TwoBool_mk/positivity).

%% inductive recursor TwoBool.rec
TwoBool_rec/type-wf :
   {u : lvl} defeq (eforall (eforall (econst "TwoBool" lnil) ([x] (esort u))) ([x] (eforall (eforall (econst "Bool" lnil) ([y] (eforall (econst "Bool" lnil) ([z] (eapp x (eapp (eapp (econst "TwoBool.mk" lnil) y) z)))))) ([y] (eforall (econst "TwoBool" lnil) ([z] (eapp x z))))))) (eforall (eforall (econst "TwoBool" lnil) ([x] (esort u))) ([x] (eforall (eforall (econst "Bool" lnil) ([y] (eforall (econst "Bool" lnil) ([z] (eapp x (eapp (eapp (econst "TwoBool.mk" lnil) y) z)))))) ([y] (eforall (econst "TwoBool" lnil) ([z] (eapp x z))))))) (esort (limax (limax (lsucc lzero) (lsucc u)) (limax (limax (lsucc lzero) (limax (lsucc lzero) u)) (limax (lsucc lzero) u))))
   = [u] (defeq/forall (defeq/forall (defeq/const TwoBool/decl) ([x] [y] (defeq/sort-refl-at u))) ([x] [y] (defeq/forall (defeq/forall (defeq/const Bool/decl) ([z] [w] (defeq/forall (defeq/const Bool/decl) ([x1] [y1] (defeq/app y (defeq/app (defeq/app (defeq/const TwoBool_mk/decl) w) y1)))))) ([z] [w] (defeq/forall (defeq/const TwoBool/decl) ([x1] [y1] (defeq/app y y1))))))).

TwoBool_rec/decl : {u : lvl} declared "TwoBool.rec" (lcons u lnil)
   (eforall (eforall (econst "TwoBool" lnil) ([x] (esort u))) ([x] (eforall (eforall (econst "Bool" lnil) ([y] (eforall (econst "Bool" lnil) ([z] (eapp x (eapp (eapp (econst "TwoBool.mk" lnil) y) z)))))) ([y] (eforall (econst "TwoBool" lnil) ([z] (eapp x z)))))))
   irec
   (dkind-ok/irec (TwoBool_rec/type-wf u)).

%% def twoBool
twoBool/type-wf :
   defeq (esort (lsucc lzero)) (esort (lsucc lzero)) (esort (lsucc (lsucc lzero)))
   = (defeq/sort-refl-at (lsucc lzero)).

twoBool/value-typed :
   defeq (econst "TwoBool" lnil) (econst "TwoBool" lnil) (esort (lsucc lzero))
   = (defeq/const TwoBool/decl).

twoBool/decl : declared "twoBool" lnil
   (esort (lsucc lzero))
   (defn (econst "TwoBool" lnil))
   (dkind-ok/defn twoBool/type-wf twoBool/value-typed).

%mode declared +N +LS -T -DK -W.
%worlds () (declared _ _ _ _ _).
%unique declared +N +LS -1T -1DK *W.
