%%% Expected outcome: accept
%%% Asserting the type of the generated recursor
%% inductive N
%%% HOLE
N/type-wf : defeq (esort (lsucc lzero)) (esort (lsucc lzero)) (esort lzero).

%%% HOLE
N/ends-in-sort : ends-in-sort (esort (lsucc lzero)).

N/decl : declared "N" lnil
   (esort (lsucc lzero))
   indt
   (dkind-ok/indt N/type-wf N/ends-in-sort).

%% ctor N.zero (of N)
%%% HOLE
N_zero/type-wf : defeq (econst "N" lnil) (econst "N" lnil) (esort lzero).

%%% HOLE
N_zero/positivity : ctor-positive "N" lnil (econst "N" lnil).

N_zero/decl : declared "N.zero" lnil
   (econst "N" lnil)
   ctor
   (dkind-ok/ctor N_zero/type-wf N_zero/positivity).

%% ctor N.succ (of N)
%%% HOLE
N_succ/type-wf : defeq (eforall (econst "N" lnil) ([x] (econst "N" lnil))) (eforall (econst "N" lnil) ([x] (econst "N" lnil))) (esort lzero).

%%% HOLE
N_succ/positivity : ctor-positive "N" lnil (eforall (econst "N" lnil) ([x] (econst "N" lnil))).

N_succ/decl : declared "N.succ" lnil
   (eforall (econst "N" lnil) ([x] (econst "N" lnil)))
   ctor
   (dkind-ok/ctor N_succ/type-wf N_succ/positivity).

%% recursor N.rec
%%% HOLE
N_rec/type-wf : {u : lvl} defeq (eforall (eforall (econst "N" lnil) ([x] (esort u))) ([x] (eforall (eapp x (econst "N.zero" lnil)) ([y] (eforall (eforall (econst "N" lnil) ([z] (eforall (eapp x z) ([w] (eapp x (eapp (econst "N.succ" lnil) z)))))) ([z] (eforall (econst "N" lnil) ([w] (eapp x w))))))))) (eforall (eforall (econst "N" lnil) ([x] (esort u))) ([x] (eforall (eapp x (econst "N.zero" lnil)) ([y] (eforall (eforall (econst "N" lnil) ([z] (eforall (eapp x z) ([w] (eapp x (eapp (econst "N.succ" lnil) z)))))) ([z] (eforall (econst "N" lnil) ([w] (eapp x w))))))))) (esort lzero).

N_rec/decl : {u : lvl} declared "N.rec" (lcons u lnil)
   (eforall (eforall (econst "N" lnil) ([x] (esort u))) ([x] (eforall (eapp x (econst "N.zero" lnil)) ([y] (eforall (eforall (econst "N" lnil) ([z] (eforall (eapp x z) ([w] (eapp x (eapp (econst "N.succ" lnil) z)))))) ([z] (eforall (econst "N" lnil) ([w] (eapp x w)))))))))
   irec
   (dkind-ok/irec (N_rec/type-wf u)).

%% def nRec
%%% HOLE
nRec/type-wf : {u : lvl} defeq (eforall (eforall (econst "N" lnil) ([x] (esort u))) ([x] (eforall (eapp x (econst "N.zero" lnil)) ([y] (eforall (eforall (econst "N" lnil) ([z] (eforall (eapp x z) ([w] (eapp x (eapp (econst "N.succ" lnil) z)))))) ([z] (eforall (econst "N" lnil) ([w] (eapp x w))))))))) (eforall (eforall (econst "N" lnil) ([x] (esort u))) ([x] (eforall (eapp x (econst "N.zero" lnil)) ([y] (eforall (eforall (econst "N" lnil) ([z] (eforall (eapp x z) ([w] (eapp x (eapp (econst "N.succ" lnil) z)))))) ([z] (eforall (econst "N" lnil) ([w] (eapp x w))))))))) (esort lzero).

%%% HOLE
nRec/value-typed : {u : lvl} defeq (econst "N.rec" (lcons u lnil)) (econst "N.rec" (lcons u lnil)) (eforall (eforall (econst "N" lnil) ([x] (esort u))) ([x] (eforall (eapp x (econst "N.zero" lnil)) ([y] (eforall (eforall (econst "N" lnil) ([z] (eforall (eapp x z) ([w] (eapp x (eapp (econst "N.succ" lnil) z)))))) ([z] (eforall (econst "N" lnil) ([w] (eapp x w))))))))).

nRec/decl : {u : lvl} declared "nRec" (lcons u lnil)
   (eforall (eforall (econst "N" lnil) ([x] (esort u))) ([x] (eforall (eapp x (econst "N.zero" lnil)) ([y] (eforall (eforall (econst "N" lnil) ([z] (eforall (eapp x z) ([w] (eapp x (eapp (econst "N.succ" lnil) z)))))) ([z] (eforall (econst "N" lnil) ([w] (eapp x w)))))))))
   (defn (econst "N.rec" (lcons u lnil)))
   (dkind-ok/defn (nRec/type-wf u) (nRec/value-typed u)).

