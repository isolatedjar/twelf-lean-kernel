%%% Expected outcome: accept
%%% Peano arithmetic: 1 + 1 = 2
%% def PN
%%% HOLE
PN/type-wf-sort : {u_1 : lvl} lvl.

%%% HOLE
PN/type-wf : {u_1 : lvl} defeq (esort (limax (lsucc u_1) u_1)) (esort (limax (lsucc u_1) u_1)) (esort (PN/type-wf-sort u_1)).

%%% HOLE
PN/value-typed : {u_1 : lvl} defeq (eforall (esort u_1) ([x] (eforall (eforall x ([y] x)) ([y] (eforall x ([z] x)))))) (eforall (esort u_1) ([x] (eforall (eforall x ([y] x)) ([y] (eforall x ([z] x)))))) (esort (limax (lsucc u_1) u_1)).

PN/name : {u_1 : lvl} name "PN" (is-decl (lcons u_1 lnil) (esort (limax (lsucc u_1) u_1)) (defn (eforall (esort u_1) ([x] (eforall (eforall x ([y] x)) ([y] (eforall x ([z] x)))))))).

PN/decl : {u_1 : lvl} declared "PN" (lcons u_1 lnil) (esort (limax (lsucc u_1) u_1)) (defn (eforall (esort u_1) ([x] (eforall (eforall x ([y] x)) ([y] (eforall x ([z] x)))))))
   = [u_1] declared/ok (PN/name u_1) (dkind-ok/defn (PN/type-wf u_1) (PN/value-typed u_1)).

%% def PN.succ
%%% HOLE
PN_succ/type-wf-sort : {u_1 : lvl} lvl.

%%% HOLE
PN_succ/type-wf : {u_1 : lvl} defeq (eforall (econst "PN" (lcons u_1 lnil)) ([x] (econst "PN" (lcons u_1 lnil)))) (eforall (econst "PN" (lcons u_1 lnil)) ([x] (econst "PN" (lcons u_1 lnil)))) (esort (PN_succ/type-wf-sort u_1)).

%%% HOLE
PN_succ/value-typed : {u_1 : lvl} defeq (elam (econst "PN" (lcons u_1 lnil)) ([x] (elam (esort u_1) ([y] (elam (eforall y ([z] y)) ([z] (elam y ([w] (eapp z (eapp (eapp (eapp x y) z) w)))))))))) (elam (econst "PN" (lcons u_1 lnil)) ([x] (elam (esort u_1) ([y] (elam (eforall y ([z] y)) ([z] (elam y ([w] (eapp z (eapp (eapp (eapp x y) z) w)))))))))) (eforall (econst "PN" (lcons u_1 lnil)) ([x] (econst "PN" (lcons u_1 lnil)))).

PN_succ/name : {u_1 : lvl} name "PN.succ" (is-decl (lcons u_1 lnil) (eforall (econst "PN" (lcons u_1 lnil)) ([x] (econst "PN" (lcons u_1 lnil)))) (defn (elam (econst "PN" (lcons u_1 lnil)) ([x] (elam (esort u_1) ([y] (elam (eforall y ([z] y)) ([z] (elam y ([w] (eapp z (eapp (eapp (eapp x y) z) w)))))))))))).

PN_succ/decl : {u_1 : lvl} declared "PN.succ" (lcons u_1 lnil) (eforall (econst "PN" (lcons u_1 lnil)) ([x] (econst "PN" (lcons u_1 lnil)))) (defn (elam (econst "PN" (lcons u_1 lnil)) ([x] (elam (esort u_1) ([y] (elam (eforall y ([z] y)) ([z] (elam y ([w] (eapp z (eapp (eapp (eapp x y) z) w)))))))))))
   = [u_1] declared/ok (PN_succ/name u_1) (dkind-ok/defn (PN_succ/type-wf u_1) (PN_succ/value-typed u_1)).

