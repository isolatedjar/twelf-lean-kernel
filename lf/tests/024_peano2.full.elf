%%% Expected outcome: accept
%%% Peano arithmetic: 1 + 1 = 2
%% def PN
PN/type-wf-sort : lvl
   = (lsucc (limax (lsucc (lvar liz)) (lvar liz))).

PN/type-wf : defeq (esort (limax (lsucc (lvar liz)) (lvar liz))) (esort (limax (lsucc (lvar liz)) (lvar liz))) (esort PN/type-wf-sort)
   = defeq/sort-refl.

%%% HOLE
PN/value-typed : defeq (eforall (esort (lvar liz)) ([x] (eforall (eforall x ([y] x)) ([y] (eforall x ([z] x)))))) (eforall (esort (lvar liz)) ([x] (eforall (eforall x ([y] x)) ([y] (eforall x ([z] x)))))) (esort (limax (lsucc (lvar liz)) (lvar liz))).

PN/name : name "PN" (is-decl (esort (limax (lsucc (lvar liz)) (lvar liz))) (defn (eforall (esort (lvar liz)) ([x] (eforall (eforall x ([y] x)) ([y] (eforall x ([z] x)))))))).

PN/decl : declared "PN" (esort (limax (lsucc (lvar liz)) (lvar liz))) (defn (eforall (esort (lvar liz)) ([x] (eforall (eforall x ([y] x)) ([y] (eforall x ([z] x)))))))
   = declared/ok PN/name (dkind-ok/defn PN/type-wf PN/value-typed).

