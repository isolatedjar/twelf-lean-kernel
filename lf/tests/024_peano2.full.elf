%% def PN.add
%%% HOLE
PN_add/type-wf-sort : {u_1 : lvl} lvl.

%%% HOLE
PN_add/type-wf : {u_1 : lvl} defeq (eforall (econst "PN" (lcons u_1 lnil)) ([x] (eforall (econst "PN" (lcons u_1 lnil)) ([y] (econst "PN" (lcons u_1 lnil)))))) (eforall (econst "PN" (lcons u_1 lnil)) ([x] (eforall (econst "PN" (lcons u_1 lnil)) ([y] (econst "PN" (lcons u_1 lnil)))))) (esort (PN_add/type-wf-sort u_1)).

%%% HOLE
