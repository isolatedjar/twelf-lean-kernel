%% recursor Bool.rec
Bool_rec/type-wf-sort : lvl
   = (limax
       (limax (lsucc lzero) (lsucc (lvar liz)))
       (limax (lvar liz) (limax (lvar liz) (limax (lsucc lzero) (lvar liz))))).

Bool_rec/type-wf : of
  (eforall (eforall (econst "Bool" lnil) ([x] (esort (lvar liz))))
    ([x] (eforall (eapp x (econst "Bool.false" lnil)) ([y] (eforall (eapp x (econst "Bool.true" lnil)) ([z] (eforall (econst "Bool" lnil) ([w] (eapp x w)))))))))
  (esort Bool_rec/type-wf-sort)
   = (defeq/forall
       (defeq/forall
         (defeq/const Bool/decl (inst-expr/sort (lvl-inst/succ lvl-inst/zero)))
         ([x] ([h] defeq/sort-refl)))
       ([x]
         ([h]
           (defeq/forall
             (defeq/app
               h
               (defeq/const Bool_false/decl (inst-expr/const lvls-inst/nil)))
             ([y]
               ([h1]
                 (defeq/forall
                   (defeq/app
                     h
                     (defeq/const
                       Bool_true/decl
                       (inst-expr/const lvls-inst/nil)))
                   ([z]
                     ([h2]
                       (defeq/forall
                         (defeq/const
                           Bool/decl
                           (inst-expr/sort (lvl-inst/succ lvl-inst/zero)))
                         ([w] ([h3] (defeq/app h h3))))))))))))).

Bool_rec/ert : enum-rec-type (eforall (eforall (econst "Bool" lnil) ([x] (esort (lvar liz)))) ([x] (eforall (eapp x (econst "Bool.false" lnil)) ([y] (eforall (eapp x (econst "Bool.true" lnil)) ([z] (eforall (econst "Bool" lnil) ([w] (eapp x w))))))))) "Bool" lnil (ccons "Bool.false" (ccons "Bool.true" cnil)) (lvar liz)
   = (enum-rec-type/intro
       ([x]
         ([h]
           (enum-rec-body/minor
             ([y]
               ([h1] (enum-rec-body/minor ([z] ([h2] enum-rec-body/done))))))))).

Bool_rec/lee : le-eligible (lsucc lzero) (ccons "Bool.false" (ccons "Bool.true" cnil)) (lvar liz)
   = (le-eligible/non-prop (mleq/self nonneg_0)).

Bool_rec/decl : declared "Bool.rec"
  (eforall (eforall (econst "Bool" lnil) ([x] (esort (lvar liz))))
    ([x] (eforall (eapp x (econst "Bool.false" lnil)) ([y] (eforall (eapp x (econst "Bool.true" lnil)) ([z] (eforall (econst "Bool" lnil) ([w] (eapp x w)))))))))
  (irec "Bool")
   = declared/ok-irec Bool/rec-name (dkind-ok/irec Bool_rec/type-wf Bool/name Bool/eisl Bool_rec/ert Bool_rec/lee).

%% inductive Nat
Nat/type-wf-sort : lvl
   = (lsucc (lsucc lzero)).

Nat/type-wf : of (esort (lsucc lzero)) (esort Nat/type-wf-sort)
