%% axiom Quot.sound
%%% HOLE
Quot_sound/type-wf : of
  (eforall (esort (lvar z))
    ([x]
      (eforall (eforall x ([y] (eforall x ([w] (esort lzero)))))
        ([y]
          (eforall x
            ([w]
              (eforall x
                ([v]
                  (eforall (eapp (eapp y w) v)
                    ([x1]
                      (eapp (eapp (eapp (econst "Eq" (lcons (lvar z) lnil)) (eapp (eapp (econst "Quot" (lcons (lvar z) lnil)) x) y))
                        (eapp (eapp (eapp (econst "Quot.mk" (lcons (lvar z) lnil)) x) y) w))
                        (eapp (eapp (eapp (econst "Quot.mk" (lcons (lvar z) lnil)) x) y) v))))))))))))
  (esort _).

Quot_sound/name : name "Quot.sound" (is-decl
  (eforall (esort (lvar z))
    ([x]
      (eforall (eforall x ([y] (eforall x ([w] (esort lzero)))))
        ([y]
          (eforall x
            ([w]
              (eforall x
                ([v]
                  (eforall (eapp (eapp y w) v)
                    ([x1]
                      (eapp (eapp (eapp (econst "Eq" (lcons (lvar z) lnil)) (eapp (eapp (econst "Quot" (lcons (lvar z) lnil)) x) y))
                        (eapp (eapp (eapp (econst "Quot.mk" (lcons (lvar z) lnil)) x) y) w))
                        (eapp (eapp (eapp (econst "Quot.mk" (lcons (lvar z) lnil)) x) y) v))))))))))))
  ax).

Quot_sound/decl : declared "Quot.sound"
  (eforall (esort (lvar z))
    ([x]
      (eforall (eforall x ([y] (eforall x ([w] (esort lzero)))))
        ([y]
          (eforall x
            ([w]
              (eforall x
                ([v]
                  (eforall (eapp (eapp y w) v)
                    ([x1]
                      (eapp (eapp (eapp (econst "Eq" (lcons (lvar z) lnil)) (eapp (eapp (econst "Quot" (lcons (lvar z) lnil)) x) y))
                        (eapp (eapp (eapp (econst "Quot.mk" (lcons (lvar z) lnil)) x) y) w))
                        (eapp (eapp (eapp (econst "Quot.mk" (lcons (lvar z) lnil)) x) y) v))))))))))))
  ax
   = declared/ok Quot_sound/name dkind-non-inductive/ax (dkind-ok/ax Quot_sound/type-wf).

