%%% Render-only view of: 095_aNatLit
%%% Type checking Nat literals
%solve nonneg_0 : 0 >= 0.

%% inductive Nat
%%% HOLE
Nat/type-wf-sort : lvl.

%%% HOLE
Nat/type-wf : of (esort (lsucc lzero)) (esort Nat/type-wf-sort).

%%% HOLE
Nat/ends-in-sort : ends-in-sort (esort (lsucc lzero)).

Nat/rec-name : name "Nat.rec" (is-rec-for "Nat").

Nat/name : name "Nat" (is-decl (esort (lsucc lzero)) indt).

Nat/decl : declared "Nat" (esort (lsucc lzero)) indt
   = declared/ok Nat/name (dkind-ok/indt Nat/type-wf Nat/ends-in-sort).

%% ctor Nat.zero (of Nat)
%%% HOLE
Nat_zero/type-wf-sort : lvl.

%%% HOLE
Nat_zero/type-wf : of (econst "Nat" lnil) (esort Nat_zero/type-wf-sort).

%%% HOLE
