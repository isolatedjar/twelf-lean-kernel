TypeWithTypeFieldPoly_mk/fuo : field-universes-ok (eforall (esort (lsucc (lvar z))) ([x] (econst "TypeWithTypeFieldPoly" (lcons (lvar z) lnil)))) (lsucc (lsucc (lvar z)))
