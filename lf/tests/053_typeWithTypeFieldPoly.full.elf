TypeWithTypeFieldPoly_mk/positivity : ctor-positive "TypeWithTypeFieldPoly" (lcons (lvar z) lnil) (eforall (esort (lsucc (lvar z))) ([x] (econst "TypeWithTypeFieldPoly" (lcons (lvar z) lnil))))
