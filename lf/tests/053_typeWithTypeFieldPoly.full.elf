%% def typeWithTypeFieldPoly
typeWithTypeFieldPoly/type-wf-sort : lvl
   = (lsucc (lsucc (lsucc (lvar liz)))).

typeWithTypeFieldPoly/type-wf : of (esort (lsucc (lsucc (lvar liz)))) (esort typeWithTypeFieldPoly/type-wf-sort)
   = defeq/sort-refl.

typeWithTypeFieldPoly/value-typed : of (econst "TypeWithTypeFieldPoly" (lcons (lvar liz) lnil)) (esort (lsucc (lsucc (lvar liz))))
   = (defeq/const
       TypeWithTypeFieldPoly/decl
       (inst-expr/sort
         (lvl-inst/succ (lvl-inst/succ (lvl-inst/var lvl-nth/zero))))).

typeWithTypeFieldPoly/name : name "typeWithTypeFieldPoly" (is-decl (esort (lsucc (lsucc (lvar liz)))) (defn (econst "TypeWithTypeFieldPoly" (lcons (lvar liz) lnil)))).

typeWithTypeFieldPoly/decl : declared "typeWithTypeFieldPoly" (esort (lsucc (lsucc (lvar liz)))) (defn (econst "TypeWithTypeFieldPoly" (lcons (lvar liz) lnil)))
   = declared/ok typeWithTypeFieldPoly/name dkind-non-inductive/defn (dkind-ok/defn typeWithTypeFieldPoly/type-wf typeWithTypeFieldPoly/value-typed).
