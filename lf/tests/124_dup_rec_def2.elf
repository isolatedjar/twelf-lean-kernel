%%% Expected outcome: reject
%%% A definition with the name of a recursor, and the recursor named differently.
This would pass simple checks for duplicate definitions in the parser, but should still
be rejected by the checker.
%% def dup_rec_def2.rec
dup_rec_def2_rec/type-wf :
   defeq (esort (lsucc lzero)) (esort (lsucc lzero)) (esort (lsucc (lsucc lzero)))
   = (defeq/sort-refl-at (lsucc lzero)).

dup_rec_def2_rec/value-typed :
   defeq (esort lzero) (esort lzero) (esort (lsucc lzero))
   = (defeq/sort-refl-at lzero).

dup_rec_def2_rec/decl : declared "dup_rec_def2.rec" lnil
   (esort (lsucc lzero))
   (defn (esort lzero))
   (dkind-ok/defn dup_rec_def2_rec/type-wf dup_rec_def2_rec/value-typed).

%% inductive dup_rec_def2
dup_rec_def2/type-wf :
   defeq (esort (lsucc lzero)) (esort (lsucc lzero)) (esort (lsucc (lsucc lzero)))
   = (defeq/sort-refl-at (lsucc lzero)).

dup_rec_def2/ends-in-sort :
   ends-in-sort (esort (lsucc lzero))
   = ends-in-sort/sort.

dup_rec_def2/decl : declared "dup_rec_def2" lnil
   (esort (lsucc lzero))
   indt
   (dkind-ok/indt dup_rec_def2/type-wf dup_rec_def2/ends-in-sort).

%% inductive ctor dup_rec_def2.mk
dup_rec_def2_mk/type-wf :
   defeq (econst "dup_rec_def2" lnil) (econst "dup_rec_def2" lnil) (esort (lsucc lzero))
   = (defeq/const dup_rec_def2/decl).

dup_rec_def2_mk/positivity :
   ctor-positive "dup_rec_def2" lnil (econst "dup_rec_def2" lnil)
   = (ctor-positive/intro ([S] S) ([S] (ctor-spine/result applies-self/refl))).

dup_rec_def2_mk/decl : declared "dup_rec_def2.mk" lnil
   (econst "dup_rec_def2" lnil)
   ctor
   (dkind-ok/ctor dup_rec_def2_mk/type-wf dup_rec_def2_mk/positivity).

%% inductive recursor dup_rec_def2.original_rec
dup_rec_def2_original_rec/type-wf :
   {u : lvl} defeq (eforall (eforall (econst "dup_rec_def2" lnil) ([x] (esort u))) ([x] (eforall (eapp x (econst "dup_rec_def2.mk" lnil)) ([y] (eforall (econst "dup_rec_def2" lnil) ([z] (eapp x z))))))) (eforall (eforall (econst "dup_rec_def2" lnil) ([x] (esort u))) ([x] (eforall (eapp x (econst "dup_rec_def2.mk" lnil)) ([y] (eforall (econst "dup_rec_def2" lnil) ([z] (eapp x z))))))) (esort (limax (limax (lsucc lzero) (lsucc u)) (limax u (limax (lsucc lzero) u))))
   = [u] (defeq/forall (defeq/forall (defeq/const dup_rec_def2/decl) ([x] [y] (defeq/sort-refl-at u))) ([x] [y] (defeq/forall (defeq/app y (defeq/const dup_rec_def2_mk/decl)) ([z] [w] (defeq/forall (defeq/const dup_rec_def2/decl) ([x1] [y1] (defeq/app y y1))))))).

dup_rec_def2_original_rec/decl : {u : lvl} declared "dup_rec_def2.original_rec" (lcons u lnil)
   (eforall (eforall (econst "dup_rec_def2" lnil) ([x] (esort u))) ([x] (eforall (eapp x (econst "dup_rec_def2.mk" lnil)) ([y] (eforall (econst "dup_rec_def2" lnil) ([z] (eapp x z)))))))
   irec
   (dkind-ok/irec (dup_rec_def2_original_rec/type-wf u)).

%mode declared +N +LS -T -DK -W.
%worlds () (declared _ _ _ _ _).
%unique declared +N +LS -1T -1DK *W.
