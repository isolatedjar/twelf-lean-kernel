%%% Expected outcome: accept
%%% Type inference for forall using imax
%% def imax1
%%% HOLE
imax1/type-wf : defeq (eforall (esort lzero) ([x] (esort lzero))) (eforall (esort lzero) ([x] (esort lzero))) (esort lzero).

%%% HOLE
imax1/value-typed : defeq (elam (esort lzero) ([x] (eforall (esort (lsucc lzero)) ([y] x)))) (elam (esort lzero) ([x] (eforall (esort (lsucc lzero)) ([y] x)))) (eforall (esort lzero) ([x] (esort lzero))).

imax1/decl : declared "imax1" lnil
   (eforall (esort lzero) ([x] (esort lzero)))
   (defn (elam (esort lzero) ([x] (eforall (esort (lsucc lzero)) ([y] x)))))
   (dkind-ok/defn imax1/type-wf imax1/value-typed).

