%%% Expected outcome: accept
%%% Type inference for forall using imax
%solve nonneg_0 : 0 >= 0.

%% def imax1
imax1/type-wf-sort : lvl
   = (limax (lsucc lzero) (lsucc lzero)).

imax1/type-wf : of (eforall (esort lzero) ([x] (esort lzero))) (esort imax1/type-wf-sort)
   = (defeq/forall defeq/sort-refl ([x] ([h] defeq/sort-refl))).

imax1/value-typed : of (elam (esort lzero) ([x] (eforall (esort (lsucc lzero)) ([y] x)))) (eforall (esort lzero) ([x] (esort lzero)))
   = (defeq/conv (defeq/forall (defeq/sort-eq lvl-eq/refl) ([x] ([h] (defeq/sort-eq (lvl-eq/le (mleq/imax-lzL (mleq/self nonneg_0)) (mleq/lz nonneg_0)))))) (defeq/lam defeq/sort-refl ([x] ([h] (defeq/forall defeq/sort-refl ([y] ([h1] h))))))).

imax1/name : name "imax1" (is-decl (eforall (esort lzero) ([x] (esort lzero))) (defn (elam (esort lzero) ([x] (eforall (esort (lsucc lzero)) ([y] x)))))).

imax1/decl : declared "imax1" (eforall (esort lzero) ([x] (esort lzero))) (defn (elam (esort lzero) ([x] (eforall (esort (lsucc lzero)) ([y] x)))))
   = declared/ok imax1/name (dkind-ok/defn imax1/type-wf imax1/value-typed).
