%%% Expected outcome: accept
%%% Asserting the type of the generated recursor
%% inductive Empty
%%% HOLE
Empty/type-wf : defeq (esort (lsucc lzero)) (esort (lsucc lzero)) (esort lzero).

%%% HOLE
Empty/ends-in-sort : ends-in-sort (esort (lsucc lzero)).

Empty/decl : declared "Empty" lnil
   (esort (lsucc lzero))
   indt
   (dkind-ok/indt Empty/type-wf Empty/ends-in-sort).

%% recursor Empty.rec
%%% HOLE
Empty_rec/type-wf : {u : lvl} defeq (eforall (eforall (econst "Empty" lnil) ([x] (esort u))) ([x] (eforall (econst "Empty" lnil) ([y] (eapp x y))))) (eforall (eforall (econst "Empty" lnil) ([x] (esort u))) ([x] (eforall (econst "Empty" lnil) ([y] (eapp x y))))) (esort lzero).

Empty_rec/decl : {u : lvl} declared "Empty.rec" (lcons u lnil)
   (eforall (eforall (econst "Empty" lnil) ([x] (esort u))) ([x] (eforall (econst "Empty" lnil) ([y] (eapp x y)))))
   irec
   (dkind-ok/irec (Empty_rec/type-wf u)).

%% def emptyRec
%%% HOLE
emptyRec/type-wf : {u : lvl} defeq (eforall (eforall (econst "Empty" lnil) ([x] (esort u))) ([x] (eforall (econst "Empty" lnil) ([y] (eapp x y))))) (eforall (eforall (econst "Empty" lnil) ([x] (esort u))) ([x] (eforall (econst "Empty" lnil) ([y] (eapp x y))))) (esort lzero).

%%% HOLE
emptyRec/value-typed : {u : lvl} defeq (econst "Empty.rec" (lcons u lnil)) (econst "Empty.rec" (lcons u lnil)) (eforall (eforall (econst "Empty" lnil) ([x] (esort u))) ([x] (eforall (econst "Empty" lnil) ([y] (eapp x y))))).

emptyRec/decl : {u : lvl} declared "emptyRec" (lcons u lnil)
   (eforall (eforall (econst "Empty" lnil) ([x] (esort u))) ([x] (eforall (econst "Empty" lnil) ([y] (eapp x y)))))
   (defn (econst "Empty.rec" (lcons u lnil)))
   (dkind-ok/defn (emptyRec/type-wf u) (emptyRec/value-typed u)).

