%%% Expected outcome: accept
%%% Asserting the type of `Quot.lift`.
%solve nonneg_0 : 0 >= 0.

%% inductive Eq
Eq/type-wf-sort : lvl
   = (limax
       (lsucc (lvar liz))
       (limax (lvar liz) (limax (lvar liz) (lsucc lzero)))).

Eq/type-wf : of (eforall (esort (lvar liz)) ([x] (eforall x ([y] (eforall x ([z] (esort lzero))))))) (esort Eq/type-wf-sort)
   = (defeq/forall
       defeq/sort-refl
       ([x]
         ([h]
           (defeq/forall
             h
             ([y] ([h1] (defeq/forall h ([z] ([h2] defeq/sort-refl))))))))).

Eq/ends-in-sort : ends-in-sort (eforall (esort (lvar liz)) ([x] (eforall x ([y] (eforall x ([z] (esort lzero)))))))
   = (ends-in-sort/forall
       ([x]
         (ends-in-sort/forall
           ([y] (ends-in-sort/forall ([z] ends-in-sort/sort)))))).

Eq/rec-name : name "Eq.rec" (is-rec-for "Eq").

Eq/eisl : ends-in-sort-with-level (eforall (esort (lvar liz)) ([x] (eforall x ([y] (eforall x ([z] (esort lzero))))))) lzero
   = (ends-in-sort-with-level/forall
       ([x]
         (ends-in-sort-with-level/forall
           ([y]
             (ends-in-sort-with-level/forall
               ([z] ends-in-sort-with-level/sort)))))).

Eq/cnd : cnames-distinct (ccons "Eq.refl" cnil)
   = (cnames-distinct/cons cnames-distinct/nil all-string-neq/nil).

Eq/name : name "Eq" (is-decl (eforall (esort (lvar liz)) ([x] (eforall x ([y] (eforall x ([z] (esort lzero))))))) (indt (ccons "Eq.refl" cnil) (lis (lis liz)))).

Eq/decl : declared "Eq" (eforall (esort (lvar liz)) ([x] (eforall x ([y] (eforall x ([z] (esort lzero))))))) (indt (ccons "Eq.refl" cnil) (lis (lis liz)))
   = declared/ok-indt Eq/name Eq/rec-name Eq/cnd (dkind-ok/indt Eq/type-wf Eq/ends-in-sort).

%% ctor Eq.refl (of Eq)
Eq_refl/type-wf-sort : lvl
   = (limax (lsucc (lvar liz)) (limax (lvar liz) lzero)).

Eq_refl/type-wf : of (eforall (esort (lvar liz)) ([x] (eforall x ([y] (eapp (eapp (eapp (econst "Eq" (lcons (lvar liz) lnil)) x) y) y))))) (esort Eq_refl/type-wf-sort)
   = (defeq/forall
       defeq/sort-refl
       ([x]
         ([h]
           (defeq/forall
             h
             ([y]
               ([h1]
                 (defeq/app
                   (defeq/app
                     (defeq/app
                       (defeq/const
                         Eq/decl
                         (inst-expr/forall
                           (inst-expr/sort (lvl-inst/var lvl-nth/zero))
                           ([x]
                             ([h]
                               (inst-expr/forall
                                 h
                                 ([y]
                                   ([h1]
                                     (inst-expr/forall
                                       h
                                       ([z]
                                         ([h2]
                                           (inst-expr/sort
                                             lvl-inst/zero)))))))))))
                       h)
                     h1)
                   h1))))))).

Eq_refl/positivity : ctor-positive "Eq" (lcons (lvar liz) lnil) (eforall (esort (lvar liz)) ([x] (eforall x ([y] (eapp (eapp (eapp (econst "Eq" (lcons (lvar liz) lnil)) x) y) y)))))
   = (ctor-positive/intro ([S] (eforall (esort (lvar liz)) ([x] (eforall x ([y] (eapp (eapp (eapp S x) y) y)))))) (ctor-spine/arg
       (strict-pos/no-occur (esort (lvar liz)) no-self-ref/sort)
       ([x]
         ([y]
           (ctor-spine/arg
             (strict-pos/no-occur x y)
             ([z]
               ([w]
                 (ctor-spine/result
                   (applies-self/app
                     (applies-self/app
                       (applies-self/app applies-self/refl))))))))))).

Eq_refl/cmem : cmem "Eq.refl" (ccons "Eq.refl" cnil)
   = cmem/here.

Eq_refl/fuo : field-universes-ok (eforall (esort (lvar liz)) ([x] (eforall x ([y] (eapp (eapp (eapp (econst "Eq" (lcons (lvar liz) lnil)) x) y) y))))) lzero
   = (field-universes-ok/forall
       defeq/sort-refl
       (mleq/imax-lzL (mleq/self nonneg_0))
       ([x]
         ([h]
           (field-universes-ok/forall
             h
             (mleq/imax-lzL (mleq/self nonneg_0))
             ([y] ([h1] (field-universes-ok/done not-forall/app))))))).

Eq_refl/name : name "Eq.refl" (is-decl (eforall (esort (lvar liz)) ([x] (eforall x ([y] (eapp (eapp (eapp (econst "Eq" (lcons (lvar liz) lnil)) x) y) y))))) (ctor "Eq" liz)).

Eq_refl/decl : declared "Eq.refl" (eforall (esort (lvar liz)) ([x] (eforall x ([y] (eapp (eapp (eapp (econst "Eq" (lcons (lvar liz) lnil)) x) y) y))))) (ctor "Eq" liz)
   = declared/ok-ctor Eq_refl/name Eq/name Eq_refl/cmem Eq/eisl Eq_refl/fuo (dkind-ok/ctor Eq_refl/type-wf Eq_refl/positivity).

%% recursor Eq.rec (TCB-derived; informational only)
%%   level params: u u_1
%%   type:   (eforall (esort (lvar (lis liz))) ([x] (eforall x ([y] (eforall (eforall x ([z] (eforall (eapp (eapp (eapp (econst "Eq" (lcons (lvar (lis liz)) lnil)) x) y) z) ([w] (esort (lvar liz)))))) ([z] (eforall (eapp (eapp z y) (eapp (eapp (econst "Eq.refl" (lcons (lvar (lis liz)) lnil)) x) y)) ([w] (eforall x ([x1] (eforall (eapp (eapp (eapp (econst "Eq" (lcons (lvar (lis liz)) lnil)) x) y) x1) ([y1] (eapp (eapp z x1) y1)))))))))))))
%%   rules:
%%     Eq.rec … Eq.refl … = (elam (esort (lvar (lis liz))) ([x] (elam x ([y] (elam (eforall x ([z] (eforall (eapp (eapp (eapp (econst "Eq" (lcons (lvar (lis liz)) lnil)) x) y) z) ([w] (esort (lvar liz)))))) ([z] (elam (eapp (eapp z y) (eapp (eapp (econst "Eq.refl" (lcons (lvar (lis liz)) lnil)) x) y)) ([w] w))))))))   (0 fields)
%%   K-like reduction: yes

%% quot Quot (type) (TCB-derived; informational only)
%%   type: (type not representable in LF)

%% quot Quot.mk (ctor) (TCB-derived; informational only)
%%   type: (type not representable in LF)

%% quot Quot.lift (lift) (TCB-derived; informational only)
%%   type: (type not representable in LF)

%% quot Quot.ind (ind) (TCB-derived; informational only)
%%   type: (type not representable in LF)

%% def quotLiftType
%%% HOLE
quotLiftType/type-wf-sort : lvl.

%%% HOLE
quotLiftType/type-wf : of
  (eforall (esort (lvar liz))
    ([x]
      (eforall (eforall x ([y] (eforall x ([z] (esort lzero)))))
        ([y]
          (eforall (esort (lvar (lis liz)))
            ([z]
              (eforall (eforall x ([w] z))
                ([w]
                  (eforall (eforall x ([x1] (eforall x ([y1] (eforall (eapp (eapp y x1) y1) ([z1] (eapp (eapp (eapp (econst "Eq" (lcons (lvar (lis liz)) lnil)) z) (eapp w x1)) (eapp w y1))))))))
                    ([x1] (eforall (eapp (eapp (econst "Quot" (lcons (lvar liz) lnil)) x) y) ([y1] z))))))))))))
  (esort quotLiftType/type-wf-sort).

%%% HOLE
quotLiftType/value-typed : of
  (econst "Quot.lift" (lcons (lvar liz) (lcons (lvar (lis liz)) lnil)))
  (eforall (esort (lvar liz))
    ([x]
      (eforall (eforall x ([y] (eforall x ([z] (esort lzero)))))
        ([y]
          (eforall (esort (lvar (lis liz)))
            ([z]
              (eforall (eforall x ([w] z))
                ([w]
                  (eforall (eforall x ([x1] (eforall x ([y1] (eforall (eapp (eapp y x1) y1) ([z1] (eapp (eapp (eapp (econst "Eq" (lcons (lvar (lis liz)) lnil)) z) (eapp w x1)) (eapp w y1))))))))
                    ([x1] (eforall (eapp (eapp (econst "Quot" (lcons (lvar liz) lnil)) x) y) ([y1] z)))))))))))).

quotLiftType/name : name "quotLiftType" (is-decl
  (eforall (esort (lvar liz))
    ([x]
      (eforall (eforall x ([y] (eforall x ([z] (esort lzero)))))
        ([y]
          (eforall (esort (lvar (lis liz)))
            ([z]
              (eforall (eforall x ([w] z))
                ([w]
                  (eforall (eforall x ([x1] (eforall x ([y1] (eforall (eapp (eapp y x1) y1) ([z1] (eapp (eapp (eapp (econst "Eq" (lcons (lvar (lis liz)) lnil)) z) (eapp w x1)) (eapp w y1))))))))
                    ([x1] (eforall (eapp (eapp (econst "Quot" (lcons (lvar liz) lnil)) x) y) ([y1] z))))))))))))
  (defn (econst "Quot.lift" (lcons (lvar liz) (lcons (lvar (lis liz)) lnil))))).

quotLiftType/decl : declared "quotLiftType"
  (eforall (esort (lvar liz))
    ([x]
      (eforall (eforall x ([y] (eforall x ([z] (esort lzero)))))
        ([y]
          (eforall (esort (lvar (lis liz)))
            ([z]
              (eforall (eforall x ([w] z))
                ([w]
                  (eforall (eforall x ([x1] (eforall x ([y1] (eforall (eapp (eapp y x1) y1) ([z1] (eapp (eapp (eapp (econst "Eq" (lcons (lvar (lis liz)) lnil)) z) (eapp w x1)) (eapp w y1))))))))
                    ([x1] (eforall (eapp (eapp (econst "Quot" (lcons (lvar liz) lnil)) x) y) ([y1] z))))))))))))
  (defn (econst "Quot.lift" (lcons (lvar liz) (lcons (lvar (lis liz)) lnil))))
   = declared/ok quotLiftType/name dkind-non-inductive/defn (dkind-ok/defn quotLiftType/type-wf quotLiftType/value-typed).
