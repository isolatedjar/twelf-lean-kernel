%%% Expected outcome: reject
%%% Corner case for function eta:
%%% Does a defeq between a partially applied constructor trigger eta expansion?
%%% 
%%% Taking the official kernel as the specification, the answer is no.
%%% See <https://github.com/leanprover/lean4/issues/12520> for a discussion.
%solve nonneg_1 : 1 >= 0.
%solve nonneg_0 : 0 >= 0.

sneq/0 : string-neq "Bool" "T".
sneq/1 : string-neq "True" "T".

%% inductive True
True/type-wf-sort : lvl
   = (lsucc lzero).

True/type-wf : of (esort lzero) (esort True/type-wf-sort)
   = defeq/sort-refl.

True/ends-in-sort : ends-in-sort (esort lzero)
   = ends-in-sort/sort.

True/rec-name : name "True.rec" (is-rec-for "True").

True/name : name "True" (is-decl (esort lzero) indt).

True/decl : declared "True" (esort lzero) indt
   = declared/ok True/name (dkind-ok/indt True/type-wf True/ends-in-sort).

%% ctor True.intro (of True)
True_intro/type-wf-sort : lvl
   = lzero.

True_intro/type-wf : of (econst "True" lnil) (esort True_intro/type-wf-sort)
   = (defeq/const True/decl (inst-expr/sort lvl-inst/zero)).

True_intro/positivity : ctor-positive "True" lnil (econst "True" lnil)
   = (ctor-positive/intro ([S] S) (ctor-spine/result applies-self/refl)).

True_intro/eisl : ends-in-sort-with-level (esort lzero) lzero
   = ends-in-sort-with-level/sort.

%%% HOLE: True_intro/fuo — prover for field-universes-ok-skip-params not yet implemented
True_intro/fuo : field-universes-ok-skip-params liz (econst "True" lnil) lzero.

True_intro/name : name "True.intro" (is-decl (econst "True" lnil) ctor).

True_intro/decl : declared "True.intro" (econst "True" lnil) ctor
   = declared/ok True_intro/name (dkind-ok/ctor True_intro/type-wf True_intro/positivity True/decl True_intro/eisl True_intro/fuo).

%% recursor True.rec
True_rec/type-wf-sort : lvl
   = (limax
       (limax lzero (lsucc (lvar liz)))
       (limax (lvar liz) (limax lzero (lvar liz)))).

True_rec/type-wf : of (eforall (eforall (econst "True" lnil) ([x] (esort (lvar liz))))
                     ([x] (eforall (eapp x (econst "True.intro" lnil)) ([y] (eforall (econst "True" lnil) ([z] (eapp x z))))))) (esort True_rec/type-wf-sort)
   = (defeq/forall
       (defeq/forall
         (defeq/const True/decl (inst-expr/sort lvl-inst/zero))
         ([x] ([h] defeq/sort-refl)))
       ([x]
         ([h]
           (defeq/forall
             (defeq/app
               h
               (defeq/const True_intro/decl (inst-expr/const lvls-inst/nil)))
             ([y]
               ([h1]
                 (defeq/forall
                   (defeq/const True/decl (inst-expr/sort lvl-inst/zero))
                   ([z] ([h2] (defeq/app h h2)))))))))).

True_rec/decl : declared "True.rec" (eforall (eforall (econst "True" lnil) ([x] (esort (lvar liz))))
                                      ([x] (eforall (eapp x (econst "True.intro" lnil)) ([y] (eforall (econst "True" lnil) ([z] (eapp x z))))))) irec
   = declared/ok-irec True/rec-name (dkind-ok/irec True_rec/type-wf).

%% inductive Bool
Bool/type-wf-sort : lvl
   = (lsucc (lsucc lzero)).

Bool/type-wf : of (esort (lsucc lzero)) (esort Bool/type-wf-sort)
   = defeq/sort-refl.

Bool/ends-in-sort : ends-in-sort (esort (lsucc lzero))
   = ends-in-sort/sort.

Bool/rec-name : name "Bool.rec" (is-rec-for "Bool").

Bool/name : name "Bool" (is-decl (esort (lsucc lzero)) indt).

Bool/decl : declared "Bool" (esort (lsucc lzero)) indt
   = declared/ok Bool/name (dkind-ok/indt Bool/type-wf Bool/ends-in-sort).

%% ctor Bool.false (of Bool)
Bool_false/type-wf-sort : lvl
   = (lsucc lzero).

Bool_false/type-wf : of (econst "Bool" lnil) (esort Bool_false/type-wf-sort)
   = (defeq/const Bool/decl (inst-expr/sort (lvl-inst/succ lvl-inst/zero))).

Bool_false/positivity : ctor-positive "Bool" lnil (econst "Bool" lnil)
   = (ctor-positive/intro ([S] S) (ctor-spine/result applies-self/refl)).

Bool_false/eisl : ends-in-sort-with-level (esort (lsucc lzero)) (lsucc lzero)
   = ends-in-sort-with-level/sort.

%%% HOLE: Bool_false/fuo — prover for field-universes-ok-skip-params not yet implemented
Bool_false/fuo : field-universes-ok-skip-params liz (econst "Bool" lnil) (lsucc lzero).

Bool_false/name : name "Bool.false" (is-decl (econst "Bool" lnil) ctor).

Bool_false/decl : declared "Bool.false" (econst "Bool" lnil) ctor
   = declared/ok Bool_false/name (dkind-ok/ctor Bool_false/type-wf Bool_false/positivity Bool/decl Bool_false/eisl Bool_false/fuo).

%% ctor Bool.true (of Bool)
Bool_true/type-wf-sort : lvl
   = (lsucc lzero).

Bool_true/type-wf : of (econst "Bool" lnil) (esort Bool_true/type-wf-sort)
   = (defeq/const Bool/decl (inst-expr/sort (lvl-inst/succ lvl-inst/zero))).

Bool_true/positivity : ctor-positive "Bool" lnil (econst "Bool" lnil)
   = (ctor-positive/intro ([S] S) (ctor-spine/result applies-self/refl)).

Bool_true/eisl : ends-in-sort-with-level (esort (lsucc lzero)) (lsucc lzero)
   = ends-in-sort-with-level/sort.

%%% HOLE: Bool_true/fuo — prover for field-universes-ok-skip-params not yet implemented
Bool_true/fuo : field-universes-ok-skip-params liz (econst "Bool" lnil) (lsucc lzero).

Bool_true/name : name "Bool.true" (is-decl (econst "Bool" lnil) ctor).

Bool_true/decl : declared "Bool.true" (econst "Bool" lnil) ctor
   = declared/ok Bool_true/name (dkind-ok/ctor Bool_true/type-wf Bool_true/positivity Bool/decl Bool_true/eisl Bool_true/fuo).

%% recursor Bool.rec
Bool_rec/type-wf-sort : lvl
   = (limax
       (limax (lsucc lzero) (lsucc (lvar liz)))
       (limax (lvar liz) (limax (lvar liz) (limax (lsucc lzero) (lvar liz))))).

Bool_rec/type-wf : of (eforall (eforall (econst "Bool" lnil) ([x] (esort (lvar liz))))
                     ([x]
                       (eforall (eapp x (econst "Bool.false" lnil))
                         ([y] (eforall (eapp x (econst "Bool.true" lnil)) ([z] (eforall (econst "Bool" lnil) ([w] (eapp x w))))))))) (esort Bool_rec/type-wf-sort)
   = (defeq/forall
       (defeq/forall
         (defeq/const Bool/decl (inst-expr/sort (lvl-inst/succ lvl-inst/zero)))
         ([x] ([h] defeq/sort-refl)))
       ([x]
         ([h]
           (defeq/forall
             (defeq/app
               h
               (defeq/const Bool_false/decl (inst-expr/const lvls-inst/nil)))
             ([y]
               ([h1]
                 (defeq/forall
                   (defeq/app
                     h
                     (defeq/const
                       Bool_true/decl
                       (inst-expr/const lvls-inst/nil)))
                   ([z]
                     ([h2]
                       (defeq/forall
                         (defeq/const
                           Bool/decl
                           (inst-expr/sort (lvl-inst/succ lvl-inst/zero)))
                         ([w] ([h3] (defeq/app h h3))))))))))))).

Bool_rec/decl : declared "Bool.rec" (eforall (eforall (econst "Bool" lnil) ([x] (esort (lvar liz))))
                                      ([x] (eforall (eapp x (econst "Bool.false" lnil)) ([y] (eforall (eapp x (econst "Bool.true" lnil)) ([z] (eforall (econst "Bool" lnil) ([w] (eapp x w))))))))) irec
   = declared/ok-irec Bool/rec-name (dkind-ok/irec Bool_rec/type-wf).

%% inductive T
T/type-wf-sort : lvl
   = (lsucc (lsucc lzero)).

T/type-wf : of (esort (lsucc lzero)) (esort T/type-wf-sort)
   = defeq/sort-refl.

T/ends-in-sort : ends-in-sort (esort (lsucc lzero))
   = ends-in-sort/sort.

T/rec-name : name "T.rec" (is-rec-for "T").

T/name : name "T" (is-decl (esort (lsucc lzero)) indt).

T/decl : declared "T" (esort (lsucc lzero)) indt
   = declared/ok T/name (dkind-ok/indt T/type-wf T/ends-in-sort).

%% ctor T.mk (of T)
T_mk/type-wf-sort : lvl
   = (limax (lsucc lzero) (limax lzero (lsucc lzero))).

T_mk/type-wf : of (eforall (econst "Bool" lnil) ([x] (eforall (econst "True" lnil) ([y] (econst "T" lnil))))) (esort T_mk/type-wf-sort)
   = (defeq/forall
       (defeq/const Bool/decl (inst-expr/sort (lvl-inst/succ lvl-inst/zero)))
       ([x]
         ([h]
           (defeq/forall
             (defeq/const True/decl (inst-expr/sort lvl-inst/zero))
             ([y]
               ([h1]
                 (defeq/const
                   T/decl
                   (inst-expr/sort (lvl-inst/succ lvl-inst/zero))))))))).

T_mk/positivity : ctor-positive "T" lnil (eforall (econst "Bool" lnil) ([x] (eforall (econst "True" lnil) ([y] (econst "T" lnil)))))
   = (ctor-positive/intro ([S] (eforall (econst "Bool" lnil) ([x] (eforall (econst "True" lnil) ([y] S))))) (ctor-spine/arg
       (strict-pos/no-occur (econst "Bool" lnil) (no-self-ref/const sneq/0))
       ([x]
         ([y]
           (ctor-spine/arg
             (strict-pos/no-occur
               (econst "True" lnil)
               (no-self-ref/const sneq/1))
             ([z] ([w] (ctor-spine/result applies-self/refl)))))))).

T_mk/eisl : ends-in-sort-with-level (esort (lsucc lzero)) (lsucc lzero)
   = ends-in-sort-with-level/sort.

%%% HOLE: T_mk/fuo — prover for field-universes-ok-skip-params not yet implemented
T_mk/fuo : field-universes-ok-skip-params liz (eforall (econst "Bool" lnil) ([x] (eforall (econst "True" lnil) ([y] (econst "T" lnil))))) (lsucc lzero).

T_mk/name : name "T.mk" (is-decl (eforall (econst "Bool" lnil) ([x] (eforall (econst "True" lnil) ([y] (econst "T" lnil))))) ctor).

T_mk/decl : declared "T.mk" (eforall (econst "Bool" lnil) ([x] (eforall (econst "True" lnil) ([y] (econst "T" lnil))))) ctor
   = declared/ok T_mk/name (dkind-ok/ctor T_mk/type-wf T_mk/positivity T/decl T_mk/eisl T_mk/fuo).

%% recursor T.rec
T_rec/type-wf-sort : lvl
   = (limax
       (limax (lsucc lzero) (lsucc (lvar liz)))
       (limax
         (limax (lsucc lzero) (limax lzero (lvar liz)))
         (limax (lsucc lzero) (lvar liz)))).

T_rec/type-wf : of (eforall (eforall (econst "T" lnil) ([x] (esort (lvar liz))))
                  ([x]
                    (eforall (eforall (econst "Bool" lnil) ([y] (eforall (econst "True" lnil) ([z] (eapp x (eapp (eapp (econst "T.mk" lnil) y) z))))))
                      ([y] (eforall (econst "T" lnil) ([z] (eapp x z))))))) (esort T_rec/type-wf-sort)
   = (defeq/forall
       (defeq/forall
         (defeq/const T/decl (inst-expr/sort (lvl-inst/succ lvl-inst/zero)))
         ([x] ([h] defeq/sort-refl)))
       ([x]
         ([h]
           (defeq/forall
             (defeq/forall
               (defeq/const
                 Bool/decl
                 (inst-expr/sort (lvl-inst/succ lvl-inst/zero)))
               ([y]
                 ([h1]
                   (defeq/forall
                     (defeq/const True/decl (inst-expr/sort lvl-inst/zero))
                     ([z]
                       ([h2]
                         (defeq/app
                           h
                           (defeq/app
                             (defeq/app
                               (defeq/const
                                 T_mk/decl
                                 (inst-expr/forall
                                   (inst-expr/const lvls-inst/nil)
                                   ([x]
                                     ([h]
                                       (inst-expr/forall
                                         (inst-expr/const lvls-inst/nil)
                                         ([y]
                                           ([h1]
                                             (inst-expr/const
                                               lvls-inst/nil))))))))
                               h1)
                             h2))))))))
             ([y]
               ([h1]
                 (defeq/forall
                   (defeq/const
                     T/decl
                     (inst-expr/sort (lvl-inst/succ lvl-inst/zero)))
                   ([z] ([h2] (defeq/app h h2)))))))))).

T_rec/decl : declared "T.rec" (eforall (eforall (econst "T" lnil) ([x] (esort (lvar liz))))
                                ([x]
                                  (eforall (eforall (econst "Bool" lnil) ([y] (eforall (econst "True" lnil) ([z] (eapp x (eapp (eapp (econst "T.mk" lnil) y) z))))))
                                    ([y] (eforall (econst "T" lnil) ([z] (eapp x z))))))) irec
   = declared/ok-irec T/rec-name (dkind-ok/irec T_rec/type-wf).

%% inductive Eq
Eq/type-wf-sort : lvl
   = (limax
       (lsucc (lvar liz))
       (limax (lvar liz) (limax (lvar liz) (lsucc lzero)))).

Eq/type-wf : of (eforall (esort (lvar liz)) ([x] (eforall x ([y] (eforall x ([z] (esort lzero))))))) (esort Eq/type-wf-sort)
   = (defeq/forall
       defeq/sort-refl
       ([x]
         ([h]
           (defeq/forall
             h
             ([y] ([h1] (defeq/forall h ([z] ([h2] defeq/sort-refl))))))))).

Eq/ends-in-sort : ends-in-sort (eforall (esort (lvar liz)) ([x] (eforall x ([y] (eforall x ([z] (esort lzero)))))))
   = (ends-in-sort/forall
       ([x]
         (ends-in-sort/forall
           ([y] (ends-in-sort/forall ([z] ends-in-sort/sort)))))).

Eq/rec-name : name "Eq.rec" (is-rec-for "Eq").

Eq/name : name "Eq" (is-decl (eforall (esort (lvar liz)) ([x] (eforall x ([y] (eforall x ([z] (esort lzero))))))) indt).

Eq/decl : declared "Eq" (eforall (esort (lvar liz)) ([x] (eforall x ([y] (eforall x ([z] (esort lzero))))))) indt
   = declared/ok Eq/name (dkind-ok/indt Eq/type-wf Eq/ends-in-sort).

%% ctor Eq.refl (of Eq)
Eq_refl/type-wf-sort : lvl
   = (limax (lsucc (lvar liz)) (limax (lvar liz) lzero)).

Eq_refl/type-wf : of (eforall (esort (lvar liz)) ([x] (eforall x ([y] (eapp (eapp (eapp (econst "Eq" (lcons (lvar liz) lnil)) x) y) y))))) (esort Eq_refl/type-wf-sort)
   = (defeq/forall
       defeq/sort-refl
       ([x]
         ([h]
           (defeq/forall
             h
             ([y]
               ([h1]
                 (defeq/app
                   (defeq/app
                     (defeq/app
                       (defeq/const
                         Eq/decl
                         (inst-expr/forall
                           (inst-expr/sort (lvl-inst/var lvl-nth/zero))
                           ([x]
                             ([h]
                               (inst-expr/forall
                                 h
                                 ([y]
                                   ([h1]
                                     (inst-expr/forall
                                       h
                                       ([z]
                                         ([h2]
                                           (inst-expr/sort
                                             lvl-inst/zero)))))))))))
                       h)
                     h1)
                   h1))))))).

Eq_refl/positivity : ctor-positive "Eq" (lcons (lvar liz) lnil) (eforall (esort (lvar liz)) ([x] (eforall x ([y] (eapp (eapp (eapp (econst "Eq" (lcons (lvar liz) lnil)) x) y) y)))))
   = (ctor-positive/intro ([S] (eforall (esort (lvar liz)) ([x] (eforall x ([y] (eapp (eapp (eapp S x) y) y)))))) (ctor-spine/arg
       (strict-pos/no-occur (esort (lvar liz)) no-self-ref/sort)
       ([x]
         ([y]
           (ctor-spine/arg
             (strict-pos/no-occur x y)
             ([z]
               ([w]
                 (ctor-spine/result
                   (applies-self/app
                     (applies-self/app
                       (applies-self/app applies-self/refl))))))))))).

Eq_refl/eisl : ends-in-sort-with-level (eforall (esort (lvar liz)) ([x] (eforall x ([y] (eforall x ([z] (esort lzero))))))) lzero
   = (ends-in-sort-with-level/forall
       ([x]
         (ends-in-sort-with-level/forall
           ([y]
             (ends-in-sort-with-level/forall
               ([z] ends-in-sort-with-level/sort)))))).

%%% HOLE: Eq_refl/fuo — prover for field-universes-ok-skip-params not yet implemented
Eq_refl/fuo : field-universes-ok-skip-params (lis (lis liz)) (eforall (esort (lvar liz)) ([x] (eforall x ([y] (eapp (eapp (eapp (econst "Eq" (lcons (lvar liz) lnil)) x) y) y))))) lzero.

Eq_refl/name : name "Eq.refl" (is-decl (eforall (esort (lvar liz)) ([x] (eforall x ([y] (eapp (eapp (eapp (econst "Eq" (lcons (lvar liz) lnil)) x) y) y))))) ctor).

Eq_refl/decl : declared "Eq.refl" (eforall (esort (lvar liz)) ([x] (eforall x ([y] (eapp (eapp (eapp (econst "Eq" (lcons (lvar liz) lnil)) x) y) y))))) ctor
   = declared/ok Eq_refl/name (dkind-ok/ctor Eq_refl/type-wf Eq_refl/positivity Eq/decl Eq_refl/eisl Eq_refl/fuo).

%% recursor Eq.rec
Eq_rec/type-wf-sort : lvl
   = (limax
       (lsucc (lvar (lis liz)))
       (limax
         (lvar (lis liz))
         (limax
           (limax (lvar (lis liz)) (limax lzero (lsucc (lvar liz))))
           (limax
             (lvar liz)
             (limax (lvar (lis liz)) (limax lzero (lvar liz))))))).

Eq_rec/type-wf : of (eforall (esort (lvar (lis liz)))
                   ([x]
                     (eforall x
                       ([y]
                         (eforall (eforall x ([z] (eforall (eapp (eapp (eapp (econst "Eq" (lcons (lvar (lis liz)) lnil)) x) y) z) ([w] (esort (lvar liz))))))
                           ([z]
                             (eforall (eapp (eapp z y) (eapp (eapp (econst "Eq.refl" (lcons (lvar (lis liz)) lnil)) x) y))
                               ([w]
                                 (eforall x ([x1] (eforall (eapp (eapp (eapp (econst "Eq" (lcons (lvar (lis liz)) lnil)) x) y) x1) ([y1] (eapp (eapp z x1) y1))))))))))))) (esort Eq_rec/type-wf-sort)
   = (defeq/forall
       defeq/sort-refl
       ([x]
         ([h]
           (defeq/forall
             h
             ([y]
               ([h1]
                 (defeq/forall
                   (defeq/forall
                     h
                     ([z]
                       ([h2]
                         (defeq/forall
                           (defeq/app
                             (defeq/app
                               (defeq/app
                                 (defeq/const
                                   Eq/decl
                                   (inst-expr/forall
                                     (inst-expr/sort
                                       (lvl-inst/var lvl-nth/zero))
                                     ([x]
                                       ([h]
                                         (inst-expr/forall
                                           h
                                           ([y]
                                             ([h1]
                                               (inst-expr/forall
                                                 h
                                                 ([z]
                                                   ([h2]
                                                     (inst-expr/sort
                                                       lvl-inst/zero)))))))))))
                                 h)
                               h1)
                             h2)
                           ([w] ([h3] defeq/sort-refl))))))
                   ([z]
                     ([h2]
                       (defeq/forall
                         (defeq/app
                           (defeq/app h2 h1)
                           (defeq/app
                             (defeq/app
                               (defeq/const
                                 Eq_refl/decl
                                 (inst-expr/forall
                                   (inst-expr/sort (lvl-inst/var lvl-nth/zero))
                                   ([x]
                                     ([h]
                                       (inst-expr/forall
                                         h
                                         ([y]
                                           ([h1]
                                             (inst-expr/app
                                               (inst-expr/app
                                                 (inst-expr/app
                                                   (inst-expr/const
                                                     (lvls-inst/cons
                                                       (lvl-inst/var
                                                         lvl-nth/zero)
                                                       lvls-inst/nil))
                                                   h)
                                                 h1)
                                               h1))))))))
                               h)
                             h1))
                         ([w]
                           ([h3]
                             (defeq/forall
                               h
                               ([x1]
                                 ([h4]
                                   (defeq/forall
                                     (defeq/app
                                       (defeq/app
                                         (defeq/app
                                           (defeq/const
                                             Eq/decl
                                             (inst-expr/forall
                                               (inst-expr/sort
                                                 (lvl-inst/var lvl-nth/zero))
                                               ([x]
                                                 ([h]
                                                   (inst-expr/forall
                                                     h
                                                     ([y]
                                                       ([h1]
                                                         (inst-expr/forall
                                                           h
                                                           ([z]
                                                             ([h2]
                                                               (inst-expr/sort
                                                                 lvl-inst/zero)))))))))))
                                           h)
                                         h1)
                                       h4)
                                     ([y1]
                                       ([h5]
                                         (defeq/app
                                           (defeq/app h2 h4)
                                           h5))))))))))))))))))).

Eq_rec/decl : declared "Eq.rec" (eforall (esort (lvar (lis liz)))
                                  ([x]
                                    (eforall x
                                      ([y]
                                        (eforall (eforall x ([z] (eforall (eapp (eapp (eapp (econst "Eq" (lcons (lvar (lis liz)) lnil)) x) y) z) ([w] (esort (lvar liz))))))
                                          ([z]
                                            (eforall (eapp (eapp z y) (eapp (eapp (econst "Eq.refl" (lcons (lvar (lis liz)) lnil)) x) y))
                                              ([w] (eforall x ([x1] (eforall (eapp (eapp (eapp (econst "Eq" (lcons (lvar (lis liz)) lnil)) x) y) x1) ([y1] (eapp (eapp z x1) y1))))))))))))) irec
   = declared/ok-irec Eq/rec-name (dkind-ok/irec Eq_rec/type-wf).

%% def T.val
T_val/type-wf-sort : lvl
   = (limax (lsucc lzero) (lsucc lzero)).

T_val/type-wf : of (eforall (econst "T" lnil) ([x] (econst "Bool" lnil))) (esort T_val/type-wf-sort)
   = (defeq/forall
       (defeq/const T/decl (inst-expr/sort (lvl-inst/succ lvl-inst/zero)))
       ([x]
         ([h]
           (defeq/const
             Bool/decl
             (inst-expr/sort (lvl-inst/succ lvl-inst/zero)))))).

%%% HOLE
T_val/value-typed : of (elam (econst "T" lnil) ([x] (eproj "T" 0 x))) (eforall (econst "T" lnil) ([x] (econst "Bool" lnil))).

T_val/name : name "T.val" (is-decl (eforall (econst "T" lnil) ([x] (econst "Bool" lnil))) (defn (elam (econst "T" lnil) ([x] (eproj "T" 0 x))))).

T_val/decl : declared "T.val" (eforall (econst "T" lnil) ([x] (econst "Bool" lnil))) (defn (elam (econst "T" lnil) ([x] (eproj "T" 0 x))))
   = declared/ok T_val/name (dkind-ok/defn T_val/type-wf T_val/value-typed).

%% def etaCtor
etaCtor/type-wf-sort : lvl
   = (limax (limax lzero (lsucc lzero)) lzero).

etaCtor/type-wf : of (eforall (eforall (econst "True" lnil) ([x] (econst "T" lnil)))
                    ([x]
                      (eapp (eapp (eapp (econst "Eq" (lcons (lsucc lzero) lnil)) (eforall (econst "True" lnil) ([y] (econst "T" lnil))))
                        (eapp (econst "T.mk" lnil) (eapp (econst "T.val" lnil) (eapp x (econst "True.intro" lnil)))))
                        x))) (esort etaCtor/type-wf-sort)
   = (defeq/forall
       (defeq/forall
         (defeq/const True/decl (inst-expr/sort lvl-inst/zero))
         ([x]
           ([h]
             (defeq/const
               T/decl
               (inst-expr/sort (lvl-inst/succ lvl-inst/zero))))))
       ([x]
         ([h]
           (defeq/app
             (defeq/app
               (defeq/app
                 (defeq/const
                   Eq/decl
                   (inst-expr/forall
                     (inst-expr/sort (lvl-inst/var lvl-nth/zero))
                     ([x]
                       ([h]
                         (inst-expr/forall
                           h
                           ([y]
                             ([h1]
                               (inst-expr/forall
                                 h
                                 ([z]
                                   ([h2]
                                     (inst-expr/sort lvl-inst/zero)))))))))))
                 (defeq/conv
                   (defeq/sort-eq
                     (lvl-eq/le
                       (mleq/imax-lsL
                         (mleq/sR
                           (mleq/maxL
                             (mleq/self nonneg_1)
                             (mleq/sL (mleq/self nonneg_0)))))
                       (mleq/sL
                         (mleq/imax-lsR
                           (mleq/maxR-r (mleq/sR (mleq/self nonneg_0)))))))
                   (defeq/forall
                     (defeq/const True/decl (inst-expr/sort lvl-inst/zero))
                     ([y]
                       ([h1]
                         (defeq/const
                           T/decl
                           (inst-expr/sort (lvl-inst/succ lvl-inst/zero))))))))
               (defeq/app
                 (defeq/const
                   T_mk/decl
                   (inst-expr/forall
                     (inst-expr/const lvls-inst/nil)
                     ([x]
                       ([h]
                         (inst-expr/forall
                           (inst-expr/const lvls-inst/nil)
                           ([y] ([h1] (inst-expr/const lvls-inst/nil))))))))
                 (defeq/app
                   (defeq/const
                     T_val/decl
                     (inst-expr/forall
                       (inst-expr/const lvls-inst/nil)
                       ([x] ([h] (inst-expr/const lvls-inst/nil)))))
                   (defeq/app
                     h
                     (defeq/const
                       True_intro/decl
                       (inst-expr/const lvls-inst/nil))))))
             h)))).

%%% HOLE
etaCtor/value-typed : of (elam (eforall (econst "True" lnil) ([x] (econst "T" lnil)))
                        ([x]
                          (eapp (eapp (econst "Eq.refl" (lcons (lsucc lzero) lnil)) (eforall (econst "True" lnil) ([y] (econst "T" lnil))))
                            x))) (eforall (eforall (econst "True" lnil) ([x] (econst "T" lnil)))
                        ([x]
                          (eapp (eapp (eapp (econst "Eq" (lcons (lsucc lzero) lnil)) (eforall (econst "True" lnil) ([y] (econst "T" lnil))))
                            (eapp (econst "T.mk" lnil) (eapp (econst "T.val" lnil) (eapp x (econst "True.intro" lnil)))))
                            x))).

etaCtor/name : name "etaCtor" (is-decl (eforall (eforall (econst "True" lnil) ([x] (econst "T" lnil)))
                                         ([x]
                                           (eapp (eapp (eapp (econst "Eq" (lcons (lsucc lzero) lnil)) (eforall (econst "True" lnil) ([y] (econst "T" lnil))))
                                             (eapp (econst "T.mk" lnil) (eapp (econst "T.val" lnil) (eapp x (econst "True.intro" lnil)))))
                                             x))) (defn (elam (eforall (econst "True" lnil) ([x] (econst "T" lnil))) ([x] (eapp (eapp (econst "Eq.refl" (lcons (lsucc lzero) lnil)) (eforall (econst "True" lnil) ([y] (econst "T" lnil)))) x))))).

etaCtor/decl : declared "etaCtor" (eforall (eforall (econst "True" lnil) ([x] (econst "T" lnil)))
                                    ([x]
                                      (eapp (eapp (eapp (econst "Eq" (lcons (lsucc lzero) lnil)) (eforall (econst "True" lnil) ([y] (econst "T" lnil))))
                                        (eapp (econst "T.mk" lnil) (eapp (econst "T.val" lnil) (eapp x (econst "True.intro" lnil)))))
                                        x))) (defn (elam (eforall (econst "True" lnil) ([x] (econst "T" lnil))) ([x] (eapp (eapp (econst "Eq.refl" (lcons (lsucc lzero) lnil)) (eforall (econst "True" lnil) ([y] (econst "T" lnil)))) x))))
   = declared/ok etaCtor/name (dkind-ok/defn etaCtor/type-wf etaCtor/value-typed).
