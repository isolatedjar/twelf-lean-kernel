%%% Expected outcome: reject
%%% Corner case for function eta:
%%% Does a defeq between a partially applied constructor trigger eta expansion?
%%% 
%%% Taking the official kernel as the specification, the answer is no.
%%% See <https://github.com/leanprover/lean4/issues/12520> for a discussion.
sneq/0 : string-neq "Bool.false" "Bool.true".
sneq/1 : string-neq "Bool" "T".
sneq/2 : string-neq "True" "T".

%% inductive True
True/type-wf : of (esort lzero) (esort (lsucc lzero))
   = defeq/sort-refl.

True/ends-in-sort : ends-in-sort (esort lzero)
   = ends-in-sort/sort.

True/rec-name : name "True.rec" (is-rec-for "True").

True/eisl : ends-in-sort-with-level (esort lzero) lzero
   = ends-in-sort-with-level/sort.

True/cnd : cnames-distinct (ccons "True.intro" cnil)
   = (cnames-distinct/cons cnames-distinct/nil all-string-neq/nil).

True/name : name "True" (is-decl (esort lzero) (indt (ccons "True.intro" cnil) z)).

True/decl : declared "True" (esort lzero) (indt (ccons "True.intro" cnil) z)
   = declared/ok-indt True/name True/rec-name True/cnd (dkind-ok/indt True/type-wf True/ends-in-sort).

%% ctor True.intro (of True)
True_intro/type-wf : of (econst "True" lnil) (esort lzero)
   = (defeq/const True/decl (inst-expr/sort inst-lvl/zero)).

True_intro/positivity : ctor-positive "True" lnil (econst "True" lnil)
   = (ctor-positive/intro ([S] S) (ctor-spine/result applies-self/refl)).

True_intro/cmem : cmem "True.intro" (ccons "True.intro" cnil)
   = cmem/here.

True_intro/fuo : field-universes-ok (econst "True" lnil) lzero
   = (field-universes-ok/done not-forall/const).

True_intro/name : name "True.intro" (is-decl (econst "True" lnil) (ctor "True" z)).

True_intro/decl : declared "True.intro" (econst "True" lnil) (ctor "True" z)
   = declared/ok-ctor True_intro/name True/name True_intro/cmem True/eisl True_intro/fuo (dkind-ok/ctor True_intro/type-wf True_intro/positivity).

%% recursor True.rec (TCB-derived; informational only)
%%   level params: u
%%   type:   (eforall (eforall (econst "True" lnil) ([x] (esort (lvar z)))) ([x] (eforall (eapp x (econst "True.intro" lnil)) ([y] (eforall (econst "True" lnil) ([w] (eapp x w)))))))
%%   rules:
%%     True.rec … True.intro … = (elam (eforall (econst "True" lnil) ([x] (esort (lvar z)))) ([x] (elam (eapp x (econst "True.intro" lnil)) ([y] y))))   (0 fields)
%%   K-like reduction: yes

%% inductive Bool
Bool/type-wf : of (esort (lsucc lzero)) (esort (lsucc (lsucc lzero)))
   = defeq/sort-refl.

Bool/ends-in-sort : ends-in-sort (esort (lsucc lzero))
   = ends-in-sort/sort.

Bool/rec-name : name "Bool.rec" (is-rec-for "Bool").

Bool/eisl : ends-in-sort-with-level (esort (lsucc lzero)) (lsucc lzero)
   = ends-in-sort-with-level/sort.

Bool/cnd : cnames-distinct (ccons "Bool.false" (ccons "Bool.true" cnil))
   = (cnames-distinct/cons
       (cnames-distinct/cons cnames-distinct/nil all-string-neq/nil)
       (all-string-neq/cons sneq/0 all-string-neq/nil)).

Bool/name : name "Bool" (is-decl (esort (lsucc lzero)) (indt (ccons "Bool.false" (ccons "Bool.true" cnil)) z)).

Bool/decl : declared "Bool" (esort (lsucc lzero)) (indt (ccons "Bool.false" (ccons "Bool.true" cnil)) z)
   = declared/ok-indt Bool/name Bool/rec-name Bool/cnd (dkind-ok/indt Bool/type-wf Bool/ends-in-sort).

%% ctor Bool.false (of Bool)
Bool_false/type-wf : of (econst "Bool" lnil) (esort (lsucc lzero))
   = (defeq/const Bool/decl (inst-expr/sort (inst-lvl/succ inst-lvl/zero))).

Bool_false/positivity : ctor-positive "Bool" lnil (econst "Bool" lnil)
   = (ctor-positive/intro ([S] S) (ctor-spine/result applies-self/refl)).

Bool_false/cmem : cmem "Bool.false" (ccons "Bool.false" (ccons "Bool.true" cnil))
   = cmem/here.

Bool_false/fuo : field-universes-ok (econst "Bool" lnil) (lsucc lzero)
   = (field-universes-ok/done not-forall/const).

Bool_false/name : name "Bool.false" (is-decl (econst "Bool" lnil) (ctor "Bool" z)).

Bool_false/decl : declared "Bool.false" (econst "Bool" lnil) (ctor "Bool" z)
   = declared/ok-ctor Bool_false/name Bool/name Bool_false/cmem Bool/eisl Bool_false/fuo (dkind-ok/ctor Bool_false/type-wf Bool_false/positivity).

%% ctor Bool.true (of Bool)
Bool_true/type-wf : of (econst "Bool" lnil) (esort (lsucc lzero))
   = (defeq/const Bool/decl (inst-expr/sort (inst-lvl/succ inst-lvl/zero))).

Bool_true/positivity : ctor-positive "Bool" lnil (econst "Bool" lnil)
   = (ctor-positive/intro ([S] S) (ctor-spine/result applies-self/refl)).

Bool_true/cmem : cmem "Bool.true" (ccons "Bool.false" (ccons "Bool.true" cnil))
   = (cmem/there cmem/here).

Bool_true/fuo : field-universes-ok (econst "Bool" lnil) (lsucc lzero)
   = (field-universes-ok/done not-forall/const).

Bool_true/name : name "Bool.true" (is-decl (econst "Bool" lnil) (ctor "Bool" (s z))).

Bool_true/decl : declared "Bool.true" (econst "Bool" lnil) (ctor "Bool" (s z))
   = declared/ok-ctor Bool_true/name Bool/name Bool_true/cmem Bool/eisl Bool_true/fuo (dkind-ok/ctor Bool_true/type-wf Bool_true/positivity).

%% recursor Bool.rec (TCB-derived; informational only)
%%   level params: u
%%   type:   (eforall (eforall (econst "Bool" lnil) ([x] (esort (lvar z)))) ([x] (eforall (eapp x (econst "Bool.false" lnil)) ([y] (eforall (eapp x (econst "Bool.true" lnil)) ([w] (eforall (econst "Bool" lnil) ([v] (eapp x v)))))))))
%%   rules:
%%     Bool.rec … Bool.false … = (elam (eforall (econst "Bool" lnil) ([x] (esort (lvar z)))) ([x] (elam (eapp x (econst "Bool.false" lnil)) ([y] (elam (eapp x (econst "Bool.true" lnil)) ([w] y))))))   (0 fields)
%%     Bool.rec … Bool.true … = (elam (eforall (econst "Bool" lnil) ([x] (esort (lvar z)))) ([x] (elam (eapp x (econst "Bool.false" lnil)) ([y] (elam (eapp x (econst "Bool.true" lnil)) ([w] w))))))   (0 fields)

%% inductive T
T/type-wf : of (esort (lsucc lzero)) (esort (lsucc (lsucc lzero)))
   = defeq/sort-refl.

T/ends-in-sort : ends-in-sort (esort (lsucc lzero))
   = ends-in-sort/sort.

T/rec-name : name "T.rec" (is-rec-for "T").

T/eisl : ends-in-sort-with-level (esort (lsucc lzero)) (lsucc lzero)
   = ends-in-sort-with-level/sort.

T/cnd : cnames-distinct (ccons "T.mk" cnil)
   = (cnames-distinct/cons cnames-distinct/nil all-string-neq/nil).

T/name : name "T" (is-decl (esort (lsucc lzero)) (indt (ccons "T.mk" cnil) z)).

T/decl : declared "T" (esort (lsucc lzero)) (indt (ccons "T.mk" cnil) z)
   = declared/ok-indt T/name T/rec-name T/cnd (dkind-ok/indt T/type-wf T/ends-in-sort).

%% ctor T.mk (of T)
T_mk/type-wf : of (eforall (econst "Bool" lnil) ([x] (eforall (econst "True" lnil) ([y] (econst "T" lnil))))) (esort (limax (lsucc lzero) (limax lzero (lsucc lzero))))
   = (defeq/forall
       (defeq/const Bool/decl (inst-expr/sort (inst-lvl/succ inst-lvl/zero)))
       ([x]
         ([h]
           (defeq/forall
             (defeq/const True/decl (inst-expr/sort inst-lvl/zero))
             ([y]
               ([h1]
                 (defeq/const
                   T/decl
                   (inst-expr/sort (inst-lvl/succ inst-lvl/zero))))))))).

T_mk/positivity : ctor-positive "T" lnil (eforall (econst "Bool" lnil) ([x] (eforall (econst "True" lnil) ([y] (econst "T" lnil)))))
   = (ctor-positive/intro ([S] (eforall (econst "Bool" lnil) ([x] (eforall (econst "True" lnil) ([y] S))))) (ctor-spine/arg
       (strict-pos/no-occur (econst "Bool" lnil) (no-self-ref/const sneq/1))
       ([x]
         ([y]
           (ctor-spine/arg
             (strict-pos/no-occur
               (econst "True" lnil)
               (no-self-ref/const sneq/2))
             ([w] ([v] (ctor-spine/result applies-self/refl)))))))).

T_mk/cmem : cmem "T.mk" (ccons "T.mk" cnil)
   = cmem/here.

T_mk/fuo : field-universes-ok (eforall (econst "Bool" lnil) ([x] (eforall (econst "True" lnil) ([y] (econst "T" lnil))))) (lsucc lzero)
   = (field-universes-ok/forall
       (defeq/const Bool/decl (inst-expr/sort (inst-lvl/succ inst-lvl/zero)))
       (leq-lvl/imaxLs
         (leq-lvl/sR
           (leq-lvl/maxL (leq-lvl/sL leq-lvl/self) (leq-lvl/sL leq-lvl/self))))
       ([x]
         ([h]
           (field-universes-ok/forall
             (defeq/const True/decl (inst-expr/sort inst-lvl/zero))
             (leq-lvl/imaxLs
               (leq-lvl/sR
                 (leq-lvl/maxL (leq-lvl/sL leq-lvl/self) leq-lvl/self)))
             ([y] ([h1] (field-universes-ok/done not-forall/const))))))).

T_mk/name : name "T.mk" (is-decl (eforall (econst "Bool" lnil) ([x] (eforall (econst "True" lnil) ([y] (econst "T" lnil))))) (ctor "T" z)).

T_mk/decl : declared "T.mk" (eforall (econst "Bool" lnil) ([x] (eforall (econst "True" lnil) ([y] (econst "T" lnil))))) (ctor "T" z)
   = declared/ok-ctor T_mk/name T/name T_mk/cmem T/eisl T_mk/fuo (dkind-ok/ctor T_mk/type-wf T_mk/positivity).

%% recursor T.rec (TCB-derived; informational only)
%%   level params: u
%%   type:   (eforall (eforall (econst "T" lnil) ([x] (esort (lvar z)))) ([x] (eforall (eforall (econst "Bool" lnil) ([y] (eforall (econst "True" lnil) ([w] (eapp x (eapp (eapp (econst "T.mk" lnil) y) w)))))) ([y] (eforall (econst "T" lnil) ([w] (eapp x w)))))))
%%   rules:
%%     T.rec … T.mk … = (elam (eforall (econst "T" lnil) ([x] (esort (lvar z)))) ([x] (elam (eforall (econst "Bool" lnil) ([y] (eforall (econst "True" lnil) ([w] (eapp x (eapp (eapp (econst "T.mk" lnil) y) w)))))) ([y] (elam (econst "Bool" lnil) ([w] (elam (econst "True" lnil) ([v] (eapp (eapp y w) v)))))))))   (2 fields)

%% inductive Eq
Eq/type-wf : of (eforall (esort (lvar z)) ([x] (eforall x ([y] (eforall x ([w] (esort lzero))))))) (esort (limax (lsucc (lvar z)) (limax (lvar z) (limax (lvar z) (lsucc lzero)))))
   = (defeq/forall
       defeq/sort-refl
       ([x]
         ([h]
           (defeq/forall
             h
             ([y] ([h1] (defeq/forall h ([w] ([h2] defeq/sort-refl))))))))).

Eq/ends-in-sort : ends-in-sort (eforall (esort (lvar z)) ([x] (eforall x ([y] (eforall x ([w] (esort lzero)))))))
   = (ends-in-sort/forall
       ([x]
         (ends-in-sort/forall
           ([y] (ends-in-sort/forall ([w] ends-in-sort/sort)))))).

Eq/rec-name : name "Eq.rec" (is-rec-for "Eq").

Eq/eisl : ends-in-sort-with-level (eforall (esort (lvar z)) ([x] (eforall x ([y] (eforall x ([w] (esort lzero))))))) lzero
   = (ends-in-sort-with-level/forall
       ([x]
         (ends-in-sort-with-level/forall
           ([y]
             (ends-in-sort-with-level/forall
               ([w] ends-in-sort-with-level/sort)))))).

Eq/cnd : cnames-distinct (ccons "Eq.refl" cnil)
   = (cnames-distinct/cons cnames-distinct/nil all-string-neq/nil).

Eq/name : name "Eq" (is-decl (eforall (esort (lvar z)) ([x] (eforall x ([y] (eforall x ([w] (esort lzero))))))) (indt (ccons "Eq.refl" cnil) (s (s z)))).

Eq/decl : declared "Eq" (eforall (esort (lvar z)) ([x] (eforall x ([y] (eforall x ([w] (esort lzero))))))) (indt (ccons "Eq.refl" cnil) (s (s z)))
   = declared/ok-indt Eq/name Eq/rec-name Eq/cnd (dkind-ok/indt Eq/type-wf Eq/ends-in-sort).

%% ctor Eq.refl (of Eq)
Eq_refl/type-wf : of (eforall (esort (lvar z)) ([x] (eforall x ([y] (eapp (eapp (eapp (econst "Eq" (lcons (lvar z) lnil)) x) y) y))))) (esort (limax (lsucc (lvar z)) (limax (lvar z) lzero)))
   = (defeq/forall
       defeq/sort-refl
       ([x]
         ([h]
           (defeq/forall
             h
             ([y]
               ([h1]
                 (defeq/app
                   (defeq/app
                     (defeq/app
                       (defeq/const
                         Eq/decl
                         (inst-expr/forall
                           (inst-expr/sort (inst-lvl/var nth-lvl/z))
                           ([x]
                             ([h]
                               (inst-expr/forall
                                 h
                                 ([y]
                                   ([h1]
                                     (inst-expr/forall
                                       h
                                       ([w]
                                         ([h2]
                                           (inst-expr/sort
                                             inst-lvl/zero)))))))))))
                       h)
                     h1)
                   h1))))))).

Eq_refl/positivity : ctor-positive "Eq" (lcons (lvar z) lnil) (eforall (esort (lvar z)) ([x] (eforall x ([y] (eapp (eapp (eapp (econst "Eq" (lcons (lvar z) lnil)) x) y) y)))))
   = (ctor-positive/intro ([S] (eforall (esort (lvar z)) ([x] (eforall x ([y] (eapp (eapp (eapp S x) y) y)))))) (ctor-spine/arg
       (strict-pos/no-occur (esort (lvar z)) no-self-ref/sort)
       ([x]
         ([y]
           (ctor-spine/arg
             (strict-pos/no-occur x y)
             ([w]
               ([v]
                 (ctor-spine/result
                   (applies-self/app
                     (applies-self/app
                       (applies-self/app applies-self/refl))))))))))).

Eq_refl/cmem : cmem "Eq.refl" (ccons "Eq.refl" cnil)
   = cmem/here.

Eq_refl/fuo : field-universes-ok (eforall (esort (lvar z)) ([x] (eforall x ([y] (eapp (eapp (eapp (econst "Eq" (lcons (lvar z) lnil)) x) y) y))))) lzero
   = (field-universes-ok/forall
       defeq/sort-refl
       (leq-lvl/imaxLz leq-lvl/self)
       ([x]
         ([h]
           (field-universes-ok/forall
             h
             (leq-lvl/imaxLz leq-lvl/self)
             ([y] ([h1] (field-universes-ok/done not-forall/app))))))).

Eq_refl/name : name "Eq.refl" (is-decl (eforall (esort (lvar z)) ([x] (eforall x ([y] (eapp (eapp (eapp (econst "Eq" (lcons (lvar z) lnil)) x) y) y))))) (ctor "Eq" z)).

Eq_refl/decl : declared "Eq.refl" (eforall (esort (lvar z)) ([x] (eforall x ([y] (eapp (eapp (eapp (econst "Eq" (lcons (lvar z) lnil)) x) y) y))))) (ctor "Eq" z)
   = declared/ok-ctor Eq_refl/name Eq/name Eq_refl/cmem Eq/eisl Eq_refl/fuo (dkind-ok/ctor Eq_refl/type-wf Eq_refl/positivity).

%% recursor Eq.rec (TCB-derived; informational only)
%%   level params: u u_1
%%   type:   (eforall (esort (lvar (s z))) ([x] (eforall x ([y] (eforall (eforall x ([w] (eforall (eapp (eapp (eapp (econst "Eq" (lcons (lvar (s z)) lnil)) x) y) w) ([v] (esort (lvar z)))))) ([w] (eforall (eapp (eapp w y) (eapp (eapp (econst "Eq.refl" (lcons (lvar (s z)) lnil)) x) y)) ([v] (eforall x ([x1] (eforall (eapp (eapp (eapp (econst "Eq" (lcons (lvar (s z)) lnil)) x) y) x1) ([y1] (eapp (eapp w x1) y1)))))))))))))
%%   rules:
%%     Eq.rec … Eq.refl … = (elam (esort (lvar (s z))) ([x] (elam x ([y] (elam (eforall x ([w] (eforall (eapp (eapp (eapp (econst "Eq" (lcons (lvar (s z)) lnil)) x) y) w) ([v] (esort (lvar z)))))) ([w] (elam (eapp (eapp w y) (eapp (eapp (econst "Eq.refl" (lcons (lvar (s z)) lnil)) x) y)) ([v] v))))))))   (0 fields)
%%   K-like reduction: yes

%% def T.val
T_val/type-wf : of (eforall (econst "T" lnil) ([x] (econst "Bool" lnil))) (esort (limax (lsucc lzero) (lsucc lzero)))
   = (defeq/forall
       (defeq/const T/decl (inst-expr/sort (inst-lvl/succ inst-lvl/zero)))
       ([x]
         ([h]
           (defeq/const
             Bool/decl
             (inst-expr/sort (inst-lvl/succ inst-lvl/zero)))))).

%%% HOLE
T_val/value-typed : of (elam (econst "T" lnil) ([x] (eproj "T" 0 x))) (eforall (econst "T" lnil) ([x] (econst "Bool" lnil))).

T_val/name : name "T.val" (is-decl (eforall (econst "T" lnil) ([x] (econst "Bool" lnil))) (defn (elam (econst "T" lnil) ([x] (eproj "T" 0 x))))).

T_val/decl : declared "T.val" (eforall (econst "T" lnil) ([x] (econst "Bool" lnil))) (defn (elam (econst "T" lnil) ([x] (eproj "T" 0 x))))
   = declared/ok T_val/name dkind-non-inductive/defn (dkind-ok/defn T_val/type-wf T_val/value-typed).

%% def etaCtor
etaCtor/type-wf : of
  (eforall (eforall (econst "True" lnil) ([x] (econst "T" lnil)))
    ([x]
      (eapp (eapp (eapp (econst "Eq" (lcons (lsucc lzero) lnil)) (eforall (econst "True" lnil) ([y] (econst "T" lnil))))
        (eapp (econst "T.mk" lnil) (eapp (econst "T.val" lnil) (eapp x (econst "True.intro" lnil)))))
        x)))
  (esort (limax (limax lzero (lsucc lzero)) lzero))
   = (defeq/forall
       (defeq/forall
         (defeq/const True/decl (inst-expr/sort inst-lvl/zero))
         ([x]
           ([h]
             (defeq/const
               T/decl
               (inst-expr/sort (inst-lvl/succ inst-lvl/zero))))))
       ([x]
         ([h]
           (defeq/app
             (defeq/app
               (defeq/app
                 (defeq/const
                   Eq/decl
                   (inst-expr/forall
                     (inst-expr/sort (inst-lvl/var nth-lvl/z))
                     ([x]
                       ([h]
                         (inst-expr/forall
                           h
                           ([y]
                             ([h1]
                               (inst-expr/forall
                                 h
                                 ([w]
                                   ([h2]
                                     (inst-expr/sort inst-lvl/zero)))))))))))
                 (defeq/conv
                   (defeq/sort-eq
                     (eq-lvl/le
                       (leq-lvl/imaxRs (leq-lvl/maxR2 leq-lvl/self))
                       (leq-lvl/imaxLs
                         (leq-lvl/sR
                           (leq-lvl/maxL
                             (leq-lvl/sL leq-lvl/self)
                             leq-lvl/self)))))
                   (defeq/forall
                     (defeq/const True/decl (inst-expr/sort inst-lvl/zero))
                     ([y]
                       ([h1]
                         (defeq/const
                           T/decl
                           (inst-expr/sort (inst-lvl/succ inst-lvl/zero))))))))
               (defeq/app
                 (defeq/const
                   T_mk/decl
                   (inst-expr/forall
                     (inst-expr/const inst-lvls/nil)
                     ([x]
                       ([h]
                         (inst-expr/forall
                           (inst-expr/const inst-lvls/nil)
                           ([y] ([h1] (inst-expr/const inst-lvls/nil))))))))
                 (defeq/app
                   (defeq/const
                     T_val/decl
                     (inst-expr/forall
                       (inst-expr/const inst-lvls/nil)
                       ([x] ([h] (inst-expr/const inst-lvls/nil)))))
                   (defeq/app
                     h
                     (defeq/const
                       True_intro/decl
                       (inst-expr/const inst-lvls/nil))))))
             h)))).

%%% HOLE
etaCtor/value-typed : of
  (elam (eforall (econst "True" lnil) ([x] (econst "T" lnil))) ([x] (eapp (eapp (econst "Eq.refl" (lcons (lsucc lzero) lnil)) (eforall (econst "True" lnil) ([y] (econst "T" lnil)))) x)))
  (eforall (eforall (econst "True" lnil) ([x] (econst "T" lnil)))
    ([x]
      (eapp (eapp (eapp (econst "Eq" (lcons (lsucc lzero) lnil)) (eforall (econst "True" lnil) ([y] (econst "T" lnil))))
        (eapp (econst "T.mk" lnil) (eapp (econst "T.val" lnil) (eapp x (econst "True.intro" lnil)))))
        x))).

etaCtor/name : name "etaCtor" (is-decl
  (eforall (eforall (econst "True" lnil) ([x] (econst "T" lnil)))
    ([x]
      (eapp (eapp (eapp (econst "Eq" (lcons (lsucc lzero) lnil)) (eforall (econst "True" lnil) ([y] (econst "T" lnil))))
        (eapp (econst "T.mk" lnil) (eapp (econst "T.val" lnil) (eapp x (econst "True.intro" lnil)))))
        x)))
  (defn (elam (eforall (econst "True" lnil) ([x] (econst "T" lnil))) ([x] (eapp (eapp (econst "Eq.refl" (lcons (lsucc lzero) lnil)) (eforall (econst "True" lnil) ([y] (econst "T" lnil)))) x))))).

etaCtor/decl : declared "etaCtor"
  (eforall (eforall (econst "True" lnil) ([x] (econst "T" lnil)))
    ([x]
      (eapp (eapp (eapp (econst "Eq" (lcons (lsucc lzero) lnil)) (eforall (econst "True" lnil) ([y] (econst "T" lnil))))
        (eapp (econst "T.mk" lnil) (eapp (econst "T.val" lnil) (eapp x (econst "True.intro" lnil)))))
        x)))
  (defn (elam (eforall (econst "True" lnil) ([x] (econst "T" lnil))) ([x] (eapp (eapp (econst "Eq.refl" (lcons (lsucc lzero) lnil)) (eforall (econst "True" lnil) ([y] (econst "T" lnil)))) x))))
   = declared/ok etaCtor/name dkind-non-inductive/defn (dkind-ok/defn etaCtor/type-wf etaCtor/value-typed).
