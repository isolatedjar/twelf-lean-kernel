And/rec-name : name "And.rec" (is-rec-for "And").

And/name : name "And" (is-decl (eforall (esort lzero) ([x] (eforall (esort lzero) ([y] (esort lzero))))) indt).

And/decl : declared "And" (eforall (esort lzero) ([x] (eforall (esort lzero) ([y] (esort lzero))))) indt
   = declared/ok And/name (dkind-ok/indt And/type-wf And/ends-in-sort).

