%% recursor Bool.rec
%%% HOLE
Bool_rec/type-wf-sort : lvl.

%%% HOLE
Bool_rec/type-wf : of
  (eforall (eforall (econst "Bool" lnil) ([x] (esort (lvar liz))))
    ([x] (eforall (eapp x (econst "Bool.false" lnil)) ([y] (eforall (eapp x (econst "Bool.true" lnil)) ([z] (eforall (econst "Bool" lnil) ([w] (eapp x w)))))))))
  (esort Bool_rec/type-wf-sort).

Bool_rec/ert : enum-rec-type (eforall (eforall (econst "Bool" lnil) ([x] (esort (lvar liz)))) ([x] (eforall (eapp x (econst "Bool.false" lnil)) ([y] (eforall (eapp x (econst "Bool.true" lnil)) ([z] (eforall (econst "Bool" lnil) ([w] (eapp x w))))))))) "Bool" lnil (ccons "Bool.false" (ccons "Bool.true" cnil)) (lvar liz)
   = (enum-rec-type/intro
       ([x]
         ([h]
           (enum-rec-body/minor
             ([y]
               ([h1] (enum-rec-body/minor ([z] ([h2] enum-rec-body/done))))))))).

Bool_rec/lee : le-eligible (lsucc lzero) (ccons "Bool.false" (ccons "Bool.true" cnil)) (lvar liz)
   = (le-eligible/non-prop (mleq/self nonneg_0)).

Bool_rec/decl : declared "Bool.rec"
  (eforall (eforall (econst "Bool" lnil) ([x] (esort (lvar liz))))
    ([x] (eforall (eapp x (econst "Bool.false" lnil)) ([y] (eforall (eapp x (econst "Bool.true" lnil)) ([z] (eforall (econst "Bool" lnil) ([w] (eapp x w)))))))))
  (irec "Bool")
