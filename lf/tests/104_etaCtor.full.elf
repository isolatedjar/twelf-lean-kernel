%%% Expected outcome: reject
%%% Corner case for function eta:
%%% Does a defeq between a partially applied constructor trigger eta expansion?
%%% 
%%% Taking the official kernel as the specification, the answer is no.
%%% See <https://github.com/leanprover/lean4/issues/12520> for a discussion.
%% inductive True
True/type-wf-sort : lvl
   = (lsucc lzero).

True/type-wf : defeq (esort lzero) (esort lzero) (esort True/type-wf-sort)
   = defeq/sort-refl.

%%% HOLE
True/ends-in-sort : ends-in-sort (esort lzero).

True/name : name "True" (is-decl (esort lzero) indt).

True/decl : declared "True" (esort lzero) indt
   = declared/ok True/name (dkind-ok/indt True/type-wf True/ends-in-sort).

%% ctor True.intro (of True)
%%% HOLE
True_intro/type-wf-sort : lvl.

%%% HOLE
True_intro/type-wf : defeq (econst "True" lnil) (econst "True" lnil) (esort True_intro/type-wf-sort).

%%% HOLE
True_intro/positivity : ctor-positive "True" lnil (econst "True" lnil).

True_intro/name : name "True.intro" (is-decl (econst "True" lnil) ctor).

True_intro/decl : declared "True.intro" (econst "True" lnil) ctor
   = declared/ok True_intro/name (dkind-ok/ctor True_intro/type-wf True_intro/positivity).

%% recursor True.rec
%%% HOLE
True_rec/type-wf-sort : lvl.

%%% HOLE
True_rec/type-wf : defeq (eforall (eforall (econst "True" lnil) ([x] (esort (lvar liz)))) ([x] (eforall (eapp x (econst "True.intro" lnil)) ([y] (eforall (econst "True" lnil) ([z] (eapp x z))))))) (eforall (eforall (econst "True" lnil) ([x] (esort (lvar liz)))) ([x] (eforall (eapp x (econst "True.intro" lnil)) ([y] (eforall (econst "True" lnil) ([z] (eapp x z))))))) (esort True_rec/type-wf-sort).

True_rec/name : name "True.rec" (is-decl (eforall (eforall (econst "True" lnil) ([x] (esort (lvar liz)))) ([x] (eforall (eapp x (econst "True.intro" lnil)) ([y] (eforall (econst "True" lnil) ([z] (eapp x z))))))) irec).

True_rec/decl : declared "True.rec" (eforall (eforall (econst "True" lnil) ([x] (esort (lvar liz)))) ([x] (eforall (eapp x (econst "True.intro" lnil)) ([y] (eforall (econst "True" lnil) ([z] (eapp x z))))))) irec
   = declared/ok True_rec/name (dkind-ok/irec True_rec/type-wf).

%% inductive Bool
Bool/type-wf-sort : lvl
   = (lsucc (lsucc lzero)).

Bool/type-wf : defeq (esort (lsucc lzero)) (esort (lsucc lzero)) (esort Bool/type-wf-sort)
   = defeq/sort-refl.

%%% HOLE
Bool/ends-in-sort : ends-in-sort (esort (lsucc lzero)).

Bool/name : name "Bool" (is-decl (esort (lsucc lzero)) indt).

Bool/decl : declared "Bool" (esort (lsucc lzero)) indt
   = declared/ok Bool/name (dkind-ok/indt Bool/type-wf Bool/ends-in-sort).

