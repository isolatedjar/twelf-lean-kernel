%%% Expected outcome: reject
%%% Corner case for function eta:
%%% Does a defeq between a partially applied constructor trigger eta expansion?
%%% 
%%% Taking the official kernel as the specification, the answer is no.
%%% See <https://github.com/leanprover/lean4/issues/12520> for a discussion.
%% inductive True
%%% HOLE
True/type-wf-sort : lvl.

%%% HOLE
True/type-wf : defeq (esort lzero) (esort lzero) (esort True/type-wf-sort).

%%% HOLE
True/ends-in-sort : ends-in-sort (esort lzero).

True/decl : declared "True" lnil
   (esort lzero)
   indt
   (dkind-ok/indt True/type-wf True/ends-in-sort).

%% ctor True.intro (of True)
%%% HOLE
True_intro/type-wf-sort : lvl.

%%% HOLE
True_intro/type-wf : defeq (econst "True" lnil) (econst "True" lnil) (esort True_intro/type-wf-sort).

%%% HOLE
True_intro/positivity : ctor-positive "True" lnil (econst "True" lnil).

True_intro/decl : declared "True.intro" lnil
   (econst "True" lnil)
   ctor
   (dkind-ok/ctor True_intro/type-wf True_intro/positivity).

%% recursor True.rec
%%% HOLE
True_rec/type-wf-sort : {u : lvl} lvl.

%%% HOLE
True_rec/type-wf : {u : lvl} defeq (eforall (eforall (econst "True" lnil) ([x] (esort u))) ([x] (eforall (eapp x (econst "True.intro" lnil)) ([y] (eforall (econst "True" lnil) ([z] (eapp x z))))))) (eforall (eforall (econst "True" lnil) ([x] (esort u))) ([x] (eforall (eapp x (econst "True.intro" lnil)) ([y] (eforall (econst "True" lnil) ([z] (eapp x z))))))) (esort (True_rec/type-wf-sort u)).

True_rec/decl : {u : lvl} declared "True.rec" (lcons u lnil)
   (eforall (eforall (econst "True" lnil) ([x] (esort u))) ([x] (eforall (eapp x (econst "True.intro" lnil)) ([y] (eforall (econst "True" lnil) ([z] (eapp x z)))))))
   irec
   (dkind-ok/irec (True_rec/type-wf u)).

%% inductive Bool
