%%% Render-only view of: 089_projRed
%%% Projection reductions
%% inductive Eq (numParams=2, numIndices=1)
Eq/render-type : {u_1 : lvl} expr =
   [u_1] (eforall (esort u_1) ([x] (eforall x ([y] (eforall x ([z] (esort lzero))))))).

%% ctor Eq.refl (induct=Eq, numFields=0)
Eq_refl/render-type : {u_1 : lvl} expr =
   [u_1] (eforall (esort u_1) ([x] (eforall x ([y] (eapp (eapp (eapp (econst "Eq" (lcons u_1 lnil)) x) y) y))))).

%% recursor Eq.rec (numMotives=1, numMinors=1, k=true)
Eq_rec/render-type : {u : lvl} {u_1 : lvl} expr =
   [u] [u_1] (eforall (esort u_1) ([x] (eforall x ([y] (eforall (eforall x ([z] (eforall (eapp (eapp (eapp (econst "Eq" (lcons u_1 lnil)) x) y) z) ([w] (esort u))))) ([z] (eforall (eapp (eapp z y) (eapp (eapp (econst "Eq.refl" (lcons u_1 lnil)) x) y)) ([w] (eforall x ([x1] (eforall (eapp (eapp (eapp (econst "Eq" (lcons u_1 lnil)) x) y) x1) ([y1] (eapp (eapp z x1) y1))))))))))))).
%%   rec-rule for Eq.refl (nfields=0)
Eq_rec/render-rule0-rhs : {u : lvl} {u_1 : lvl} expr =
   [u] [u_1] (elam (esort u_1) ([x] (elam x ([y] (elam (eforall x ([z] (eforall (eapp (eapp (eapp (econst "Eq" (lcons u_1 lnil)) x) y) z) ([w] (esort u))))) ([z] (elam (eapp (eapp z y) (eapp (eapp (econst "Eq.refl" (lcons u_1 lnil)) x) y)) ([w] w)))))))).

%% inductive Bool (numParams=0, numIndices=0)
Bool/render-type : expr =
   (esort (lsucc lzero)).

%% ctor Bool.false (induct=Bool, numFields=0)
Bool_false/render-type : expr =
   (econst "Bool" lnil).

%% ctor Bool.true (induct=Bool, numFields=0)
Bool_true/render-type : expr =
   (econst "Bool" lnil).

%% recursor Bool.rec (numMotives=1, numMinors=2, k=false)
Bool_rec/render-type : {u : lvl} expr =
   [u] (eforall (eforall (econst "Bool" lnil) ([x] (esort u))) ([x] (eforall (eapp x (econst "Bool.false" lnil)) ([y] (eforall (eapp x (econst "Bool.true" lnil)) ([z] (eforall (econst "Bool" lnil) ([w] (eapp x w))))))))).
%%   rec-rule for Bool.false (nfields=0)
Bool_rec/render-rule0-rhs : {u : lvl} expr =
   [u] (elam (eforall (econst "Bool" lnil) ([x] (esort u))) ([x] (elam (eapp x (econst "Bool.false" lnil)) ([y] (elam (eapp x (econst "Bool.true" lnil)) ([z] y)))))).
%%   rec-rule for Bool.true (nfields=0)
Bool_rec/render-rule1-rhs : {u : lvl} expr =
   [u] (elam (eforall (econst "Bool" lnil) ([x] (esort u))) ([x] (elam (eapp x (econst "Bool.false" lnil)) ([y] (elam (eapp x (econst "Bool.true" lnil)) ([z] z)))))).

%% inductive Prod (numParams=2, numIndices=0)
Prod/render-type : {u : lvl} {v : lvl} expr =
   [u] [v] (eforall (esort (lsucc u)) ([x] (eforall (esort (lsucc v)) ([y] (esort (lmax (lsucc u) (lsucc v))))))).

%% ctor Prod.mk (induct=Prod, numFields=2)
Prod_mk/render-type : {u : lvl} {v : lvl} expr =
   [u] [v] (eforall (esort (lsucc u)) ([x] (eforall (esort (lsucc v)) ([y] (eforall x ([z] (eforall y ([w] (eapp (eapp (econst "Prod" (lcons u (lcons v lnil))) x) y))))))))).

%% recursor Prod.rec (numMotives=1, numMinors=1, k=false)
Prod_rec/render-type : {u_1 : lvl} {u : lvl} {v : lvl} expr =
   [u_1] [u] [v] (eforall (esort (lsucc u)) ([x] (eforall (esort (lsucc v)) ([y] (eforall (eforall (eapp (eapp (econst "Prod" (lcons u (lcons v lnil))) x) y) ([z] (esort u_1))) ([z] (eforall (eforall x ([w] (eforall y ([x1] (eapp z (eapp (eapp (eapp (eapp (econst "Prod.mk" (lcons u (lcons v lnil))) x) y) w) x1)))))) ([w] (eforall (eapp (eapp (econst "Prod" (lcons u (lcons v lnil))) x) y) ([x1] (eapp z x1))))))))))).
%%   rec-rule for Prod.mk (nfields=2)
Prod_rec/render-rule0-rhs : {u_1 : lvl} {u : lvl} {v : lvl} expr =
   [u_1] [u] [v] (elam (esort (lsucc u)) ([x] (elam (esort (lsucc v)) ([y] (elam (eforall (eapp (eapp (econst "Prod" (lcons u (lcons v lnil))) x) y) ([z] (esort u_1))) ([z] (elam (eforall x ([w] (eforall y ([x1] (eapp z (eapp (eapp (eapp (eapp (econst "Prod.mk" (lcons u (lcons v lnil))) x) y) w) x1)))))) ([w] (elam x ([x1] (elam y ([y1] (eapp (eapp w x1) y1))))))))))))).

%% def Prod.snd
Prod_snd/render-type : {u : lvl} {v : lvl} expr =
   [u] [v] (eforall (esort (lsucc u)) ([x] (eforall (esort (lsucc v)) ([y] (eforall (eapp (eapp (econst "Prod" (lcons u (lcons v lnil))) x) y) ([z] y)))))).
Prod_snd/render-value : {u : lvl} {v : lvl} expr =
   [u] [v] (elam (esort (lsucc u)) ([x] (elam (esort (lsucc v)) ([y] (elam (eapp (eapp (econst "Prod" (lcons u (lcons v lnil))) x) y) ([z] (eproj "Prod" 1 z))))))).

%% def rfl
rfl/render-type : {u : lvl} expr =
   [u] (eforall (esort u) ([x] (eforall x ([y] (eapp (eapp (eapp (econst "Eq" (lcons u lnil)) x) y) y))))).
rfl/render-value : {u : lvl} expr =
   [u] (elam (esort u) ([x] (elam x ([y] (eapp (eapp (econst "Eq.refl" (lcons u lnil)) x) y))))).

%% def projRed
projRed/render-type : expr =
   (eapp (eapp (eapp (econst "Eq" (lcons (lsucc lzero) lnil)) (econst "Bool" lnil)) (eapp (eapp (eapp (econst "Prod.snd" (lcons lzero (lcons lzero lnil))) (econst "Bool" lnil)) (econst "Bool" lnil)) (eapp (eapp (eapp (eapp (econst "Prod.mk" (lcons lzero (lcons lzero lnil))) (econst "Bool" lnil)) (econst "Bool" lnil)) (econst "Bool.true" lnil)) (econst "Bool.false" lnil)))) (econst "Bool.false" lnil)).
projRed/render-value : expr =
   (eapp (eapp (econst "rfl" (lcons (lsucc lzero) lnil)) (econst "Bool" lnil)) (eapp (eapp (eapp (econst "Prod.snd" (lcons lzero (lcons lzero lnil))) (econst "Bool" lnil)) (econst "Bool" lnil)) (eapp (eapp (eapp (eapp (econst "Prod.mk" (lcons lzero (lcons lzero lnil))) (econst "Bool" lnil)) (econst "Bool" lnil)) (econst "Bool.true" lnil)) (econst "Bool.false" lnil)))).

