%%% Expected outcome: accept
%%% A parametrized product type (with level parameters)
%solve nonneg_0 : 0 >= 0.

%% inductive Prod
Prod/type-wf-sort : lvl
   = (limax
       (lsucc (lsucc (lvar liz)))
       (limax
         (lsucc (lsucc (lvar (lis liz))))
         (lsucc (lmax (lsucc (lvar liz)) (lsucc (lvar (lis liz))))))).

Prod/type-wf : of (eforall (esort (lsucc (lvar liz))) ([x] (eforall (esort (lsucc (lvar (lis liz)))) ([y] (esort (lmax (lsucc (lvar liz)) (lsucc (lvar (lis liz))))))))) (esort Prod/type-wf-sort)
   = (defeq/forall
       defeq/sort-refl
       ([x] ([h] (defeq/forall defeq/sort-refl ([y] ([h1] defeq/sort-refl)))))).

Prod/ends-in-sort : ends-in-sort (eforall (esort (lsucc (lvar liz))) ([x] (eforall (esort (lsucc (lvar (lis liz)))) ([y] (esort (lmax (lsucc (lvar liz)) (lsucc (lvar (lis liz)))))))))
   = (ends-in-sort/forall ([x] (ends-in-sort/forall ([y] ends-in-sort/sort)))).

Prod/rec-name : name "Prod.rec" (is-rec-for "Prod").

Prod/name : name "Prod" (is-decl (eforall (esort (lsucc (lvar liz))) ([x] (eforall (esort (lsucc (lvar (lis liz)))) ([y] (esort (lmax (lsucc (lvar liz)) (lsucc (lvar (lis liz))))))))) indt).

Prod/decl : declared "Prod" (eforall (esort (lsucc (lvar liz))) ([x] (eforall (esort (lsucc (lvar (lis liz)))) ([y] (esort (lmax (lsucc (lvar liz)) (lsucc (lvar (lis liz))))))))) indt
   = declared/ok Prod/name (dkind-ok/indt Prod/type-wf Prod/ends-in-sort).

%% ctor Prod.mk (of Prod)
Prod_mk/type-wf-sort : lvl
   = (limax
       (lsucc (lsucc (lvar liz)))
       (limax
         (lsucc (lsucc (lvar (lis liz))))
         (limax
           (lsucc (lvar liz))
           (limax
             (lsucc (lvar (lis liz)))
             (lmax (lsucc (lvar liz)) (lsucc (lvar (lis liz)))))))).

Prod_mk/type-wf : of (eforall (esort (lsucc (lvar liz)))
                    ([x]
                      (eforall (esort (lsucc (lvar (lis liz))))
                        ([y] (eforall x ([z] (eforall y ([w] (eapp (eapp (econst "Prod" (lcons (lvar liz) (lcons (lvar (lis liz)) lnil))) x) y))))))))) (esort Prod_mk/type-wf-sort)
   = (defeq/forall
       defeq/sort-refl
       ([x]
         ([h]
           (defeq/forall
             defeq/sort-refl
             ([y]
               ([h1]
                 (defeq/forall
                   h
                   ([z]
                     ([h2]
                       (defeq/forall
                         h1
                         ([w]
                           ([h3]
                             (defeq/app
                               (defeq/app
                                 (defeq/const
                                   Prod/decl
                                   (inst-expr/forall
                                     (inst-expr/sort
                                       (lvl-inst/succ
                                         (lvl-inst/var lvl-nth/zero)))
                                     ([x]
                                       ([h]
                                         (inst-expr/forall
                                           (inst-expr/sort
                                             (lvl-inst/succ
                                               (lvl-inst/var
                                                 (lvl-nth/succ lvl-nth/zero))))
                                           ([y]
                                             ([h1]
                                               (inst-expr/sort
                                                 (lvl-inst/max
                                                   (lvl-inst/succ
                                                     (lvl-inst/var
                                                       lvl-nth/zero))
                                                   (lvl-inst/succ
                                                     (lvl-inst/var
                                                       (lvl-nth/succ
                                                         lvl-nth/zero))))))))))))
                                 h)
                               h1))))))))))))).

Prod_mk/positivity : ctor-positive "Prod" (lcons (lvar liz) (lcons (lvar (lis liz)) lnil)) (eforall (esort (lsucc (lvar liz))) ([x] (eforall (esort (lsucc (lvar (lis liz)))) ([y] (eforall x ([z] (eforall y ([w] (eapp (eapp (econst "Prod" (lcons (lvar liz) (lcons (lvar (lis liz)) lnil))) x) y)))))))))
   = (ctor-positive/intro ([S] (eforall (esort (lsucc (lvar liz))) ([x] (eforall (esort (lsucc (lvar (lis liz)))) ([y] (eforall x ([z] (eforall y ([w] (eapp (eapp S x) y)))))))))) (ctor-spine/arg
       (strict-pos/no-occur (esort (lsucc (lvar liz))) no-self-ref/sort)
       ([x]
         ([y]
           (ctor-spine/arg
             (strict-pos/no-occur
               (esort (lsucc (lvar (lis liz))))
               no-self-ref/sort)
             ([z]
               ([w]
                 (ctor-spine/arg
                   (strict-pos/no-occur x y)
                   ([x1]
                     ([y1]
                       (ctor-spine/arg
                         (strict-pos/no-occur z w)
                         ([z1]
                           ([w1]
                             (ctor-spine/result
                               (applies-self/app
                                 (applies-self/app
                                   applies-self/refl)))))))))))))))).

Prod_mk/eisl : ends-in-sort-with-level (eforall (esort (lsucc (lvar liz))) ([x] (eforall (esort (lsucc (lvar (lis liz)))) ([y] (esort (lmax (lsucc (lvar liz)) (lsucc (lvar (lis liz))))))))) (lmax (lsucc (lvar liz)) (lsucc (lvar (lis liz))))
   = (ends-in-sort-with-level/forall
       ([x]
         (ends-in-sort-with-level/forall ([y] ends-in-sort-with-level/sort)))).

%%% HOLE: Prod_mk/fuo — prover for field-universes-ok-skip-params not yet implemented
Prod_mk/fuo : field-universes-ok-skip-params (lis (lis liz)) (eforall (esort (lsucc (lvar liz))) ([x] (eforall (esort (lsucc (lvar (lis liz)))) ([y] (eforall x ([z] (eforall y ([w] (eapp (eapp (econst "Prod" (lcons (lvar liz) (lcons (lvar (lis liz)) lnil))) x) y))))))))) (lmax (lsucc (lvar liz)) (lsucc (lvar (lis liz)))).

Prod_mk/name : name "Prod.mk" (is-decl (eforall (esort (lsucc (lvar liz)))
                                         ([x]
                                           (eforall (esort (lsucc (lvar (lis liz))))
                                             ([y] (eforall x ([z] (eforall y ([w] (eapp (eapp (econst "Prod" (lcons (lvar liz) (lcons (lvar (lis liz)) lnil))) x) y))))))))) ctor).

Prod_mk/decl : declared "Prod.mk" (eforall (esort (lsucc (lvar liz)))
                                    ([x]
                                      (eforall (esort (lsucc (lvar (lis liz))))
                                        ([y] (eforall x ([z] (eforall y ([w] (eapp (eapp (econst "Prod" (lcons (lvar liz) (lcons (lvar (lis liz)) lnil))) x) y))))))))) ctor
   = declared/ok Prod_mk/name (dkind-ok/ctor Prod_mk/type-wf Prod_mk/positivity Prod/decl Prod_mk/eisl Prod_mk/fuo).

%% recursor Prod.rec
Prod_rec/type-wf-sort : lvl
   = (limax
       (lsucc (lsucc (lvar (lis liz))))
       (limax
         (lsucc (lsucc (lvar (lis (lis liz)))))
         (limax
           (limax
             (lmax (lsucc (lvar (lis liz))) (lsucc (lvar (lis (lis liz)))))
             (lsucc (lvar liz)))
           (limax
             (limax
               (lsucc (lvar (lis liz)))
               (limax (lsucc (lvar (lis (lis liz)))) (lvar liz)))
             (limax
               (lmax (lsucc (lvar (lis liz))) (lsucc (lvar (lis (lis liz)))))
               (lvar liz)))))).

Prod_rec/type-wf : of (eforall (esort (lsucc (lvar (lis liz))))
                     ([x]
                       (eforall (esort (lsucc (lvar (lis (lis liz)))))
                         ([y]
                           (eforall (eforall (eapp (eapp (econst "Prod" (lcons (lvar (lis liz)) (lcons (lvar (lis (lis liz))) lnil))) x) y) ([z] (esort (lvar liz))))
                             ([z]
                               (eforall (eforall x
                                 ([w] (eforall y ([x1] (eapp z (eapp (eapp (eapp (eapp (econst "Prod.mk" (lcons (lvar (lis liz)) (lcons (lvar (lis (lis liz))) lnil))) x) y) w) x1))))))
                                 ([w] (eforall (eapp (eapp (econst "Prod" (lcons (lvar (lis liz)) (lcons (lvar (lis (lis liz))) lnil))) x) y) ([x1] (eapp z x1))))))))))) (esort Prod_rec/type-wf-sort)
   = (defeq/forall
       defeq/sort-refl
       ([x]
         ([h]
           (defeq/forall
             defeq/sort-refl
             ([y]
               ([h1]
                 (defeq/forall
                   (defeq/forall
                     (defeq/app
                       (defeq/app
                         (defeq/const
                           Prod/decl
                           (inst-expr/forall
                             (inst-expr/sort
                               (lvl-inst/succ (lvl-inst/var lvl-nth/zero)))
                             ([x]
                               ([h]
                                 (inst-expr/forall
                                   (inst-expr/sort
                                     (lvl-inst/succ
                                       (lvl-inst/var
                                         (lvl-nth/succ lvl-nth/zero))))
                                   ([y]
                                     ([h1]
                                       (inst-expr/sort
                                         (lvl-inst/max
                                           (lvl-inst/succ
                                             (lvl-inst/var lvl-nth/zero))
                                           (lvl-inst/succ
                                             (lvl-inst/var
                                               (lvl-nth/succ
                                                 lvl-nth/zero))))))))))))
                         h)
                       h1)
                     ([z] ([h2] defeq/sort-refl)))
                   ([z]
                     ([h2]
                       (defeq/forall
                         (defeq/forall
                           h
                           ([w]
                             ([h3]
                               (defeq/forall
                                 h1
                                 ([x1]
                                   ([h4]
                                     (defeq/app
                                       h2
                                       (defeq/app
                                         (defeq/app
                                           (defeq/app
                                             (defeq/app
                                               (defeq/const
                                                 Prod_mk/decl
                                                 (inst-expr/forall
                                                   (inst-expr/sort
                                                     (lvl-inst/succ
                                                       (lvl-inst/var
                                                         lvl-nth/zero)))
                                                   ([x]
                                                     ([h]
                                                       (inst-expr/forall
                                                         (inst-expr/sort
                                                           (lvl-inst/succ
                                                             (lvl-inst/var
                                                               (lvl-nth/succ
                                                                 lvl-nth/zero))))
                                                         ([y]
                                                           ([h1]
                                                             (inst-expr/forall
                                                               h
                                                               ([z]
                                                                 ([h2]
                                                                   (inst-expr/forall
                                                                     h1
                                                                     ([w]
                                                                       ([h3]
                                                                         (inst-expr/app
                                                                           (inst-expr/app
                                                                             (inst-expr/const
                                                                               (lvls-inst/cons
                                                                                 (lvl-inst/var
                                                                                   lvl-nth/zero)
                                                                                 (lvls-inst/cons
                                                                                   (lvl-inst/var
                                                                                     (lvl-nth/succ
                                                                                       lvl-nth/zero))
                                                                                   lvls-inst/nil)))
                                                                             h)
                                                                           h1))))))))))))))
                                               h)
                                             h1)
                                           h3)
                                         h4))))))))
                         ([w]
                           ([h3]
                             (defeq/forall
                               (defeq/app
                                 (defeq/app
                                   (defeq/const
                                     Prod/decl
                                     (inst-expr/forall
                                       (inst-expr/sort
                                         (lvl-inst/succ
                                           (lvl-inst/var lvl-nth/zero)))
                                       ([x]
                                         ([h]
                                           (inst-expr/forall
                                             (inst-expr/sort
                                               (lvl-inst/succ
                                                 (lvl-inst/var
                                                   (lvl-nth/succ
                                                     lvl-nth/zero))))
                                             ([y]
                                               ([h1]
                                                 (inst-expr/sort
                                                   (lvl-inst/max
                                                     (lvl-inst/succ
                                                       (lvl-inst/var
                                                         lvl-nth/zero))
                                                     (lvl-inst/succ
                                                       (lvl-inst/var
                                                         (lvl-nth/succ
                                                           lvl-nth/zero))))))))))))
                                   h)
                                 h1)
                               ([x1] ([h4] (defeq/app h2 h4)))))))))))))))).

Prod_rec/decl : declared "Prod.rec" (eforall (esort (lsucc (lvar (lis liz))))
                                      ([x]
                                        (eforall (esort (lsucc (lvar (lis (lis liz)))))
                                          ([y]
                                            (eforall (eforall (eapp (eapp (econst "Prod" (lcons (lvar (lis liz)) (lcons (lvar (lis (lis liz))) lnil))) x) y) ([z] (esort (lvar liz))))
                                              ([z]
                                                (eforall (eforall x
                                                  ([w]
                                                    (eforall y ([x1] (eapp z (eapp (eapp (eapp (eapp (econst "Prod.mk" (lcons (lvar (lis liz)) (lcons (lvar (lis (lis liz))) lnil))) x) y) w) x1))))))
                                                  ([w] (eforall (eapp (eapp (econst "Prod" (lcons (lvar (lis liz)) (lcons (lvar (lis (lis liz))) lnil))) x) y) ([x1] (eapp z x1))))))))))) irec
   = declared/ok-irec Prod/rec-name (dkind-ok/irec Prod_rec/type-wf).

%% def prodType
prodType/type-wf-sort : lvl
   = (limax
       (lsucc (lsucc lzero))
       (limax (lsucc (lsucc lzero)) (lsucc (lsucc lzero)))).

prodType/type-wf : of (eforall (esort (lsucc lzero)) ([x] (eforall (esort (lsucc lzero)) ([y] (esort (lsucc lzero)))))) (esort prodType/type-wf-sort)
   = (defeq/forall
       defeq/sort-refl
       ([x] ([h] (defeq/forall defeq/sort-refl ([y] ([h1] defeq/sort-refl)))))).

prodType/value-typed : of (econst "Prod" (lcons lzero (lcons lzero lnil))) (eforall (esort (lsucc lzero)) ([x] (eforall (esort (lsucc lzero)) ([y] (esort (lsucc lzero))))))
   = (defeq/conv
       (defeq/forall
         (defeq/sort-eq lvl-eq/refl)
         ([x]
           ([h]
             (defeq/forall
               (defeq/sort-eq lvl-eq/refl)
               ([y]
                 ([h1]
                   (defeq/sort-eq
                     (lvl-eq/le
                       (mleq/sR
                         (mleq/maxL
                           (mleq/sL (mleq/self nonneg_0))
                           (mleq/sL (mleq/self nonneg_0))))
                       (mleq/sL
                         (mleq/maxR-l (mleq/sR (mleq/self nonneg_0))))))))))))
       (defeq/const
         Prod/decl
         (inst-expr/forall
           (inst-expr/sort (lvl-inst/succ (lvl-inst/var lvl-nth/zero)))
           ([x]
             ([h]
               (inst-expr/forall
                 (inst-expr/sort
                   (lvl-inst/succ (lvl-inst/var (lvl-nth/succ lvl-nth/zero))))
                 ([y]
                   ([h1]
                     (inst-expr/sort
                       (lvl-inst/max
                         (lvl-inst/succ (lvl-inst/var lvl-nth/zero))
                         (lvl-inst/succ
                           (lvl-inst/var (lvl-nth/succ lvl-nth/zero))))))))))))).

prodType/name : name "prodType" (is-decl (eforall (esort (lsucc lzero)) ([x] (eforall (esort (lsucc lzero)) ([y] (esort (lsucc lzero)))))) (defn (econst "Prod" (lcons lzero (lcons lzero lnil))))).

prodType/decl : declared "prodType" (eforall (esort (lsucc lzero)) ([x] (eforall (esort (lsucc lzero)) ([y] (esort (lsucc lzero)))))) (defn (econst "Prod" (lcons lzero (lcons lzero lnil))))
   = declared/ok prodType/name (dkind-ok/defn prodType/type-wf prodType/value-typed).
