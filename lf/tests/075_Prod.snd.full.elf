%%% Expected outcome: accept
%%% Type-checking projection functions with parameters
%% This file contains 1 hole tag(s):
%%   - hole/defeq (count: see HOLE/defeq markers below)
%% Files with any hole/<tag> use are NOT Twelf-verified.
hole/defeq : {E1 : expr} {E2 : expr} {T : expr} defeq E1 E2 T.

%% inductive Prod
Prod/type-wf :
   {u : lvl} {v : lvl} defeq (eforall (esort (lsucc u)) ([x] (eforall (esort (lsucc v)) ([y] (esort (lmax (lsucc u) (lsucc v))))))) (eforall (esort (lsucc u)) ([x] (eforall (esort (lsucc v)) ([y] (esort (lmax (lsucc u) (lsucc v))))))) (esort (limax (lsucc (lsucc u)) (limax (lsucc (lsucc v)) (lsucc (lmax (lsucc u) (lsucc v))))))
   = [u] [v] (defeq/forall (defeq/sort-refl-at (lsucc u)) ([x] [y] (defeq/forall (defeq/sort-refl-at (lsucc v)) ([z] [w] (defeq/sort-refl-at (lmax (lsucc u) (lsucc v))))))).

Prod/ends-in-sort :
   {u : lvl} {v : lvl} ends-in-sort (eforall (esort (lsucc u)) ([x] (eforall (esort (lsucc v)) ([y] (esort (lmax (lsucc u) (lsucc v)))))))
   = [u] [v] (ends-in-sort/forall ([x] (ends-in-sort/forall ([y] ends-in-sort/sort)))).

Prod/decl : {u : lvl} {v : lvl} declared "Prod" (lcons u (lcons v lnil))
   (eforall (esort (lsucc u)) ([x] (eforall (esort (lsucc v)) ([y] (esort (lmax (lsucc u) (lsucc v)))))))
   indt
   (dkind-ok/indt (Prod/type-wf u v) (Prod/ends-in-sort u v)).

