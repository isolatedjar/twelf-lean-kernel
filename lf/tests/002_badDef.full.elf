%%% Expected outcome: reject
%%% Mismatched types
%% def badDef
badDef/type-wf : of (esort lzero) (esort (lsucc lzero))
   = defeq/sort-refl.

badDef/value-typed : of (esort (lsucc lzero)) (esort lzero)
   = fail-on-purpose.

badDef/name : name "badDef" (is-decl (esort lzero) (defn (esort (lsucc lzero)))).

badDef/decl : declared "badDef" (esort lzero) (defn (esort (lsucc lzero)))
   = declared/ok badDef/name dkind-non-inductive/defn (dkind-ok/defn badDef/type-wf badDef/value-typed).
