%%% Expected outcome: accept
%%% Reducing a let
%% axiom aProp
aProp/type-wf-sort : lvl
   = (lsucc lzero).

aProp/type-wf : defeq (esort lzero) (esort lzero) (esort aProp/type-wf-sort)
   = defeq/sort-refl.

aProp/name : name "aProp" (is-decl (esort lzero) ax).

aProp/decl : declared "aProp" (esort lzero) ax
   = declared/ok aProp/name (dkind-ok/ax aProp/type-wf).

%% def letRed
letRed/type-wf-sort : lvl
   = (lsucc lzero).

letRed/type-wf : defeq (eapp (elam (esort (lsucc lzero)) ([x] x)) (esort lzero)) (eapp (elam (esort (lsucc lzero)) ([x] x)) (esort lzero)) (esort letRed/type-wf-sort)
   = (defeq/app (defeq/lam defeq/sort-refl ([x] ([h] h))) defeq/sort-refl).

letRed/value-typed : defeq (econst "aProp" lnil) (econst "aProp" lnil) (eapp (elam (esort (lsucc lzero)) ([x] x)) (esort lzero))
   = (defeq/conv (defeq/trans defeq/sort-refl (defeq/symm (defeq/beta ([x] ([h] h)) defeq/sort-refl))) (defeq/const aProp/decl (inst-expr/sort lvl-inst/zero))).

letRed/name : name "letRed" (is-decl (eapp (elam (esort (lsucc lzero)) ([x] x)) (esort lzero)) (defn (econst "aProp" lnil))).

letRed/decl : declared "letRed" (eapp (elam (esort (lsucc lzero)) ([x] x)) (esort lzero)) (defn (econst "aProp" lnil))
   = declared/ok letRed/name (dkind-ok/defn letRed/type-wf letRed/value-typed).

