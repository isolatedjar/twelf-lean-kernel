%% recursor PropStructure.rec
%%% HOLE
PropStructure_rec/type-wf-sort : lvl.

%%% HOLE
PropStructure_rec/type-wf : defeq (eforall (eforall (econst "PropStructure" (lcons (lvar liz) (lcons (lvar (lis liz)) lnil))) ([x] (esort lzero))) ([x] (eforall (eforall (econst "PUnit" (lcons (lvar liz) lnil)) ([y] (eforall (econst "PUnit" (lcons (lvar (lis liz)) lnil)) ([z] (eforall (econst "PUnit" (lcons (lvar liz) lnil)) ([w] (eforall (econst "PUnit" (lcons (lvar (lis liz)) lnil)) ([x1] (eforall (eapp (eapp (eapp (econst "Eq" (lcons (lvar (lis liz)) lnil)) (econst "PUnit" (lcons (lvar (lis liz)) lnil))) x1) x1) ([y1] (eforall (econst "PUnit" (lcons (lvar liz) lnil)) ([z1] (eapp x (eapp (eapp (eapp (eapp (eapp (eapp (econst "PropStructure.mk" (lcons (lvar liz) (lcons (lvar (lis liz)) lnil))) y) z) w) x1) y1) z1)))))))))))))) ([y] (eforall (econst "PropStructure" (lcons (lvar liz) (lcons (lvar (lis liz)) lnil))) ([z] (eapp x z))))))) (eforall (eforall (econst "PropStructure" (lcons (lvar liz) (lcons (lvar (lis liz)) lnil))) ([x] (esort lzero))) ([x] (eforall (eforall (econst "PUnit" (lcons (lvar liz) lnil)) ([y] (eforall (econst "PUnit" (lcons (lvar (lis liz)) lnil)) ([z] (eforall (econst "PUnit" (lcons (lvar liz) lnil)) ([w] (eforall (econst "PUnit" (lcons (lvar (lis liz)) lnil)) ([x1] (eforall (eapp (eapp (eapp (econst "Eq" (lcons (lvar (lis liz)) lnil)) (econst "PUnit" (lcons (lvar (lis liz)) lnil))) x1) x1) ([y1] (eforall (econst "PUnit" (lcons (lvar liz) lnil)) ([z1] (eapp x (eapp (eapp (eapp (eapp (eapp (eapp (econst "PropStructure.mk" (lcons (lvar liz) (lcons (lvar (lis liz)) lnil))) y) z) w) x1) y1) z1)))))))))))))) ([y] (eforall (econst "PropStructure" (lcons (lvar liz) (lcons (lvar (lis liz)) lnil))) ([z] (eapp x z))))))) (esort PropStructure_rec/type-wf-sort).

