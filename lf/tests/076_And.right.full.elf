%%% Expected outcome: accept
%%% Type-checking simple projection functions
%solve nonneg_0 : 0 >= 0.

%% inductive And
And/type-wf-sort : lvl
   = (limax (lsucc lzero) (limax (lsucc lzero) (lsucc lzero))).

And/type-wf : of (eforall (esort lzero) ([x] (eforall (esort lzero) ([y] (esort lzero))))) (esort And/type-wf-sort)
   = (defeq/forall
       defeq/sort-refl
       ([x] ([h] (defeq/forall defeq/sort-refl ([y] ([h1] defeq/sort-refl)))))).

And/ends-in-sort : ends-in-sort (eforall (esort lzero) ([x] (eforall (esort lzero) ([y] (esort lzero)))))
   = (ends-in-sort/forall ([x] (ends-in-sort/forall ([y] ends-in-sort/sort)))).

And/rec-name : name "And.rec" (is-rec-for "And").

And/clf : count-leading-foralls (eforall (esort lzero) ([x] (eforall (esort lzero) ([y] (esort lzero))))) (lis (lis liz))
   = (count-leading-foralls/succ
       ([x] (count-leading-foralls/succ ([y] count-leading-foralls/zero)))).

And/cnd : cnames-distinct (ccons "And.intro" cnil)
   = (cnames-distinct/cons cnames-distinct/nil all-string-neq/nil).

And/name : name "And" (is-decl (eforall (esort lzero) ([x] (eforall (esort lzero) ([y] (esort lzero))))) (indt (ccons "And.intro" cnil) (lis (lis liz)))).

And/decl : declared "And" (eforall (esort lzero) ([x] (eforall (esort lzero) ([y] (esort lzero))))) (indt (ccons "And.intro" cnil) (lis (lis liz)))
   = declared/ok-indt And/name And/rec-name And/clf And/cnd (dkind-ok/indt And/type-wf And/ends-in-sort).

%% ctor And.intro (of And)
And_intro/type-wf-sort : lvl
   = (limax
       (lsucc lzero)
       (limax (lsucc lzero) (limax lzero (limax lzero lzero)))).

And_intro/type-wf : of (eforall (esort lzero) ([x] (eforall (esort lzero) ([y] (eforall x ([z] (eforall y ([w] (eapp (eapp (econst "And" lnil) x) y))))))))) (esort And_intro/type-wf-sort)
   = (defeq/forall
       defeq/sort-refl
       ([x]
         ([h]
           (defeq/forall
             defeq/sort-refl
             ([y]
               ([h1]
                 (defeq/forall
                   h
                   ([z]
                     ([h2]
                       (defeq/forall
                         h1
                         ([w]
                           ([h3]
                             (defeq/app
                               (defeq/app
                                 (defeq/const
                                   And/decl
                                   (inst-expr/forall
                                     (inst-expr/sort lvl-inst/zero)
                                     ([x]
                                       ([h]
                                         (inst-expr/forall
                                           (inst-expr/sort lvl-inst/zero)
                                           ([y]
                                             ([h1]
                                               (inst-expr/sort
                                                 lvl-inst/zero))))))))
                                 h)
                               h1))))))))))))).

And_intro/positivity : ctor-positive "And" lnil (eforall (esort lzero) ([x] (eforall (esort lzero) ([y] (eforall x ([z] (eforall y ([w] (eapp (eapp (econst "And" lnil) x) y)))))))))
   = (ctor-positive/intro ([S] (eforall (esort lzero) ([x] (eforall (esort lzero) ([y] (eforall x ([z] (eforall y ([w] (eapp (eapp S x) y)))))))))) (ctor-spine/arg
       (strict-pos/no-occur (esort lzero) no-self-ref/sort)
       ([x]
         ([y]
           (ctor-spine/arg
             (strict-pos/no-occur (esort lzero) no-self-ref/sort)
             ([z]
               ([w]
                 (ctor-spine/arg
                   (strict-pos/no-occur x y)
                   ([x1]
                     ([y1]
                       (ctor-spine/arg
                         (strict-pos/no-occur z w)
                         ([z1]
                           ([w1]
                             (ctor-spine/result
                               (applies-self/app
                                 (applies-self/app
                                   applies-self/refl)))))))))))))))).

And_intro/eisl : ends-in-sort-with-level (eforall (esort lzero) ([x] (eforall (esort lzero) ([y] (esort lzero))))) lzero
   = (ends-in-sort-with-level/forall
       ([x]
         (ends-in-sort-with-level/forall ([y] ends-in-sort-with-level/sort)))).

And_intro/cmem : cmem "And.intro" (ccons "And.intro" cnil)
   = cmem/here.

And_intro/fuo : field-universes-ok-skip-params (lis (lis liz)) (eforall (esort lzero) ([x] (eforall (esort lzero) ([y] (eforall x ([z] (eforall y ([w] (eapp (eapp (econst "And" lnil) x) y))))))))) lzero
   = (field-universes-ok-skip-params/skip
       ([x]
         ([h]
           (field-universes-ok-skip-params/skip
             ([y]
               ([h1]
                 (field-universes-ok-skip-params/start
                   (field-universes-ok/forall
                     h
                     (mleq/self nonneg_0)
                     ([z]
                       ([h2]
                         (field-universes-ok/forall
                           h1
                           (mleq/self nonneg_0)
                           ([w]
                             ([h3]
                               (field-universes-ok/done
                                 not-forall/app)))))))))))))).

And_intro/name : name "And.intro" (is-decl (eforall (esort lzero) ([x] (eforall (esort lzero) ([y] (eforall x ([z] (eforall y ([w] (eapp (eapp (econst "And" lnil) x) y))))))))) (ctor "And" liz)).

And_intro/decl : declared "And.intro" (eforall (esort lzero) ([x] (eforall (esort lzero) ([y] (eforall x ([z] (eforall y ([w] (eapp (eapp (econst "And" lnil) x) y))))))))) (ctor "And" liz)
   = declared/ok-ctor And_intro/name And/name And_intro/cmem And_intro/eisl And_intro/fuo (dkind-ok/ctor And_intro/type-wf And_intro/positivity).

%% recursor And.rec
And_rec/type-wf-sort : lvl
   = (limax
       (lsucc lzero)
       (limax
         (lsucc lzero)
         (limax
           (limax lzero (lsucc (lvar liz)))
           (limax
             (limax lzero (limax lzero (lvar liz)))
             (limax lzero (lvar liz)))))).

And_rec/type-wf : of
  (eforall (esort lzero)
    ([x]
      (eforall (esort lzero)
        ([y]
          (eforall (eforall (eapp (eapp (econst "And" lnil) x) y) ([z] (esort (lvar liz))))
            ([z]
              (eforall (eforall x ([w] (eforall y ([x1] (eapp z (eapp (eapp (eapp (eapp (econst "And.intro" lnil) x) y) w) x1))))))
                ([w] (eforall (eapp (eapp (econst "And" lnil) x) y) ([x1] (eapp z x1)))))))))))
  (esort And_rec/type-wf-sort)
   = (defeq/forall
       defeq/sort-refl
       ([x]
         ([h]
           (defeq/forall
             defeq/sort-refl
             ([y]
               ([h1]
                 (defeq/forall
                   (defeq/forall
                     (defeq/app
                       (defeq/app
                         (defeq/const
                           And/decl
                           (inst-expr/forall
                             (inst-expr/sort lvl-inst/zero)
                             ([x]
                               ([h]
                                 (inst-expr/forall
                                   (inst-expr/sort lvl-inst/zero)
                                   ([y]
                                     ([h1] (inst-expr/sort lvl-inst/zero))))))))
                         h)
                       h1)
                     ([z] ([h2] defeq/sort-refl)))
                   ([z]
                     ([h2]
                       (defeq/forall
                         (defeq/forall
                           h
                           ([w]
                             ([h3]
                               (defeq/forall
                                 h1
                                 ([x1]
                                   ([h4]
                                     (defeq/app
                                       h2
                                       (defeq/app
                                         (defeq/app
                                           (defeq/app
                                             (defeq/app
                                               (defeq/const
                                                 And_intro/decl
                                                 (inst-expr/forall
                                                   (inst-expr/sort
                                                     lvl-inst/zero)
                                                   ([x]
                                                     ([h]
                                                       (inst-expr/forall
                                                         (inst-expr/sort
                                                           lvl-inst/zero)
                                                         ([y]
                                                           ([h1]
                                                             (inst-expr/forall
                                                               h
                                                               ([z]
                                                                 ([h2]
                                                                   (inst-expr/forall
                                                                     h1
                                                                     ([w]
                                                                       ([h3]
                                                                         (inst-expr/app
                                                                           (inst-expr/app
                                                                             (inst-expr/const
                                                                               lvls-inst/nil)
                                                                             h)
                                                                           h1))))))))))))))
                                               h)
                                             h1)
                                           h3)
                                         h4))))))))
                         ([w]
                           ([h3]
                             (defeq/forall
                               (defeq/app
                                 (defeq/app
                                   (defeq/const
                                     And/decl
                                     (inst-expr/forall
                                       (inst-expr/sort lvl-inst/zero)
                                       ([x]
                                         ([h]
                                           (inst-expr/forall
                                             (inst-expr/sort lvl-inst/zero)
                                             ([y]
                                               ([h1]
                                                 (inst-expr/sort
                                                   lvl-inst/zero))))))))
                                   h)
                                 h1)
                               ([x1] ([h4] (defeq/app h2 h4)))))))))))))))).

And_rec/decl : declared "And.rec"
  (eforall (esort lzero)
    ([x]
      (eforall (esort lzero)
        ([y]
          (eforall (eforall (eapp (eapp (econst "And" lnil) x) y) ([z] (esort (lvar liz))))
            ([z]
              (eforall (eforall x ([w] (eforall y ([x1] (eapp z (eapp (eapp (eapp (eapp (econst "And.intro" lnil) x) y) w) x1))))))
                ([w] (eforall (eapp (eapp (econst "And" lnil) x) y) ([x1] (eapp z x1)))))))))))
  (irec "And")
   = declared/ok-irec And/rec-name (dkind-ok/irec And_rec/type-wf).

%% thm And.left
And_left/type-wf : of (eforall (esort lzero) ([x] (eforall (esort lzero) ([y] (eforall (eapp (eapp (econst "And" lnil) x) y) ([z] x)))))) (esort lzero)
   = (defeq/conv
       (defeq/sort-eq
         (lvl-eq/le
           (mleq/imax-imL
             (mleq/maxL
               (mleq/imax-imL
                 (mleq/maxL
                   (mleq/imax-lzL (mleq/self nonneg_0))
                   (mleq/imax-lzL (mleq/self nonneg_0))))
               (mleq/imax-imL
                 (mleq/maxL
                   (mleq/imax-lzL (mleq/self nonneg_0))
                   (mleq/imax-lzL (mleq/self nonneg_0))))))
           (mleq/lz nonneg_0)))
       (defeq/forall
         defeq/sort-refl
         ([x]
           ([h]
             (defeq/forall
               defeq/sort-refl
               ([y]
                 ([h1]
                   (defeq/forall
                     (defeq/app
                       (defeq/app
                         (defeq/const
                           And/decl
                           (inst-expr/forall
                             (inst-expr/sort lvl-inst/zero)
                             ([x]
                               ([h]
                                 (inst-expr/forall
                                   (inst-expr/sort lvl-inst/zero)
                                   ([y]
                                     ([h1] (inst-expr/sort lvl-inst/zero))))))))
                         h)
                       h1)
                     ([z] ([h2] h)))))))))).

%%% HOLE
And_left/value-typed : of
  (elam (esort lzero) ([x] (elam (esort lzero) ([y] (elam (eapp (eapp (econst "And" lnil) x) y) ([z] (eproj "And" 0 z)))))))
  (eforall (esort lzero) ([x] (eforall (esort lzero) ([y] (eforall (eapp (eapp (econst "And" lnil) x) y) ([z] x)))))).

And_left/name : name "And.left" (is-decl
  (eforall (esort lzero) ([x] (eforall (esort lzero) ([y] (eforall (eapp (eapp (econst "And" lnil) x) y) ([z] x))))))
  (thm (elam (esort lzero) ([x] (elam (esort lzero) ([y] (elam (eapp (eapp (econst "And" lnil) x) y) ([z] (eproj "And" 0 z))))))))).

And_left/decl : declared "And.left"
  (eforall (esort lzero) ([x] (eforall (esort lzero) ([y] (eforall (eapp (eapp (econst "And" lnil) x) y) ([z] x))))))
  (thm (elam (esort lzero) ([x] (elam (esort lzero) ([y] (elam (eapp (eapp (econst "And" lnil) x) y) ([z] (eproj "And" 0 z))))))))
   = declared/ok And_left/name dkind-non-inductive/thm (dkind-ok/thm And_left/type-wf And_left/value-typed).

%% thm And.right
And_right/type-wf : of (eforall (esort lzero) ([x] (eforall (esort lzero) ([y] (eforall (eapp (eapp (econst "And" lnil) x) y) ([z] y)))))) (esort lzero)
   = (defeq/conv
       (defeq/sort-eq
         (lvl-eq/le
           (mleq/imax-imL
             (mleq/maxL
               (mleq/imax-imL
                 (mleq/maxL
                   (mleq/imax-lzL (mleq/self nonneg_0))
                   (mleq/imax-lzL (mleq/self nonneg_0))))
               (mleq/imax-imL
                 (mleq/maxL
                   (mleq/imax-lzL (mleq/self nonneg_0))
                   (mleq/imax-lzL (mleq/self nonneg_0))))))
           (mleq/lz nonneg_0)))
       (defeq/forall
         defeq/sort-refl
         ([x]
           ([h]
             (defeq/forall
               defeq/sort-refl
               ([y]
                 ([h1]
                   (defeq/forall
                     (defeq/app
                       (defeq/app
                         (defeq/const
                           And/decl
                           (inst-expr/forall
                             (inst-expr/sort lvl-inst/zero)
                             ([x]
                               ([h]
                                 (inst-expr/forall
                                   (inst-expr/sort lvl-inst/zero)
                                   ([y]
                                     ([h1] (inst-expr/sort lvl-inst/zero))))))))
                         h)
                       h1)
                     ([z] ([h2] h1)))))))))).

%%% HOLE
And_right/value-typed : of
  (elam (esort lzero) ([x] (elam (esort lzero) ([y] (elam (eapp (eapp (econst "And" lnil) x) y) ([z] (eproj "And" 1 z)))))))
  (eforall (esort lzero) ([x] (eforall (esort lzero) ([y] (eforall (eapp (eapp (econst "And" lnil) x) y) ([z] y)))))).

And_right/name : name "And.right" (is-decl
  (eforall (esort lzero) ([x] (eforall (esort lzero) ([y] (eforall (eapp (eapp (econst "And" lnil) x) y) ([z] y))))))
  (thm (elam (esort lzero) ([x] (elam (esort lzero) ([y] (elam (eapp (eapp (econst "And" lnil) x) y) ([z] (eproj "And" 1 z))))))))).

And_right/decl : declared "And.right"
  (eforall (esort lzero) ([x] (eforall (esort lzero) ([y] (eforall (eapp (eapp (econst "And" lnil) x) y) ([z] y))))))
  (thm (elam (esort lzero) ([x] (elam (esort lzero) ([y] (elam (eapp (eapp (econst "And" lnil) x) y) ([z] (eproj "And" 1 z))))))))
   = declared/ok And_right/name dkind-non-inductive/thm (dkind-ok/thm And_right/type-wf And_right/value-typed).
