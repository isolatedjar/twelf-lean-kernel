%%% Expected outcome: accept
%%% A recursive inductive data type
%% inductive N
%%% HOLE
N/type-wf-sort : lvl.

%%% HOLE
N/type-wf : defeq (esort (lsucc lzero)) (esort (lsucc lzero)) (esort N/type-wf-sort).

%%% HOLE
N/ends-in-sort : ends-in-sort (esort (lsucc lzero)).

N/decl : declared "N" lnil
   (esort (lsucc lzero))
   indt
   (dkind-ok/indt N/type-wf N/ends-in-sort).

%% ctor N.zero (of N)
%%% HOLE
N_zero/type-wf-sort : lvl.

%%% HOLE
N_zero/type-wf : defeq (econst "N" lnil) (econst "N" lnil) (esort N_zero/type-wf-sort).

%%% HOLE
N_zero/positivity : ctor-positive "N" lnil (econst "N" lnil).

N_zero/decl : declared "N.zero" lnil
   (econst "N" lnil)
   ctor
   (dkind-ok/ctor N_zero/type-wf N_zero/positivity).

%% ctor N.succ (of N)
%%% HOLE
N_succ/type-wf-sort : lvl.

%%% HOLE
N_succ/type-wf : defeq (eforall (econst "N" lnil) ([x] (econst "N" lnil))) (eforall (econst "N" lnil) ([x] (econst "N" lnil))) (esort N_succ/type-wf-sort).

%%% HOLE
N_succ/positivity : ctor-positive "N" lnil (eforall (econst "N" lnil) ([x] (econst "N" lnil))).

N_succ/decl : declared "N.succ" lnil
   (eforall (econst "N" lnil) ([x] (econst "N" lnil)))
   ctor
   (dkind-ok/ctor N_succ/type-wf N_succ/positivity).

%% recursor N.rec
%%% HOLE
N_rec/type-wf-sort : {u : lvl} lvl.

%%% HOLE
N_rec/type-wf : {u : lvl} defeq (eforall (eforall (econst "N" lnil) ([x] (esort u))) ([x] (eforall (eapp x (econst "N.zero" lnil)) ([y] (eforall (eforall (econst "N" lnil) ([z] (eforall (eapp x z) ([w] (eapp x (eapp (econst "N.succ" lnil) z)))))) ([z] (eforall (econst "N" lnil) ([w] (eapp x w))))))))) (eforall (eforall (econst "N" lnil) ([x] (esort u))) ([x] (eforall (eapp x (econst "N.zero" lnil)) ([y] (eforall (eforall (econst "N" lnil) ([z] (eforall (eapp x z) ([w] (eapp x (eapp (econst "N.succ" lnil) z)))))) ([z] (eforall (econst "N" lnil) ([w] (eapp x w))))))))) (esort (N_rec/type-wf-sort u)).

N_rec/decl : {u : lvl} declared "N.rec" (lcons u lnil)
   (eforall (eforall (econst "N" lnil) ([x] (esort u))) ([x] (eforall (eapp x (econst "N.zero" lnil)) ([y] (eforall (eforall (econst "N" lnil) ([z] (eforall (eapp x z) ([w] (eapp x (eapp (econst "N.succ" lnil) z)))))) ([z] (eforall (econst "N" lnil) ([w] (eapp x w)))))))))
   irec
   (dkind-ok/irec (N_rec/type-wf u)).

%% def natDef
%%% HOLE
natDef/type-wf-sort : lvl.

%%% HOLE
natDef/type-wf : defeq (esort (lsucc lzero)) (esort (lsucc lzero)) (esort natDef/type-wf-sort).

%%% HOLE
natDef/value-typed : defeq (econst "N" lnil) (econst "N" lnil) (esort (lsucc lzero)).

natDef/decl : declared "natDef" lnil
   (esort (lsucc lzero))
   (defn (econst "N" lnil))
   (dkind-ok/defn natDef/type-wf natDef/value-typed).

