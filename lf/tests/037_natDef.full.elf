%%% Expected outcome: accept
%%% A recursive inductive data type
sneq/0 : string-neq "N.zero" "N.succ".

%% inductive N
N/type-wf : of (esort (lsucc lzero)) (esort (lsucc (lsucc lzero)))
   = defeq/sort-refl.

N/ends-in-sort : ends-in-sort (esort (lsucc lzero))
   = ends-in-sort/sort.

N/rec-name : name "N.rec" (is-rec-for "N").

N/eisl : ends-in-sort-with-level (esort (lsucc lzero)) (lsucc lzero)
   = ends-in-sort-with-level/sort.

N/cnd : cnames-distinct (ccons "N.zero" (ccons "N.succ" cnil))
   = (cnames-distinct/cons
       (cnames-distinct/cons cnames-distinct/nil all-string-neq/nil)
       (all-string-neq/cons sneq/0 all-string-neq/nil)).

N/name : name "N" (is-decl (esort (lsucc lzero)) (indt (ccons "N.zero" (ccons "N.succ" cnil)) z)).

N/decl : declared "N" (esort (lsucc lzero)) (indt (ccons "N.zero" (ccons "N.succ" cnil)) z)
   = declared/ok-indt N/name N/rec-name N/cnd (dkind-ok/indt N/type-wf N/ends-in-sort).

%% ctor N.zero (of N)
N_zero/type-wf : of (econst "N" lnil) (esort (lsucc lzero))
   = (defeq/const N/decl (inst-expr/sort (inst-lvl/succ inst-lvl/zero))).

N_zero/positivity : ctor-positive "N" lnil (econst "N" lnil)
   = (ctor-positive/intro ([S] S) (ctor-spine/result applies-self/refl)).

N_zero/cmem : cmem "N.zero" (ccons "N.zero" (ccons "N.succ" cnil))
   = cmem/here.

N_zero/fuo : field-universes-ok (econst "N" lnil) (lsucc lzero)
   = (field-universes-ok/done not-forall/const).

N_zero/name : name "N.zero" (is-decl (econst "N" lnil) (ctor "N" z)).

N_zero/decl : declared "N.zero" (econst "N" lnil) (ctor "N" z)
   = declared/ok-ctor N_zero/name N/name N_zero/cmem N/eisl N_zero/fuo (dkind-ok/ctor N_zero/type-wf N_zero/positivity).

%% ctor N.succ (of N)
N_succ/type-wf : of (eforall (econst "N" lnil) ([x] (econst "N" lnil))) (esort (limax (lsucc lzero) (lsucc lzero)))
   = (defeq/forall
       (defeq/const N/decl (inst-expr/sort (inst-lvl/succ inst-lvl/zero)))
       ([x]
         ([h]
           (defeq/const
             N/decl
             (inst-expr/sort (inst-lvl/succ inst-lvl/zero)))))).

N_succ/positivity : ctor-positive "N" lnil (eforall (econst "N" lnil) ([x] (econst "N" lnil)))
   = (ctor-positive/intro ([S] (eforall S ([x] S))) (ctor-spine/arg
       (strict-pos/head applies-self/refl)
       ([x] ([y] (ctor-spine/result applies-self/refl))))).

N_succ/cmem : cmem "N.succ" (ccons "N.zero" (ccons "N.succ" cnil))
   = (cmem/there cmem/here).

N_succ/fuo : field-universes-ok (eforall (econst "N" lnil) ([x] (econst "N" lnil))) (lsucc lzero)
   = (field-universes-ok/forall
       (defeq/const N/decl (inst-expr/sort (inst-lvl/succ inst-lvl/zero)))
       (leq-lvl/imaxLs
         (leq-lvl/sR
           (leq-lvl/maxL (leq-lvl/sL leq-lvl/self) (leq-lvl/sL leq-lvl/self))))
       ([x] ([h] (field-universes-ok/done not-forall/const)))).

N_succ/name : name "N.succ" (is-decl (eforall (econst "N" lnil) ([x] (econst "N" lnil))) (ctor "N" (s z))).

N_succ/decl : declared "N.succ" (eforall (econst "N" lnil) ([x] (econst "N" lnil))) (ctor "N" (s z))
   = declared/ok-ctor N_succ/name N/name N_succ/cmem N/eisl N_succ/fuo (dkind-ok/ctor N_succ/type-wf N_succ/positivity).

%% recursor N.rec (TCB-derived; informational only)
%%   level params: u
%%   type:   (eforall (eforall (econst "N" lnil) ([x] (esort (lvar z)))) ([x] (eforall (eapp x (econst "N.zero" lnil)) ([y] (eforall (eforall (econst "N" lnil) ([w] (eforall (eapp x w) ([v] (eapp x (eapp (econst "N.succ" lnil) w)))))) ([w] (eforall (econst "N" lnil) ([v] (eapp x v)))))))))
%%   rules:
%%     N.rec … N.zero … = (elam (eforall (econst "N" lnil) ([x] (esort (lvar z)))) ([x] (elam (eapp x (econst "N.zero" lnil)) ([y] (elam (eforall (econst "N" lnil) ([w] (eforall (eapp x w) ([v] (eapp x (eapp (econst "N.succ" lnil) w)))))) ([w] y))))))   (0 fields)
%%     N.rec … N.succ … = (elam (eforall (econst "N" lnil) ([x] (esort (lvar z)))) ([x] (elam (eapp x (econst "N.zero" lnil)) ([y] (elam (eforall (econst "N" lnil) ([w] (eforall (eapp x w) ([v] (eapp x (eapp (econst "N.succ" lnil) w)))))) ([w] (elam (econst "N" lnil) ([v] (eapp (eapp w v) (eapp (eapp (eapp (eapp (econst "N.rec" (lcons (lvar z) lnil)) x) y) w) v))))))))))   (1 fields)

%% def natDef
natDef/type-wf : of (esort (lsucc lzero)) (esort (lsucc (lsucc lzero)))
   = defeq/sort-refl.

natDef/value-typed : of (econst "N" lnil) (esort (lsucc lzero))
   = (defeq/const N/decl (inst-expr/sort (inst-lvl/succ inst-lvl/zero))).

natDef/name : name "natDef" (is-decl (esort (lsucc lzero)) (defn (econst "N" lnil))).

natDef/decl : declared "natDef" (esort (lsucc lzero)) (defn (econst "N" lnil))
   = declared/ok natDef/name dkind-non-inductive/defn (dkind-ok/defn natDef/type-wf natDef/value-typed).
