%%% Render-only view of: 008_forallSortWhnf
%%% The binding domain of a forall may need to be reduce before it is a sort
%% def id
id/render-type : {u : lvl} expr =
   [u] (eforall (esort u) ([x] (eforall x ([y] x)))).
id/render-value : {u : lvl} expr =
   [u] (elam (esort u) ([x] (elam x ([y] y)))).

%% def forallSortWhnf
forallSortWhnf/render-type : expr =
   (esort lzero).
forallSortWhnf/render-value : expr =
   (eforall (eapp (eapp (econst "id" (lcons (lsucc (lsucc lzero)) lnil)) (esort (lsucc lzero))) (esort lzero)) ([x] (eforall x ([y] x)))).

