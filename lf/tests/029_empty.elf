%%% Expected outcome: accept
%%% A simple empty inductive type
%% inductive Empty
Empty/type-wf :
   defeq (esort (lsucc lzero)) (esort (lsucc lzero)) (esort (lsucc (lsucc lzero)))
   = (defeq/sort-refl-at (lsucc lzero)).

Empty/decl : declared "Empty" lnil
   (esort (lsucc lzero))
   indt
   (dkind-ok/indt Empty/type-wf).

%% inductive recursor Empty.rec
Empty_rec/type-wf :
   {u : lvl} defeq (eforall (eforall (econst "Empty" lnil) ([x] (esort u))) ([x] (eforall (econst "Empty" lnil) ([y] (eapp x y))))) (eforall (eforall (econst "Empty" lnil) ([x] (esort u))) ([x] (eforall (econst "Empty" lnil) ([y] (eapp x y))))) (esort (limax (limax (lsucc lzero) (lsucc u)) (limax (lsucc lzero) u)))
   = [u] (defeq/forall (defeq/forall (defeq/const Empty/decl) ([x] [y] (defeq/sort-refl-at u))) ([x] [y] (defeq/forall (defeq/const Empty/decl) ([z] [w] (defeq/app y w))))).

Empty_rec/decl : {u : lvl} declared "Empty.rec" (lcons u lnil)
   (eforall (eforall (econst "Empty" lnil) ([x] (esort u))) ([x] (eforall (econst "Empty" lnil) ([y] (eapp x y)))))
   irec
   (dkind-ok/irec (Empty_rec/type-wf u)).

%% def empty
empty/type-wf :
   defeq (esort (lsucc lzero)) (esort (lsucc lzero)) (esort (lsucc (lsucc lzero)))
   = (defeq/sort-refl-at (lsucc lzero)).

empty/value-typed :
   defeq (econst "Empty" lnil) (econst "Empty" lnil) (esort (lsucc lzero))
   = (defeq/const Empty/decl).

empty/decl : declared "empty" lnil
   (esort (lsucc lzero))
   (defn (econst "Empty" lnil))
   (dkind-ok/defn empty/type-wf empty/value-typed).

%mode declared +N +LS -T -DK -W.
%worlds () (declared _ _ _ _ _).
%unique declared +N +LS -1T -1DK *W.
