%%% SKIP: recursor PropTwo.rec — large elimination (motive into a non-Prop sort) from a Prop inductive with 2 constructors

%% def discriminate
%%% HOLE
discriminate/type-wf-sort : lvl.

%%% HOLE
discriminate/type-wf : of (eforall (econst "PropTwo" lnil) ([x] (econst "Bool" lnil))) (esort discriminate/type-wf-sort).

%%% HOLE
discriminate/value-typed : of (elam (econst "PropTwo" lnil)
                             ([x]
                               (eapp (eapp (eapp (eapp (econst "PropTwo.rec" lnil) (elam (econst "PropTwo" lnil) ([y] (econst "Bool" lnil)))) (econst "Bool.true" lnil)) (econst "Bool.false" lnil))
                                 x))) (eforall (econst "PropTwo" lnil) ([x] (econst "Bool" lnil))).

discriminate/name : name "discriminate" (is-decl (eforall (econst "PropTwo" lnil) ([x] (econst "Bool" lnil))) (defn (elam (econst "PropTwo" lnil) ([x] (eapp (eapp (eapp (eapp (econst "PropTwo.rec" lnil) (elam (econst "PropTwo" lnil) ([y] (econst "Bool" lnil)))) (econst "Bool.true" lnil)) (econst "Bool.false" lnil)) x))))).

discriminate/decl : declared "discriminate" (eforall (econst "PropTwo" lnil) ([x] (econst "Bool" lnil))) (defn (elam (econst "PropTwo" lnil) ([x] (eapp (eapp (eapp (eapp (econst "PropTwo.rec" lnil) (elam (econst "PropTwo" lnil) ([y] (econst "Bool" lnil)))) (econst "Bool.true" lnil)) (econst "Bool.false" lnil)) x))))
   = declared/ok discriminate/name (dkind-ok/defn discriminate/type-wf discriminate/value-typed).

