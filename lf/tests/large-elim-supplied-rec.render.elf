%%% Render-only view of: large-elim-supplied-rec
%%% Proof of False via large elimination of a multi-constructor `Prop`, using a
%%% hand-supplied recursor.
%%% 
%%% A `Prop` with two or more constructors admits only **small** elimination: its
%%% recursor's motive must target `Prop`. Allowing large elimination would
%%% transport a genuine case distinction out of `Prop` into `Type`, which is
%%% unsound under proof irrelevance.
%%% 
%%% This export defines `PropTwo : Prop` with constructors `PropTwo.a`, `PropTwo.b`
%%% and supplies a recursor `PropTwo.rec` whose motive targets `Sort u` (large
%%% elimination). The recursor is otherwise well-formed — correct rule count and
%%% correct reduction rules — so the only defect is the elimination level. From it:
%%% 
%%%     discriminate : PropTwo → Bool := PropTwo.rec (fun _ => Bool) true false
%%%     ab_eq        : PropTwo.a = PropTwo.b           -- proof irrelevance
%%%     discr_eq     : discriminate a = discriminate b -- congrArg
%%%     falseViaLargeElim : False                       -- transport True.intro along discr_eq
%%% 
%%% Because `discriminate a` reduces to `true` and `discriminate b` to `false`,
%%% `discr_eq` is a proof of `true = false`, and transporting `True.intro` along it
%%% lands in `False`.
%%% 
%%% A sound checker must reject this. The two safe behaviors observed:
%%% * the official kernel and lean4lean **regenerate** the canonical recursor with
%%%   a `Prop` motive, so `discriminate` (eliminating into `Type`) fails to type;
%%% * nanoda likewise rejects.
%%% 
%%% rpylean accepts it: it trusts the supplied recursor's declared elimination
%%% level instead of enforcing the small-elimination restriction, so the proof of
%%% `False` goes through. (mini also ignores the supplied recursor and regenerates
%%% its own, so it too rejects — its recursor-handling gap happens to be safe here.)
%%% 
%%% This is distinct from `large-elim-param`, which exploits an incorrect
%%% "level is surely not zero" check on universe *parameters*; here the inductive
%%% is monomorphic at `Prop` (`Sort 0`) and the defect is that the checker does
%%% not validate the recursor's elimination strength at all.
sneq/0 : string-neq "Bool.false" "Bool.true".

%% inductive False
%%% HOLE
False/type-wf : of (esort lzero) (esort _).

%%% HOLE
False/ends-in-sort : ends-in-sort (esort lzero).

False/rec-name : name "False.rec" (is-rec-for "False").

False/eisl : ends-in-sort-with-level (esort lzero) lzero
   = ends-in-sort-with-level/sort.

False/cnd : cnames-distinct cnil
   = cnames-distinct/nil.

False/name : name "False" (is-decl (esort lzero) (indt cnil z)).

False/decl : declared "False" (esort lzero) (indt cnil z)
   = declared/ok-indt False/name False/rec-name False/cnd (dkind-ok/indt False/type-wf False/ends-in-sort).

%% recursor False.rec (TCB-derived; informational only)
%%   level params: u
%%   type:   (eforall (eforall (econst "False" lnil) ([x] (esort (lvar z)))) ([x] (eforall (econst "False" lnil) ([y] (eapp x y)))))

%% inductive Eq
%%% HOLE
Eq/type-wf : of (eforall (esort (lvar z)) ([x] (eforall x ([y] (eforall x ([w] (esort lzero))))))) (esort _).

%%% HOLE
Eq/ends-in-sort : ends-in-sort (eforall (esort (lvar z)) ([x] (eforall x ([y] (eforall x ([w] (esort lzero))))))).

Eq/rec-name : name "Eq.rec" (is-rec-for "Eq").

Eq/eisl : ends-in-sort-with-level (eforall (esort (lvar z)) ([x] (eforall x ([y] (eforall x ([w] (esort lzero))))))) lzero
   = (ends-in-sort-with-level/forall
       ([x]
         (ends-in-sort-with-level/forall
           ([y]
             (ends-in-sort-with-level/forall
               ([w] ends-in-sort-with-level/sort)))))).

Eq/cnd : cnames-distinct (ccons "Eq.refl" cnil)
   = (cnames-distinct/cons cnames-distinct/nil all-string-neq/nil).

Eq/name : name "Eq" (is-decl (eforall (esort (lvar z)) ([x] (eforall x ([y] (eforall x ([w] (esort lzero))))))) (indt (ccons "Eq.refl" cnil) (s (s z)))).

Eq/decl : declared "Eq" (eforall (esort (lvar z)) ([x] (eforall x ([y] (eforall x ([w] (esort lzero))))))) (indt (ccons "Eq.refl" cnil) (s (s z)))
   = declared/ok-indt Eq/name Eq/rec-name Eq/cnd (dkind-ok/indt Eq/type-wf Eq/ends-in-sort).

%% ctor Eq.refl (of Eq)
%%% HOLE
Eq_refl/type-wf : of (eforall (esort (lvar z)) ([x] (eforall x ([y] (eapp (eapp (eapp (econst "Eq" (lcons (lvar z) lnil)) x) y) y))))) (esort _).

%%% HOLE
Eq_refl/positivity : ctor-positive "Eq" (lcons (lvar z) lnil) (eforall (esort (lvar z)) ([x] (eforall x ([y] (eapp (eapp (eapp (econst "Eq" (lcons (lvar z) lnil)) x) y) y))))).

Eq_refl/cmem : cmem "Eq.refl" (ccons "Eq.refl" cnil)
   = cmem/here.

%%% HOLE: Eq_refl/fuo
Eq_refl/fuo : field-universes-ok (eforall (esort (lvar z)) ([x] (eforall x ([y] (eapp (eapp (eapp (econst "Eq" (lcons (lvar z) lnil)) x) y) y))))) lzero.

Eq_refl/name : name "Eq.refl" (is-decl (eforall (esort (lvar z)) ([x] (eforall x ([y] (eapp (eapp (eapp (econst "Eq" (lcons (lvar z) lnil)) x) y) y))))) (ctor "Eq" z)).

Eq_refl/decl : declared "Eq.refl" (eforall (esort (lvar z)) ([x] (eforall x ([y] (eapp (eapp (eapp (econst "Eq" (lcons (lvar z) lnil)) x) y) y))))) (ctor "Eq" z)
   = declared/ok-ctor Eq_refl/name Eq/name Eq_refl/cmem Eq/eisl Eq_refl/fuo (dkind-ok/ctor Eq_refl/type-wf Eq_refl/positivity).

%% recursor Eq.rec (TCB-derived; informational only)
%%   level params: u u_1
%%   type:   (eforall (esort (lvar (s z))) ([x] (eforall x ([y] (eforall (eforall x ([w] (eforall (eapp (eapp (eapp (econst "Eq" (lcons (lvar (s z)) lnil)) x) y) w) ([v] (esort (lvar z)))))) ([w] (eforall (eapp (eapp w y) (eapp (eapp (econst "Eq.refl" (lcons (lvar (s z)) lnil)) x) y)) ([v] (eforall x ([x1] (eforall (eapp (eapp (eapp (econst "Eq" (lcons (lvar (s z)) lnil)) x) y) x1) ([y1] (eapp (eapp w x1) y1)))))))))))))
%%   rules:
%%     Eq.rec … Eq.refl … = (elam (esort (lvar (s z))) ([x] (elam x ([y] (elam (eforall x ([w] (eforall (eapp (eapp (eapp (econst "Eq" (lcons (lvar (s z)) lnil)) x) y) w) ([v] (esort (lvar z)))))) ([w] (elam (eapp (eapp w y) (eapp (eapp (econst "Eq.refl" (lcons (lvar (s z)) lnil)) x) y)) ([v] v))))))))   (0 fields)
%%   K-like reduction: yes

