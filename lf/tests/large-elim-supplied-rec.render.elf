  (elam (econst "PropTwo" lnil)
    ([x] (eapp (eapp (eapp (eapp (econst "PropTwo.rec" lnil) (elam (econst "PropTwo" lnil) ([y] (econst "Bool" lnil)))) (econst "Bool.true" lnil)) (econst "Bool.false" lnil)) x)))
  (eforall (econst "PropTwo" lnil) ([x] (econst "Bool" lnil))).

discriminate/name : name "discriminate" (is-decl
  (eforall (econst "PropTwo" lnil) ([x] (econst "Bool" lnil)))
  (defn (elam (econst "PropTwo" lnil) ([x] (eapp (eapp (eapp (eapp (econst "PropTwo.rec" lnil) (elam (econst "PropTwo" lnil) ([y] (econst "Bool" lnil)))) (econst "Bool.true" lnil)) (econst "Bool.false" lnil)) x))))).

