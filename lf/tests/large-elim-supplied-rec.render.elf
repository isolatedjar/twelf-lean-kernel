%% thm congrArg
%%% HOLE
congrArg/type-wf : of
  (eforall (esort (lvar z))
    ([x]
      (eforall (esort (lvar (s z)))
        ([y]
          (eforall x
            ([w]
              (eforall x
                ([v]
                  (eforall (eforall x ([x1] y))
                    ([x1]
                      (eforall (eapp (eapp (eapp (econst "Eq" (lcons (lvar z) lnil)) x) w) v) ([y1] (eapp (eapp (eapp (econst "Eq" (lcons (lvar (s z)) lnil)) y) (eapp x1 w)) (eapp x1 v))))))))))))))
  (esort lzero).

%%% HOLE
congrArg/value-typed : of
  (elam (esort (lvar z))
    ([x]
      (elam (esort (lvar (s z)))
        ([y]
          (elam x
            ([w]
              (elam x
                ([v]
                  (elam (eforall x ([x1] y))
                    ([x1]
                      (elam (eapp (eapp (eapp (econst "Eq" (lcons (lvar z) lnil)) x) w) v)
                        ([y1]
                          (eapp (eapp (eapp (eapp (eapp (eapp (econst "Eq.rec" (lcons lzero (lcons (lvar z) lnil))) x) w)
                            (elam x
                              ([w1]
                                (elam (eapp (eapp (eapp (econst "Eq" (lcons (lvar z) lnil)) x) w) w1) ([v1] (eapp (eapp (eapp (econst "Eq" (lcons (lvar (s z)) lnil)) y) (eapp x1 w)) (eapp x1 w1)))))))
                            (eapp (eapp (econst "rfl" (lcons (lvar (s z)) lnil)) y) (eapp x1 w)))
                            v)
                            y1)))))))))))))
  (eforall (esort (lvar z))
    ([x]
      (eforall (esort (lvar (s z)))
        ([y]
          (eforall x
            ([w]
              (eforall x
                ([v]
                  (eforall (eforall x ([x1] y))
                    ([x1]
                      (eforall (eapp (eapp (eapp (econst "Eq" (lcons (lvar z) lnil)) x) w) v) ([y1] (eapp (eapp (eapp (econst "Eq" (lcons (lvar (s z)) lnil)) y) (eapp x1 w)) (eapp x1 v)))))))))))))).

congrArg/name : name "congrArg" (is-decl
  (eforall (esort (lvar z))
    ([x]
      (eforall (esort (lvar (s z)))
        ([y]
          (eforall x
            ([w]
              (eforall x
                ([v]
                  (eforall (eforall x ([x1] y))
                    ([x1]
                      (eforall (eapp (eapp (eapp (econst "Eq" (lcons (lvar z) lnil)) x) w) v) ([y1] (eapp (eapp (eapp (econst "Eq" (lcons (lvar (s z)) lnil)) y) (eapp x1 w)) (eapp x1 v))))))))))))))
  (thm (elam (esort (lvar z)) ([x] (elam (esort (lvar (s z))) ([y] (elam x ([w] (elam x ([v] (elam (eforall x ([x1] y)) ([x1] (elam (eapp (eapp (eapp (econst "Eq" (lcons (lvar z) lnil)) x) w) v) ([y1] (eapp (eapp (eapp (eapp (eapp (eapp (econst "Eq.rec" (lcons lzero (lcons (lvar z) lnil))) x) w) (elam x ([w1] (elam (eapp (eapp (eapp (econst "Eq" (lcons (lvar z) lnil)) x) w) w1) ([v1] (eapp (eapp (eapp (econst "Eq" (lcons (lvar (s z)) lnil)) y) (eapp x1 w)) (eapp x1 w1))))))) (eapp (eapp (econst "rfl" (lcons (lvar (s z)) lnil)) y) (eapp x1 w))) v) y1))))))))))))))).

congrArg/decl : declared "congrArg"
  (eforall (esort (lvar z))
    ([x]
      (eforall (esort (lvar (s z)))
        ([y]
          (eforall x
            ([w]
              (eforall x
                ([v]
                  (eforall (eforall x ([x1] y))
                    ([x1]
                      (eforall (eapp (eapp (eapp (econst "Eq" (lcons (lvar z) lnil)) x) w) v) ([y1] (eapp (eapp (eapp (econst "Eq" (lcons (lvar (s z)) lnil)) y) (eapp x1 w)) (eapp x1 v))))))))))))))
  (thm (elam (esort (lvar z)) ([x] (elam (esort (lvar (s z))) ([y] (elam x ([w] (elam x ([v] (elam (eforall x ([x1] y)) ([x1] (elam (eapp (eapp (eapp (econst "Eq" (lcons (lvar z) lnil)) x) w) v) ([y1] (eapp (eapp (eapp (eapp (eapp (eapp (econst "Eq.rec" (lcons lzero (lcons (lvar z) lnil))) x) w) (elam x ([w1] (elam (eapp (eapp (eapp (econst "Eq" (lcons (lvar z) lnil)) x) w) w1) ([v1] (eapp (eapp (eapp (econst "Eq" (lcons (lvar (s z)) lnil)) y) (eapp x1 w)) (eapp x1 w1))))))) (eapp (eapp (econst "rfl" (lcons (lvar (s z)) lnil)) y) (eapp x1 w))) v) y1))))))))))))))
   = declared/ok congrArg/name dkind-non-inductive/thm (dkind-ok/thm congrArg/type-wf congrArg/value-typed).

