%%% Render-only view of: large-elim-supplied-rec
%%% Proof of False via large elimination of a multi-constructor `Prop`, using a
%%% hand-supplied recursor.
%%% 
%%% A `Prop` with two or more constructors admits only **small** elimination: its
%%% recursor's motive must target `Prop`. Allowing large elimination would
%%% transport a genuine case distinction out of `Prop` into `Type`, which is
%%% unsound under proof irrelevance.
%%% 
%%% This export defines `PropTwo : Prop` with constructors `PropTwo.a`, `PropTwo.b`
%%% and supplies a recursor `PropTwo.rec` whose motive targets `Sort u` (large
%%% elimination). The recursor is otherwise well-formed — correct rule count and
%%% correct reduction rules — so the only defect is the elimination level. From it:
%%% 
%%%     discriminate : PropTwo → Bool := PropTwo.rec (fun _ => Bool) true false
%%%     ab_eq        : PropTwo.a = PropTwo.b           -- proof irrelevance
%%%     discr_eq     : discriminate a = discriminate b -- congrArg
%%%     falseViaLargeElim : False                       -- transport True.intro along discr_eq
%%% 
%%% Because `discriminate a` reduces to `true` and `discriminate b` to `false`,
%%% `discr_eq` is a proof of `true = false`, and transporting `True.intro` along it
%%% lands in `False`.
%%% 
%%% A sound checker must reject this. The two safe behaviors observed:
%%% * the official kernel and lean4lean **regenerate** the canonical recursor with
%%%   a `Prop` motive, so `discriminate` (eliminating into `Type`) fails to type;
%%% * nanoda likewise rejects.
%%% 
%%% rpylean accepts it: it trusts the supplied recursor's declared elimination
%%% level instead of enforcing the small-elimination restriction, so the proof of
%%% `False` goes through. (mini also ignores the supplied recursor and regenerates
%%% its own, so it too rejects — its recursor-handling gap happens to be safe here.)
%%% 
%%% This is distinct from `large-elim-param`, which exploits an incorrect
%%% "level is surely not zero" check on universe *parameters*; here the inductive
%%% is monomorphic at `Prop` (`Sort 0`) and the defect is that the checker does
%%% not validate the recursor's elimination strength at all.
%% inductive False
%%% HOLE
False/type-wf-sort : lvl.

%%% HOLE
False/type-wf : of (esort lzero) (esort False/type-wf-sort).

%%% HOLE
False/ends-in-sort : ends-in-sort (esort lzero).

False/rec-name : name "False.rec" (is-rec-for "False").

False/name : name "False" (is-decl (esort lzero) indt).

False/decl : declared "False" (esort lzero) indt
   = declared/ok False/name (dkind-ok/indt False/type-wf False/ends-in-sort).

%% recursor False.rec
%%% HOLE
False_rec/type-wf-sort : lvl.

%%% HOLE
False_rec/type-wf : of (eforall (eforall (econst "False" lnil) ([x] (esort (lvar liz)))) ([x] (eforall (econst "False" lnil) ([y] (eapp x y))))) (esort False_rec/type-wf-sort).

False_rec/decl : declared "False.rec" (eforall (eforall (econst "False" lnil) ([x] (esort (lvar liz)))) ([x] (eforall (econst "False" lnil) ([y] (eapp x y))))) irec
   = declared/ok-irec False/rec-name (dkind-ok/irec False_rec/type-wf).

%% inductive Eq
%%% HOLE
Eq/type-wf-sort : lvl.

%%% HOLE
Eq/type-wf : of (eforall (esort (lvar liz)) ([x] (eforall x ([y] (eforall x ([z] (esort lzero))))))) (esort Eq/type-wf-sort).

%%% HOLE
Eq/ends-in-sort : ends-in-sort (eforall (esort (lvar liz)) ([x] (eforall x ([y] (eforall x ([z] (esort lzero))))))).

Eq/rec-name : name "Eq.rec" (is-rec-for "Eq").

Eq/name : name "Eq" (is-decl (eforall (esort (lvar liz)) ([x] (eforall x ([y] (eforall x ([z] (esort lzero))))))) indt).

Eq/decl : declared "Eq" (eforall (esort (lvar liz)) ([x] (eforall x ([y] (eforall x ([z] (esort lzero))))))) indt
   = declared/ok Eq/name (dkind-ok/indt Eq/type-wf Eq/ends-in-sort).

%% ctor Eq.refl (of Eq)
%%% HOLE
Eq_refl/type-wf-sort : lvl.

%%% HOLE
Eq_refl/type-wf : of (eforall (esort (lvar liz)) ([x] (eforall x ([y] (eapp (eapp (eapp (econst "Eq" (lcons (lvar liz) lnil)) x) y) y))))) (esort Eq_refl/type-wf-sort).

%%% HOLE
Eq_refl/positivity : ctor-positive "Eq" (lcons (lvar liz) lnil) (eforall (esort (lvar liz)) ([x] (eforall x ([y] (eapp (eapp (eapp (econst "Eq" (lcons (lvar liz) lnil)) x) y) y))))).

Eq_refl/eisl : ends-in-sort-with-level (eforall (esort (lvar liz)) ([x] (eforall x ([y] (eforall x ([z] (esort lzero))))))) lzero
   = (ends-in-sort-with-level/forall
       ([x]
         (ends-in-sort-with-level/forall
           ([y]
             (ends-in-sort-with-level/forall
               ([z] ends-in-sort-with-level/sort)))))).

%%% HOLE: Eq_refl/fuo — prover for field-universes-ok-skip-params not yet implemented
Eq_refl/fuo : field-universes-ok-skip-params (lis (lis liz)) (eforall (esort (lvar liz)) ([x] (eforall x ([y] (eapp (eapp (eapp (econst "Eq" (lcons (lvar liz) lnil)) x) y) y))))) lzero.

Eq_refl/name : name "Eq.refl" (is-decl (eforall (esort (lvar liz)) ([x] (eforall x ([y] (eapp (eapp (eapp (econst "Eq" (lcons (lvar liz) lnil)) x) y) y))))) ctor).

Eq_refl/decl : declared "Eq.refl" (eforall (esort (lvar liz)) ([x] (eforall x ([y] (eapp (eapp (eapp (econst "Eq" (lcons (lvar liz) lnil)) x) y) y))))) ctor
   = declared/ok Eq_refl/name (dkind-ok/ctor Eq_refl/type-wf Eq_refl/positivity Eq/decl Eq_refl/eisl Eq_refl/fuo).

%% recursor Eq.rec
%%% HOLE
Eq_rec/type-wf-sort : lvl.

%%% HOLE
Eq_rec/type-wf : of (eforall (esort (lvar (lis liz)))
                   ([x]
                     (eforall x
                       ([y]
                         (eforall (eforall x ([z] (eforall (eapp (eapp (eapp (econst "Eq" (lcons (lvar (lis liz)) lnil)) x) y) z) ([w] (esort (lvar liz))))))
                           ([z]
                             (eforall (eapp (eapp z y) (eapp (eapp (econst "Eq.refl" (lcons (lvar (lis liz)) lnil)) x) y))
                               ([w]
                                 (eforall x ([x1] (eforall (eapp (eapp (eapp (econst "Eq" (lcons (lvar (lis liz)) lnil)) x) y) x1) ([y1] (eapp (eapp z x1) y1))))))))))))) (esort Eq_rec/type-wf-sort).

Eq_rec/decl : declared "Eq.rec" (eforall (esort (lvar (lis liz)))
                                  ([x]
                                    (eforall x
                                      ([y]
                                        (eforall (eforall x ([z] (eforall (eapp (eapp (eapp (econst "Eq" (lcons (lvar (lis liz)) lnil)) x) y) z) ([w] (esort (lvar liz))))))
                                          ([z]
                                            (eforall (eapp (eapp z y) (eapp (eapp (econst "Eq.refl" (lcons (lvar (lis liz)) lnil)) x) y))
                                              ([w] (eforall x ([x1] (eforall (eapp (eapp (eapp (econst "Eq" (lcons (lvar (lis liz)) lnil)) x) y) x1) ([y1] (eapp (eapp z x1) y1))))))))))))) irec
   = declared/ok-irec Eq/rec-name (dkind-ok/irec Eq_rec/type-wf).

