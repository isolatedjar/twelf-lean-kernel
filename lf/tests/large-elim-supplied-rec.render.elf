%% thm congrArg
%%% HOLE
congrArg/type-wf : of (eforall (esort (lvar liz))
                     ([x]
                       (eforall (esort (lvar (lis liz)))
                         ([y]
                           (eforall x
                             ([z]
                               (eforall x
                                 ([w]
                                   (eforall (eforall x ([x1] y))
                                     ([x1]
                                       (eforall (eapp (eapp (eapp (econst "Eq" (lcons (lvar liz) lnil)) x) z) w)
                                         ([y1] (eapp (eapp (eapp (econst "Eq" (lcons (lvar (lis liz)) lnil)) y) (eapp x1 z)) (eapp x1 w)))))))))))))) (esort lzero).

%%% HOLE
congrArg/value-typed : of (elam (esort (lvar liz))
                         ([x]
                           (elam (esort (lvar (lis liz)))
                             ([y]
                               (elam x
                                 ([z]
                                   (elam x
                                     ([w]
                                       (elam (eforall x ([x1] y))
                                         ([x1]
                                           (elam (eapp (eapp (eapp (econst "Eq" (lcons (lvar liz) lnil)) x) z) w)
                                             ([y1]
                                               (eapp (eapp (eapp (eapp (eapp (eapp (econst "Eq.rec" (lcons lzero (lcons (lvar liz) lnil))) x) z)
                                                 (elam x
                                                   ([z1]
                                                     (elam (eapp (eapp (eapp (econst "Eq" (lcons (lvar liz) lnil)) x) z) z1)
                                                       ([w1] (eapp (eapp (eapp (econst "Eq" (lcons (lvar (lis liz)) lnil)) y) (eapp x1 z)) (eapp x1 z1)))))))
                                                 (eapp (eapp (econst "rfl" (lcons (lvar (lis liz)) lnil)) y) (eapp x1 z)))
                                                 w)
                                                 y1))))))))))))) (eforall (esort (lvar liz))
                         ([x]
                           (eforall (esort (lvar (lis liz)))
                             ([y]
                               (eforall x
                                 ([z]
                                   (eforall x
                                     ([w]
                                       (eforall (eforall x ([x1] y))
                                         ([x1]
                                           (eforall (eapp (eapp (eapp (econst "Eq" (lcons (lvar liz) lnil)) x) z) w)
                                             ([y1] (eapp (eapp (eapp (econst "Eq" (lcons (lvar (lis liz)) lnil)) y) (eapp x1 z)) (eapp x1 w)))))))))))))).

congrArg/name : name "congrArg" (is-decl (eforall (esort (lvar liz))
                                           ([x]
                                             (eforall (esort (lvar (lis liz)))
                                               ([y]
                                                 (eforall x
                                                   ([z]
                                                     (eforall x
                                                       ([w]
                                                         (eforall (eforall x ([x1] y))
                                                           ([x1]
                                                             (eforall (eapp (eapp (eapp (econst "Eq" (lcons (lvar liz) lnil)) x) z) w)
                                                               ([y1] (eapp (eapp (eapp (econst "Eq" (lcons (lvar (lis liz)) lnil)) y) (eapp x1 z)) (eapp x1 w)))))))))))))) (thm (elam (esort (lvar liz)) ([x] (elam (esort (lvar (lis liz))) ([y] (elam x ([z] (elam x ([w] (elam (eforall x ([x1] y)) ([x1] (elam (eapp (eapp (eapp (econst "Eq" (lcons (lvar liz) lnil)) x) z) w) ([y1] (eapp (eapp (eapp (eapp (eapp (eapp (econst "Eq.rec" (lcons lzero (lcons (lvar liz) lnil))) x) z) (elam x ([z1] (elam (eapp (eapp (eapp (econst "Eq" (lcons (lvar liz) lnil)) x) z) z1) ([w1] (eapp (eapp (eapp (econst "Eq" (lcons (lvar (lis liz)) lnil)) y) (eapp x1 z)) (eapp x1 z1))))))) (eapp (eapp (econst "rfl" (lcons (lvar (lis liz)) lnil)) y) (eapp x1 z))) w) y1))))))))))))))).

congrArg/decl : declared "congrArg" (eforall (esort (lvar liz))
                                      ([x]
                                        (eforall (esort (lvar (lis liz)))
                                          ([y]
                                            (eforall x
                                              ([z]
                                                (eforall x
                                                  ([w]
                                                    (eforall (eforall x ([x1] y))
                                                      ([x1]
                                                        (eforall (eapp (eapp (eapp (econst "Eq" (lcons (lvar liz) lnil)) x) z) w)
                                                          ([y1] (eapp (eapp (eapp (econst "Eq" (lcons (lvar (lis liz)) lnil)) y) (eapp x1 z)) (eapp x1 w)))))))))))))) (thm (elam (esort (lvar liz)) ([x] (elam (esort (lvar (lis liz))) ([y] (elam x ([z] (elam x ([w] (elam (eforall x ([x1] y)) ([x1] (elam (eapp (eapp (eapp (econst "Eq" (lcons (lvar liz) lnil)) x) z) w) ([y1] (eapp (eapp (eapp (eapp (eapp (eapp (econst "Eq.rec" (lcons lzero (lcons (lvar liz) lnil))) x) z) (elam x ([z1] (elam (eapp (eapp (eapp (econst "Eq" (lcons (lvar liz) lnil)) x) z) z1) ([w1] (eapp (eapp (eapp (econst "Eq" (lcons (lvar (lis liz)) lnil)) y) (eapp x1 z)) (eapp x1 z1))))))) (eapp (eapp (econst "rfl" (lcons (lvar (lis liz)) lnil)) y) (eapp x1 z))) w) y1))))))))))))))
   = declared/ok congrArg/name (dkind-ok/thm congrArg/type-wf congrArg/value-typed).

%% def ab_eq
%%% HOLE
ab_eq/type-wf-sort : lvl.

%%% HOLE
ab_eq/type-wf : of (eapp (eapp (eapp (econst "Eq" (lcons lzero lnil)) (econst "PropTwo" lnil)) (econst "PropTwo.a" lnil)) (econst "PropTwo.b" lnil)) (esort ab_eq/type-wf-sort).

