%%% Expected outcome: reject
%%% A definition and a recursor with the same name
%% def dup_rec_def.rec
dup_rec_def_rec/type-wf :
   defeq (esort (lsucc lzero)) (esort (lsucc lzero)) (esort (lsucc (lsucc lzero)))
   = (defeq/sort-refl-at (lsucc lzero)).

dup_rec_def_rec/value-typed :
   defeq (esort lzero) (esort lzero) (esort (lsucc lzero))
   = (defeq/sort-refl-at lzero).

dup_rec_def_rec/decl : declared "dup_rec_def.rec" lnil
   (esort (lsucc lzero))
   (defn (esort lzero))
   (dkind-ok/defn dup_rec_def_rec/type-wf dup_rec_def_rec/value-typed).

%% inductive dup_rec_def
dup_rec_def/type-wf :
   defeq (esort (lsucc lzero)) (esort (lsucc lzero)) (esort (lsucc (lsucc lzero)))
   = (defeq/sort-refl-at (lsucc lzero)).

dup_rec_def/ends-in-sort :
   ends-in-sort (esort (lsucc lzero))
   = ends-in-sort/sort.

dup_rec_def/decl : declared "dup_rec_def" lnil
   (esort (lsucc lzero))
   indt
   (dkind-ok/indt dup_rec_def/type-wf dup_rec_def/ends-in-sort).

%% inductive ctor dup_rec_def.mk
dup_rec_def_mk/type-wf :
   defeq (econst "dup_rec_def" lnil) (econst "dup_rec_def" lnil) (esort (lsucc lzero))
   = (defeq/const dup_rec_def/decl).

dup_rec_def_mk/positivity :
   ctor-positive "dup_rec_def" lnil (econst "dup_rec_def" lnil)
   = (ctor-positive/intro ([S] S) (ctor-spine/result applies-self/refl)).

dup_rec_def_mk/decl : declared "dup_rec_def.mk" lnil
   (econst "dup_rec_def" lnil)
   ctor
   (dkind-ok/ctor dup_rec_def_mk/type-wf dup_rec_def_mk/positivity).

%% inductive recursor dup_rec_def.rec
dup_rec_def_rec__dup1/type-wf :
   {u : lvl} defeq (eforall (eforall (econst "dup_rec_def" lnil) ([x] (esort u))) ([x] (eforall (eapp x (econst "dup_rec_def.mk" lnil)) ([y] (eforall (econst "dup_rec_def" lnil) ([z] (eapp x z))))))) (eforall (eforall (econst "dup_rec_def" lnil) ([x] (esort u))) ([x] (eforall (eapp x (econst "dup_rec_def.mk" lnil)) ([y] (eforall (econst "dup_rec_def" lnil) ([z] (eapp x z))))))) (esort (limax (limax (lsucc lzero) (lsucc u)) (limax u (limax (lsucc lzero) u))))
   = [u] (defeq/forall (defeq/forall (defeq/const dup_rec_def/decl) ([x] [y] (defeq/sort-refl-at u))) ([x] [y] (defeq/forall (defeq/app y (defeq/const dup_rec_def_mk/decl)) ([z] [w] (defeq/forall (defeq/const dup_rec_def/decl) ([x1] [y1] (defeq/app y y1))))))).

dup_rec_def_rec__dup1/decl : {u : lvl} declared "dup_rec_def.rec" (lcons u lnil)
   (eforall (eforall (econst "dup_rec_def" lnil) ([x] (esort u))) ([x] (eforall (eapp x (econst "dup_rec_def.mk" lnil)) ([y] (eforall (econst "dup_rec_def" lnil) ([z] (eapp x z)))))))
   irec
   (dkind-ok/irec (dup_rec_def_rec__dup1/type-wf u)).

%% stage-1 enum iota helpers: dup_rec_def
dup_rec_def/as-enum : {u : lvl}
   enum-rec-type
      (eforall (eforall (econst "dup_rec_def" lnil) ([x] (esort u))) ([M] (eforall (eapp M (econst "dup_rec_def.mk" lnil)) ([x] (eforall (econst "dup_rec_def" lnil) ([t] (eapp M t)))))))
      "dup_rec_def" lnil (ccons "dup_rec_def.mk" cnil) u
   = [u] enum-rec-type/intro ([M] [hM] (enum-rec-body/minor ([m1] [hm1] enum-rec-body/done))).

dup_rec_def_mk/iota : {u : lvl}
   defeq M M (eforall (econst "dup_rec_def" lnil) ([x] (esort u)))
   -> defeq Mp1 Mp1 (eapp M (econst "dup_rec_def.mk" lnil))
   -> defeq (eapp (eapp (eapp (econst "dup_rec_def.rec" (lcons u lnil)) M) Mp1) (econst "dup_rec_def.mk" lnil)) Mp1 (eapp M (econst "dup_rec_def.mk" lnil))
   = [u] [hM] [hMp1]
     defeq/extra (defeq/iota-enum-1 (dup_rec_def_rec/decl u) dup_rec_def_mk/decl (dup_rec_def/as-enum u) hM hMp1).

