%%% Expected outcome: reject
%%% A definition and a recursor with the same name
%% def dup_rec_def.rec
dup_rec_def_rec/type-wf :
   defeq (esort (lsucc lzero)) (esort (lsucc lzero)) (esort (lsucc (lsucc lzero)))
   = (defeq/sort-refl-at (lsucc lzero)).

dup_rec_def_rec/value-typed :
   defeq (esort lzero) (esort lzero) (esort (lsucc lzero))
   = (defeq/sort-refl-at lzero).

dup_rec_def_rec/decl : declared "dup_rec_def.rec" lnil
   (esort (lsucc lzero))
   (defn (esort lzero))
   (dkind-ok/defn dup_rec_def_rec/type-wf dup_rec_def_rec/value-typed).

%% SKIP: inductive not yet supported
%mode declared +N +LS -T -DK -W.
%worlds () (declared _ _ _ _ _).
%unique declared +N +LS -1T -1DK *W.
