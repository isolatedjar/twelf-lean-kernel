%%% Expected outcome: accept
%%% Some level computation
%% TRANSLATOR: could not construct lvl-eq (lsucc (limax (lsucc lzero) lzero)) ≈ (lsucc lzero)
%%   emitting value-typed at declared type; Twelf will reject if mismatch is real.
%% def levelComp1
levelComp1 : name.

levelComp1/type-wf :
   defeq (esort (lsucc lzero)) (esort (lsucc lzero)) (esort (lsucc (lsucc lzero)))
   = defeq/sort-refl.

levelComp1/value-typed :
   defeq (esort (limax (lsucc lzero) lzero)) (esort (limax (lsucc lzero) lzero)) (esort (lsucc lzero))
   = defeq/sort-refl.

levelComp1/decl : declared levelComp1 lnil
   (esort (lsucc lzero))
   (defn (esort (limax (lsucc lzero) lzero)))
   (dkind-ok/defn levelComp1/type-wf levelComp1/value-typed).

%mode declared +N -LS -T -DK -W.
%worlds () (declared _ _ _ _ _).
%unique declared +N -1LS -1T -1DK *W.
