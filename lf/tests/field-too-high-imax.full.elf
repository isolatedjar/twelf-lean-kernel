%%% Expected outcome: reject
%%% Constructor field universe exceeds the inductive's, disguised behind `imax`.
%%% 
%%% `inductive Foo : Type 0` with `mk (a : Sort (imax 1 1)) : Foo`.  Since
%%% `imax 1 1 = 1`, the field's type is `Sort 1 = Type 0` (which lives at `Sort 2`),
%%% exceeding the inductive's `Sort 1` — tutorial 054 (`typeWithTooHighTypeField`),
%%% rejected by Lean.
%%% 
%%% A sound checker must reject it. official / lean4lean / nanoda normalize the
%%% field level and reject the universe-inconsistent constructor.
%%% 
%%% Regression for a **translator-bypass** in twelf-lean-kernel: the field-universe
%%% preflight (`checkCtorStructure`) only fires when `levelToNumber(fieldLvl)` is a
%%% concrete number, and `levelToNumber` does not normalize `imax 1 1` (returns
%%% `null`), so the check is skipped; the LF TCB has no universe check, so the bad
%%% ctor is accepted.  Same `levelToNumber` non-normalization bug as the large-elim
%%% gate (`large-elim-imax-prop`).  The plain `Sort 1` field (tutorial 054) is
%%% correctly SKIP-declined; the `imax` disguise slips past.
%% inductive Foo
Foo/type-wf-sort : lvl
   = (lsucc (lsucc lzero)).

Foo/type-wf : of (esort (lsucc lzero)) (esort Foo/type-wf-sort)
   = defeq/sort-refl.

Foo/ends-in-sort : ends-in-sort (esort (lsucc lzero))
   = ends-in-sort/sort.

Foo/rec-name : name "Foo.rec" (is-rec-for "Foo").

Foo/eisl : ends-in-sort-with-level (esort (lsucc lzero)) (lsucc lzero)
   = ends-in-sort-with-level/sort.

Foo/clf : count-leading-foralls (esort (lsucc lzero)) liz
   = count-leading-foralls/zero.

Foo/cnd : cnames-distinct (ccons "Foo.mk" cnil)
   = (cnames-distinct/cons cnames-distinct/nil all-string-neq/nil).

Foo/name : name "Foo" (is-decl (esort (lsucc lzero)) (indt (ccons "Foo.mk" cnil) liz)).

Foo/decl : declared "Foo" (esort (lsucc lzero)) (indt (ccons "Foo.mk" cnil) liz)
   = declared/ok-indt Foo/name Foo/rec-name Foo/clf Foo/cnd (dkind-ok/indt Foo/type-wf Foo/ends-in-sort).

%% ctor Foo.mk (of Foo)
Foo_mk/type-wf-sort : lvl
   = (limax (lsucc (limax (lsucc lzero) (lsucc lzero))) (lsucc lzero)).

Foo_mk/type-wf : of (eforall (esort (limax (lsucc lzero) (lsucc lzero))) ([x] (econst "Foo" lnil))) (esort Foo_mk/type-wf-sort)
   = (defeq/forall
       defeq/sort-refl
       ([x]
         ([h]
           (defeq/const
             Foo/decl
             (inst-expr/sort (lvl-inst/succ lvl-inst/zero)))))).

Foo_mk/positivity : ctor-positive "Foo" lnil (eforall (esort (limax (lsucc lzero) (lsucc lzero))) ([x] (econst "Foo" lnil)))
   = (ctor-positive/intro ([S] (eforall (esort (limax (lsucc lzero) (lsucc lzero))) ([x] S))) (ctor-spine/arg
       (strict-pos/no-occur
         (esort (limax (lsucc lzero) (lsucc lzero)))
         no-self-ref/sort)
       ([x] ([y] (ctor-spine/result applies-self/refl))))).

Foo_mk/cmem : cmem "Foo.mk" (ccons "Foo.mk" cnil)
   = cmem/here.

%%% HOLE: Foo_mk/fuo
Foo_mk/fuo : field-universes-ok-skip-params liz (eforall (esort (limax (lsucc lzero) (lsucc lzero))) ([x] (econst "Foo" lnil))) (lsucc lzero).

Foo_mk/name : name "Foo.mk" (is-decl (eforall (esort (limax (lsucc lzero) (lsucc lzero))) ([x] (econst "Foo" lnil))) (ctor "Foo" liz)).

Foo_mk/decl : declared "Foo.mk" (eforall (esort (limax (lsucc lzero) (lsucc lzero))) ([x] (econst "Foo" lnil))) (ctor "Foo" liz)
   = declared/ok-ctor Foo_mk/name Foo/name Foo_mk/cmem Foo/eisl Foo_mk/fuo (dkind-ok/ctor Foo_mk/type-wf Foo_mk/positivity).

%% recursor Foo.rec
Foo_rec/type-wf-sort : lvl
   = (lsucc lzero).

Foo_rec/type-wf : of (esort lzero) (esort Foo_rec/type-wf-sort)
   = defeq/sort-refl.

%%% HOLE: recursor Foo.rec — non-enum shape (parametric/indexed inductive, or ctor with fields) — §3.1 canonical-schema only handles plain enums in phase 1
Foo_rec/decl : declared "Foo.rec" (esort lzero) (irec "Foo").
