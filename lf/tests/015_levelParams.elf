%%% Expected outcome: accept
%%% Level parameters
%% def levelParamF
levelParamF/type-wf :
   {u : lvl} defeq (eforall (esort u) ([x] (eforall (esort u) ([y] (esort u))))) (eforall (esort u) ([x] (eforall (esort u) ([y] (esort u))))) (esort (limax (lsucc u) (limax (lsucc u) (lsucc u))))
   = [u] (defeq/forall (defeq/sort-refl-at u) ([x] [y] (defeq/forall (defeq/sort-refl-at u) ([z] [w] (defeq/sort-refl-at u))))).

levelParamF/value-typed :
   {u : lvl} defeq (elam (esort u) ([x] (elam (esort u) ([y] x)))) (elam (esort u) ([x] (elam (esort u) ([y] x)))) (eforall (esort u) ([x] (eforall (esort u) ([y] (esort u)))))
   = [u] (defeq/lam (defeq/sort-refl-at u) ([x] [y] (defeq/lam (defeq/sort-refl-at u) ([z] [w] y)))).

levelParamF/decl : {u : lvl} declared "levelParamF" (lcons u lnil)
   (eforall (esort u) ([x] (eforall (esort u) ([y] (esort u)))))
   (defn (elam (esort u) ([x] (elam (esort u) ([y] x)))))
   (dkind-ok/defn (levelParamF/type-wf u) (levelParamF/value-typed u)).

%% def levelParams
levelParams/type-wf :
   defeq (eapp (eapp (econst "levelParamF" (lcons (lsucc lzero) lnil)) (esort lzero)) (eforall (esort lzero) ([x] (esort lzero)))) (eapp (eapp (econst "levelParamF" (lcons (lsucc lzero) lnil)) (esort lzero)) (eforall (esort lzero) ([x] (esort lzero)))) (esort (lsucc lzero))
   = (defeq/app (defeq/app (defeq/const (levelParamF/decl (lsucc lzero))) (defeq/sort-refl-at lzero)) (defeq/conv (defeq/sort-eq (lvl-eq/trans lvl-eq/imax-succ (lvl-eq/trans lvl-eq/max-idem lvl-eq/refl))) (defeq/forall (defeq/sort-refl-at lzero) ([x] [y] (defeq/sort-refl-at lzero))))).

levelParams/value-typed :
   defeq (eforall (esort lzero) ([x] x)) (eforall (esort lzero) ([x] x)) (eapp (eapp (econst "levelParamF" (lcons (lsucc lzero) lnil)) (esort lzero)) (eforall (esort lzero) ([x] (esort lzero))))
   = (defeq/conv (defeq/trans (defeq/conv (defeq/sort-eq (lvl-eq/trans (lvl-eq/lsucc-cong lvl-eq/imax-zero) lvl-eq/refl)) (defeq/sort-eq lvl-eq/imax-zero)) (defeq/symm (defeq/trans (defeq/trans (defeq/app (defeq/app (defeq/delta (levelParamF/decl (lsucc lzero))) (defeq/sort-refl-at lzero)) (defeq/conv (defeq/sort-eq (lvl-eq/trans lvl-eq/imax-succ (lvl-eq/trans lvl-eq/max-idem lvl-eq/refl))) (defeq/forall (defeq/sort-refl-at lzero) ([x] [y] (defeq/sort-refl-at lzero))))) (defeq/app (defeq/beta ([x] [y] (defeq/lam (defeq/sort-refl-at (lsucc lzero)) ([z] [w] y))) (defeq/sort-refl-at lzero)) (defeq/conv (defeq/sort-eq (lvl-eq/trans lvl-eq/imax-succ (lvl-eq/trans lvl-eq/max-idem lvl-eq/refl))) (defeq/forall (defeq/sort-refl-at lzero) ([x] [y] (defeq/sort-refl-at lzero)))))) (defeq/beta ([x] [y] (defeq/sort-refl-at lzero)) (defeq/conv (defeq/sort-eq (lvl-eq/trans lvl-eq/imax-succ (lvl-eq/trans lvl-eq/max-idem lvl-eq/refl))) (defeq/forall (defeq/sort-refl-at lzero) ([x] [y] (defeq/sort-refl-at lzero)))))))) (defeq/forall (defeq/sort-refl-at lzero) ([x] [y] y))).

levelParams/decl : declared "levelParams" lnil
   (eapp (eapp (econst "levelParamF" (lcons (lsucc lzero) lnil)) (esort lzero)) (eforall (esort lzero) ([x] (esort lzero))))
   (defn (eforall (esort lzero) ([x] x)))
   (dkind-ok/defn levelParams/type-wf levelParams/value-typed).

%mode declared +N +LS -T -DK -W.
%worlds () (declared _ _ _ _ _).
%unique declared +N +LS -1T -1DK *W.
