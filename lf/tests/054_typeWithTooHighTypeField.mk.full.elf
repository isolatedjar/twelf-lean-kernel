%%% Expected outcome: reject
%%% An inductive type can have fields of from higher universes.
%% inductive typeWithTooHighTypeField
%%% HOLE
typeWithTooHighTypeField/type-wf : defeq (esort (lsucc lzero)) (esort (lsucc lzero)) (esort lzero).

%%% HOLE
typeWithTooHighTypeField/ends-in-sort : ends-in-sort (esort (lsucc lzero)).

typeWithTooHighTypeField/decl : declared "typeWithTooHighTypeField" lnil
   (esort (lsucc lzero))
   indt
   (dkind-ok/indt typeWithTooHighTypeField/type-wf typeWithTooHighTypeField/ends-in-sort).

%% ctor typeWithTooHighTypeField.mk (of typeWithTooHighTypeField)
%%% HOLE
typeWithTooHighTypeField_mk/type-wf : defeq (eforall (esort (lsucc lzero)) ([x] (econst "typeWithTooHighTypeField" lnil))) (eforall (esort (lsucc lzero)) ([x] (econst "typeWithTooHighTypeField" lnil))) (esort lzero).

%%% HOLE
typeWithTooHighTypeField_mk/positivity : ctor-positive "typeWithTooHighTypeField" lnil (eforall (esort (lsucc lzero)) ([x] (econst "typeWithTooHighTypeField" lnil))).

typeWithTooHighTypeField_mk/decl : declared "typeWithTooHighTypeField.mk" lnil
   (eforall (esort (lsucc lzero)) ([x] (econst "typeWithTooHighTypeField" lnil)))
   ctor
   (dkind-ok/ctor typeWithTooHighTypeField_mk/type-wf typeWithTooHighTypeField_mk/positivity).

%% recursor typeWithTooHighTypeField.rec
%%% HOLE
typeWithTooHighTypeField_rec/type-wf : defeq (esort lzero) (esort lzero) (esort lzero).

typeWithTooHighTypeField_rec/decl : declared "typeWithTooHighTypeField.rec" lnil
   (esort lzero)
   irec
   (dkind-ok/irec typeWithTooHighTypeField_rec/type-wf).

