%%% Expected outcome: accept
%%% Level parameters
%% def levelParamF
%%% HOLE
levelParamF/type-wf-sort : {u : lvl} lvl.

%%% HOLE
levelParamF/type-wf : {u : lvl} defeq (eforall (esort u) ([x] (eforall (esort u) ([y] (esort u))))) (eforall (esort u) ([x] (eforall (esort u) ([y] (esort u))))) (esort (levelParamF/type-wf-sort u)).

%%% HOLE
levelParamF/value-typed : {u : lvl} defeq (elam (esort u) ([x] (elam (esort u) ([y] x)))) (elam (esort u) ([x] (elam (esort u) ([y] x)))) (eforall (esort u) ([x] (eforall (esort u) ([y] (esort u))))).

levelParamF/name : {u : lvl} name "levelParamF" (is-decl (lcons u lnil) (eforall (esort u) ([x] (eforall (esort u) ([y] (esort u))))) (defn (elam (esort u) ([x] (elam (esort u) ([y] x)))))).

levelParamF/decl : {u : lvl} declared "levelParamF" (lcons u lnil) (eforall (esort u) ([x] (eforall (esort u) ([y] (esort u))))) (defn (elam (esort u) ([x] (elam (esort u) ([y] x)))))
   = [u] declared/ok (levelParamF/name u) (dkind-ok/defn (levelParamF/type-wf u) (levelParamF/value-typed u)).

%% def levelParams
%%% HOLE
levelParams/type-wf-sort : lvl.

%%% HOLE
levelParams/type-wf : defeq (eapp (eapp (econst "levelParamF" (lcons (lsucc lzero) lnil)) (esort lzero)) (eforall (esort lzero) ([x] (esort lzero)))) (eapp (eapp (econst "levelParamF" (lcons (lsucc lzero) lnil)) (esort lzero)) (eforall (esort lzero) ([x] (esort lzero)))) (esort levelParams/type-wf-sort).

%%% HOLE
levelParams/value-typed : defeq (eforall (esort lzero) ([x] x)) (eforall (esort lzero) ([x] x)) (eapp (eapp (econst "levelParamF" (lcons (lsucc lzero) lnil)) (esort lzero)) (eforall (esort lzero) ([x] (esort lzero)))).

levelParams/name : name "levelParams" (is-decl lnil (eapp (eapp (econst "levelParamF" (lcons (lsucc lzero) lnil)) (esort lzero)) (eforall (esort lzero) ([x] (esort lzero)))) (defn (eforall (esort lzero) ([x] x)))).

levelParams/decl : declared "levelParams" lnil (eapp (eapp (econst "levelParamF" (lcons (lsucc lzero) lnil)) (esort lzero)) (eforall (esort lzero) ([x] (esort lzero)))) (defn (eforall (esort lzero) ([x] x)))
   = declared/ok levelParams/name (dkind-ok/defn levelParams/type-wf levelParams/value-typed).

