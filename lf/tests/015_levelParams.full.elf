%%% Expected outcome: accept
%%% Level parameters
%solve nonneg_0 : 0 >= 0.

%% def levelParamF
levelParamF/type-wf-sort : lvl
   = (limax (lsucc (lvar liz)) (limax (lsucc (lvar liz)) (lsucc (lvar liz)))).

levelParamF/type-wf : of (eforall (esort (lvar liz)) ([x] (eforall (esort (lvar liz)) ([y] (esort (lvar liz)))))) (esort levelParamF/type-wf-sort)
   = (defeq/forall
       defeq/sort-refl
       ([x] ([h] (defeq/forall defeq/sort-refl ([y] ([h1] defeq/sort-refl)))))).

levelParamF/value-typed : of (elam (esort (lvar liz)) ([x] (elam (esort (lvar liz)) ([y] x)))) (eforall (esort (lvar liz)) ([x] (eforall (esort (lvar liz)) ([y] (esort (lvar liz))))))
   = (defeq/lam
       defeq/sort-refl
       ([x] ([h] (defeq/lam defeq/sort-refl ([y] ([h1] h)))))).

levelParamF/name : name "levelParamF" (is-decl (eforall (esort (lvar liz)) ([x] (eforall (esort (lvar liz)) ([y] (esort (lvar liz)))))) (defn (elam (esort (lvar liz)) ([x] (elam (esort (lvar liz)) ([y] x)))))).

levelParamF/decl : declared "levelParamF" (eforall (esort (lvar liz)) ([x] (eforall (esort (lvar liz)) ([y] (esort (lvar liz)))))) (defn (elam (esort (lvar liz)) ([x] (elam (esort (lvar liz)) ([y] x)))))
   = declared/ok levelParamF/name dkind-non-inductive/defn (dkind-ok/defn levelParamF/type-wf levelParamF/value-typed).

%% def levelParams
levelParams/type-wf-sort : lvl
   = (lsucc lzero).

levelParams/type-wf : of (eapp (eapp (econst "levelParamF" (lcons (lsucc lzero) lnil)) (esort lzero)) (eforall (esort lzero) ([x] (esort lzero)))) (esort levelParams/type-wf-sort)
   = (defeq/app
       (defeq/app
         (defeq/const
           levelParamF/decl
           (inst-expr/forall
             (inst-expr/sort (lvl-inst/var lvl-nth/zero))
             ([x]
               ([h]
                 (inst-expr/forall
                   (inst-expr/sort (lvl-inst/var lvl-nth/zero))
                   ([y]
                     ([h1] (inst-expr/sort (lvl-inst/var lvl-nth/zero)))))))))
         defeq/sort-refl)
       (defeq/conv
         (defeq/sort-eq
           (lvl-eq/le
             (mleq/imax-lsL
               (mleq/sR
                 (mleq/maxL
                   (mleq/sL (mleq/self nonneg_0))
                   (mleq/sL (mleq/self nonneg_0)))))
             (mleq/sL
               (mleq/imax-lsR (mleq/maxR-l (mleq/sR (mleq/self nonneg_0)))))))
         (defeq/forall defeq/sort-refl ([x] ([h] defeq/sort-refl))))).

levelParams/value-typed : of (eforall (esort lzero) ([x] x)) (eapp (eapp (econst "levelParamF" (lcons (lsucc lzero) lnil)) (esort lzero)) (eforall (esort lzero) ([x] (esort lzero))))
   = (defeq/conv
       (defeq/trans
         (defeq/trans
           (defeq/trans
             (defeq/sort-eq
               (lvl-eq/le
                 (mleq/imax-lzL (mleq/self nonneg_0))
                 (mleq/lz nonneg_0)))
             (defeq/conv
               (defeq/sort-eq
                 (lvl-eq/le
                   (mleq/sL (mleq/sR (mleq/lz nonneg_0)))
                   (mleq/sL (mleq/imax-lzL (mleq/sR (mleq/self nonneg_0))))))
               (defeq/symm
                 (defeq/beta
                   ([x] ([h] defeq/sort-refl))
                   (defeq/conv
                     (defeq/sort-eq
                       (lvl-eq/le
                         (mleq/imax-lsL
                           (mleq/sR
                             (mleq/maxL
                               (mleq/sL (mleq/self nonneg_0))
                               (mleq/sL (mleq/self nonneg_0)))))
                         (mleq/sL
                           (mleq/imax-lsR
                             (mleq/maxR-l (mleq/sR (mleq/self nonneg_0)))))))
                     (defeq/forall
                       defeq/sort-refl
                       ([x] ([h] defeq/sort-refl))))))))
           (defeq/conv
             (defeq/sort-eq
               (lvl-eq/le
                 (mleq/sL (mleq/sR (mleq/lz nonneg_0)))
                 (mleq/sL (mleq/imax-lzL (mleq/sR (mleq/self nonneg_0))))))
             (defeq/symm
               (defeq/app
                 (defeq/beta
                   ([x] ([h] (defeq/lam defeq/sort-refl ([y] ([h1] h)))))
                   defeq/sort-refl)
                 (defeq/conv
                   (defeq/sort-eq
                     (lvl-eq/le
                       (mleq/imax-lsL
                         (mleq/sR
                           (mleq/maxL
                             (mleq/sL (mleq/self nonneg_0))
                             (mleq/sL (mleq/self nonneg_0)))))
                       (mleq/sL
                         (mleq/imax-lsR
                           (mleq/maxR-l (mleq/sR (mleq/self nonneg_0)))))))
                   (defeq/forall
                     defeq/sort-refl
                     ([x] ([h] defeq/sort-refl))))))))
         (defeq/conv
           (defeq/sort-eq
             (lvl-eq/le
               (mleq/sL (mleq/sR (mleq/lz nonneg_0)))
               (mleq/sL (mleq/imax-lzL (mleq/sR (mleq/self nonneg_0))))))
           (defeq/symm
             (defeq/app
               (defeq/app
                 (defeq/delta
                   levelParamF/decl
                   (inst-expr/forall
                     (inst-expr/sort (lvl-inst/var lvl-nth/zero))
                     ([x]
                       ([h]
                         (inst-expr/forall
                           (inst-expr/sort (lvl-inst/var lvl-nth/zero))
                           ([y]
                             ([h1]
                               (inst-expr/sort
                                 (lvl-inst/var lvl-nth/zero))))))))
                   (inst-expr/lam
                     (inst-expr/sort (lvl-inst/var lvl-nth/zero))
                     ([x]
                       ([h]
                         (inst-expr/lam
                           (inst-expr/sort (lvl-inst/var lvl-nth/zero))
                           ([y] ([h1] h)))))))
                 defeq/sort-refl)
               (defeq/conv
                 (defeq/sort-eq
                   (lvl-eq/le
                     (mleq/imax-lsL
                       (mleq/sR
                         (mleq/maxL
                           (mleq/sL (mleq/self nonneg_0))
                           (mleq/sL (mleq/self nonneg_0)))))
                     (mleq/sL
                       (mleq/imax-lsR
                         (mleq/maxR-l (mleq/sR (mleq/self nonneg_0)))))))
                 (defeq/forall defeq/sort-refl ([x] ([h] defeq/sort-refl))))))))
       (defeq/forall defeq/sort-refl ([x] ([h] h)))).

levelParams/name : name "levelParams" (is-decl (eapp (eapp (econst "levelParamF" (lcons (lsucc lzero) lnil)) (esort lzero)) (eforall (esort lzero) ([x] (esort lzero)))) (defn (eforall (esort lzero) ([x] x)))).

levelParams/decl : declared "levelParams" (eapp (eapp (econst "levelParamF" (lcons (lsucc lzero) lnil)) (esort lzero)) (eforall (esort lzero) ([x] (esort lzero)))) (defn (eforall (esort lzero) ([x] x)))
   = declared/ok levelParams/name dkind-non-inductive/defn (dkind-ok/defn levelParams/type-wf levelParams/value-typed).
