%%% Expected outcome: accept
%%% Level parameters
%% def levelParamF
levelParamF/type-wf : of (eforall (esort (lvar z)) ([x] (eforall (esort (lvar z)) ([y] (esort (lvar z)))))) (esort (limax (lsucc (lvar z)) (limax (lsucc (lvar z)) (lsucc (lvar z)))))
   = (defeq/forall
       defeq/sort-refl
       ([x] ([h] (defeq/forall defeq/sort-refl ([y] ([h1] defeq/sort-refl)))))).

levelParamF/value-typed : of (elam (esort (lvar z)) ([x] (elam (esort (lvar z)) ([y] x)))) (eforall (esort (lvar z)) ([x] (eforall (esort (lvar z)) ([y] (esort (lvar z))))))
   = (defeq/lam
       defeq/sort-refl
       ([x] ([h] (defeq/lam defeq/sort-refl ([y] ([h1] h)))))).

levelParamF/name : name "levelParamF" (is-decl (eforall (esort (lvar z)) ([x] (eforall (esort (lvar z)) ([y] (esort (lvar z)))))) (defn (elam (esort (lvar z)) ([x] (elam (esort (lvar z)) ([y] x)))))).

levelParamF/decl : declared "levelParamF" (eforall (esort (lvar z)) ([x] (eforall (esort (lvar z)) ([y] (esort (lvar z)))))) (defn (elam (esort (lvar z)) ([x] (elam (esort (lvar z)) ([y] x)))))
   = declared/ok levelParamF/name dkind-non-inductive/defn (dkind-ok/defn levelParamF/type-wf levelParamF/value-typed).

%% def levelParams
levelParams/type-wf : of (eapp (eapp (econst "levelParamF" (lcons (lsucc lzero) lnil)) (esort lzero)) (eforall (esort lzero) ([x] (esort lzero)))) (esort (lsucc lzero))
   = (defeq/app
       (defeq/app
         (defeq/const
           levelParamF/decl
           (inst-expr/forall
             (inst-expr/sort (inst-lvl/var nth-lvl/z))
             ([x]
               ([h]
                 (inst-expr/forall
                   (inst-expr/sort (inst-lvl/var nth-lvl/z))
                   ([y] ([h1] (inst-expr/sort (inst-lvl/var nth-lvl/z)))))))))
         defeq/sort-refl)
       (defeq/conv
         (defeq/sort-eq
           (eq-lvl/le
             (leq-lvl/imaxRs (leq-lvl/maxR1 leq-lvl/self))
             (leq-lvl/imaxLs
               (leq-lvl/sR
                 (leq-lvl/maxL
                   (leq-lvl/sL leq-lvl/self)
                   (leq-lvl/sL leq-lvl/self))))))
         (defeq/forall defeq/sort-refl ([x] ([h] defeq/sort-refl))))).

levelParams/value-typed : of (eforall (esort lzero) ([x] x)) (eapp (eapp (econst "levelParamF" (lcons (lsucc lzero) lnil)) (esort lzero)) (eforall (esort lzero) ([x] (esort lzero))))
   = (defeq/conv
       (defeq/trans
         (defeq/trans
           (defeq/trans
             (defeq/sort-eq
               (eq-lvl/le leq-lvl/lz (leq-lvl/imaxLz leq-lvl/self)))
             (defeq/conv
               (defeq/sort-eq
                 (eq-lvl/le
                   (leq-lvl/sR (leq-lvl/sL (leq-lvl/imaxLz leq-lvl/self)))
                   (leq-lvl/sR (leq-lvl/sL leq-lvl/lz))))
               (defeq/symm
                 (defeq/beta
                   ([x] ([h] defeq/sort-refl))
                   (defeq/conv
                     (defeq/sort-eq
                       (eq-lvl/le
                         (leq-lvl/imaxRs (leq-lvl/maxR1 leq-lvl/self))
                         (leq-lvl/imaxLs
                           (leq-lvl/sR
                             (leq-lvl/maxL
                               (leq-lvl/sL leq-lvl/self)
                               (leq-lvl/sL leq-lvl/self))))))
                     (defeq/forall
                       defeq/sort-refl
                       ([x] ([h] defeq/sort-refl))))))))
           (defeq/conv
             (defeq/sort-eq
               (eq-lvl/le
                 (leq-lvl/sR (leq-lvl/sL (leq-lvl/imaxLz leq-lvl/self)))
                 (leq-lvl/sR (leq-lvl/sL leq-lvl/lz))))
             (defeq/symm
               (defeq/app
                 (defeq/beta
                   ([x] ([h] (defeq/lam defeq/sort-refl ([y] ([h1] h)))))
                   defeq/sort-refl)
                 (defeq/conv
                   (defeq/sort-eq
                     (eq-lvl/le
                       (leq-lvl/imaxRs (leq-lvl/maxR1 leq-lvl/self))
                       (leq-lvl/imaxLs
                         (leq-lvl/sR
                           (leq-lvl/maxL
                             (leq-lvl/sL leq-lvl/self)
                             (leq-lvl/sL leq-lvl/self))))))
                   (defeq/forall
                     defeq/sort-refl
                     ([x] ([h] defeq/sort-refl))))))))
         (defeq/conv
           (defeq/sort-eq
             (eq-lvl/le
               (leq-lvl/sR (leq-lvl/sL (leq-lvl/imaxLz leq-lvl/self)))
               (leq-lvl/sR (leq-lvl/sL leq-lvl/lz))))
           (defeq/symm
             (defeq/app
               (defeq/app
                 (defeq/delta
                   levelParamF/decl
                   (inst-expr/forall
                     (inst-expr/sort (inst-lvl/var nth-lvl/z))
                     ([x]
                       ([h]
                         (inst-expr/forall
                           (inst-expr/sort (inst-lvl/var nth-lvl/z))
                           ([y]
                             ([h1]
                               (inst-expr/sort (inst-lvl/var nth-lvl/z))))))))
                   (inst-expr/lam
                     (inst-expr/sort (inst-lvl/var nth-lvl/z))
                     ([x]
                       ([h]
                         (inst-expr/lam
                           (inst-expr/sort (inst-lvl/var nth-lvl/z))
                           ([y] ([h1] h)))))))
                 defeq/sort-refl)
               (defeq/conv
                 (defeq/sort-eq
                   (eq-lvl/le
                     (leq-lvl/imaxRs (leq-lvl/maxR1 leq-lvl/self))
                     (leq-lvl/imaxLs
                       (leq-lvl/sR
                         (leq-lvl/maxL
                           (leq-lvl/sL leq-lvl/self)
                           (leq-lvl/sL leq-lvl/self))))))
                 (defeq/forall defeq/sort-refl ([x] ([h] defeq/sort-refl))))))))
       (defeq/forall defeq/sort-refl ([x] ([h] h)))).

levelParams/name : name "levelParams" (is-decl (eapp (eapp (econst "levelParamF" (lcons (lsucc lzero) lnil)) (esort lzero)) (eforall (esort lzero) ([x] (esort lzero)))) (defn (eforall (esort lzero) ([x] x)))).

levelParams/decl : declared "levelParams" (eapp (eapp (econst "levelParamF" (lcons (lsucc lzero) lnil)) (esort lzero)) (eforall (esort lzero) ([x] (esort lzero)))) (defn (eforall (esort lzero) ([x] x)))
   = declared/ok levelParams/name dkind-non-inductive/defn (dkind-ok/defn levelParams/type-wf levelParams/value-typed).
