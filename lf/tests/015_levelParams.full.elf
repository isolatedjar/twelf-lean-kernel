%%% Expected outcome: accept
%%% Level parameters
%% def levelParamF
levelParamF/type-wf-sort : lvl
   = (limax (lsucc (lvar liz)) (limax (lsucc (lvar liz)) (lsucc (lvar liz)))).

levelParamF/type-wf : defeq (eforall (esort (lvar liz)) ([x] (eforall (esort (lvar liz)) ([y] (esort (lvar liz)))))) (eforall (esort (lvar liz)) ([x] (eforall (esort (lvar liz)) ([y] (esort (lvar liz)))))) (esort levelParamF/type-wf-sort)
   = (defeq/forall defeq/sort-refl ([x] ([h] (defeq/forall defeq/sort-refl ([y] ([h1] defeq/sort-refl)))))).

levelParamF/value-typed : defeq (elam (esort (lvar liz)) ([x] (elam (esort (lvar liz)) ([y] x)))) (elam (esort (lvar liz)) ([x] (elam (esort (lvar liz)) ([y] x)))) (eforall (esort (lvar liz)) ([x] (eforall (esort (lvar liz)) ([y] (esort (lvar liz))))))
   = (defeq/lam defeq/sort-refl ([x] ([h] (defeq/lam defeq/sort-refl ([y] ([h1] h)))))).

levelParamF/name : name "levelParamF" (is-decl (eforall (esort (lvar liz)) ([x] (eforall (esort (lvar liz)) ([y] (esort (lvar liz)))))) (defn (elam (esort (lvar liz)) ([x] (elam (esort (lvar liz)) ([y] x)))))).

levelParamF/decl : declared "levelParamF" (eforall (esort (lvar liz)) ([x] (eforall (esort (lvar liz)) ([y] (esort (lvar liz)))))) (defn (elam (esort (lvar liz)) ([x] (elam (esort (lvar liz)) ([y] x)))))
   = declared/ok levelParamF/name (dkind-ok/defn levelParamF/type-wf levelParamF/value-typed).

%% def levelParams
%%% HOLE
levelParams/type-wf-sort : lvl.

%%% HOLE
levelParams/type-wf : defeq (eapp (eapp (econst "levelParamF" (lcons (lsucc lzero) lnil)) (esort lzero)) (eforall (esort lzero) ([x] (esort lzero)))) (eapp (eapp (econst "levelParamF" (lcons (lsucc lzero) lnil)) (esort lzero)) (eforall (esort lzero) ([x] (esort lzero)))) (esort levelParams/type-wf-sort).

%%% HOLE
levelParams/value-typed : defeq (eforall (esort lzero) ([x] x)) (eforall (esort lzero) ([x] x)) (eapp (eapp (econst "levelParamF" (lcons (lsucc lzero) lnil)) (esort lzero)) (eforall (esort lzero) ([x] (esort lzero)))).

levelParams/name : name "levelParams" (is-decl (eapp (eapp (econst "levelParamF" (lcons (lsucc lzero) lnil)) (esort lzero)) (eforall (esort lzero) ([x] (esort lzero)))) (defn (eforall (esort lzero) ([x] x)))).

levelParams/decl : declared "levelParams" (eapp (eapp (econst "levelParamF" (lcons (lsucc lzero) lnil)) (esort lzero)) (eforall (esort lzero) ([x] (esort lzero)))) (defn (eforall (esort lzero) ([x] x)))
   = declared/ok levelParams/name (dkind-ok/defn levelParams/type-wf levelParams/value-typed).

