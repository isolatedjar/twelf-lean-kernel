%%% HOLE: Nat_succ/fuo — prover for field-universes-ok-skip-params not yet implemented
Nat_succ/fuo : field-universes-ok-skip-params liz (eforall (econst "Nat" lnil) ([x] (econst "Nat" lnil))) (lsucc lzero).

Nat_succ/name : name "Nat.succ" (is-decl (eforall (econst "Nat" lnil) ([x] (econst "Nat" lnil))) (ctor "Nat" (lis liz))).

Nat_succ/decl : declared "Nat.succ" (eforall (econst "Nat" lnil) ([x] (econst "Nat" lnil))) (ctor "Nat" (lis liz))
   = declared/ok-ctor Nat_succ/name Nat/name Nat_succ/cmem Nat_succ/eisl Nat_succ/fuo (dkind-ok/ctor Nat_succ/type-wf Nat_succ/positivity).

%% recursor Nat.rec
%%% HOLE
Nat_rec/type-wf-sort : lvl.

%%% HOLE
Nat_rec/type-wf : of
  (eforall (eforall (econst "Nat" lnil) ([x] (esort (lvar liz))))
    ([x]
      (eforall (eapp x (econst "Nat.zero" lnil))
        ([y] (eforall (eforall (econst "Nat" lnil) ([z] (eforall (eapp x z) ([w] (eapp x (eapp (econst "Nat.succ" lnil) z)))))) ([z] (eforall (econst "Nat" lnil) ([w] (eapp x w)))))))))
  (esort Nat_rec/type-wf-sort).

Nat_rec/decl : declared "Nat.rec"
  (eforall (eforall (econst "Nat" lnil) ([x] (esort (lvar liz))))
    ([x]
      (eforall (eapp x (econst "Nat.zero" lnil))
        ([y] (eforall (eforall (econst "Nat" lnil) ([z] (eforall (eapp x z) ([w] (eapp x (eapp (econst "Nat.succ" lnil) z)))))) ([z] (eforall (econst "Nat" lnil) ([w] (eapp x w)))))))))
  (irec "Nat")
   = declared/ok-irec Nat/rec-name (dkind-ok/irec Nat_rec/type-wf).

