   = (defeq/forall (defeq/const Unit/decl) ([x] [y] (defeq/forall (defeq/const Unit/decl) ([z] [w] (defeq/app (defeq/app (defeq/app (defeq/const (Eq/decl (lsucc lzero))) (defeq/const Unit/decl)) y) w))))).

unitEta1/value-typed :
   defeq (elam (econst "Unit" lnil) ([x] (elam (econst "Unit" lnil) ([y] (eapp (eapp (econst "rfl" (lcons (lsucc lzero) lnil)) (econst "Unit" lnil)) x))))) (elam (econst "Unit" lnil) ([x] (elam (econst "Unit" lnil) ([y] (eapp (eapp (econst "rfl" (lcons (lsucc lzero) lnil)) (econst "Unit" lnil)) x))))) (eforall (econst "Unit" lnil) ([x] (eforall (econst "Unit" lnil) ([y] (eapp (eapp (eapp (econst "Eq" (lcons (lsucc lzero) lnil)) (econst "Unit" lnil)) x) y)))))
   = (defeq/lam (defeq/const Unit/decl) ([x] [y] (defeq/lam (defeq/const Unit/decl) ([z] [w] (defeq/app (defeq/app (defeq/const (rfl/decl (lsucc lzero))) (defeq/const Unit/decl)) y))))).

unitEta1/decl : declared "unitEta1" lnil
   (eforall (econst "Unit" lnil) ([x] (eforall (econst "Unit" lnil) ([y] (eapp (eapp (eapp (econst "Eq" (lcons (lsucc lzero) lnil)) (econst "Unit" lnil)) x) y)))))
