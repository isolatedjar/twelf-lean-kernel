%% recursor PropStructure.rec
PropStructure_rec/type-wf-sort : lvl
   = (limax
       (limax lzero (lsucc lzero))
       (limax
         (limax
           (lvar liz)
           (limax
             (lvar (lis liz))
             (limax
               (lvar liz)
               (limax
                 (lvar (lis liz))
                 (limax lzero (limax (lvar liz) lzero))))))
         (limax lzero lzero))).

PropStructure_rec/type-wf : of (eforall (eforall (econst "PropStructure" (lcons (lvar liz) (lcons (lvar (lis liz)) lnil))) ([x] (esort lzero)))
                              ([x]
