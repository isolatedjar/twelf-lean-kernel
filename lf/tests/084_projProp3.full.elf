                   ([x1]
                     ([y1]
                       (ctor-spine/arg
                         (strict-pos/no-occur
                           (econst "PUnit" (lcons (lvar (lis liz)) lnil))
                           (no-self-ref/const sneq/0))
                         ([z1]
                           ([w1]
