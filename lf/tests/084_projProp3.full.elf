%%% Expected outcome: accept
%%% Projecting out of a proposition
%%% 
%%% The lean kernel allows projections out of propositions if they precede
%%% all dependent data fields. Non-dependent data fields are not relevant.
sneq/0 : string-neq "PUnit" "PropStructure".
sneq/1 : string-neq "Eq" "PropStructure".

%% inductive PUnit
PUnit/type-wf-sort : lvl
   = (lsucc (lvar liz)).

PUnit/type-wf : of (esort (lvar liz)) (esort PUnit/type-wf-sort)
   = defeq/sort-refl.

PUnit/ends-in-sort : ends-in-sort (esort (lvar liz))
   = ends-in-sort/sort.

PUnit/rec-name : name "PUnit.rec" (is-rec-for "PUnit").

PUnit/name : name "PUnit" (is-decl (esort (lvar liz)) indt).

PUnit/decl : declared "PUnit" (esort (lvar liz)) indt
   = declared/ok PUnit/name (dkind-ok/indt PUnit/type-wf PUnit/ends-in-sort).

%% ctor PUnit.unit (of PUnit)
PUnit_unit/type-wf-sort : lvl
   = (lvar liz).

PUnit_unit/type-wf : of (econst "PUnit" (lcons (lvar liz) lnil)) (esort PUnit_unit/type-wf-sort)
   = (defeq/const PUnit/decl (inst-expr/sort (lvl-inst/var lvl-nth/zero))).

PUnit_unit/positivity : ctor-positive "PUnit" (lcons (lvar liz) lnil) (econst "PUnit" (lcons (lvar liz) lnil))
   = (ctor-positive/intro ([S] S) (ctor-spine/result applies-self/refl)).

PUnit_unit/eisl : ends-in-sort-with-level (esort (lvar liz)) (lvar liz)
   = ends-in-sort-with-level/sort.

%%% HOLE: PUnit_unit/fuo — prover for field-universes-ok-skip-params not yet implemented
PUnit_unit/fuo : field-universes-ok-skip-params liz (econst "PUnit" (lcons (lvar liz) lnil)) (lvar liz).

PUnit_unit/name : name "PUnit.unit" (is-decl (econst "PUnit" (lcons (lvar liz) lnil)) ctor).

PUnit_unit/decl : declared "PUnit.unit" (econst "PUnit" (lcons (lvar liz) lnil)) ctor
   = declared/ok PUnit_unit/name (dkind-ok/ctor PUnit_unit/type-wf PUnit_unit/positivity PUnit/decl PUnit_unit/eisl PUnit_unit/fuo).

%% recursor PUnit.rec
PUnit_rec/type-wf-sort : lvl
   = (limax
       (limax (lvar (lis liz)) (lsucc (lvar liz)))
       (limax (lvar liz) (limax (lvar (lis liz)) (lvar liz)))).

PUnit_rec/type-wf : of (eforall (eforall (econst "PUnit" (lcons (lvar (lis liz)) lnil)) ([x] (esort (lvar liz))))
                      ([x]
                        (eforall (eapp x (econst "PUnit.unit" (lcons (lvar (lis liz)) lnil)))
                          ([y] (eforall (econst "PUnit" (lcons (lvar (lis liz)) lnil)) ([z] (eapp x z))))))) (esort PUnit_rec/type-wf-sort)
   = (defeq/forall
       (defeq/forall
         (defeq/const PUnit/decl (inst-expr/sort (lvl-inst/var lvl-nth/zero)))
         ([x] ([h] defeq/sort-refl)))
       ([x]
         ([h]
           (defeq/forall
             (defeq/app
               h
               (defeq/const
                 PUnit_unit/decl
                 (inst-expr/const
                   (lvls-inst/cons (lvl-inst/var lvl-nth/zero) lvls-inst/nil))))
             ([y]
               ([h1]
                 (defeq/forall
                   (defeq/const
                     PUnit/decl
                     (inst-expr/sort (lvl-inst/var lvl-nth/zero)))
                   ([z] ([h2] (defeq/app h h2)))))))))).

PUnit_rec/decl : declared "PUnit.rec" (eforall (eforall (econst "PUnit" (lcons (lvar (lis liz)) lnil)) ([x] (esort (lvar liz)))) ([x] (eforall (eapp x (econst "PUnit.unit" (lcons (lvar (lis liz)) lnil))) ([y] (eforall (econst "PUnit" (lcons (lvar (lis liz)) lnil)) ([z] (eapp x z))))))) irec
   = declared/ok-irec PUnit/rec-name (dkind-ok/irec PUnit_rec/type-wf).

%% inductive Eq
Eq/type-wf-sort : lvl
   = (limax
       (lsucc (lvar liz))
       (limax (lvar liz) (limax (lvar liz) (lsucc lzero)))).

Eq/type-wf : of (eforall (esort (lvar liz)) ([x] (eforall x ([y] (eforall x ([z] (esort lzero))))))) (esort Eq/type-wf-sort)
   = (defeq/forall
       defeq/sort-refl
       ([x]
         ([h]
           (defeq/forall
             h
             ([y] ([h1] (defeq/forall h ([z] ([h2] defeq/sort-refl))))))))).

Eq/ends-in-sort : ends-in-sort (eforall (esort (lvar liz)) ([x] (eforall x ([y] (eforall x ([z] (esort lzero)))))))
   = (ends-in-sort/forall
       ([x]
         (ends-in-sort/forall
           ([y] (ends-in-sort/forall ([z] ends-in-sort/sort)))))).

Eq/rec-name : name "Eq.rec" (is-rec-for "Eq").

Eq/name : name "Eq" (is-decl (eforall (esort (lvar liz)) ([x] (eforall x ([y] (eforall x ([z] (esort lzero))))))) indt).

Eq/decl : declared "Eq" (eforall (esort (lvar liz)) ([x] (eforall x ([y] (eforall x ([z] (esort lzero))))))) indt
   = declared/ok Eq/name (dkind-ok/indt Eq/type-wf Eq/ends-in-sort).

%% ctor Eq.refl (of Eq)
Eq_refl/type-wf-sort : lvl
   = (limax (lsucc (lvar liz)) (limax (lvar liz) lzero)).

Eq_refl/type-wf : of (eforall (esort (lvar liz)) ([x] (eforall x ([y] (eapp (eapp (eapp (econst "Eq" (lcons (lvar liz) lnil)) x) y) y))))) (esort Eq_refl/type-wf-sort)
   = (defeq/forall
       defeq/sort-refl
       ([x]
         ([h]
           (defeq/forall
             h
             ([y]
               ([h1]
                 (defeq/app
                   (defeq/app
                     (defeq/app
                       (defeq/const
                         Eq/decl
                         (inst-expr/forall
                           (inst-expr/sort (lvl-inst/var lvl-nth/zero))
                           ([x]
                             ([h]
                               (inst-expr/forall
                                 h
                                 ([y]
                                   ([h1]
                                     (inst-expr/forall
                                       h
                                       ([z]
                                         ([h2]
                                           (inst-expr/sort
                                             lvl-inst/zero)))))))))))
                       h)
                     h1)
                   h1))))))).

Eq_refl/positivity : ctor-positive "Eq" (lcons (lvar liz) lnil) (eforall (esort (lvar liz)) ([x] (eforall x ([y] (eapp (eapp (eapp (econst "Eq" (lcons (lvar liz) lnil)) x) y) y)))))
   = (ctor-positive/intro ([S] (eforall (esort (lvar liz)) ([x] (eforall x ([y] (eapp (eapp (eapp S x) y) y)))))) (ctor-spine/arg
       (strict-pos/no-occur (esort (lvar liz)) no-self-ref/sort)
       ([x]
         ([y]
           (ctor-spine/arg
             (strict-pos/no-occur x y)
             ([z]
               ([w]
                 (ctor-spine/result
                   (applies-self/app
                     (applies-self/app
                       (applies-self/app applies-self/refl))))))))))).

Eq_refl/eisl : ends-in-sort-with-level (eforall (esort (lvar liz)) ([x] (eforall x ([y] (eforall x ([z] (esort lzero))))))) lzero
   = (ends-in-sort-with-level/forall
       ([x]
         (ends-in-sort-with-level/forall
           ([y]
             (ends-in-sort-with-level/forall
               ([z] ends-in-sort-with-level/sort)))))).

%%% HOLE: Eq_refl/fuo — prover for field-universes-ok-skip-params not yet implemented
Eq_refl/fuo : field-universes-ok-skip-params (lis (lis liz)) (eforall (esort (lvar liz)) ([x] (eforall x ([y] (eapp (eapp (eapp (econst "Eq" (lcons (lvar liz) lnil)) x) y) y))))) lzero.

Eq_refl/name : name "Eq.refl" (is-decl (eforall (esort (lvar liz)) ([x] (eforall x ([y] (eapp (eapp (eapp (econst "Eq" (lcons (lvar liz) lnil)) x) y) y))))) ctor).

Eq_refl/decl : declared "Eq.refl" (eforall (esort (lvar liz)) ([x] (eforall x ([y] (eapp (eapp (eapp (econst "Eq" (lcons (lvar liz) lnil)) x) y) y))))) ctor
   = declared/ok Eq_refl/name (dkind-ok/ctor Eq_refl/type-wf Eq_refl/positivity Eq/decl Eq_refl/eisl Eq_refl/fuo).

%% recursor Eq.rec
Eq_rec/type-wf-sort : lvl
   = (limax
       (lsucc (lvar (lis liz)))
       (limax
         (lvar (lis liz))
         (limax
           (limax (lvar (lis liz)) (limax lzero (lsucc (lvar liz))))
           (limax
             (lvar liz)
             (limax (lvar (lis liz)) (limax lzero (lvar liz))))))).

Eq_rec/type-wf : of (eforall (esort (lvar (lis liz)))
                   ([x]
                     (eforall x
                       ([y]
                         (eforall (eforall x ([z] (eforall (eapp (eapp (eapp (econst "Eq" (lcons (lvar (lis liz)) lnil)) x) y) z) ([w] (esort (lvar liz))))))
                           ([z]
                             (eforall (eapp (eapp z y) (eapp (eapp (econst "Eq.refl" (lcons (lvar (lis liz)) lnil)) x) y))
                               ([w]
                                 (eforall x ([x1] (eforall (eapp (eapp (eapp (econst "Eq" (lcons (lvar (lis liz)) lnil)) x) y) x1) ([y1] (eapp (eapp z x1) y1))))))))))))) (esort Eq_rec/type-wf-sort)
   = (defeq/forall
       defeq/sort-refl
       ([x]
         ([h]
           (defeq/forall
             h
             ([y]
               ([h1]
                 (defeq/forall
                   (defeq/forall
                     h
                     ([z]
                       ([h2]
                         (defeq/forall
                           (defeq/app
                             (defeq/app
                               (defeq/app
                                 (defeq/const
                                   Eq/decl
                                   (inst-expr/forall
                                     (inst-expr/sort
                                       (lvl-inst/var lvl-nth/zero))
                                     ([x]
                                       ([h]
                                         (inst-expr/forall
                                           h
                                           ([y]
                                             ([h1]
                                               (inst-expr/forall
                                                 h
                                                 ([z]
                                                   ([h2]
                                                     (inst-expr/sort
                                                       lvl-inst/zero)))))))))))
                                 h)
                               h1)
                             h2)
                           ([w] ([h3] defeq/sort-refl))))))
                   ([z]
                     ([h2]
                       (defeq/forall
                         (defeq/app
                           (defeq/app h2 h1)
                           (defeq/app
                             (defeq/app
                               (defeq/const
                                 Eq_refl/decl
                                 (inst-expr/forall
                                   (inst-expr/sort (lvl-inst/var lvl-nth/zero))
                                   ([x]
                                     ([h]
                                       (inst-expr/forall
                                         h
                                         ([y]
                                           ([h1]
                                             (inst-expr/app
                                               (inst-expr/app
                                                 (inst-expr/app
                                                   (inst-expr/const
                                                     (lvls-inst/cons
                                                       (lvl-inst/var
                                                         lvl-nth/zero)
                                                       lvls-inst/nil))
                                                   h)
                                                 h1)
                                               h1))))))))
                               h)
                             h1))
                         ([w]
                           ([h3]
                             (defeq/forall
                               h
                               ([x1]
                                 ([h4]
                                   (defeq/forall
                                     (defeq/app
                                       (defeq/app
                                         (defeq/app
                                           (defeq/const
                                             Eq/decl
                                             (inst-expr/forall
                                               (inst-expr/sort
                                                 (lvl-inst/var lvl-nth/zero))
                                               ([x]
                                                 ([h]
                                                   (inst-expr/forall
                                                     h
                                                     ([y]
                                                       ([h1]
                                                         (inst-expr/forall
                                                           h
                                                           ([z]
                                                             ([h2]
                                                               (inst-expr/sort
                                                                 lvl-inst/zero)))))))))))
                                           h)
                                         h1)
                                       h4)
                                     ([y1]
                                       ([h5]
                                         (defeq/app
                                           (defeq/app h2 h4)
                                           h5))))))))))))))))))).

Eq_rec/decl : declared "Eq.rec" (eforall (esort (lvar (lis liz))) ([x] (eforall x ([y] (eforall (eforall x ([z] (eforall (eapp (eapp (eapp (econst "Eq" (lcons (lvar (lis liz)) lnil)) x) y) z) ([w] (esort (lvar liz)))))) ([z] (eforall (eapp (eapp z y) (eapp (eapp (econst "Eq.refl" (lcons (lvar (lis liz)) lnil)) x) y)) ([w] (eforall x ([x1] (eforall (eapp (eapp (eapp (econst "Eq" (lcons (lvar (lis liz)) lnil)) x) y) x1) ([y1] (eapp (eapp z x1) y1))))))))))))) irec
   = declared/ok-irec Eq/rec-name (dkind-ok/irec Eq_rec/type-wf).

