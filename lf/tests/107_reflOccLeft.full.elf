%%% Expected outcome: reject
%%% Rejection: recursive occurrence on the *left* of an arrow,
%%% *behind further arrows* inside a constructor argument.
%%% 
%%% The constructor argument is a function type `Nat → (I → Nat)`.
sneq/0 : string-neq "Nat" "reflOccLeft".

%% inductive Nat
Nat/type-wf-sort : lvl
   = (lsucc (lsucc lzero)).

Nat/type-wf : of (esort (lsucc lzero)) (esort Nat/type-wf-sort)
   = defeq/sort-refl.

Nat/ends-in-sort : ends-in-sort (esort (lsucc lzero))
   = ends-in-sort/sort.

Nat/rec-name : name "Nat.rec" (is-rec-for "Nat").

Nat/name : name "Nat" (is-decl (esort (lsucc lzero)) indt).

Nat/decl : declared "Nat" (esort (lsucc lzero)) indt
   = declared/ok Nat/name (dkind-ok/indt Nat/type-wf Nat/ends-in-sort).

%% ctor Nat.zero (of Nat)
Nat_zero/type-wf-sort : lvl
   = (lsucc lzero).

Nat_zero/type-wf : of (econst "Nat" lnil) (esort Nat_zero/type-wf-sort)
   = (defeq/const Nat/decl (inst-expr/sort (lvl-inst/succ lvl-inst/zero))).

Nat_zero/positivity : ctor-positive "Nat" lnil (econst "Nat" lnil)
   = (ctor-positive/intro ([S] S) (ctor-spine/result applies-self/refl)).

Nat_zero/eisl : ends-in-sort-with-level (esort (lsucc lzero)) (lsucc lzero)
   = ends-in-sort-with-level/sort.

%%% HOLE: Nat_zero/fuo — prover for field-universes-ok-skip-params not yet implemented
Nat_zero/fuo : field-universes-ok-skip-params liz (econst "Nat" lnil) (lsucc lzero).

Nat_zero/name : name "Nat.zero" (is-decl (econst "Nat" lnil) ctor).

Nat_zero/decl : declared "Nat.zero" (econst "Nat" lnil) ctor
   = declared/ok Nat_zero/name (dkind-ok/ctor Nat_zero/type-wf Nat_zero/positivity Nat/decl Nat_zero/eisl Nat_zero/fuo).

%% ctor Nat.succ (of Nat)
Nat_succ/type-wf-sort : lvl
   = (limax (lsucc lzero) (lsucc lzero)).

Nat_succ/type-wf : of (eforall (econst "Nat" lnil) ([x] (econst "Nat" lnil))) (esort Nat_succ/type-wf-sort)
   = (defeq/forall
       (defeq/const Nat/decl (inst-expr/sort (lvl-inst/succ lvl-inst/zero)))
       ([x]
         ([h]
           (defeq/const
             Nat/decl
             (inst-expr/sort (lvl-inst/succ lvl-inst/zero)))))).

Nat_succ/positivity : ctor-positive "Nat" lnil (eforall (econst "Nat" lnil) ([x] (econst "Nat" lnil)))
   = (ctor-positive/intro ([S] (eforall S ([x] S))) (ctor-spine/arg
       (strict-pos/head applies-self/refl)
       ([x] ([y] (ctor-spine/result applies-self/refl))))).

Nat_succ/eisl : ends-in-sort-with-level (esort (lsucc lzero)) (lsucc lzero)
   = ends-in-sort-with-level/sort.

%%% HOLE: Nat_succ/fuo — prover for field-universes-ok-skip-params not yet implemented
Nat_succ/fuo : field-universes-ok-skip-params liz (eforall (econst "Nat" lnil) ([x] (econst "Nat" lnil))) (lsucc lzero).

Nat_succ/name : name "Nat.succ" (is-decl (eforall (econst "Nat" lnil) ([x] (econst "Nat" lnil))) ctor).

Nat_succ/decl : declared "Nat.succ" (eforall (econst "Nat" lnil) ([x] (econst "Nat" lnil))) ctor
   = declared/ok Nat_succ/name (dkind-ok/ctor Nat_succ/type-wf Nat_succ/positivity Nat/decl Nat_succ/eisl Nat_succ/fuo).

%% recursor Nat.rec
Nat_rec/type-wf-sort : lvl
   = (limax
       (limax (lsucc lzero) (lsucc (lvar liz)))
       (limax
         (lvar liz)
         (limax
           (limax (lsucc lzero) (limax (lvar liz) (lvar liz)))
           (limax (lsucc lzero) (lvar liz))))).

Nat_rec/type-wf : of (eforall (eforall (econst "Nat" lnil) ([x] (esort (lvar liz))))
                    ([x]
                      (eforall (eapp x (econst "Nat.zero" lnil))
                        ([y]
                          (eforall (eforall (econst "Nat" lnil) ([z] (eforall (eapp x z) ([w] (eapp x (eapp (econst "Nat.succ" lnil) z))))))
                            ([z] (eforall (econst "Nat" lnil) ([w] (eapp x w))))))))) (esort Nat_rec/type-wf-sort)
   = (defeq/forall
       (defeq/forall
         (defeq/const Nat/decl (inst-expr/sort (lvl-inst/succ lvl-inst/zero)))
         ([x] ([h] defeq/sort-refl)))
       ([x]
         ([h]
           (defeq/forall
             (defeq/app
               h
               (defeq/const Nat_zero/decl (inst-expr/const lvls-inst/nil)))
             ([y]
               ([h1]
                 (defeq/forall
                   (defeq/forall
                     (defeq/const
                       Nat/decl
                       (inst-expr/sort (lvl-inst/succ lvl-inst/zero)))
                     ([z]
                       ([h2]
                         (defeq/forall
                           (defeq/app h h2)
                           ([w]
                             ([h3]
                               (defeq/app
                                 h
                                 (defeq/app
                                   (defeq/const
                                     Nat_succ/decl
                                     (inst-expr/forall
                                       (inst-expr/const lvls-inst/nil)
                                       ([x]
                                         ([h]
                                           (inst-expr/const lvls-inst/nil)))))
                                   h2))))))))
                   ([z]
                     ([h2]
                       (defeq/forall
                         (defeq/const
                           Nat/decl
                           (inst-expr/sort (lvl-inst/succ lvl-inst/zero)))
                         ([w] ([h3] (defeq/app h h3))))))))))))).

Nat_rec/decl : declared "Nat.rec" (eforall (eforall (econst "Nat" lnil) ([x] (esort (lvar liz))))
                                    ([x]
                                      (eforall (eapp x (econst "Nat.zero" lnil))
                                        ([y]
                                          (eforall (eforall (econst "Nat" lnil) ([z] (eforall (eapp x z) ([w] (eapp x (eapp (econst "Nat.succ" lnil) z))))))
                                            ([z] (eforall (econst "Nat" lnil) ([w] (eapp x w))))))))) irec
   = declared/ok-irec Nat/rec-name (dkind-ok/irec Nat_rec/type-wf).

%% inductive reflOccLeft
reflOccLeft/type-wf-sort : lvl
   = (lsucc (lsucc lzero)).

reflOccLeft/type-wf : of (esort (lsucc lzero)) (esort reflOccLeft/type-wf-sort)
   = defeq/sort-refl.

reflOccLeft/ends-in-sort : ends-in-sort (esort (lsucc lzero))
   = ends-in-sort/sort.

reflOccLeft/rec-name : name "reflOccLeft.rec" (is-rec-for "reflOccLeft").

reflOccLeft/name : name "reflOccLeft" (is-decl (esort (lsucc lzero)) indt).

reflOccLeft/decl : declared "reflOccLeft" (esort (lsucc lzero)) indt
   = declared/ok reflOccLeft/name (dkind-ok/indt reflOccLeft/type-wf reflOccLeft/ends-in-sort).

%% ctor reflOccLeft.mk (of reflOccLeft)
reflOccLeft_mk/type-wf-sort : lvl
   = (limax
       (limax (lsucc lzero) (limax (lsucc lzero) (lsucc lzero)))
       (lsucc lzero)).

reflOccLeft_mk/type-wf : of (eforall (eforall (econst "Nat" lnil) ([x] (eforall (econst "reflOccLeft" lnil) ([y] (econst "Nat" lnil)))))
                           ([x] (econst "reflOccLeft" lnil))) (esort reflOccLeft_mk/type-wf-sort)
   = (defeq/forall
       (defeq/forall
         (defeq/const Nat/decl (inst-expr/sort (lvl-inst/succ lvl-inst/zero)))
         ([x]
           ([h]
             (defeq/forall
               (defeq/const
                 reflOccLeft/decl
                 (inst-expr/sort (lvl-inst/succ lvl-inst/zero)))
               ([y]
                 ([h1]
                   (defeq/const
                     Nat/decl
                     (inst-expr/sort (lvl-inst/succ lvl-inst/zero)))))))))
       ([x]
         ([h]
           (defeq/const
             reflOccLeft/decl
             (inst-expr/sort (lvl-inst/succ lvl-inst/zero)))))).

%%% HOLE
reflOccLeft_mk/positivity : ctor-positive "reflOccLeft" lnil (eforall (eforall (econst "Nat" lnil) ([x] (eforall (econst "reflOccLeft" lnil) ([y] (econst "Nat" lnil))))) ([x] (econst "reflOccLeft" lnil))).

reflOccLeft_mk/eisl : ends-in-sort-with-level (esort (lsucc lzero)) (lsucc lzero)
   = ends-in-sort-with-level/sort.

%%% HOLE: reflOccLeft_mk/fuo — prover for field-universes-ok-skip-params not yet implemented
reflOccLeft_mk/fuo : field-universes-ok-skip-params liz (eforall (eforall (econst "Nat" lnil) ([x] (eforall (econst "reflOccLeft" lnil) ([y] (econst "Nat" lnil))))) ([x] (econst "reflOccLeft" lnil))) (lsucc lzero).

reflOccLeft_mk/name : name "reflOccLeft.mk" (is-decl (eforall (eforall (econst "Nat" lnil) ([x] (eforall (econst "reflOccLeft" lnil) ([y] (econst "Nat" lnil))))) ([x] (econst "reflOccLeft" lnil))) ctor).

reflOccLeft_mk/decl : declared "reflOccLeft.mk" (eforall (eforall (econst "Nat" lnil) ([x] (eforall (econst "reflOccLeft" lnil) ([y] (econst "Nat" lnil))))) ([x] (econst "reflOccLeft" lnil))) ctor
   = declared/ok reflOccLeft_mk/name (dkind-ok/ctor reflOccLeft_mk/type-wf reflOccLeft_mk/positivity reflOccLeft/decl reflOccLeft_mk/eisl reflOccLeft_mk/fuo).

%% recursor reflOccLeft.rec
reflOccLeft_rec/type-wf-sort : lvl
   = (lsucc lzero).

reflOccLeft_rec/type-wf : of (esort lzero) (esort reflOccLeft_rec/type-wf-sort)
   = defeq/sort-refl.

reflOccLeft_rec/decl : declared "reflOccLeft.rec" (esort lzero) irec
   = declared/ok-irec reflOccLeft/rec-name (dkind-ok/irec reflOccLeft_rec/type-wf).
