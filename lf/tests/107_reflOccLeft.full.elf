%%% Expected outcome: reject
%%% Rejection: recursive occurrence on the *left* of an arrow,
%%% *behind further arrows* inside a constructor argument.
%%% 
%%% The constructor argument is a function type `Nat → (I → Nat)`.
%solve nonneg_0 : 0 >= 0.

sneq/0 : string-neq "Nat.zero" "Nat.succ".
sneq/1 : string-neq "Nat" "reflOccLeft".

%% inductive Nat
Nat/type-wf-sort : lvl
   = (lsucc (lsucc lzero)).

Nat/type-wf : of (esort (lsucc lzero)) (esort Nat/type-wf-sort)
   = defeq/sort-refl.

Nat/ends-in-sort : ends-in-sort (esort (lsucc lzero))
   = ends-in-sort/sort.

Nat/rec-name : name "Nat.rec" (is-rec-for "Nat").

Nat/eisl : ends-in-sort-with-level (esort (lsucc lzero)) (lsucc lzero)
   = ends-in-sort-with-level/sort.

Nat/clf : count-leading-foralls (esort (lsucc lzero)) liz
   = count-leading-foralls/zero.

Nat/cnd : cnames-distinct (ccons "Nat.zero" (ccons "Nat.succ" cnil))
   = (cnames-distinct/cons
       (cnames-distinct/cons cnames-distinct/nil all-string-neq/nil)
       (all-string-neq/cons sneq/0 all-string-neq/nil)).

Nat/name : name "Nat" (is-decl (esort (lsucc lzero)) (indt (ccons "Nat.zero" (ccons "Nat.succ" cnil)) liz)).

Nat/decl : declared "Nat" (esort (lsucc lzero)) (indt (ccons "Nat.zero" (ccons "Nat.succ" cnil)) liz)
   = declared/ok-indt Nat/name Nat/rec-name Nat/clf Nat/cnd (dkind-ok/indt Nat/type-wf Nat/ends-in-sort).

%% ctor Nat.zero (of Nat)
Nat_zero/type-wf-sort : lvl
   = (lsucc lzero).

Nat_zero/type-wf : of (econst "Nat" lnil) (esort Nat_zero/type-wf-sort)
   = (defeq/const Nat/decl (inst-expr/sort (lvl-inst/succ lvl-inst/zero))).

Nat_zero/positivity : ctor-positive "Nat" lnil (econst "Nat" lnil)
   = (ctor-positive/intro ([S] S) (ctor-spine/result applies-self/refl)).

Nat_zero/cmem : cmem "Nat.zero" (ccons "Nat.zero" (ccons "Nat.succ" cnil))
   = cmem/here.

Nat_zero/fuo : field-universes-ok-skip-params liz (econst "Nat" lnil) (lsucc lzero)
   = (field-universes-ok-skip-params/start
       (field-universes-ok/done not-forall/const)).

Nat_zero/name : name "Nat.zero" (is-decl (econst "Nat" lnil) (ctor "Nat" liz)).

Nat_zero/decl : declared "Nat.zero" (econst "Nat" lnil) (ctor "Nat" liz)
   = declared/ok-ctor Nat_zero/name Nat/name Nat_zero/cmem Nat/eisl Nat_zero/fuo (dkind-ok/ctor Nat_zero/type-wf Nat_zero/positivity).

%% ctor Nat.succ (of Nat)
Nat_succ/type-wf-sort : lvl
   = (limax (lsucc lzero) (lsucc lzero)).

Nat_succ/type-wf : of (eforall (econst "Nat" lnil) ([x] (econst "Nat" lnil))) (esort Nat_succ/type-wf-sort)
   = (defeq/forall
       (defeq/const Nat/decl (inst-expr/sort (lvl-inst/succ lvl-inst/zero)))
       ([x]
         ([h]
           (defeq/const
             Nat/decl
             (inst-expr/sort (lvl-inst/succ lvl-inst/zero)))))).

Nat_succ/positivity : ctor-positive "Nat" lnil (eforall (econst "Nat" lnil) ([x] (econst "Nat" lnil)))
   = (ctor-positive/intro ([S] (eforall S ([x] S))) (ctor-spine/arg
       (strict-pos/head applies-self/refl)
       ([x] ([y] (ctor-spine/result applies-self/refl))))).

Nat_succ/cmem : cmem "Nat.succ" (ccons "Nat.zero" (ccons "Nat.succ" cnil))
   = (cmem/there cmem/here).

Nat_succ/fuo : field-universes-ok-skip-params liz (eforall (econst "Nat" lnil) ([x] (econst "Nat" lnil))) (lsucc lzero)
   = (field-universes-ok-skip-params/start
       (field-universes-ok/forall
         (defeq/const Nat/decl (inst-expr/sort (lvl-inst/succ lvl-inst/zero)))
         (mleq/self nonneg_0)
         ([x] ([h] (field-universes-ok/done not-forall/const))))).

Nat_succ/name : name "Nat.succ" (is-decl (eforall (econst "Nat" lnil) ([x] (econst "Nat" lnil))) (ctor "Nat" (lis liz))).

Nat_succ/decl : declared "Nat.succ" (eforall (econst "Nat" lnil) ([x] (econst "Nat" lnil))) (ctor "Nat" (lis liz))
   = declared/ok-ctor Nat_succ/name Nat/name Nat_succ/cmem Nat/eisl Nat_succ/fuo (dkind-ok/ctor Nat_succ/type-wf Nat_succ/positivity).

%% recursor Nat.rec
Nat_rec/type-wf-sort : lvl
   = (limax
       (limax (lsucc lzero) (lsucc (lvar liz)))
       (limax
         (lvar liz)
         (limax
           (limax (lsucc lzero) (limax (lvar liz) (lvar liz)))
           (limax (lsucc lzero) (lvar liz))))).

Nat_rec/type-wf : of
  (eforall (eforall (econst "Nat" lnil) ([x] (esort (lvar liz))))
    ([x]
      (eforall (eapp x (econst "Nat.zero" lnil))
        ([y] (eforall (eforall (econst "Nat" lnil) ([z] (eforall (eapp x z) ([w] (eapp x (eapp (econst "Nat.succ" lnil) z)))))) ([z] (eforall (econst "Nat" lnil) ([w] (eapp x w)))))))))
  (esort Nat_rec/type-wf-sort)
   = (defeq/forall
       (defeq/forall
         (defeq/const Nat/decl (inst-expr/sort (lvl-inst/succ lvl-inst/zero)))
         ([x] ([h] defeq/sort-refl)))
       ([x]
         ([h]
           (defeq/forall
             (defeq/app
               h
               (defeq/const Nat_zero/decl (inst-expr/const lvls-inst/nil)))
             ([y]
               ([h1]
                 (defeq/forall
                   (defeq/forall
                     (defeq/const
                       Nat/decl
                       (inst-expr/sort (lvl-inst/succ lvl-inst/zero)))
                     ([z]
                       ([h2]
                         (defeq/forall
                           (defeq/app h h2)
                           ([w]
                             ([h3]
                               (defeq/app
                                 h
                                 (defeq/app
                                   (defeq/const
                                     Nat_succ/decl
                                     (inst-expr/forall
                                       (inst-expr/const lvls-inst/nil)
                                       ([x]
                                         ([h]
                                           (inst-expr/const lvls-inst/nil)))))
                                   h2))))))))
                   ([z]
                     ([h2]
                       (defeq/forall
                         (defeq/const
                           Nat/decl
                           (inst-expr/sort (lvl-inst/succ lvl-inst/zero)))
                         ([w] ([h3] (defeq/app h h3))))))))))))).

%%% HOLE: recursor Nat.rec — non-enum shape (parametric/indexed inductive, or ctor with fields) — §3.1 canonical-schema only handles plain enums in phase 1
Nat_rec/decl : declared "Nat.rec"
  (eforall (eforall (econst "Nat" lnil) ([x] (esort (lvar liz))))
    ([x]
      (eforall (eapp x (econst "Nat.zero" lnil))
        ([y] (eforall (eforall (econst "Nat" lnil) ([z] (eforall (eapp x z) ([w] (eapp x (eapp (econst "Nat.succ" lnil) z)))))) ([z] (eforall (econst "Nat" lnil) ([w] (eapp x w)))))))))
  (irec "Nat").

%% inductive reflOccLeft
reflOccLeft/type-wf-sort : lvl
   = (lsucc (lsucc lzero)).

reflOccLeft/type-wf : of (esort (lsucc lzero)) (esort reflOccLeft/type-wf-sort)
   = defeq/sort-refl.

reflOccLeft/ends-in-sort : ends-in-sort (esort (lsucc lzero))
   = ends-in-sort/sort.

reflOccLeft/rec-name : name "reflOccLeft.rec" (is-rec-for "reflOccLeft").

reflOccLeft/eisl : ends-in-sort-with-level (esort (lsucc lzero)) (lsucc lzero)
   = ends-in-sort-with-level/sort.

reflOccLeft/clf : count-leading-foralls (esort (lsucc lzero)) liz
   = count-leading-foralls/zero.

reflOccLeft/cnd : cnames-distinct (ccons "reflOccLeft.mk" cnil)
   = (cnames-distinct/cons cnames-distinct/nil all-string-neq/nil).

reflOccLeft/name : name "reflOccLeft" (is-decl (esort (lsucc lzero)) (indt (ccons "reflOccLeft.mk" cnil) liz)).

reflOccLeft/decl : declared "reflOccLeft" (esort (lsucc lzero)) (indt (ccons "reflOccLeft.mk" cnil) liz)
   = declared/ok-indt reflOccLeft/name reflOccLeft/rec-name reflOccLeft/clf reflOccLeft/cnd (dkind-ok/indt reflOccLeft/type-wf reflOccLeft/ends-in-sort).

%% ctor reflOccLeft.mk (of reflOccLeft)
reflOccLeft_mk/type-wf-sort : lvl
   = (limax
       (limax (lsucc lzero) (limax (lsucc lzero) (lsucc lzero)))
       (lsucc lzero)).

reflOccLeft_mk/type-wf : of (eforall (eforall (econst "Nat" lnil) ([x] (eforall (econst "reflOccLeft" lnil) ([y] (econst "Nat" lnil))))) ([x] (econst "reflOccLeft" lnil))) (esort reflOccLeft_mk/type-wf-sort)
   = (defeq/forall
       (defeq/forall
         (defeq/const Nat/decl (inst-expr/sort (lvl-inst/succ lvl-inst/zero)))
         ([x]
           ([h]
             (defeq/forall
               (defeq/const
                 reflOccLeft/decl
                 (inst-expr/sort (lvl-inst/succ lvl-inst/zero)))
               ([y]
                 ([h1]
                   (defeq/const
                     Nat/decl
                     (inst-expr/sort (lvl-inst/succ lvl-inst/zero)))))))))
       ([x]
         ([h]
           (defeq/const
             reflOccLeft/decl
             (inst-expr/sort (lvl-inst/succ lvl-inst/zero)))))).

%%% HOLE
reflOccLeft_mk/positivity : ctor-positive "reflOccLeft" lnil (eforall (eforall (econst "Nat" lnil) ([x] (eforall (econst "reflOccLeft" lnil) ([y] (econst "Nat" lnil))))) ([x] (econst "reflOccLeft" lnil))).

reflOccLeft_mk/cmem : cmem "reflOccLeft.mk" (ccons "reflOccLeft.mk" cnil)
   = cmem/here.

reflOccLeft_mk/fuo : field-universes-ok-skip-params liz (eforall (eforall (econst "Nat" lnil) ([x] (eforall (econst "reflOccLeft" lnil) ([y] (econst "Nat" lnil))))) ([x] (econst "reflOccLeft" lnil))) (lsucc lzero)
   = (field-universes-ok-skip-params/start
       (field-universes-ok/forall
         (defeq/forall
           (defeq/const Nat/decl (inst-expr/sort (lvl-inst/succ lvl-inst/zero)))
           ([x]
             ([h]
               (defeq/forall
                 (defeq/const
                   reflOccLeft/decl
                   (inst-expr/sort (lvl-inst/succ lvl-inst/zero)))
                 ([y]
                   ([h1]
                     (defeq/const
                       Nat/decl
                       (inst-expr/sort (lvl-inst/succ lvl-inst/zero)))))))))
         (mleq/imax-imL
           (mleq/sR
             (mleq/maxL
               (mleq/imax-lsL
                 (mleq/maxL
                   (mleq/sL (mleq/self nonneg_0))
                   (mleq/sL (mleq/self nonneg_0))))
               (mleq/imax-lsL
                 (mleq/maxL
                   (mleq/sL (mleq/self nonneg_0))
                   (mleq/sL (mleq/self nonneg_0)))))))
         ([x] ([h] (field-universes-ok/done not-forall/const))))).

reflOccLeft_mk/name : name "reflOccLeft.mk" (is-decl (eforall (eforall (econst "Nat" lnil) ([x] (eforall (econst "reflOccLeft" lnil) ([y] (econst "Nat" lnil))))) ([x] (econst "reflOccLeft" lnil))) (ctor "reflOccLeft" liz)).

reflOccLeft_mk/decl : declared "reflOccLeft.mk" (eforall (eforall (econst "Nat" lnil) ([x] (eforall (econst "reflOccLeft" lnil) ([y] (econst "Nat" lnil))))) ([x] (econst "reflOccLeft" lnil))) (ctor "reflOccLeft" liz)
   = declared/ok-ctor reflOccLeft_mk/name reflOccLeft/name reflOccLeft_mk/cmem reflOccLeft/eisl reflOccLeft_mk/fuo (dkind-ok/ctor reflOccLeft_mk/type-wf reflOccLeft_mk/positivity).

%% recursor reflOccLeft.rec
reflOccLeft_rec/type-wf-sort : lvl
   = (lsucc lzero).

reflOccLeft_rec/type-wf : of (esort lzero) (esort reflOccLeft_rec/type-wf-sort)
   = defeq/sort-refl.

%%% HOLE: recursor reflOccLeft.rec — non-enum shape (parametric/indexed inductive, or ctor with fields) — §3.1 canonical-schema only handles plain enums in phase 1
reflOccLeft_rec/decl : declared "reflOccLeft.rec" (esort lzero) (irec "reflOccLeft").
