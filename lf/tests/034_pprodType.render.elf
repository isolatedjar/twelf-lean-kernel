%%% Render-only view of: 034_pprodType
%%% A parametrized product type (with more general level parameters)
%% inductive PProd
%%% HOLE
PProd/type-wf : of (eforall (esort (lvar z)) ([x] (eforall (esort (lvar (s z))) ([y] (esort (lmax (lmax (lsucc lzero) (lvar z)) (lvar (s z)))))))) (esort _).

%%% HOLE
PProd/ends-in-sort : ends-in-sort (eforall (esort (lvar z)) ([x] (eforall (esort (lvar (s z))) ([y] (esort (lmax (lmax (lsucc lzero) (lvar z)) (lvar (s z)))))))).

PProd/rec-name : name "PProd.rec" (is-rec-for "PProd").

PProd/eisl : ends-in-sort-with-level (eforall (esort (lvar z)) ([x] (eforall (esort (lvar (s z))) ([y] (esort (lmax (lmax (lsucc lzero) (lvar z)) (lvar (s z)))))))) (lmax (lmax (lsucc lzero) (lvar z)) (lvar (s z)))
   = (ends-in-sort-with-level/forall
       ([x]
         (ends-in-sort-with-level/forall ([y] ends-in-sort-with-level/sort)))).

PProd/cnd : cnames-distinct (ccons "PProd.mk" cnil)
   = (cnames-distinct/cons cnames-distinct/nil all-string-neq/nil).

PProd/name : name "PProd" (is-decl (eforall (esort (lvar z)) ([x] (eforall (esort (lvar (s z))) ([y] (esort (lmax (lmax (lsucc lzero) (lvar z)) (lvar (s z)))))))) (indt (ccons "PProd.mk" cnil) (s (s z)))).

PProd/decl : declared "PProd" (eforall (esort (lvar z)) ([x] (eforall (esort (lvar (s z))) ([y] (esort (lmax (lmax (lsucc lzero) (lvar z)) (lvar (s z)))))))) (indt (ccons "PProd.mk" cnil) (s (s z)))
   = declared/ok-indt PProd/name PProd/rec-name PProd/cnd (dkind-ok/indt PProd/type-wf PProd/ends-in-sort).

%% ctor PProd.mk (of PProd)
%%% HOLE
PProd_mk/type-wf : of (eforall (esort (lvar z)) ([x] (eforall (esort (lvar (s z))) ([y] (eforall x ([w] (eforall y ([v] (eapp (eapp (econst "PProd" (lcons (lvar z) (lcons (lvar (s z)) lnil))) x) y))))))))) (esort _).

%%% HOLE
PProd_mk/positivity : ctor-positive "PProd" (lcons (lvar z) (lcons (lvar (s z)) lnil)) (eforall (esort (lvar z)) ([x] (eforall (esort (lvar (s z))) ([y] (eforall x ([w] (eforall y ([v] (eapp (eapp (econst "PProd" (lcons (lvar z) (lcons (lvar (s z)) lnil))) x) y))))))))).

PProd_mk/cmem : cmem "PProd.mk" (ccons "PProd.mk" cnil)
   = cmem/here.

%%% HOLE: PProd_mk/fuo
PProd_mk/fuo : field-universes-ok (eforall (esort (lvar z)) ([x] (eforall (esort (lvar (s z))) ([y] (eforall x ([w] (eforall y ([v] (eapp (eapp (econst "PProd" (lcons (lvar z) (lcons (lvar (s z)) lnil))) x) y))))))))) (lmax (lmax (lsucc lzero) (lvar z)) (lvar (s z))).

PProd_mk/name : name "PProd.mk" (is-decl
  (eforall (esort (lvar z)) ([x] (eforall (esort (lvar (s z))) ([y] (eforall x ([w] (eforall y ([v] (eapp (eapp (econst "PProd" (lcons (lvar z) (lcons (lvar (s z)) lnil))) x) y)))))))))
  (ctor "PProd" z)).

PProd_mk/decl : declared "PProd.mk"
  (eforall (esort (lvar z)) ([x] (eforall (esort (lvar (s z))) ([y] (eforall x ([w] (eforall y ([v] (eapp (eapp (econst "PProd" (lcons (lvar z) (lcons (lvar (s z)) lnil))) x) y)))))))))
  (ctor "PProd" z)
   = declared/ok-ctor PProd_mk/name PProd/name PProd_mk/cmem PProd/eisl PProd_mk/fuo (dkind-ok/ctor PProd_mk/type-wf PProd_mk/positivity).

%% recursor PProd.rec (TCB-derived; informational only)
%%   level params: u_1 u v
%%   type:   (eforall (esort (lvar (s z))) ([x] (eforall (esort (lvar (s (s z)))) ([y] (eforall (eforall (eapp (eapp (econst "PProd" (lcons (lvar (s z)) (lcons (lvar (s (s z))) lnil))) x) y) ([w] (esort (lvar z)))) ([w] (eforall (eforall x ([v] (eforall y ([x1] (eapp w (eapp (eapp (eapp (eapp (econst "PProd.mk" (lcons (lvar (s z)) (lcons (lvar (s (s z))) lnil))) x) y) v) x1)))))) ([v] (eforall (eapp (eapp (econst "PProd" (lcons (lvar (s z)) (lcons (lvar (s (s z))) lnil))) x) y) ([x1] (eapp w x1)))))))))))
%%   rules:
%%     PProd.rec … PProd.mk … = (elam (esort (lvar (s z))) ([x] (elam (esort (lvar (s (s z)))) ([y] (elam (eforall (eapp (eapp (econst "PProd" (lcons (lvar (s z)) (lcons (lvar (s (s z))) lnil))) x) y) ([w] (esort (lvar z)))) ([w] (elam (eforall x ([v] (eforall y ([x1] (eapp w (eapp (eapp (eapp (eapp (econst "PProd.mk" (lcons (lvar (s z)) (lcons (lvar (s (s z))) lnil))) x) y) v) x1)))))) ([v] (elam x ([x1] (elam y ([y1] (eapp (eapp v x1) y1)))))))))))))   (2 fields)

%% def pprodType
%%% HOLE
pprodType/type-wf : of (eforall (esort (lsucc lzero)) ([x] (eforall (esort (lsucc lzero)) ([y] (esort (lsucc lzero)))))) (esort _).

%%% HOLE
pprodType/value-typed : of (econst "PProd" (lcons (lsucc lzero) (lcons (lsucc lzero) lnil))) (eforall (esort (lsucc lzero)) ([x] (eforall (esort (lsucc lzero)) ([y] (esort (lsucc lzero)))))).

pprodType/name : name "pprodType" (is-decl (eforall (esort (lsucc lzero)) ([x] (eforall (esort (lsucc lzero)) ([y] (esort (lsucc lzero)))))) (defn (econst "PProd" (lcons (lsucc lzero) (lcons (lsucc lzero) lnil))))).

pprodType/decl : declared "pprodType" (eforall (esort (lsucc lzero)) ([x] (eforall (esort (lsucc lzero)) ([y] (esort (lsucc lzero)))))) (defn (econst "PProd" (lcons (lsucc lzero) (lcons (lsucc lzero) lnil))))
