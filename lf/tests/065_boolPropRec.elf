%%% Expected outcome: accept
%%% Inductive predicates eliminate into Prop if they have more than one constructor.
%% inductive BoolProp
BoolProp/type-wf :
   defeq (esort lzero) (esort lzero) (esort (lsucc lzero))
   = (defeq/sort-refl-at lzero).

BoolProp/decl : declared "BoolProp" lnil
   (esort lzero)
   indt
   (dkind-ok/indt BoolProp/type-wf).

%% inductive ctor BoolProp.a
BoolProp_a/type-wf :
   defeq (econst "BoolProp" lnil) (econst "BoolProp" lnil) (esort lzero)
   = (defeq/const BoolProp/decl).

BoolProp_a/decl : declared "BoolProp.a" lnil
   (econst "BoolProp" lnil)
   ctor
   (dkind-ok/ctor BoolProp_a/type-wf).

%% inductive ctor BoolProp.b
BoolProp_b/type-wf :
   defeq (econst "BoolProp" lnil) (econst "BoolProp" lnil) (esort lzero)
   = (defeq/const BoolProp/decl).

BoolProp_b/decl : declared "BoolProp.b" lnil
   (econst "BoolProp" lnil)
   ctor
   (dkind-ok/ctor BoolProp_b/type-wf).

%% inductive recursor BoolProp.rec
BoolProp_rec/type-wf :
   defeq (eforall (eforall (econst "BoolProp" lnil) ([x] (esort lzero))) ([x] (eforall (eapp x (econst "BoolProp.a" lnil)) ([y] (eforall (eapp x (econst "BoolProp.b" lnil)) ([z] (eforall (econst "BoolProp" lnil) ([w] (eapp x w))))))))) (eforall (eforall (econst "BoolProp" lnil) ([x] (esort lzero))) ([x] (eforall (eapp x (econst "BoolProp.a" lnil)) ([y] (eforall (eapp x (econst "BoolProp.b" lnil)) ([z] (eforall (econst "BoolProp" lnil) ([w] (eapp x w))))))))) (esort (limax (limax lzero (lsucc lzero)) (limax lzero (limax lzero (limax lzero lzero)))))
   = (defeq/forall (defeq/forall (defeq/const BoolProp/decl) ([x] [y] (defeq/sort-refl-at lzero))) ([x] [y] (defeq/forall (defeq/app y (defeq/const BoolProp_a/decl)) ([z] [w] (defeq/forall (defeq/app y (defeq/const BoolProp_b/decl)) ([x1] [y1] (defeq/forall (defeq/const BoolProp/decl) ([z1] [w1] (defeq/app y w1))))))))).

BoolProp_rec/decl : declared "BoolProp.rec" lnil
   (eforall (eforall (econst "BoolProp" lnil) ([x] (esort lzero))) ([x] (eforall (eapp x (econst "BoolProp.a" lnil)) ([y] (eforall (eapp x (econst "BoolProp.b" lnil)) ([z] (eforall (econst "BoolProp" lnil) ([w] (eapp x w)))))))))
   irec
   (dkind-ok/irec BoolProp_rec/type-wf).

%% def boolPropRec
boolPropRec/type-wf :
   defeq (eforall (eforall (econst "BoolProp" lnil) ([x] (esort lzero))) ([x] (eforall (eapp x (econst "BoolProp.a" lnil)) ([y] (eforall (eapp x (econst "BoolProp.b" lnil)) ([z] (eforall (econst "BoolProp" lnil) ([w] (eapp x w))))))))) (eforall (eforall (econst "BoolProp" lnil) ([x] (esort lzero))) ([x] (eforall (eapp x (econst "BoolProp.a" lnil)) ([y] (eforall (eapp x (econst "BoolProp.b" lnil)) ([z] (eforall (econst "BoolProp" lnil) ([w] (eapp x w))))))))) (esort (limax (limax lzero (lsucc lzero)) (limax lzero (limax lzero (limax lzero lzero)))))
   = (defeq/forall (defeq/forall (defeq/const BoolProp/decl) ([x] [y] (defeq/sort-refl-at lzero))) ([x] [y] (defeq/forall (defeq/app y (defeq/const BoolProp_a/decl)) ([z] [w] (defeq/forall (defeq/app y (defeq/const BoolProp_b/decl)) ([x1] [y1] (defeq/forall (defeq/const BoolProp/decl) ([z1] [w1] (defeq/app y w1))))))))).

boolPropRec/value-typed :
   defeq (econst "BoolProp.rec" lnil) (econst "BoolProp.rec" lnil) (eforall (eforall (econst "BoolProp" lnil) ([x] (esort lzero))) ([x] (eforall (eapp x (econst "BoolProp.a" lnil)) ([y] (eforall (eapp x (econst "BoolProp.b" lnil)) ([z] (eforall (econst "BoolProp" lnil) ([w] (eapp x w)))))))))
   = (defeq/const BoolProp_rec/decl).

boolPropRec/decl : declared "boolPropRec" lnil
   (eforall (eforall (econst "BoolProp" lnil) ([x] (esort lzero))) ([x] (eforall (eapp x (econst "BoolProp.a" lnil)) ([y] (eforall (eapp x (econst "BoolProp.b" lnil)) ([z] (eforall (econst "BoolProp" lnil) ([w] (eapp x w)))))))))
   (defn (econst "BoolProp.rec" lnil))
   (dkind-ok/defn boolPropRec/type-wf boolPropRec/value-typed).

%mode declared +N +LS -T -DK -W.
%worlds () (declared _ _ _ _ _).
%unique declared +N +LS -1T -1DK *W.
