%%% Expected outcome: reject
%%% Proof of False via large elimination of a multi-constructor `Prop`, using a
%%% hand-supplied recursor.
%%% 
%%% A `Prop` with two or more constructors admits only **small** elimination: its
%%% recursor's motive must target `Prop`. Allowing large elimination would
%%% transport a genuine case distinction out of `Prop` into `Type`, which is
%%% unsound under proof irrelevance.
%%% 
%%% This export defines `PropTwo : Prop` with constructors `PropTwo.a`, `PropTwo.b`
%%% and supplies a recursor `PropTwo.rec` whose motive targets `Sort u` (large
%%% elimination). The recursor is otherwise well-formed — correct rule count and
%%% correct reduction rules — so the only defect is the elimination level. From it:
%%% 
%%%     discriminate : PropTwo → Bool := PropTwo.rec (fun _ => Bool) true false
%%%     ab_eq        : PropTwo.a = PropTwo.b           -- proof irrelevance
%%%     discr_eq     : discriminate a = discriminate b -- congrArg
%%%     falseViaLargeElim : False                       -- transport True.intro along discr_eq
%%% 
%%% Because `discriminate a` reduces to `true` and `discriminate b` to `false`,
%%% `discr_eq` is a proof of `true = false`, and transporting `True.intro` along it
%%% lands in `False`.
%%% 
%%% A sound checker must reject this. The two safe behaviors observed:
%%% * the official kernel and lean4lean **regenerate** the canonical recursor with
%%%   a `Prop` motive, so `discriminate` (eliminating into `Type`) fails to type;
%%% * nanoda likewise rejects.
%%% 
%%% rpylean accepts it: it trusts the supplied recursor's declared elimination
%%% level instead of enforcing the small-elimination restriction, so the proof of
%%% `False` goes through. (mini also ignores the supplied recursor and regenerates
%%% its own, so it too rejects — its recursor-handling gap happens to be safe here.)
%%% 
%%% This is distinct from `large-elim-param`, which exploits an incorrect
%%% "level is surely not zero" check on universe *parameters*; here the inductive
%%% is monomorphic at `Prop` (`Sort 0`) and the defect is that the checker does
%%% not validate the recursor's elimination strength at all.
%solve nonneg_0 : 0 >= 0.

%%% SKIP: recursor PropTwo.rec — large elimination (motive into a non-Prop sort) from a Prop inductive with 2 constructors

%% inductive Bool
Bool/type-wf-sort : lvl
   = (lsucc (lsucc lzero)).

Bool/type-wf : defeq (esort (lsucc lzero)) (esort (lsucc lzero)) (esort Bool/type-wf-sort)
   = defeq/sort-refl.

Bool/ends-in-sort : ends-in-sort (esort (lsucc lzero))
   = ends-in-sort/sort.

Bool/rec-name : name "Bool.rec" (is-rec-for "Bool").

Bool/name : name "Bool" (is-decl (esort (lsucc lzero)) indt).

Bool/decl : declared "Bool" (esort (lsucc lzero)) indt
   = declared/ok Bool/name (dkind-ok/indt Bool/type-wf Bool/ends-in-sort).

%% ctor Bool.false (of Bool)
Bool_false/type-wf-sort : lvl
   = (lsucc lzero).

Bool_false/type-wf : defeq (econst "Bool" lnil) (econst "Bool" lnil) (esort Bool_false/type-wf-sort)
   = (defeq/const Bool/decl (inst-expr/sort (lvl-inst/succ lvl-inst/zero))).

Bool_false/positivity : ctor-positive "Bool" lnil (econst "Bool" lnil)
   = (ctor-positive/intro ([S] S) (ctor-spine/result applies-self/refl)).

Bool_false/name : name "Bool.false" (is-decl (econst "Bool" lnil) ctor).

Bool_false/decl : declared "Bool.false" (econst "Bool" lnil) ctor
   = declared/ok Bool_false/name (dkind-ok/ctor Bool_false/type-wf Bool_false/positivity).

%% ctor Bool.true (of Bool)
Bool_true/type-wf-sort : lvl
   = (lsucc lzero).

Bool_true/type-wf : defeq (econst "Bool" lnil) (econst "Bool" lnil) (esort Bool_true/type-wf-sort)
   = (defeq/const Bool/decl (inst-expr/sort (lvl-inst/succ lvl-inst/zero))).

Bool_true/positivity : ctor-positive "Bool" lnil (econst "Bool" lnil)
   = (ctor-positive/intro ([S] S) (ctor-spine/result applies-self/refl)).

Bool_true/name : name "Bool.true" (is-decl (econst "Bool" lnil) ctor).

Bool_true/decl : declared "Bool.true" (econst "Bool" lnil) ctor
   = declared/ok Bool_true/name (dkind-ok/ctor Bool_true/type-wf Bool_true/positivity).

%% recursor Bool.rec
Bool_rec/type-wf-sort : lvl
   = (limax (limax (lsucc lzero) (lsucc (lvar liz))) (limax (lvar liz) (limax (lvar liz) (limax (lsucc lzero) (lvar liz))))).

Bool_rec/type-wf : defeq (eforall (eforall (econst "Bool" lnil) ([x] (esort (lvar liz)))) ([x] (eforall (eapp x (econst "Bool.false" lnil)) ([y] (eforall (eapp x (econst "Bool.true" lnil)) ([z] (eforall (econst "Bool" lnil) ([w] (eapp x w))))))))) (eforall (eforall (econst "Bool" lnil) ([x] (esort (lvar liz)))) ([x] (eforall (eapp x (econst "Bool.false" lnil)) ([y] (eforall (eapp x (econst "Bool.true" lnil)) ([z] (eforall (econst "Bool" lnil) ([w] (eapp x w))))))))) (esort Bool_rec/type-wf-sort)
   = (defeq/forall (defeq/forall (defeq/const Bool/decl (inst-expr/sort (lvl-inst/succ lvl-inst/zero))) ([x] ([h] defeq/sort-refl))) ([x] ([h] (defeq/forall (defeq/app h (defeq/const Bool_false/decl (inst-expr/const lvls-inst/nil))) ([y] ([h1] (defeq/forall (defeq/app h (defeq/const Bool_true/decl (inst-expr/const lvls-inst/nil))) ([z] ([h2] (defeq/forall (defeq/const Bool/decl (inst-expr/sort (lvl-inst/succ lvl-inst/zero))) ([w] ([h3] (defeq/app h h3))))))))))))).

Bool_rec/decl : declared "Bool.rec" (eforall (eforall (econst "Bool" lnil) ([x] (esort (lvar liz)))) ([x] (eforall (eapp x (econst "Bool.false" lnil)) ([y] (eforall (eapp x (econst "Bool.true" lnil)) ([z] (eforall (econst "Bool" lnil) ([w] (eapp x w))))))))) irec
   = declared/ok-irec Bool/rec-name (dkind-ok/irec Bool_rec/type-wf).

%% def discriminate
discriminate/type-wf-sort : lvl
   = (limax lzero (lsucc lzero)).

discriminate/type-wf : defeq (eforall (econst "PropTwo" lnil) ([x] (econst "Bool" lnil))) (eforall (econst "PropTwo" lnil) ([x] (econst "Bool" lnil))) (esort discriminate/type-wf-sort)
   = (defeq/forall (defeq/const PropTwo/decl (inst-expr/sort lvl-inst/zero)) ([x] ([h] (defeq/const Bool/decl (inst-expr/sort (lvl-inst/succ lvl-inst/zero)))))).

discriminate/value-typed : defeq (elam (econst "PropTwo" lnil) ([x] (eapp (eapp (eapp (eapp (econst "PropTwo.rec" lnil) (elam (econst "PropTwo" lnil) ([y] (econst "Bool" lnil)))) (econst "Bool.true" lnil)) (econst "Bool.false" lnil)) x))) (elam (econst "PropTwo" lnil) ([x] (eapp (eapp (eapp (eapp (econst "PropTwo.rec" lnil) (elam (econst "PropTwo" lnil) ([y] (econst "Bool" lnil)))) (econst "Bool.true" lnil)) (econst "Bool.false" lnil)) x))) (eforall (econst "PropTwo" lnil) ([x] (econst "Bool" lnil)))
   = (defeq/conv (defeq/forall (defeq/const PropTwo/decl (inst-expr/sort lvl-inst/zero)) ([x] ([h] (defeq/trans (defeq/beta ([y] ([h1] (defeq/const Bool/decl (inst-expr/sort (lvl-inst/succ lvl-inst/zero))))) h) (defeq/const Bool/decl (inst-expr/sort (lvl-inst/succ lvl-inst/zero))))))) (defeq/lam (defeq/const PropTwo/decl (inst-expr/sort lvl-inst/zero)) ([x] ([h] (defeq/app (defeq/app (defeq/app (defeq/app (defeq/const PropTwo_rec/decl (inst-expr/forall (inst-expr/forall (inst-expr/const lvls-inst/nil) ([x] ([h] (inst-expr/sort (lvl-inst/succ lvl-inst/zero))))) ([x] ([h] (inst-expr/forall (inst-expr/app h (inst-expr/const lvls-inst/nil)) ([y] ([h1] (inst-expr/forall (inst-expr/app h (inst-expr/const lvls-inst/nil)) ([z] ([h2] (inst-expr/forall (inst-expr/const lvls-inst/nil) ([w] ([h3] (inst-expr/app h h3)))))))))))))) (defeq/lam (defeq/const PropTwo/decl (inst-expr/sort lvl-inst/zero)) ([y] ([h1] (defeq/const Bool/decl (inst-expr/sort (lvl-inst/succ lvl-inst/zero))))))) (defeq/conv (defeq/trans (defeq/const Bool/decl (inst-expr/sort (lvl-inst/succ lvl-inst/zero))) (defeq/symm (defeq/beta ([y] ([h1] (defeq/const Bool/decl (inst-expr/sort (lvl-inst/succ lvl-inst/zero))))) (defeq/const PropTwo_a/decl (inst-expr/const lvls-inst/nil))))) (defeq/const Bool_true/decl (inst-expr/const lvls-inst/nil)))) (defeq/conv (defeq/trans (defeq/const Bool/decl (inst-expr/sort (lvl-inst/succ lvl-inst/zero))) (defeq/symm (defeq/beta ([y] ([h1] (defeq/const Bool/decl (inst-expr/sort (lvl-inst/succ lvl-inst/zero))))) (defeq/const PropTwo_b/decl (inst-expr/const lvls-inst/nil))))) (defeq/const Bool_false/decl (inst-expr/const lvls-inst/nil)))) h))))).

discriminate/name : name "discriminate" (is-decl (eforall (econst "PropTwo" lnil) ([x] (econst "Bool" lnil))) (defn (elam (econst "PropTwo" lnil) ([x] (eapp (eapp (eapp (eapp (econst "PropTwo.rec" lnil) (elam (econst "PropTwo" lnil) ([y] (econst "Bool" lnil)))) (econst "Bool.true" lnil)) (econst "Bool.false" lnil)) x))))).

