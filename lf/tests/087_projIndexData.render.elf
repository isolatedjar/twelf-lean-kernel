%%% Render-only view of: 087_projIndexData
%%% Projecting out data is not allowed, even if this data appears as an index
%%% and the recursor would allow it.
%% inductive N (numParams=0, numIndices=0)
N/render-type : expr =
   (esort (lsucc lzero)).

%% ctor N.zero (induct=N, numFields=0)
N_zero/render-type : expr =
   (econst "N" lnil).

%% ctor N.succ (induct=N, numFields=1)
N_succ/render-type : expr =
   (eforall (econst "N" lnil) ([x] (econst "N" lnil))).

%% recursor N.rec (numMotives=1, numMinors=2, k=false)
N_rec/render-type : {u : lvl} expr =
   [u] (eforall (eforall (econst "N" lnil) ([x] (esort u))) ([x] (eforall (eapp x (econst "N.zero" lnil)) ([y] (eforall (eforall (econst "N" lnil) ([z] (eforall (eapp x z) ([w] (eapp x (eapp (econst "N.succ" lnil) z)))))) ([z] (eforall (econst "N" lnil) ([w] (eapp x w))))))))).
%%   rec-rule for N.zero (nfields=0)
N_rec/render-rule0-rhs : {u : lvl} expr =
   [u] (elam (eforall (econst "N" lnil) ([x] (esort u))) ([x] (elam (eapp x (econst "N.zero" lnil)) ([y] (elam (eforall (econst "N" lnil) ([z] (eforall (eapp x z) ([w] (eapp x (eapp (econst "N.succ" lnil) z)))))) ([z] y)))))).
%%   rec-rule for N.succ (nfields=1)
N_rec/render-rule1-rhs : {u : lvl} expr =
   [u] (elam (eforall (econst "N" lnil) ([x] (esort u))) ([x] (elam (eapp x (econst "N.zero" lnil)) ([y] (elam (eforall (econst "N" lnil) ([z] (eforall (eapp x z) ([w] (eapp x (eapp (econst "N.succ" lnil) z)))))) ([z] (elam (econst "N" lnil) ([w] (eapp (eapp z w) (eapp (eapp (eapp (eapp (econst "N.rec" (lcons u lnil)) x) y) z) w)))))))))).

%% inductive True (numParams=0, numIndices=0)
True/render-type : expr =
   (esort lzero).

%% ctor True.intro (induct=True, numFields=0)
True_intro/render-type : expr =
   (econst "True" lnil).

%% recursor True.rec (numMotives=1, numMinors=1, k=true)
True_rec/render-type : {u : lvl} expr =
   [u] (eforall (eforall (econst "True" lnil) ([x] (esort u))) ([x] (eforall (eapp x (econst "True.intro" lnil)) ([y] (eforall (econst "True" lnil) ([z] (eapp x z))))))).
%%   rec-rule for True.intro (nfields=0)
True_rec/render-rule0-rhs : {u : lvl} expr =
   [u] (elam (eforall (econst "True" lnil) ([x] (esort u))) ([x] (elam (eapp x (econst "True.intro" lnil)) ([y] y)))).

%% inductive ProjDataIndex (numParams=1, numIndices=0)
ProjDataIndex/render-type : expr =
   (eforall (econst "N" lnil) ([x] (esort lzero))).

%% ctor ProjDataIndex.mk (induct=ProjDataIndex, numFields=1)
ProjDataIndex_mk/render-type : expr =
   (eforall (econst "N" lnil) ([x] (eforall (econst "True" lnil) ([y] (eapp (econst "ProjDataIndex" lnil) x))))).

%% recursor ProjDataIndex.rec (numMotives=1, numMinors=1, k=false)
ProjDataIndex_rec/render-type : {u : lvl} expr =
   [u] (eforall (econst "N" lnil) ([x] (eforall (eforall (eapp (econst "ProjDataIndex" lnil) x) ([y] (esort u))) ([y] (eforall (eforall (econst "True" lnil) ([z] (eapp y (eapp (eapp (econst "ProjDataIndex.mk" lnil) x) z)))) ([z] (eforall (eapp (econst "ProjDataIndex" lnil) x) ([w] (eapp y w))))))))).
%%   rec-rule for ProjDataIndex.mk (nfields=1)
ProjDataIndex_rec/render-rule0-rhs : {u : lvl} expr =
   [u] (elam (econst "N" lnil) ([x] (elam (eforall (eapp (econst "ProjDataIndex" lnil) x) ([y] (esort u))) ([y] (elam (eforall (econst "True" lnil) ([z] (eapp y (eapp (eapp (econst "ProjDataIndex.mk" lnil) x) z)))) ([z] (elam (econst "True" lnil) ([w] (eapp z w))))))))).

%% def projIndexData
projIndexData/render-type : expr =
   (eforall (econst "N" lnil) ([x] (eforall (eapp (econst "ProjDataIndex" lnil) x) ([y] (econst "N" lnil))))).
projIndexData/render-value : expr =
   (elam (econst "N" lnil) ([x] (elam (eapp (econst "ProjDataIndex" lnil) x) ([y] (eproj "PropStructure" 0 y))))).

