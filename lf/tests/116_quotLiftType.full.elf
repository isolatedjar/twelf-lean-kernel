%% def quotLiftType
%%% HOLE
quotLiftType/type-wf : {u : lvl} {v : lvl} defeq (eforall (esort u) ([x] (eforall (eforall x ([y] (eforall x ([z] (esort lzero))))) ([y] (eforall (esort v) ([z] (eforall (eforall x ([w] z)) ([w] (eforall (eforall x ([x1] (eforall x ([y1] (eforall (eapp (eapp y x1) y1) ([z1] (eapp (eapp (eapp (econst "Eq" (lcons v lnil)) z) (eapp w x1)) (eapp w y1)))))))) ([x1] (eforall (eapp (eapp (econst "Quot" (lcons u lnil)) x) y) ([y1] z)))))))))))) (eforall (esort u) ([x] (eforall (eforall x ([y] (eforall x ([z] (esort lzero))))) ([y] (eforall (esort v) ([z] (eforall (eforall x ([w] z)) ([w] (eforall (eforall x ([x1] (eforall x ([y1] (eforall (eapp (eapp y x1) y1) ([z1] (eapp (eapp (eapp (econst "Eq" (lcons v lnil)) z) (eapp w x1)) (eapp w y1)))))))) ([x1] (eforall (eapp (eapp (econst "Quot" (lcons u lnil)) x) y) ([y1] z)))))))))))) (esort lzero).

%%% HOLE
quotLiftType/value-typed : {u : lvl} {v : lvl} defeq (econst "Quot.lift" (lcons u (lcons v lnil))) (econst "Quot.lift" (lcons u (lcons v lnil))) (eforall (esort u) ([x] (eforall (eforall x ([y] (eforall x ([z] (esort lzero))))) ([y] (eforall (esort v) ([z] (eforall (eforall x ([w] z)) ([w] (eforall (eforall x ([x1] (eforall x ([y1] (eforall (eapp (eapp y x1) y1) ([z1] (eapp (eapp (eapp (econst "Eq" (lcons v lnil)) z) (eapp w x1)) (eapp w y1)))))))) ([x1] (eforall (eapp (eapp (econst "Quot" (lcons u lnil)) x) y) ([y1] z)))))))))))).

quotLiftType/decl : {u : lvl} {v : lvl} declared "quotLiftType" (lcons u (lcons v lnil))
   (eforall (esort u) ([x] (eforall (eforall x ([y] (eforall x ([z] (esort lzero))))) ([y] (eforall (esort v) ([z] (eforall (eforall x ([w] z)) ([w] (eforall (eforall x ([x1] (eforall x ([y1] (eforall (eapp (eapp y x1) y1) ([z1] (eapp (eapp (eapp (econst "Eq" (lcons v lnil)) z) (eapp w x1)) (eapp w y1)))))))) ([x1] (eforall (eapp (eapp (econst "Quot" (lcons u lnil)) x) y) ([y1] z))))))))))))
   (defn (econst "Quot.lift" (lcons u (lcons v lnil))))
   (dkind-ok/defn (quotLiftType/type-wf u v) (quotLiftType/value-typed u v)).

