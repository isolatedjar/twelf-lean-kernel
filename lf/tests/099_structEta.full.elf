%%% Expected outcome: accept
%%% Structure eta
%% inductive Prod
%%% HOLE
Prod/type-wf : {u : lvl} {v : lvl} defeq (eforall (esort (lsucc u)) ([x] (eforall (esort (lsucc v)) ([y] (esort (lmax (lsucc u) (lsucc v))))))) (eforall (esort (lsucc u)) ([x] (eforall (esort (lsucc v)) ([y] (esort (lmax (lsucc u) (lsucc v))))))) (esort lzero).

%%% HOLE
Prod/ends-in-sort : {u : lvl} {v : lvl} ends-in-sort (eforall (esort (lsucc u)) ([x] (eforall (esort (lsucc v)) ([y] (esort (lmax (lsucc u) (lsucc v))))))).

Prod/decl : {u : lvl} {v : lvl} declared "Prod" (lcons u (lcons v lnil))
   (eforall (esort (lsucc u)) ([x] (eforall (esort (lsucc v)) ([y] (esort (lmax (lsucc u) (lsucc v)))))))
   indt
   (dkind-ok/indt (Prod/type-wf u v) (Prod/ends-in-sort u v)).

