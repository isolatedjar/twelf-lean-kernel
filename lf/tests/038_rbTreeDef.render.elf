%% inductive Color (numParams=0, numIndices=0)
Color/render-type : expr =
   (esort (lsucc lzero)).

%% ctor Color.r (induct=Color, numFields=0)
Color_r/render-type : expr =
   (econst "Color" lnil).

%% ctor Color.b (induct=Color, numFields=0)
Color_b/render-type : expr =
   (econst "Color" lnil).

%% recursor Color.rec (numMotives=1, numMinors=2, k=false)
Color_rec/render-type : {u : lvl} expr =
   [u] (eforall (eforall (econst "Color" lnil) ([x] (esort u))) ([x] (eforall (eapp x (econst "Color.r" lnil)) ([y] (eforall (eapp x (econst "Color.b" lnil)) ([z] (eforall (econst "Color" lnil) ([w] (eapp x w))))))))).
