%%% Render-only view of: 007_betaReduction2
%%% Lambda reduction under binder
%% def constType
constType/render-type : expr =
   (eforall (esort (lsucc lzero)) ([x] (eforall (esort (lsucc lzero)) ([y] (esort (lsucc lzero)))))).
constType/render-value : expr =
   (elam (esort (lsucc lzero)) ([x] (elam (esort (lsucc lzero)) ([y] x)))).

%% def betaReduction2
betaReduction2/render-type : expr =
   (eforall (esort lzero) ([x] (eapp (eapp (econst "constType" lnil) (esort lzero)) (eforall (esort lzero) ([y] (esort lzero)))))).
betaReduction2/render-value : expr =
   (elam (esort lzero) ([x] x)).

