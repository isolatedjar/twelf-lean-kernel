%% def PN.mul
PN_mul/type-wf : of
  (eforall (econst "PN" (lcons (lvar z) lnil)) ([x] (eforall (econst "PN" (lcons (lvar z) lnil)) ([y] (econst "PN" (lcons (lvar z) lnil))))))
  (esort (limax (limax (lsucc (lvar z)) (lvar z)) (limax (limax (lsucc (lvar z)) (lvar z)) (limax (lsucc (lvar z)) (lvar z)))))
   = (defeq/forall
       (defeq/const
         PN/decl
         (inst-expr/sort
           (inst-lvl/imax
             (inst-lvl/var nth-lvl/z)
             (inst-lvl/succ (inst-lvl/var nth-lvl/z)))))
       ([x]
         ([h]
           (defeq/forall
             (defeq/const
               PN/decl
               (inst-expr/sort
                 (inst-lvl/imax
                   (inst-lvl/var nth-lvl/z)
                   (inst-lvl/succ (inst-lvl/var nth-lvl/z)))))
             ([y]
               ([h1]
                 (defeq/const
                   PN/decl
                   (inst-expr/sort
                     (inst-lvl/imax
                       (inst-lvl/var nth-lvl/z)
                       (inst-lvl/succ (inst-lvl/var nth-lvl/z))))))))))).

%%% HOLE
PN_mul/value-typed : of
  (elam (econst "PN" (lcons (lvar z) lnil))
    ([x] (elam (econst "PN" (lcons (lvar z) lnil)) ([y] (elam (esort (lvar z)) ([w] (elam (eforall w ([v] w)) ([v] (elam w ([x1] (eapp (eapp (eapp x w) (eapp (eapp y w) v)) x1)))))))))))
  (eforall (econst "PN" (lcons (lvar z) lnil)) ([x] (eforall (econst "PN" (lcons (lvar z) lnil)) ([y] (econst "PN" (lcons (lvar z) lnil)))))).

PN_mul/name : name "PN.mul" (is-decl
  (eforall (econst "PN" (lcons (lvar z) lnil)) ([x] (eforall (econst "PN" (lcons (lvar z) lnil)) ([y] (econst "PN" (lcons (lvar z) lnil))))))
  (defn (elam (econst "PN" (lcons (lvar z) lnil)) ([x] (elam (econst "PN" (lcons (lvar z) lnil)) ([y] (elam (esort (lvar z)) ([w] (elam (eforall w ([v] w)) ([v] (elam w ([x1] (eapp (eapp (eapp x w) (eapp (eapp y w) v)) x1))))))))))))).

PN_mul/decl : declared "PN.mul"
  (eforall (econst "PN" (lcons (lvar z) lnil)) ([x] (eforall (econst "PN" (lcons (lvar z) lnil)) ([y] (econst "PN" (lcons (lvar z) lnil))))))
  (defn (elam (econst "PN" (lcons (lvar z) lnil)) ([x] (elam (econst "PN" (lcons (lvar z) lnil)) ([y] (elam (esort (lvar z)) ([w] (elam (eforall w ([v] w)) ([v] (elam w ([x1] (eapp (eapp (eapp x w) (eapp (eapp y w) v)) x1))))))))))))
   = declared/ok PN_mul/name dkind-non-inductive/defn (dkind-ok/defn PN_mul/type-wf PN_mul/value-typed).

%% thm peano3
peano3/type-wf : of
  (eforall (eforall (econst "PN" (lcons (lvar z) lnil)) ([x] (esort lzero)))
    ([x] (eforall (eforall (econst "PN" (lcons (lvar z) lnil)) ([y] (eapp x y))) ([y] (eapp x (econst "PN.lit4" (lcons (lvar z) lnil)))))))
  (esort lzero)
   = (defeq/conv
       (defeq/sort-eq
         (eq-lvl/le
           leq-lvl/lz
           (leq-lvl/imaxLi
             (leq-lvl/maxL
               (leq-lvl/imaxLz leq-lvl/self)
               (leq-lvl/imaxLz leq-lvl/self)))))
       (defeq/forall
         (defeq/forall
           (defeq/const
             PN/decl
             (inst-expr/sort
               (inst-lvl/imax
                 (inst-lvl/var nth-lvl/z)
                 (inst-lvl/succ (inst-lvl/var nth-lvl/z)))))
           ([x] ([h] defeq/sort-refl)))
         ([x]
           ([h]
             (defeq/forall
               (defeq/forall
                 (defeq/const
                   PN/decl
                   (inst-expr/sort
                     (inst-lvl/imax
                       (inst-lvl/var nth-lvl/z)
                       (inst-lvl/succ (inst-lvl/var nth-lvl/z)))))
                 ([y] ([h1] (defeq/app h h1))))
               ([y]
                 ([h1]
                   (defeq/app
                     h
                     (defeq/const
                       PN_lit4/decl
                       (inst-expr/const
                         (inst-lvls/cons
                           inst-lvls/nil
                           (inst-lvl/var nth-lvl/z)))))))))))).

%%% HOLE
peano3/value-typed : of
  (elam (eforall (econst "PN" (lcons (lvar z) lnil)) ([x] (esort lzero)))
    ([x]
      (elam (eforall (econst "PN" (lcons (lvar z) lnil)) ([y] (eapp x y)))
        ([y] (eapp y (eapp (eapp (econst "PN.mul" (lcons (lvar z) lnil)) (econst "PN.lit2" (lcons (lvar z) lnil))) (econst "PN.lit2" (lcons (lvar z) lnil))))))))
  (eforall (eforall (econst "PN" (lcons (lvar z) lnil)) ([x] (esort lzero)))
    ([x] (eforall (eforall (econst "PN" (lcons (lvar z) lnil)) ([y] (eapp x y))) ([y] (eapp x (econst "PN.lit4" (lcons (lvar z) lnil))))))).

peano3/name : name "peano3" (is-decl
  (eforall (eforall (econst "PN" (lcons (lvar z) lnil)) ([x] (esort lzero)))
    ([x] (eforall (eforall (econst "PN" (lcons (lvar z) lnil)) ([y] (eapp x y))) ([y] (eapp x (econst "PN.lit4" (lcons (lvar z) lnil)))))))
  (thm (elam (eforall (econst "PN" (lcons (lvar z) lnil)) ([x] (esort lzero))) ([x] (elam (eforall (econst "PN" (lcons (lvar z) lnil)) ([y] (eapp x y))) ([y] (eapp y (eapp (eapp (econst "PN.mul" (lcons (lvar z) lnil)) (econst "PN.lit2" (lcons (lvar z) lnil))) (econst "PN.lit2" (lcons (lvar z) lnil)))))))))).

peano3/decl : declared "peano3"
  (eforall (eforall (econst "PN" (lcons (lvar z) lnil)) ([x] (esort lzero)))
    ([x] (eforall (eforall (econst "PN" (lcons (lvar z) lnil)) ([y] (eapp x y))) ([y] (eapp x (econst "PN.lit4" (lcons (lvar z) lnil)))))))
  (thm (elam (eforall (econst "PN" (lcons (lvar z) lnil)) ([x] (esort lzero))) ([x] (elam (eforall (econst "PN" (lcons (lvar z) lnil)) ([y] (eapp x y))) ([y] (eapp y (eapp (eapp (econst "PN.mul" (lcons (lvar z) lnil)) (econst "PN.lit2" (lcons (lvar z) lnil))) (econst "PN.lit2" (lcons (lvar z) lnil)))))))))
   = declared/ok peano3/name dkind-non-inductive/thm (dkind-ok/thm peano3/type-wf peano3/value-typed).
