%%% Expected outcome: accept
%%% Peano arithmetic: 2 * 2 = 4
%% def PN
PN/type-wf : of (esort (limax (lsucc (lvar z)) (lvar z))) (esort (lsucc (limax (lsucc (lvar z)) (lvar z))))
   = defeq/sort-refl.

%%% HOLE
PN/value-typed : of (eforall (esort (lvar z)) ([x] (eforall (eforall x ([y] x)) ([y] (eforall x ([w] x)))))) (esort (limax (lsucc (lvar z)) (lvar z))).

PN/name : name "PN" (is-decl (esort (limax (lsucc (lvar z)) (lvar z))) (defn (eforall (esort (lvar z)) ([x] (eforall (eforall x ([y] x)) ([y] (eforall x ([w] x)))))))).

PN/decl : declared "PN" (esort (limax (lsucc (lvar z)) (lvar z))) (defn (eforall (esort (lvar z)) ([x] (eforall (eforall x ([y] x)) ([y] (eforall x ([w] x)))))))
   = declared/ok PN/name dkind-non-inductive/defn (dkind-ok/defn PN/type-wf PN/value-typed).

%% def PN.succ
PN_succ/type-wf : of (eforall (econst "PN" (lcons (lvar z) lnil)) ([x] (econst "PN" (lcons (lvar z) lnil)))) (esort (limax (limax (lsucc (lvar z)) (lvar z)) (limax (lsucc (lvar z)) (lvar z))))
   = (defeq/forall
       (defeq/const
         PN/decl
         (inst-expr/sort
           (inst-lvl/imax
             (inst-lvl/var nth-lvl/z)
             (inst-lvl/succ (inst-lvl/var nth-lvl/z)))))
       ([x]
         ([h]
           (defeq/const
             PN/decl
             (inst-expr/sort
               (inst-lvl/imax
                 (inst-lvl/var nth-lvl/z)
                 (inst-lvl/succ (inst-lvl/var nth-lvl/z)))))))).

%%% HOLE
PN_succ/value-typed : of
  (elam (econst "PN" (lcons (lvar z) lnil)) ([x] (elam (esort (lvar z)) ([y] (elam (eforall y ([w] y)) ([w] (elam y ([v] (eapp w (eapp (eapp (eapp x y) w) v))))))))))
  (eforall (econst "PN" (lcons (lvar z) lnil)) ([x] (econst "PN" (lcons (lvar z) lnil)))).

PN_succ/name : name "PN.succ" (is-decl
  (eforall (econst "PN" (lcons (lvar z) lnil)) ([x] (econst "PN" (lcons (lvar z) lnil))))
  (defn (elam (econst "PN" (lcons (lvar z) lnil)) ([x] (elam (esort (lvar z)) ([y] (elam (eforall y ([w] y)) ([w] (elam y ([v] (eapp w (eapp (eapp (eapp x y) w) v)))))))))))).

PN_succ/decl : declared "PN.succ"
  (eforall (econst "PN" (lcons (lvar z) lnil)) ([x] (econst "PN" (lcons (lvar z) lnil))))
  (defn (elam (econst "PN" (lcons (lvar z) lnil)) ([x] (elam (esort (lvar z)) ([y] (elam (eforall y ([w] y)) ([w] (elam y ([v] (eapp w (eapp (eapp (eapp x y) w) v)))))))))))
   = declared/ok PN_succ/name dkind-non-inductive/defn (dkind-ok/defn PN_succ/type-wf PN_succ/value-typed).

%% def PN.zero
PN_zero/type-wf : of (econst "PN" (lcons (lvar z) lnil)) (esort (limax (lsucc (lvar z)) (lvar z)))
   = (defeq/const
       PN/decl
       (inst-expr/sort
         (inst-lvl/imax
           (inst-lvl/var nth-lvl/z)
           (inst-lvl/succ (inst-lvl/var nth-lvl/z))))).

%%% HOLE
PN_zero/value-typed : of (elam (esort (lvar z)) ([x] (elam (eforall x ([y] x)) ([y] (elam x ([w] w)))))) (econst "PN" (lcons (lvar z) lnil)).

PN_zero/name : name "PN.zero" (is-decl (econst "PN" (lcons (lvar z) lnil)) (defn (elam (esort (lvar z)) ([x] (elam (eforall x ([y] x)) ([y] (elam x ([w] w)))))))).

PN_zero/decl : declared "PN.zero" (econst "PN" (lcons (lvar z) lnil)) (defn (elam (esort (lvar z)) ([x] (elam (eforall x ([y] x)) ([y] (elam x ([w] w)))))))
   = declared/ok PN_zero/name dkind-non-inductive/defn (dkind-ok/defn PN_zero/type-wf PN_zero/value-typed).

%% def PN.lit0
PN_lit0/type-wf : of (econst "PN" (lcons (lvar z) lnil)) (esort (limax (lsucc (lvar z)) (lvar z)))
   = (defeq/const
       PN/decl
       (inst-expr/sort
         (inst-lvl/imax
           (inst-lvl/var nth-lvl/z)
           (inst-lvl/succ (inst-lvl/var nth-lvl/z))))).

PN_lit0/value-typed : of (econst "PN.zero" (lcons (lvar z) lnil)) (econst "PN" (lcons (lvar z) lnil))
   = (defeq/const
       PN_zero/decl
       (inst-expr/const
         (inst-lvls/cons inst-lvls/nil (inst-lvl/var nth-lvl/z)))).

PN_lit0/name : name "PN.lit0" (is-decl (econst "PN" (lcons (lvar z) lnil)) (defn (econst "PN.zero" (lcons (lvar z) lnil)))).

PN_lit0/decl : declared "PN.lit0" (econst "PN" (lcons (lvar z) lnil)) (defn (econst "PN.zero" (lcons (lvar z) lnil)))
   = declared/ok PN_lit0/name dkind-non-inductive/defn (dkind-ok/defn PN_lit0/type-wf PN_lit0/value-typed).

