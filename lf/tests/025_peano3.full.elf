           (inst-lvl/var nth-lvl/z)
           (inst-lvl/succ (inst-lvl/var nth-lvl/z))))).

PN_lit1/value-typed : of (eapp (econst "PN.succ" (lcons (lvar z) lnil)) (econst "PN.lit0" (lcons (lvar z) lnil))) (econst "PN" (lcons (lvar z) lnil))
   = (defeq/app
       (defeq/const
         PN_succ/decl
         (inst-expr/forall
           (inst-expr/const
             (inst-lvls/cons inst-lvls/nil (inst-lvl/var nth-lvl/z)))
           ([x]
             ([h]
               (inst-expr/const
                 (inst-lvls/cons inst-lvls/nil (inst-lvl/var nth-lvl/z)))))))
       (defeq/const
         PN_lit0/decl
         (inst-expr/const
           (inst-lvls/cons inst-lvls/nil (inst-lvl/var nth-lvl/z))))).

PN_lit1/name : name "PN.lit1" (is-decl (econst "PN" (lcons (lvar z) lnil)) (defn (eapp (econst "PN.succ" (lcons (lvar z) lnil)) (econst "PN.lit0" (lcons (lvar z) lnil))))).

PN_lit1/decl : declared "PN.lit1" (econst "PN" (lcons (lvar z) lnil)) (defn (eapp (econst "PN.succ" (lcons (lvar z) lnil)) (econst "PN.lit0" (lcons (lvar z) lnil))))
   = declared/ok PN_lit1/name dkind-non-inductive/defn (dkind-ok/defn PN_lit1/type-wf PN_lit1/value-typed).

