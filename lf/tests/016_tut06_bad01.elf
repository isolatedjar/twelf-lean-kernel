%%% Expected outcome: reject
%%% Duplicate universe parameters
%% def tut06_bad01
%abbrev tut06_bad01/type-wf :
   {u : lvl} {u : lvl} defeq (esort (lsucc lzero)) (esort (lsucc lzero)) (esort (lsucc (lsucc lzero)))
   = [u] [u] (defeq/sort-refl-at (lsucc lzero)).

%abbrev tut06_bad01/value-typed :
   {u : lvl} {u : lvl} defeq (esort lzero) (esort lzero) (esort (lsucc lzero))
   = [u] [u] (defeq/sort-refl-at lzero).

tut06_bad01/decl : {u : lvl} {u : lvl} declared "tut06_bad01" (lcons u (lcons u lnil))
   (esort (lsucc lzero))
   (defn (esort lzero))
   (dkind-ok/defn (tut06_bad01/type-wf u u) (tut06_bad01/value-typed u u)).

%mode declared +N +LS -T -DK -W.
%worlds () (declared _ _ _ _ _).
%unique declared +N +LS -1T -1DK *W.
