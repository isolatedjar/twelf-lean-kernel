%%% Render-only view of: 084_projProp5
%%% Projecting out of a proposition
%%% 
%%% The lean kernel disallows proof projections out of propositional structures that depend on data.
%% inductive PUnit (numParams=0, numIndices=0)
PUnit/render-type : {u : lvl} expr =
   [u] (esort u).

%% ctor PUnit.unit (induct=PUnit, numFields=0)
PUnit_unit/render-type : {u : lvl} expr =
   [u] (econst "PUnit" (lcons u lnil)).

%% recursor PUnit.rec (numMotives=1, numMinors=1, k=false)
PUnit_rec/render-type : {u_1 : lvl} {u : lvl} expr =
   [u_1] [u] (eforall (eforall (econst "PUnit" (lcons u lnil)) ([x] (esort u_1))) ([x] (eforall (eapp x (econst "PUnit.unit" (lcons u lnil))) ([y] (eforall (econst "PUnit" (lcons u lnil)) ([z] (eapp x z))))))).
%%   rec-rule for PUnit.unit (nfields=0)
PUnit_rec/render-rule0-rhs : {u_1 : lvl} {u : lvl} expr =
   [u_1] [u] (elam (eforall (econst "PUnit" (lcons u lnil)) ([x] (esort u_1))) ([x] (elam (eapp x (econst "PUnit.unit" (lcons u lnil))) ([y] y)))).

%% inductive Eq (numParams=2, numIndices=1)
Eq/render-type : {u_1 : lvl} expr =
   [u_1] (eforall (esort u_1) ([x] (eforall x ([y] (eforall x ([z] (esort lzero))))))).

%% ctor Eq.refl (induct=Eq, numFields=0)
Eq_refl/render-type : {u_1 : lvl} expr =
   [u_1] (eforall (esort u_1) ([x] (eforall x ([y] (eapp (eapp (eapp (econst "Eq" (lcons u_1 lnil)) x) y) y))))).

%% recursor Eq.rec (numMotives=1, numMinors=1, k=true)
Eq_rec/render-type : {u : lvl} {u_1 : lvl} expr =
   [u] [u_1] (eforall (esort u_1) ([x] (eforall x ([y] (eforall (eforall x ([z] (eforall (eapp (eapp (eapp (econst "Eq" (lcons u_1 lnil)) x) y) z) ([w] (esort u))))) ([z] (eforall (eapp (eapp z y) (eapp (eapp (econst "Eq.refl" (lcons u_1 lnil)) x) y)) ([w] (eforall x ([x1] (eforall (eapp (eapp (eapp (econst "Eq" (lcons u_1 lnil)) x) y) x1) ([y1] (eapp (eapp z x1) y1))))))))))))).
%%   rec-rule for Eq.refl (nfields=0)
Eq_rec/render-rule0-rhs : {u : lvl} {u_1 : lvl} expr =
   [u] [u_1] (elam (esort u_1) ([x] (elam x ([y] (elam (eforall x ([z] (eforall (eapp (eapp (eapp (econst "Eq" (lcons u_1 lnil)) x) y) z) ([w] (esort u))))) ([z] (elam (eapp (eapp z y) (eapp (eapp (econst "Eq.refl" (lcons u_1 lnil)) x) y)) ([w] w)))))))).

%% inductive PropStructure (numParams=0, numIndices=0)
PropStructure/render-type : {u : lvl} {v : lvl} expr =
   [u] [v] (esort lzero).

%% ctor PropStructure.mk (induct=PropStructure, numFields=6)
PropStructure_mk/render-type : {u : lvl} {v : lvl} expr =
   [u] [v] (eforall (econst "PUnit" (lcons u lnil)) ([x] (eforall (econst "PUnit" (lcons v lnil)) ([y] (eforall (econst "PUnit" (lcons u lnil)) ([z] (eforall (econst "PUnit" (lcons v lnil)) ([w] (eforall (eapp (eapp (eapp (econst "Eq" (lcons v lnil)) (econst "PUnit" (lcons v lnil))) w) w) ([x1] (eforall (econst "PUnit" (lcons u lnil)) ([y1] (econst "PropStructure" (lcons u (lcons v lnil))))))))))))))).

%% recursor PropStructure.rec (numMotives=1, numMinors=1, k=false)
PropStructure_rec/render-type : {u : lvl} {v : lvl} expr =
   [u] [v] (eforall (eforall (econst "PropStructure" (lcons u (lcons v lnil))) ([x] (esort lzero))) ([x] (eforall (eforall (econst "PUnit" (lcons u lnil)) ([y] (eforall (econst "PUnit" (lcons v lnil)) ([z] (eforall (econst "PUnit" (lcons u lnil)) ([w] (eforall (econst "PUnit" (lcons v lnil)) ([x1] (eforall (eapp (eapp (eapp (econst "Eq" (lcons v lnil)) (econst "PUnit" (lcons v lnil))) x1) x1) ([y1] (eforall (econst "PUnit" (lcons u lnil)) ([z1] (eapp x (eapp (eapp (eapp (eapp (eapp (eapp (econst "PropStructure.mk" (lcons u (lcons v lnil))) y) z) w) x1) y1) z1)))))))))))))) ([y] (eforall (econst "PropStructure" (lcons u (lcons v lnil))) ([z] (eapp x z))))))).
%%   rec-rule for PropStructure.mk (nfields=6)
PropStructure_rec/render-rule0-rhs : {u : lvl} {v : lvl} expr =
   [u] [v] (elam (eforall (econst "PropStructure" (lcons u (lcons v lnil))) ([x] (esort lzero))) ([x] (elam (eforall (econst "PUnit" (lcons u lnil)) ([y] (eforall (econst "PUnit" (lcons v lnil)) ([z] (eforall (econst "PUnit" (lcons u lnil)) ([w] (eforall (econst "PUnit" (lcons v lnil)) ([x1] (eforall (eapp (eapp (eapp (econst "Eq" (lcons v lnil)) (econst "PUnit" (lcons v lnil))) x1) x1) ([y1] (eforall (econst "PUnit" (lcons u lnil)) ([z1] (eapp x (eapp (eapp (eapp (eapp (eapp (eapp (econst "PropStructure.mk" (lcons u (lcons v lnil))) y) z) w) x1) y1) z1)))))))))))))) ([y] (elam (econst "PUnit" (lcons u lnil)) ([z] (elam (econst "PUnit" (lcons v lnil)) ([w] (elam (econst "PUnit" (lcons u lnil)) ([x1] (elam (econst "PUnit" (lcons v lnil)) ([y1] (elam (eapp (eapp (eapp (econst "Eq" (lcons v lnil)) (econst "PUnit" (lcons v lnil))) y1) y1) ([z1] (elam (econst "PUnit" (lcons u lnil)) ([w1] (eapp (eapp (eapp (eapp (eapp (eapp y z) w) x1) y1) z1) w1))))))))))))))))).

%% def projProp5
projProp5/render-type : expr =
   (eforall (econst "PropStructure" (lcons lzero (lcons (lsucc lzero) lnil))) ([x] (eapp (eapp (eapp (econst "Eq" (lcons (lsucc lzero) lnil)) (econst "PUnit" (lcons (lsucc lzero) lnil))) (eproj "PropStructure" 3 x)) (eproj "PropStructure" 3 x)))).
projProp5/render-value : expr =
   (elam (econst "PropStructure" (lcons lzero (lcons (lsucc lzero) lnil))) ([x] (eproj "PropStructure" 4 x))).

