%%% Expected outcome: reject
%%% When checking inductives, we expect the kernel to **not** reduce the type of the constructor parameters
further than head normal form. Recursive occurrences nested inside the head normal form are considered
negative occurrences, even if they could be reduced to disappear.
%% def constType
constType/type-wf :
   defeq (eforall (esort (lsucc lzero)) ([x] (eforall (esort (lsucc lzero)) ([y] (esort (lsucc lzero)))))) (eforall (esort (lsucc lzero)) ([x] (eforall (esort (lsucc lzero)) ([y] (esort (lsucc lzero)))))) (esort (limax (lsucc (lsucc lzero)) (limax (lsucc (lsucc lzero)) (lsucc (lsucc lzero)))))
   = (defeq/forall (defeq/sort-refl-at (lsucc lzero)) ([x] [y] (defeq/forall (defeq/sort-refl-at (lsucc lzero)) ([z] [w] (defeq/sort-refl-at (lsucc lzero)))))).

constType/value-typed :
   defeq (elam (esort (lsucc lzero)) ([x] (elam (esort (lsucc lzero)) ([y] x)))) (elam (esort (lsucc lzero)) ([x] (elam (esort (lsucc lzero)) ([y] x)))) (eforall (esort (lsucc lzero)) ([x] (eforall (esort (lsucc lzero)) ([y] (esort (lsucc lzero))))))
   = (defeq/lam (defeq/sort-refl-at (lsucc lzero)) ([x] [y] (defeq/lam (defeq/sort-refl-at (lsucc lzero)) ([z] [w] y)))).

constType/decl : declared "constType" lnil
   (eforall (esort (lsucc lzero)) ([x] (eforall (esort (lsucc lzero)) ([y] (esort (lsucc lzero))))))
   (defn (elam (esort (lsucc lzero)) ([x] (elam (esort (lsucc lzero)) ([y] x)))))
   (dkind-ok/defn constType/type-wf constType/value-typed).

%% axiom aType
aType/type-wf :
   defeq (esort (lsucc lzero)) (esort (lsucc lzero)) (esort (lsucc (lsucc lzero)))
   = (defeq/sort-refl-at (lsucc lzero)).

aType/decl : declared "aType" lnil
   (esort (lsucc lzero))
   ax
   (dkind-ok/ax aType/type-wf).

%% inductive indNegReducible
indNegReducible/type-wf :
   defeq (esort (lsucc lzero)) (esort (lsucc lzero)) (esort (lsucc (lsucc lzero)))
   = (defeq/sort-refl-at (lsucc lzero)).

indNegReducible/ends-in-sort :
   ends-in-sort (esort (lsucc lzero))
   = ends-in-sort/sort.

indNegReducible/decl : declared "indNegReducible" lnil
   (esort (lsucc lzero))
   indt
   (dkind-ok/indt indNegReducible/type-wf indNegReducible/ends-in-sort).

%% inductive ctor indNegReducible.mk
indNegReducible_mk/type-wf :
   defeq (eforall (eforall (eapp (eapp (econst "constType" lnil) (econst "aType" lnil)) (econst "indNegReducible" lnil)) ([x] (econst "indNegReducible" lnil))) ([x] (econst "indNegReducible" lnil))) (eforall (eforall (eapp (eapp (econst "constType" lnil) (econst "aType" lnil)) (econst "indNegReducible" lnil)) ([x] (econst "indNegReducible" lnil))) ([x] (econst "indNegReducible" lnil))) (esort (limax (limax (lsucc lzero) (lsucc lzero)) (lsucc lzero)))
   = (defeq/forall (defeq/forall (defeq/app (defeq/app (defeq/const constType/decl) (defeq/const aType/decl)) (defeq/const indNegReducible/decl)) ([x] [y] (defeq/const indNegReducible/decl))) ([x] [y] (defeq/const indNegReducible/decl))).

%% TRANSLATOR REJECT: ctor indNegReducible.mk — type is not strictly positive in indNegReducible (or uses unsupported expr form)
%solve _violation_0 : tcb-violation.

%% inductive recursor indNegReducible.rec
indNegReducible_rec/type-wf :
   defeq (esort lzero) (esort lzero) (esort (lsucc lzero))
   = (defeq/sort-refl-at lzero).

indNegReducible_rec/decl : declared "indNegReducible.rec" lnil
   (esort lzero)
   irec
   (dkind-ok/irec indNegReducible_rec/type-wf).

%mode declared +N +LS -T -DK -W.
%worlds () (declared _ _ _ _ _).
%unique declared +N +LS -1T -1DK *W.

