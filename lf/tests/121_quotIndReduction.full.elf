%% thm quotIndReduction
%%% HOLE
quotIndReduction/type-wf : of (eforall (esort (lvar liz))
                             ([x]
                               (eforall (eforall x ([y] (eforall x ([z] (esort lzero)))))
                                 ([y]
                                   (eforall (eforall (eapp (eapp (econst "Quot" (lcons (lvar liz) lnil)) x) y) ([z] (esort lzero)))
                                     ([z]
                                       (eforall (eforall x ([w] (eapp z (eapp (eapp (eapp (econst "Quot.mk" (lcons (lvar liz) lnil)) x) y) w))))
                                         ([w]
                                           (eforall x
                                             ([x1]
                                               (eapp (eapp (eapp (econst "Eq" (lcons lzero lnil)) (eapp z (eapp (eapp (eapp (econst "Quot.mk" (lcons (lvar liz) lnil)) x) y) x1)))
                                                 (eapp (eapp (eapp (eapp (eapp (econst "Quot.ind" (lcons (lvar liz) lnil)) x) y) z) w)
                                                   (eapp (eapp (eapp (econst "Quot.mk" (lcons (lvar liz) lnil)) x) y) x1)))
                                                 (eapp w x1)))))))))))) (esort lzero).

%%% HOLE
quotIndReduction/value-typed : of (elam (esort (lvar liz))
                                 ([x]
                                   (elam (eforall x ([y] (eforall x ([z] (esort lzero)))))
                                     ([y]
                                       (elam (eforall (eapp (eapp (econst "Quot" (lcons (lvar liz) lnil)) x) y) ([z] (esort lzero)))
                                         ([z]
                                           (elam (eforall x ([w] (eapp z (eapp (eapp (eapp (econst "Quot.mk" (lcons (lvar liz) lnil)) x) y) w))))
                                             ([w]
                                               (elam x
                                                 ([x1]
                                                   (eapp (eapp (econst "Eq.refl" (lcons lzero lnil)) (eapp z (eapp (eapp (eapp (econst "Quot.mk" (lcons (lvar liz) lnil)) x) y) x1)))
                                                     (eapp (eapp (eapp (eapp (eapp (econst "Quot.ind" (lcons (lvar liz) lnil)) x) y) z) w)
                                                       (eapp (eapp (eapp (econst "Quot.mk" (lcons (lvar liz) lnil)) x) y)
                                                         x1))))))))))))) (eforall (esort (lvar liz))
                                 ([x]
                                   (eforall (eforall x ([y] (eforall x ([z] (esort lzero)))))
                                     ([y]
                                       (eforall (eforall (eapp (eapp (econst "Quot" (lcons (lvar liz) lnil)) x) y) ([z] (esort lzero)))
                                         ([z]
                                           (eforall (eforall x ([w] (eapp z (eapp (eapp (eapp (econst "Quot.mk" (lcons (lvar liz) lnil)) x) y) w))))
                                             ([w]
                                               (eforall x
                                                 ([x1]
                                                   (eapp (eapp (eapp (econst "Eq" (lcons lzero lnil)) (eapp z (eapp (eapp (eapp (econst "Quot.mk" (lcons (lvar liz) lnil)) x) y) x1)))
                                                     (eapp (eapp (eapp (eapp (eapp (econst "Quot.ind" (lcons (lvar liz) lnil)) x) y) z) w)
                                                       (eapp (eapp (eapp (econst "Quot.mk" (lcons (lvar liz) lnil)) x) y) x1)))
                                                     (eapp w x1)))))))))))).

quotIndReduction/name : name "quotIndReduction" (is-decl (eforall (esort (lvar liz)) ([x] (eforall (eforall x ([y] (eforall x ([z] (esort lzero))))) ([y] (eforall (eforall (eapp (eapp (econst "Quot" (lcons (lvar liz) lnil)) x) y) ([z] (esort lzero))) ([z] (eforall (eforall x ([w] (eapp z (eapp (eapp (eapp (econst "Quot.mk" (lcons (lvar liz) lnil)) x) y) w)))) ([w] (eforall x ([x1] (eapp (eapp (eapp (econst "Eq" (lcons lzero lnil)) (eapp z (eapp (eapp (eapp (econst "Quot.mk" (lcons (lvar liz) lnil)) x) y) x1))) (eapp (eapp (eapp (eapp (eapp (econst "Quot.ind" (lcons (lvar liz) lnil)) x) y) z) w) (eapp (eapp (eapp (econst "Quot.mk" (lcons (lvar liz) lnil)) x) y) x1))) (eapp w x1)))))))))))) (thm (elam (esort (lvar liz)) ([x] (elam (eforall x ([y] (eforall x ([z] (esort lzero))))) ([y] (elam (eforall (eapp (eapp (econst "Quot" (lcons (lvar liz) lnil)) x) y) ([z] (esort lzero))) ([z] (elam (eforall x ([w] (eapp z (eapp (eapp (eapp (econst "Quot.mk" (lcons (lvar liz) lnil)) x) y) w)))) ([w] (elam x ([x1] (eapp (eapp (econst "Eq.refl" (lcons lzero lnil)) (eapp z (eapp (eapp (eapp (econst "Quot.mk" (lcons (lvar liz) lnil)) x) y) x1))) (eapp (eapp (eapp (eapp (eapp (econst "Quot.ind" (lcons (lvar liz) lnil)) x) y) z) w) (eapp (eapp (eapp (econst "Quot.mk" (lcons (lvar liz) lnil)) x) y) x1))))))))))))))).

quotIndReduction/decl : declared "quotIndReduction" (eforall (esort (lvar liz)) ([x] (eforall (eforall x ([y] (eforall x ([z] (esort lzero))))) ([y] (eforall (eforall (eapp (eapp (econst "Quot" (lcons (lvar liz) lnil)) x) y) ([z] (esort lzero))) ([z] (eforall (eforall x ([w] (eapp z (eapp (eapp (eapp (econst "Quot.mk" (lcons (lvar liz) lnil)) x) y) w)))) ([w] (eforall x ([x1] (eapp (eapp (eapp (econst "Eq" (lcons lzero lnil)) (eapp z (eapp (eapp (eapp (econst "Quot.mk" (lcons (lvar liz) lnil)) x) y) x1))) (eapp (eapp (eapp (eapp (eapp (econst "Quot.ind" (lcons (lvar liz) lnil)) x) y) z) w) (eapp (eapp (eapp (econst "Quot.mk" (lcons (lvar liz) lnil)) x) y) x1))) (eapp w x1)))))))))))) (thm (elam (esort (lvar liz)) ([x] (elam (eforall x ([y] (eforall x ([z] (esort lzero))))) ([y] (elam (eforall (eapp (eapp (econst "Quot" (lcons (lvar liz) lnil)) x) y) ([z] (esort lzero))) ([z] (elam (eforall x ([w] (eapp z (eapp (eapp (eapp (econst "Quot.mk" (lcons (lvar liz) lnil)) x) y) w)))) ([w] (elam x ([x1] (eapp (eapp (econst "Eq.refl" (lcons lzero lnil)) (eapp z (eapp (eapp (eapp (econst "Quot.mk" (lcons (lvar liz) lnil)) x) y) x1))) (eapp (eapp (eapp (eapp (eapp (econst "Quot.ind" (lcons (lvar liz) lnil)) x) y) z) w) (eapp (eapp (eapp (econst "Quot.mk" (lcons (lvar liz) lnil)) x) y) x1))))))))))))))
   = declared/ok quotIndReduction/name (dkind-ok/thm quotIndReduction/type-wf quotIndReduction/value-typed).
