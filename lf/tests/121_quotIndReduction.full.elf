%%% Expected outcome: accept
%%% Reduction behavior of `Quot.ind` on `Quot.mk`.
%% inductive Eq
Eq/type-wf-sort : lvl
   = (limax
       (lsucc (lvar liz))
       (limax (lvar liz) (limax (lvar liz) (lsucc lzero)))).

Eq/type-wf : of (eforall (esort (lvar liz)) ([x] (eforall x ([y] (eforall x ([z] (esort lzero))))))) (esort Eq/type-wf-sort)
   = (defeq/forall
       defeq/sort-refl
       ([x]
         ([h]
           (defeq/forall
             h
             ([y] ([h1] (defeq/forall h ([z] ([h2] defeq/sort-refl))))))))).

Eq/ends-in-sort : ends-in-sort (eforall (esort (lvar liz)) ([x] (eforall x ([y] (eforall x ([z] (esort lzero)))))))
   = (ends-in-sort/forall
       ([x]
         (ends-in-sort/forall
           ([y] (ends-in-sort/forall ([z] ends-in-sort/sort)))))).

Eq/rec-name : name "Eq.rec" (is-rec-for "Eq").

Eq/name : name "Eq" (is-decl (eforall (esort (lvar liz)) ([x] (eforall x ([y] (eforall x ([z] (esort lzero))))))) indt).

Eq/decl : declared "Eq" (eforall (esort (lvar liz)) ([x] (eforall x ([y] (eforall x ([z] (esort lzero))))))) indt
   = declared/ok Eq/name (dkind-ok/indt Eq/type-wf Eq/ends-in-sort).

%% ctor Eq.refl (of Eq)
Eq_refl/type-wf-sort : lvl
   = (limax (lsucc (lvar liz)) (limax (lvar liz) lzero)).

Eq_refl/type-wf : of (eforall (esort (lvar liz)) ([x] (eforall x ([y] (eapp (eapp (eapp (econst "Eq" (lcons (lvar liz) lnil)) x) y) y))))) (esort Eq_refl/type-wf-sort)
   = (defeq/forall
       defeq/sort-refl
       ([x]
         ([h]
           (defeq/forall
             h
             ([y]
               ([h1]
                 (defeq/app
                   (defeq/app
                     (defeq/app
                       (defeq/const
                         Eq/decl
                         (inst-expr/forall
                           (inst-expr/sort (lvl-inst/var lvl-nth/zero))
                           ([x]
                             ([h]
                               (inst-expr/forall
                                 h
                                 ([y]
                                   ([h1]
                                     (inst-expr/forall
                                       h
                                       ([z]
                                         ([h2]
                                           (inst-expr/sort
                                             lvl-inst/zero)))))))))))
                       h)
                     h1)
                   h1))))))).

Eq_refl/positivity : ctor-positive "Eq" (lcons (lvar liz) lnil) (eforall (esort (lvar liz)) ([x] (eforall x ([y] (eapp (eapp (eapp (econst "Eq" (lcons (lvar liz) lnil)) x) y) y)))))
   = (ctor-positive/intro ([S] (eforall (esort (lvar liz)) ([x] (eforall x ([y] (eapp (eapp (eapp S x) y) y)))))) (ctor-spine/arg
       (strict-pos/no-occur (esort (lvar liz)) no-self-ref/sort)
       ([x]
         ([y]
           (ctor-spine/arg
             (strict-pos/no-occur x y)
             ([z]
               ([w]
                 (ctor-spine/result
                   (applies-self/app
                     (applies-self/app
                       (applies-self/app applies-self/refl))))))))))).

Eq_refl/eisl : ends-in-sort-with-level (eforall (esort (lvar liz)) ([x] (eforall x ([y] (eforall x ([z] (esort lzero))))))) lzero
   = (ends-in-sort-with-level/forall
       ([x]
         (ends-in-sort-with-level/forall
           ([y]
             (ends-in-sort-with-level/forall
               ([z] ends-in-sort-with-level/sort)))))).

%%% HOLE: Eq_refl/fuo — prover for field-universes-ok-skip-params not yet implemented
Eq_refl/fuo : field-universes-ok-skip-params (lis (lis liz)) (eforall (esort (lvar liz)) ([x] (eforall x ([y] (eapp (eapp (eapp (econst "Eq" (lcons (lvar liz) lnil)) x) y) y))))) lzero.

Eq_refl/name : name "Eq.refl" (is-decl (eforall (esort (lvar liz)) ([x] (eforall x ([y] (eapp (eapp (eapp (econst "Eq" (lcons (lvar liz) lnil)) x) y) y))))) ctor).

Eq_refl/decl : declared "Eq.refl" (eforall (esort (lvar liz)) ([x] (eforall x ([y] (eapp (eapp (eapp (econst "Eq" (lcons (lvar liz) lnil)) x) y) y))))) ctor
   = declared/ok Eq_refl/name (dkind-ok/ctor Eq_refl/type-wf Eq_refl/positivity Eq/decl Eq_refl/eisl Eq_refl/fuo).

%% recursor Eq.rec
Eq_rec/type-wf-sort : lvl
   = (limax
       (lsucc (lvar (lis liz)))
       (limax
         (lvar (lis liz))
         (limax
           (limax (lvar (lis liz)) (limax lzero (lsucc (lvar liz))))
           (limax
             (lvar liz)
             (limax (lvar (lis liz)) (limax lzero (lvar liz))))))).

Eq_rec/type-wf : of (eforall (esort (lvar (lis liz)))
                   ([x]
                     (eforall x
                       ([y]
                         (eforall (eforall x ([z] (eforall (eapp (eapp (eapp (econst "Eq" (lcons (lvar (lis liz)) lnil)) x) y) z) ([w] (esort (lvar liz))))))
                           ([z]
                             (eforall (eapp (eapp z y) (eapp (eapp (econst "Eq.refl" (lcons (lvar (lis liz)) lnil)) x) y))
                               ([w]
                                 (eforall x ([x1] (eforall (eapp (eapp (eapp (econst "Eq" (lcons (lvar (lis liz)) lnil)) x) y) x1) ([y1] (eapp (eapp z x1) y1))))))))))))) (esort Eq_rec/type-wf-sort)
   = (defeq/forall
       defeq/sort-refl
       ([x]
         ([h]
           (defeq/forall
             h
             ([y]
               ([h1]
                 (defeq/forall
                   (defeq/forall
                     h
                     ([z]
                       ([h2]
                         (defeq/forall
                           (defeq/app
                             (defeq/app
                               (defeq/app
                                 (defeq/const
                                   Eq/decl
                                   (inst-expr/forall
                                     (inst-expr/sort
                                       (lvl-inst/var lvl-nth/zero))
                                     ([x]
                                       ([h]
                                         (inst-expr/forall
                                           h
                                           ([y]
                                             ([h1]
                                               (inst-expr/forall
                                                 h
                                                 ([z]
                                                   ([h2]
                                                     (inst-expr/sort
                                                       lvl-inst/zero)))))))))))
                                 h)
                               h1)
                             h2)
                           ([w] ([h3] defeq/sort-refl))))))
                   ([z]
                     ([h2]
                       (defeq/forall
                         (defeq/app
                           (defeq/app h2 h1)
                           (defeq/app
                             (defeq/app
                               (defeq/const
                                 Eq_refl/decl
                                 (inst-expr/forall
                                   (inst-expr/sort (lvl-inst/var lvl-nth/zero))
                                   ([x]
                                     ([h]
                                       (inst-expr/forall
                                         h
                                         ([y]
                                           ([h1]
                                             (inst-expr/app
                                               (inst-expr/app
                                                 (inst-expr/app
                                                   (inst-expr/const
                                                     (lvls-inst/cons
                                                       (lvl-inst/var
                                                         lvl-nth/zero)
                                                       lvls-inst/nil))
                                                   h)
                                                 h1)
                                               h1))))))))
                               h)
                             h1))
                         ([w]
                           ([h3]
                             (defeq/forall
                               h
                               ([x1]
                                 ([h4]
                                   (defeq/forall
                                     (defeq/app
                                       (defeq/app
                                         (defeq/app
                                           (defeq/const
                                             Eq/decl
                                             (inst-expr/forall
                                               (inst-expr/sort
                                                 (lvl-inst/var lvl-nth/zero))
                                               ([x]
                                                 ([h]
                                                   (inst-expr/forall
                                                     h
                                                     ([y]
                                                       ([h1]
                                                         (inst-expr/forall
                                                           h
                                                           ([z]
                                                             ([h2]
                                                               (inst-expr/sort
                                                                 lvl-inst/zero)))))))))))
                                           h)
                                         h1)
                                       h4)
                                     ([y1]
                                       ([h5]
                                         (defeq/app
                                           (defeq/app h2 h4)
                                           h5))))))))))))))))))).

Eq_rec/decl : declared "Eq.rec" (eforall (esort (lvar (lis liz))) ([x] (eforall x ([y] (eforall (eforall x ([z] (eforall (eapp (eapp (eapp (econst "Eq" (lcons (lvar (lis liz)) lnil)) x) y) z) ([w] (esort (lvar liz)))))) ([z] (eforall (eapp (eapp z y) (eapp (eapp (econst "Eq.refl" (lcons (lvar (lis liz)) lnil)) x) y)) ([w] (eforall x ([x1] (eforall (eapp (eapp (eapp (econst "Eq" (lcons (lvar (lis liz)) lnil)) x) y) x1) ([y1] (eapp (eapp z x1) y1))))))))))))) irec
   = declared/ok-irec Eq/rec-name (dkind-ok/irec Eq_rec/type-wf).

