   = (defeq/forall (defeq/const N/decl (inst-expr/sort (lvl-inst/succ lvl-inst/zero))) ([x] ([h] (defeq/forall (defeq/forall (defeq/app (defeq/const ProjDataIndex/decl (inst-expr/forall (inst-expr/const lvls-inst/nil) ([x] ([h] (inst-expr/sort lvl-inst/zero))))) h) ([y] ([h1] defeq/sort-refl))) ([y] ([h1] (defeq/forall (defeq/forall (defeq/const True/decl (inst-expr/sort lvl-inst/zero)) ([z] ([h2] (defeq/app h1 (defeq/app (defeq/app (defeq/const ProjDataIndex_mk/decl (inst-expr/forall (inst-expr/const lvls-inst/nil) ([x] ([h] (inst-expr/forall (inst-expr/const lvls-inst/nil) ([y] ([h1] (inst-expr/app (inst-expr/const lvls-inst/nil) h)))))))) h) h2))))) ([z] ([h2] (defeq/forall (defeq/app (defeq/const ProjDataIndex/decl (inst-expr/forall (inst-expr/const lvls-inst/nil) ([x] ([h] (inst-expr/sort lvl-inst/zero))))) h) ([w] ([h3] (defeq/app h1 h3))))))))))))).

