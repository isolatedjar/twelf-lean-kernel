ProjDataIndex_mk/type-wf-sort : lvl
   = (limax (lsucc lzero) (limax lzero lzero)).

ProjDataIndex_mk/type-wf : defeq (eforall (econst "N" lnil) ([x] (eforall (econst "True" lnil) ([y] (eapp (econst "ProjDataIndex" lnil) x))))) (eforall (econst "N" lnil) ([x] (eforall (econst "True" lnil) ([y] (eapp (econst "ProjDataIndex" lnil) x))))) (esort ProjDataIndex_mk/type-wf-sort)
   = (defeq/forall (defeq/const N/decl (inst-expr/sort (lvl-inst/succ lvl-inst/zero))) ([x] ([h] (defeq/forall (defeq/const True/decl (inst-expr/sort lvl-inst/zero)) ([y] ([h1] (defeq/app (defeq/const ProjDataIndex/decl (inst-expr/forall (inst-expr/const lvls-inst/nil) ([x] ([h] (inst-expr/sort lvl-inst/zero))))) h))))))).

ProjDataIndex_mk/positivity : ctor-positive "ProjDataIndex" lnil (eforall (econst "N" lnil) ([x] (eforall (econst "True" lnil) ([y] (eapp (econst "ProjDataIndex" lnil) x)))))
   = (ctor-positive/intro ([S] (eforall (econst "N" lnil) ([x] (eforall (econst "True" lnil) ([y] (eapp S x)))))) (ctor-spine/arg (strict-pos/no-occur (econst "N" lnil) (no-self-ref/const sneq/0)) ([x] ([y] (ctor-spine/arg (strict-pos/no-occur (econst "True" lnil) (no-self-ref/const sneq/1)) ([z] ([w] (ctor-spine/result (applies-self/app applies-self/refl))))))))).

