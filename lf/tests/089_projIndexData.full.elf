   = declared/ok ProjDataIndex_mk/name (dkind-ok/ctor ProjDataIndex_mk/type-wf ProjDataIndex_mk/positivity).

%% recursor ProjDataIndex.rec
ProjDataIndex_rec/type-wf-sort : lvl
   = (limax (lsucc lzero) (limax (limax lzero (lsucc (lvar liz))) (limax (limax lzero (lvar liz)) (limax lzero (lvar liz))))).

