%% def projIndexData
projIndexData/type-wf-sort : lvl
   = (limax (lsucc lzero) (limax lzero (lsucc lzero))).

projIndexData/type-wf : defeq (eforall (econst "N" lnil) ([x] (eforall (eapp (econst "ProjDataIndex" lnil) x) ([y] (econst "N" lnil))))) (eforall (econst "N" lnil) ([x] (eforall (eapp (econst "ProjDataIndex" lnil) x) ([y] (econst "N" lnil))))) (esort projIndexData/type-wf-sort)
