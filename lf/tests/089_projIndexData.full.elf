%%% Expected outcome: reject
%%% Projecting out data is not allowed, even if this data appears as an index
%%% and the recursor would allow it.
sneq/0 : string-neq "N" "ProjDataIndex".
sneq/1 : string-neq "True" "ProjDataIndex".

%% inductive N
N/type-wf-sort : lvl
   = (lsucc (lsucc lzero)).

N/type-wf : defeq (esort (lsucc lzero)) (esort (lsucc lzero)) (esort N/type-wf-sort)
   = defeq/sort-refl.

N/ends-in-sort : ends-in-sort (esort (lsucc lzero))
   = ends-in-sort/sort.

N/rec-name : name "N.rec" (is-rec-for "N").

N/name : name "N" (is-decl (esort (lsucc lzero)) indt).

N/decl : declared "N" (esort (lsucc lzero)) indt
   = declared/ok N/name (dkind-ok/indt N/type-wf N/ends-in-sort).

%% ctor N.zero (of N)
N_zero/type-wf-sort : lvl
   = (lsucc lzero).

N_zero/type-wf : defeq (econst "N" lnil) (econst "N" lnil) (esort N_zero/type-wf-sort)
   = (defeq/const N/decl (inst-expr/sort (lvl-inst/succ lvl-inst/zero))).

N_zero/positivity : ctor-positive "N" lnil (econst "N" lnil)
   = (ctor-positive/intro ([S] S) (ctor-spine/result applies-self/refl)).

N_zero/name : name "N.zero" (is-decl (econst "N" lnil) ctor).

N_zero/decl : declared "N.zero" (econst "N" lnil) ctor
   = declared/ok N_zero/name (dkind-ok/ctor N_zero/type-wf N_zero/positivity).

%% ctor N.succ (of N)
N_succ/type-wf-sort : lvl
   = (limax (lsucc lzero) (lsucc lzero)).

N_succ/type-wf : defeq (eforall (econst "N" lnil) ([x] (econst "N" lnil))) (eforall (econst "N" lnil) ([x] (econst "N" lnil))) (esort N_succ/type-wf-sort)
   = (defeq/forall (defeq/const N/decl (inst-expr/sort (lvl-inst/succ lvl-inst/zero))) ([x] ([h] (defeq/const N/decl (inst-expr/sort (lvl-inst/succ lvl-inst/zero)))))).

N_succ/positivity : ctor-positive "N" lnil (eforall (econst "N" lnil) ([x] (econst "N" lnil)))
   = (ctor-positive/intro ([S] (eforall S ([x] S))) (ctor-spine/arg (strict-pos/head applies-self/refl) ([x] ([y] (ctor-spine/result applies-self/refl))))).

N_succ/name : name "N.succ" (is-decl (eforall (econst "N" lnil) ([x] (econst "N" lnil))) ctor).

N_succ/decl : declared "N.succ" (eforall (econst "N" lnil) ([x] (econst "N" lnil))) ctor
   = declared/ok N_succ/name (dkind-ok/ctor N_succ/type-wf N_succ/positivity).

%% recursor N.rec
N_rec/type-wf-sort : lvl
   = (limax (limax (lsucc lzero) (lsucc (lvar liz))) (limax (lvar liz) (limax (limax (lsucc lzero) (limax (lvar liz) (lvar liz))) (limax (lsucc lzero) (lvar liz))))).

N_rec/type-wf : defeq (eforall (eforall (econst "N" lnil) ([x] (esort (lvar liz)))) ([x] (eforall (eapp x (econst "N.zero" lnil)) ([y] (eforall (eforall (econst "N" lnil) ([z] (eforall (eapp x z) ([w] (eapp x (eapp (econst "N.succ" lnil) z)))))) ([z] (eforall (econst "N" lnil) ([w] (eapp x w))))))))) (eforall (eforall (econst "N" lnil) ([x] (esort (lvar liz)))) ([x] (eforall (eapp x (econst "N.zero" lnil)) ([y] (eforall (eforall (econst "N" lnil) ([z] (eforall (eapp x z) ([w] (eapp x (eapp (econst "N.succ" lnil) z)))))) ([z] (eforall (econst "N" lnil) ([w] (eapp x w))))))))) (esort N_rec/type-wf-sort)
   = (defeq/forall (defeq/forall (defeq/const N/decl (inst-expr/sort (lvl-inst/succ lvl-inst/zero))) ([x] ([h] defeq/sort-refl))) ([x] ([h] (defeq/forall (defeq/app h (defeq/const N_zero/decl (inst-expr/const lvls-inst/nil))) ([y] ([h1] (defeq/forall (defeq/forall (defeq/const N/decl (inst-expr/sort (lvl-inst/succ lvl-inst/zero))) ([z] ([h2] (defeq/forall (defeq/app h h2) ([w] ([h3] (defeq/app h (defeq/app (defeq/const N_succ/decl (inst-expr/forall (inst-expr/const lvls-inst/nil) ([x] ([h] (inst-expr/const lvls-inst/nil))))) h2)))))))) ([z] ([h2] (defeq/forall (defeq/const N/decl (inst-expr/sort (lvl-inst/succ lvl-inst/zero))) ([w] ([h3] (defeq/app h h3))))))))))))).

N_rec/decl : declared "N.rec" (eforall (eforall (econst "N" lnil) ([x] (esort (lvar liz)))) ([x] (eforall (eapp x (econst "N.zero" lnil)) ([y] (eforall (eforall (econst "N" lnil) ([z] (eforall (eapp x z) ([w] (eapp x (eapp (econst "N.succ" lnil) z)))))) ([z] (eforall (econst "N" lnil) ([w] (eapp x w))))))))) irec
   = declared/ok-irec N/rec-name (dkind-ok/irec N_rec/type-wf).

%% inductive True
True/type-wf-sort : lvl
   = (lsucc lzero).

True/type-wf : defeq (esort lzero) (esort lzero) (esort True/type-wf-sort)
   = defeq/sort-refl.

True/ends-in-sort : ends-in-sort (esort lzero)
   = ends-in-sort/sort.

True/rec-name : name "True.rec" (is-rec-for "True").

True/name : name "True" (is-decl (esort lzero) indt).

True/decl : declared "True" (esort lzero) indt
   = declared/ok True/name (dkind-ok/indt True/type-wf True/ends-in-sort).

%% ctor True.intro (of True)
True_intro/type-wf-sort : lvl
   = lzero.

True_intro/type-wf : defeq (econst "True" lnil) (econst "True" lnil) (esort True_intro/type-wf-sort)
   = (defeq/const True/decl (inst-expr/sort lvl-inst/zero)).

True_intro/positivity : ctor-positive "True" lnil (econst "True" lnil)
   = (ctor-positive/intro ([S] S) (ctor-spine/result applies-self/refl)).

True_intro/name : name "True.intro" (is-decl (econst "True" lnil) ctor).

True_intro/decl : declared "True.intro" (econst "True" lnil) ctor
   = declared/ok True_intro/name (dkind-ok/ctor True_intro/type-wf True_intro/positivity).

%% recursor True.rec
True_rec/type-wf-sort : lvl
   = (limax (limax lzero (lsucc (lvar liz))) (limax (lvar liz) (limax lzero (lvar liz)))).

True_rec/type-wf : defeq (eforall (eforall (econst "True" lnil) ([x] (esort (lvar liz)))) ([x] (eforall (eapp x (econst "True.intro" lnil)) ([y] (eforall (econst "True" lnil) ([z] (eapp x z))))))) (eforall (eforall (econst "True" lnil) ([x] (esort (lvar liz)))) ([x] (eforall (eapp x (econst "True.intro" lnil)) ([y] (eforall (econst "True" lnil) ([z] (eapp x z))))))) (esort True_rec/type-wf-sort)
   = (defeq/forall (defeq/forall (defeq/const True/decl (inst-expr/sort lvl-inst/zero)) ([x] ([h] defeq/sort-refl))) ([x] ([h] (defeq/forall (defeq/app h (defeq/const True_intro/decl (inst-expr/const lvls-inst/nil))) ([y] ([h1] (defeq/forall (defeq/const True/decl (inst-expr/sort lvl-inst/zero)) ([z] ([h2] (defeq/app h h2)))))))))).

True_rec/decl : declared "True.rec" (eforall (eforall (econst "True" lnil) ([x] (esort (lvar liz)))) ([x] (eforall (eapp x (econst "True.intro" lnil)) ([y] (eforall (econst "True" lnil) ([z] (eapp x z))))))) irec
   = declared/ok-irec True/rec-name (dkind-ok/irec True_rec/type-wf).

%% inductive ProjDataIndex
ProjDataIndex/type-wf-sort : lvl
   = (limax (lsucc lzero) (lsucc lzero)).

ProjDataIndex/type-wf : defeq (eforall (econst "N" lnil) ([x] (esort lzero))) (eforall (econst "N" lnil) ([x] (esort lzero))) (esort ProjDataIndex/type-wf-sort)
   = (defeq/forall (defeq/const N/decl (inst-expr/sort (lvl-inst/succ lvl-inst/zero))) ([x] ([h] defeq/sort-refl))).

ProjDataIndex/ends-in-sort : ends-in-sort (eforall (econst "N" lnil) ([x] (esort lzero)))
   = (ends-in-sort/forall ([x] ends-in-sort/sort)).

ProjDataIndex/rec-name : name "ProjDataIndex.rec" (is-rec-for "ProjDataIndex").

ProjDataIndex/name : name "ProjDataIndex" (is-decl (eforall (econst "N" lnil) ([x] (esort lzero))) indt).

ProjDataIndex/decl : declared "ProjDataIndex" (eforall (econst "N" lnil) ([x] (esort lzero))) indt
   = declared/ok ProjDataIndex/name (dkind-ok/indt ProjDataIndex/type-wf ProjDataIndex/ends-in-sort).

