%%% Expected outcome: reject
%%% Projecting out data is not allowed, even if this data appears as an index
%%% and the recursor would allow it.
%solve nonneg_0 : 0 >= 0.

sneq/0 : string-neq "N.zero" "N.succ".
sneq/1 : string-neq "N" "ProjDataIndex".
sneq/2 : string-neq "True" "ProjDataIndex".

%% inductive N
N/type-wf-sort : lvl
   = (lsucc (lsucc lzero)).

N/type-wf : of (esort (lsucc lzero)) (esort N/type-wf-sort)
   = defeq/sort-refl.

N/ends-in-sort : ends-in-sort (esort (lsucc lzero))
   = ends-in-sort/sort.

N/rec-name : name "N.rec" (is-rec-for "N").

N/clf : count-leading-foralls (esort (lsucc lzero)) liz
   = count-leading-foralls/zero.

N/cnd : cnames-distinct (ccons "N.zero" (ccons "N.succ" cnil))
   = (cnames-distinct/cons
       (cnames-distinct/cons cnames-distinct/nil all-string-neq/nil)
       (all-string-neq/cons sneq/0 all-string-neq/nil)).

N/name : name "N" (is-decl (esort (lsucc lzero)) (indt (ccons "N.zero" (ccons "N.succ" cnil)) liz)).

N/decl : declared "N" (esort (lsucc lzero)) (indt (ccons "N.zero" (ccons "N.succ" cnil)) liz)
   = declared/ok-indt N/name N/rec-name N/clf N/cnd (dkind-ok/indt N/type-wf N/ends-in-sort).

%% ctor N.zero (of N)
N_zero/type-wf-sort : lvl
   = (lsucc lzero).

N_zero/type-wf : of (econst "N" lnil) (esort N_zero/type-wf-sort)
   = (defeq/const N/decl (inst-expr/sort (lvl-inst/succ lvl-inst/zero))).

N_zero/positivity : ctor-positive "N" lnil (econst "N" lnil)
   = (ctor-positive/intro ([S] S) (ctor-spine/result applies-self/refl)).

N_zero/eisl : ends-in-sort-with-level (esort (lsucc lzero)) (lsucc lzero)
   = ends-in-sort-with-level/sort.

N_zero/cmem : cmem "N.zero" (ccons "N.zero" (ccons "N.succ" cnil))
   = cmem/here.

N_zero/fuo : field-universes-ok-skip-params liz (econst "N" lnil) (lsucc lzero)
   = (field-universes-ok-skip-params/start
       (field-universes-ok/done not-forall/const)).

N_zero/name : name "N.zero" (is-decl (econst "N" lnil) (ctor "N" liz)).

N_zero/decl : declared "N.zero" (econst "N" lnil) (ctor "N" liz)
   = declared/ok-ctor N_zero/name N/name N_zero/cmem N_zero/eisl N_zero/fuo (dkind-ok/ctor N_zero/type-wf N_zero/positivity).

%% ctor N.succ (of N)
N_succ/type-wf-sort : lvl
   = (limax (lsucc lzero) (lsucc lzero)).

N_succ/type-wf : of (eforall (econst "N" lnil) ([x] (econst "N" lnil))) (esort N_succ/type-wf-sort)
   = (defeq/forall
       (defeq/const N/decl (inst-expr/sort (lvl-inst/succ lvl-inst/zero)))
       ([x]
         ([h]
           (defeq/const
             N/decl
             (inst-expr/sort (lvl-inst/succ lvl-inst/zero)))))).

N_succ/positivity : ctor-positive "N" lnil (eforall (econst "N" lnil) ([x] (econst "N" lnil)))
   = (ctor-positive/intro ([S] (eforall S ([x] S))) (ctor-spine/arg
       (strict-pos/head applies-self/refl)
       ([x] ([y] (ctor-spine/result applies-self/refl))))).

N_succ/eisl : ends-in-sort-with-level (esort (lsucc lzero)) (lsucc lzero)
   = ends-in-sort-with-level/sort.

N_succ/cmem : cmem "N.succ" (ccons "N.zero" (ccons "N.succ" cnil))
   = (cmem/there cmem/here).

N_succ/fuo : field-universes-ok-skip-params liz (eforall (econst "N" lnil) ([x] (econst "N" lnil))) (lsucc lzero)
   = (field-universes-ok-skip-params/start
       (field-universes-ok/forall
         (defeq/const N/decl (inst-expr/sort (lvl-inst/succ lvl-inst/zero)))
         (mleq/self nonneg_0)
         ([x] ([h] (field-universes-ok/done not-forall/const))))).

N_succ/name : name "N.succ" (is-decl (eforall (econst "N" lnil) ([x] (econst "N" lnil))) (ctor "N" (lis liz))).

N_succ/decl : declared "N.succ" (eforall (econst "N" lnil) ([x] (econst "N" lnil))) (ctor "N" (lis liz))
   = declared/ok-ctor N_succ/name N/name N_succ/cmem N_succ/eisl N_succ/fuo (dkind-ok/ctor N_succ/type-wf N_succ/positivity).

%% recursor N.rec
N_rec/type-wf-sort : lvl
   = (limax
       (limax (lsucc lzero) (lsucc (lvar liz)))
       (limax
         (lvar liz)
         (limax
           (limax (lsucc lzero) (limax (lvar liz) (lvar liz)))
           (limax (lsucc lzero) (lvar liz))))).

N_rec/type-wf : of
  (eforall (eforall (econst "N" lnil) ([x] (esort (lvar liz))))
    ([x]
      (eforall (eapp x (econst "N.zero" lnil))
        ([y] (eforall (eforall (econst "N" lnil) ([z] (eforall (eapp x z) ([w] (eapp x (eapp (econst "N.succ" lnil) z)))))) ([z] (eforall (econst "N" lnil) ([w] (eapp x w)))))))))
  (esort N_rec/type-wf-sort)
   = (defeq/forall
       (defeq/forall
         (defeq/const N/decl (inst-expr/sort (lvl-inst/succ lvl-inst/zero)))
         ([x] ([h] defeq/sort-refl)))
       ([x]
         ([h]
           (defeq/forall
             (defeq/app
               h
               (defeq/const N_zero/decl (inst-expr/const lvls-inst/nil)))
             ([y]
               ([h1]
                 (defeq/forall
                   (defeq/forall
                     (defeq/const
                       N/decl
                       (inst-expr/sort (lvl-inst/succ lvl-inst/zero)))
                     ([z]
                       ([h2]
                         (defeq/forall
                           (defeq/app h h2)
                           ([w]
                             ([h3]
                               (defeq/app
                                 h
                                 (defeq/app
                                   (defeq/const
                                     N_succ/decl
                                     (inst-expr/forall
                                       (inst-expr/const lvls-inst/nil)
                                       ([x]
                                         ([h]
                                           (inst-expr/const lvls-inst/nil)))))
                                   h2))))))))
                   ([z]
                     ([h2]
                       (defeq/forall
                         (defeq/const
                           N/decl
                           (inst-expr/sort (lvl-inst/succ lvl-inst/zero)))
                         ([w] ([h3] (defeq/app h h3))))))))))))).

N_rec/decl : declared "N.rec"
  (eforall (eforall (econst "N" lnil) ([x] (esort (lvar liz))))
    ([x]
      (eforall (eapp x (econst "N.zero" lnil))
        ([y] (eforall (eforall (econst "N" lnil) ([z] (eforall (eapp x z) ([w] (eapp x (eapp (econst "N.succ" lnil) z)))))) ([z] (eforall (econst "N" lnil) ([w] (eapp x w)))))))))
  (irec "N")
   = declared/ok-irec N/rec-name (dkind-ok/irec N_rec/type-wf).

%% inductive True
True/type-wf-sort : lvl
   = (lsucc lzero).

True/type-wf : of (esort lzero) (esort True/type-wf-sort)
   = defeq/sort-refl.

True/ends-in-sort : ends-in-sort (esort lzero)
   = ends-in-sort/sort.

True/rec-name : name "True.rec" (is-rec-for "True").

True/clf : count-leading-foralls (esort lzero) liz
   = count-leading-foralls/zero.

True/cnd : cnames-distinct (ccons "True.intro" cnil)
   = (cnames-distinct/cons cnames-distinct/nil all-string-neq/nil).

True/name : name "True" (is-decl (esort lzero) (indt (ccons "True.intro" cnil) liz)).

True/decl : declared "True" (esort lzero) (indt (ccons "True.intro" cnil) liz)
   = declared/ok-indt True/name True/rec-name True/clf True/cnd (dkind-ok/indt True/type-wf True/ends-in-sort).

%% ctor True.intro (of True)
True_intro/type-wf-sort : lvl
   = lzero.

True_intro/type-wf : of (econst "True" lnil) (esort True_intro/type-wf-sort)
   = (defeq/const True/decl (inst-expr/sort lvl-inst/zero)).

True_intro/positivity : ctor-positive "True" lnil (econst "True" lnil)
   = (ctor-positive/intro ([S] S) (ctor-spine/result applies-self/refl)).

True_intro/eisl : ends-in-sort-with-level (esort lzero) lzero
   = ends-in-sort-with-level/sort.

True_intro/cmem : cmem "True.intro" (ccons "True.intro" cnil)
   = cmem/here.

True_intro/fuo : field-universes-ok-skip-params liz (econst "True" lnil) lzero
   = (field-universes-ok-skip-params/start
       (field-universes-ok/done not-forall/const)).

True_intro/name : name "True.intro" (is-decl (econst "True" lnil) (ctor "True" liz)).

True_intro/decl : declared "True.intro" (econst "True" lnil) (ctor "True" liz)
   = declared/ok-ctor True_intro/name True/name True_intro/cmem True_intro/eisl True_intro/fuo (dkind-ok/ctor True_intro/type-wf True_intro/positivity).

%% recursor True.rec
True_rec/type-wf-sort : lvl
   = (limax
       (limax lzero (lsucc (lvar liz)))
       (limax (lvar liz) (limax lzero (lvar liz)))).

True_rec/type-wf : of
  (eforall (eforall (econst "True" lnil) ([x] (esort (lvar liz)))) ([x] (eforall (eapp x (econst "True.intro" lnil)) ([y] (eforall (econst "True" lnil) ([z] (eapp x z)))))))
  (esort True_rec/type-wf-sort)
   = (defeq/forall
       (defeq/forall
         (defeq/const True/decl (inst-expr/sort lvl-inst/zero))
         ([x] ([h] defeq/sort-refl)))
       ([x]
         ([h]
           (defeq/forall
             (defeq/app
               h
               (defeq/const True_intro/decl (inst-expr/const lvls-inst/nil)))
             ([y]
               ([h1]
                 (defeq/forall
                   (defeq/const True/decl (inst-expr/sort lvl-inst/zero))
                   ([z] ([h2] (defeq/app h h2)))))))))).

True_rec/decl : declared "True.rec"
  (eforall (eforall (econst "True" lnil) ([x] (esort (lvar liz)))) ([x] (eforall (eapp x (econst "True.intro" lnil)) ([y] (eforall (econst "True" lnil) ([z] (eapp x z)))))))
  (irec "True")
   = declared/ok-irec True/rec-name (dkind-ok/irec True_rec/type-wf).

%% inductive ProjDataIndex
ProjDataIndex/type-wf-sort : lvl
   = (limax (lsucc lzero) (lsucc lzero)).

ProjDataIndex/type-wf : of (eforall (econst "N" lnil) ([x] (esort lzero))) (esort ProjDataIndex/type-wf-sort)
   = (defeq/forall
       (defeq/const N/decl (inst-expr/sort (lvl-inst/succ lvl-inst/zero)))
       ([x] ([h] defeq/sort-refl))).

ProjDataIndex/ends-in-sort : ends-in-sort (eforall (econst "N" lnil) ([x] (esort lzero)))
   = (ends-in-sort/forall ([x] ends-in-sort/sort)).

ProjDataIndex/rec-name : name "ProjDataIndex.rec" (is-rec-for "ProjDataIndex").

ProjDataIndex/clf : count-leading-foralls (eforall (econst "N" lnil) ([x] (esort lzero))) (lis liz)
   = (count-leading-foralls/succ ([x] count-leading-foralls/zero)).

ProjDataIndex/cnd : cnames-distinct (ccons "ProjDataIndex.mk" cnil)
   = (cnames-distinct/cons cnames-distinct/nil all-string-neq/nil).

ProjDataIndex/name : name "ProjDataIndex" (is-decl (eforall (econst "N" lnil) ([x] (esort lzero))) (indt (ccons "ProjDataIndex.mk" cnil) (lis liz))).

ProjDataIndex/decl : declared "ProjDataIndex" (eforall (econst "N" lnil) ([x] (esort lzero))) (indt (ccons "ProjDataIndex.mk" cnil) (lis liz))
   = declared/ok-indt ProjDataIndex/name ProjDataIndex/rec-name ProjDataIndex/clf ProjDataIndex/cnd (dkind-ok/indt ProjDataIndex/type-wf ProjDataIndex/ends-in-sort).

%% ctor ProjDataIndex.mk (of ProjDataIndex)
ProjDataIndex_mk/type-wf-sort : lvl
   = (limax (lsucc lzero) (limax lzero lzero)).

ProjDataIndex_mk/type-wf : of (eforall (econst "N" lnil) ([x] (eforall (econst "True" lnil) ([y] (eapp (econst "ProjDataIndex" lnil) x))))) (esort ProjDataIndex_mk/type-wf-sort)
   = (defeq/forall
       (defeq/const N/decl (inst-expr/sort (lvl-inst/succ lvl-inst/zero)))
       ([x]
         ([h]
           (defeq/forall
             (defeq/const True/decl (inst-expr/sort lvl-inst/zero))
             ([y]
               ([h1]
                 (defeq/app
                   (defeq/const
                     ProjDataIndex/decl
                     (inst-expr/forall
                       (inst-expr/const lvls-inst/nil)
                       ([x] ([h] (inst-expr/sort lvl-inst/zero)))))
                   h))))))).

ProjDataIndex_mk/positivity : ctor-positive "ProjDataIndex" lnil (eforall (econst "N" lnil) ([x] (eforall (econst "True" lnil) ([y] (eapp (econst "ProjDataIndex" lnil) x)))))
   = (ctor-positive/intro ([S] (eforall (econst "N" lnil) ([x] (eforall (econst "True" lnil) ([y] (eapp S x)))))) (ctor-spine/arg
       (strict-pos/no-occur (econst "N" lnil) (no-self-ref/const sneq/1))
       ([x]
         ([y]
           (ctor-spine/arg
             (strict-pos/no-occur
               (econst "True" lnil)
               (no-self-ref/const sneq/2))
             ([z]
               ([w]
                 (ctor-spine/result (applies-self/app applies-self/refl))))))))).

ProjDataIndex_mk/eisl : ends-in-sort-with-level (eforall (econst "N" lnil) ([x] (esort lzero))) lzero
   = (ends-in-sort-with-level/forall ([x] ends-in-sort-with-level/sort)).

ProjDataIndex_mk/cmem : cmem "ProjDataIndex.mk" (ccons "ProjDataIndex.mk" cnil)
   = cmem/here.

ProjDataIndex_mk/fuo : field-universes-ok-skip-params (lis liz) (eforall (econst "N" lnil) ([x] (eforall (econst "True" lnil) ([y] (eapp (econst "ProjDataIndex" lnil) x))))) lzero
   = (field-universes-ok-skip-params/skip
       ([x]
         ([h]
           (field-universes-ok-skip-params/start
             (field-universes-ok/forall
               (defeq/const True/decl (inst-expr/sort lvl-inst/zero))
               (mleq/self nonneg_0)
               ([y] ([h1] (field-universes-ok/done not-forall/app)))))))).

ProjDataIndex_mk/name : name "ProjDataIndex.mk" (is-decl (eforall (econst "N" lnil) ([x] (eforall (econst "True" lnil) ([y] (eapp (econst "ProjDataIndex" lnil) x))))) (ctor "ProjDataIndex" liz)).

ProjDataIndex_mk/decl : declared "ProjDataIndex.mk" (eforall (econst "N" lnil) ([x] (eforall (econst "True" lnil) ([y] (eapp (econst "ProjDataIndex" lnil) x))))) (ctor "ProjDataIndex" liz)
   = declared/ok-ctor ProjDataIndex_mk/name ProjDataIndex/name ProjDataIndex_mk/cmem ProjDataIndex_mk/eisl ProjDataIndex_mk/fuo (dkind-ok/ctor ProjDataIndex_mk/type-wf ProjDataIndex_mk/positivity).

%% recursor ProjDataIndex.rec
ProjDataIndex_rec/type-wf-sort : lvl
   = (limax
       (lsucc lzero)
       (limax
         (limax lzero (lsucc (lvar liz)))
         (limax (limax lzero (lvar liz)) (limax lzero (lvar liz))))).

ProjDataIndex_rec/type-wf : of
  (eforall (econst "N" lnil)
    ([x]
      (eforall (eforall (eapp (econst "ProjDataIndex" lnil) x) ([y] (esort (lvar liz))))
        ([y] (eforall (eforall (econst "True" lnil) ([z] (eapp y (eapp (eapp (econst "ProjDataIndex.mk" lnil) x) z)))) ([z] (eforall (eapp (econst "ProjDataIndex" lnil) x) ([w] (eapp y w)))))))))
  (esort ProjDataIndex_rec/type-wf-sort)
   = (defeq/forall
       (defeq/const N/decl (inst-expr/sort (lvl-inst/succ lvl-inst/zero)))
       ([x]
         ([h]
           (defeq/forall
             (defeq/forall
               (defeq/app
                 (defeq/const
                   ProjDataIndex/decl
                   (inst-expr/forall
                     (inst-expr/const lvls-inst/nil)
                     ([x] ([h] (inst-expr/sort lvl-inst/zero)))))
                 h)
               ([y] ([h1] defeq/sort-refl)))
             ([y]
               ([h1]
                 (defeq/forall
                   (defeq/forall
                     (defeq/const True/decl (inst-expr/sort lvl-inst/zero))
                     ([z]
                       ([h2]
                         (defeq/app
                           h1
                           (defeq/app
                             (defeq/app
                               (defeq/const
                                 ProjDataIndex_mk/decl
                                 (inst-expr/forall
                                   (inst-expr/const lvls-inst/nil)
                                   ([x]
                                     ([h]
                                       (inst-expr/forall
                                         (inst-expr/const lvls-inst/nil)
                                         ([y]
                                           ([h1]
                                             (inst-expr/app
                                               (inst-expr/const lvls-inst/nil)
                                               h))))))))
                               h)
                             h2)))))
                   ([z]
                     ([h2]
                       (defeq/forall
                         (defeq/app
                           (defeq/const
                             ProjDataIndex/decl
                             (inst-expr/forall
                               (inst-expr/const lvls-inst/nil)
                               ([x] ([h] (inst-expr/sort lvl-inst/zero)))))
                           h)
                         ([w] ([h3] (defeq/app h1 h3))))))))))))).

ProjDataIndex_rec/decl : declared "ProjDataIndex.rec"
  (eforall (econst "N" lnil)
    ([x]
      (eforall (eforall (eapp (econst "ProjDataIndex" lnil) x) ([y] (esort (lvar liz))))
        ([y] (eforall (eforall (econst "True" lnil) ([z] (eapp y (eapp (eapp (econst "ProjDataIndex.mk" lnil) x) z)))) ([z] (eforall (eapp (econst "ProjDataIndex" lnil) x) ([w] (eapp y w)))))))))
  (irec "ProjDataIndex")
   = declared/ok-irec ProjDataIndex/rec-name (dkind-ok/irec ProjDataIndex_rec/type-wf).

%% def projIndexData
projIndexData/type-wf-sort : lvl
   = (limax (lsucc lzero) (limax lzero (lsucc lzero))).

projIndexData/type-wf : of (eforall (econst "N" lnil) ([x] (eforall (eapp (econst "ProjDataIndex" lnil) x) ([y] (econst "N" lnil))))) (esort projIndexData/type-wf-sort)
   = (defeq/forall
       (defeq/const N/decl (inst-expr/sort (lvl-inst/succ lvl-inst/zero)))
       ([x]
         ([h]
           (defeq/forall
             (defeq/app
               (defeq/const
                 ProjDataIndex/decl
                 (inst-expr/forall
                   (inst-expr/const lvls-inst/nil)
                   ([x] ([h] (inst-expr/sort lvl-inst/zero)))))
               h)
             ([y]
               ([h1]
                 (defeq/const
                   N/decl
                   (inst-expr/sort (lvl-inst/succ lvl-inst/zero))))))))).

%%% HOLE
projIndexData/value-typed : of
  (elam (econst "N" lnil) ([x] (elam (eapp (econst "ProjDataIndex" lnil) x) ([y] (eproj "PropStructure" 0 y)))))
  (eforall (econst "N" lnil) ([x] (eforall (eapp (econst "ProjDataIndex" lnil) x) ([y] (econst "N" lnil))))).

projIndexData/name : name "projIndexData" (is-decl
  (eforall (econst "N" lnil) ([x] (eforall (eapp (econst "ProjDataIndex" lnil) x) ([y] (econst "N" lnil)))))
  (defn (elam (econst "N" lnil) ([x] (elam (eapp (econst "ProjDataIndex" lnil) x) ([y] (eproj "PropStructure" 0 y))))))).

projIndexData/decl : declared "projIndexData"
  (eforall (econst "N" lnil) ([x] (eforall (eapp (econst "ProjDataIndex" lnil) x) ([y] (econst "N" lnil)))))
  (defn (elam (econst "N" lnil) ([x] (elam (eapp (econst "ProjDataIndex" lnil) x) ([y] (eproj "PropStructure" 0 y))))))
   = declared/ok projIndexData/name dkind-non-inductive/defn (dkind-ok/defn projIndexData/type-wf projIndexData/value-typed).
