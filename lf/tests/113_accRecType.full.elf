Acc_intro/positivity : ctor-positive "Acc" (lcons (lvar liz) lnil) (eforall (esort (lvar liz)) ([x] (eforall (eforall x ([y] (eforall x ([z] (esort lzero))))) ([y] (eforall x ([z] (eforall (eforall x ([w] (eforall (eapp (eapp y w) z) ([x1] (eapp (eapp (eapp (econst "Acc" (lcons (lvar liz) lnil)) x) y) w))))) ([w] (eapp (eapp (eapp (econst "Acc" (lcons (lvar liz) lnil)) x) y) z)))))))))
   = (ctor-positive/intro ([S] (eforall (esort (lvar liz)) ([x] (eforall (eforall x ([y] (eforall x ([z] (esort lzero))))) ([y] (eforall x ([z] (eforall (eforall x ([w] (eforall (eapp (eapp y w) z) ([x1] (eapp (eapp (eapp S x) y) w))))) ([w] (eapp (eapp (eapp S x) y) z)))))))))) (ctor-spine/arg
       (strict-pos/no-occur (esort (lvar liz)) no-self-ref/sort)
       ([x]
         ([y]
           (ctor-spine/arg
             (strict-pos/no-occur
               (eforall x ([y] (eforall x ([z] (esort lzero)))))
               (no-self-ref/forall
                 y
                 ([z]
                   ([w]
                     (no-self-ref/forall y ([x1] ([y1] no-self-ref/sort)))))))
             ([z]
               ([w]
                 (ctor-spine/arg
                   (strict-pos/no-occur x y)
                   ([x1]
                     ([y1]
                       (ctor-spine/arg
                         (strict-pos/forall
                           x
                           y
                           ([z1]
                             ([w1]
                               (strict-pos/forall
                                 (eapp (eapp z z1) x1)
                                 (no-self-ref/app (no-self-ref/app w w1) y1)
                                 ([x2]
                                   ([y2]
                                     (strict-pos/head
                                       (applies-self/app
                                         (applies-self/app
                                           (applies-self/app
                                             applies-self/refl))))))))))
                         ([z1]
                           ([w1]
                             (ctor-spine/result
                               (applies-self/app
                                 (applies-self/app
                                   (applies-self/app
                                     applies-self/refl))))))))))))))))).

Acc_intro/eisl : ends-in-sort-with-level (eforall (esort (lvar liz)) ([x] (eforall (eforall x ([y] (eforall x ([z] (esort lzero))))) ([y] (eforall x ([z] (esort lzero))))))) lzero
