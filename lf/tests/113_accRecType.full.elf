             ([w]
               ([v]
                 (ctor-spine/arg
                   (strict-pos/no-occur x y)
                   ([x1]
                     ([y1]
                       (ctor-spine/arg
                         (strict-pos/forall
                           x
                           y
                           ([w1]
                             ([v1]
                               (strict-pos/forall
                                 (eapp (eapp w w1) x1)
                                 (no-self-ref/app (no-self-ref/app v v1) y1)
                                 ([x2]
                                   ([y2]
                                     (strict-pos/head
                                       (applies-self/app
                                         (applies-self/app
                                           (applies-self/app
                                             applies-self/refl))))))))))
                         ([w1]
