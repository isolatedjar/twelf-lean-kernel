%%% Expected outcome: reject
%%% The name of the recursor for `misnamed_rec` must be `misnamed_rec.rec`:
%%% another name (like `misnamed_rec.invalid_rec`) should be rejected.
%% inductive misnamed_rec
misnamed_rec/type-wf-sort : lvl
   = (lsucc (lsucc lzero)).

misnamed_rec/type-wf : of (esort (lsucc lzero)) (esort misnamed_rec/type-wf-sort)
   = defeq/sort-refl.

misnamed_rec/ends-in-sort : ends-in-sort (esort (lsucc lzero))
   = ends-in-sort/sort.

misnamed_rec/rec-name : name "misnamed_rec.rec" (is-rec-for "misnamed_rec").

misnamed_rec/name : name "misnamed_rec" (is-decl (esort (lsucc lzero)) indt).

misnamed_rec/decl : declared "misnamed_rec" (esort (lsucc lzero)) indt
   = declared/ok misnamed_rec/name (dkind-ok/indt misnamed_rec/type-wf misnamed_rec/ends-in-sort).

%% ctor misnamed_rec.mk (of misnamed_rec)
misnamed_rec_mk/type-wf-sort : lvl
   = (lsucc lzero).

misnamed_rec_mk/type-wf : of (econst "misnamed_rec" lnil) (esort misnamed_rec_mk/type-wf-sort)
   = (defeq/const
       misnamed_rec/decl
       (inst-expr/sort (lvl-inst/succ lvl-inst/zero))).

misnamed_rec_mk/positivity : ctor-positive "misnamed_rec" lnil (econst "misnamed_rec" lnil)
   = (ctor-positive/intro ([S] S) (ctor-spine/result applies-self/refl)).

misnamed_rec_mk/name : name "misnamed_rec.mk" (is-decl (econst "misnamed_rec" lnil) ctor).

misnamed_rec_mk/decl : declared "misnamed_rec.mk" (econst "misnamed_rec" lnil) ctor
   = declared/ok misnamed_rec_mk/name (dkind-ok/ctor misnamed_rec_mk/type-wf misnamed_rec_mk/positivity).

%% recursor misnamed_rec.not_rec
misnamed_rec_not_rec/type-wf-sort : lvl
   = (limax
       (limax (lsucc lzero) (lsucc (lvar liz)))
       (limax (lvar liz) (limax (lsucc lzero) (lvar liz)))).

misnamed_rec_not_rec/type-wf : of (eforall (eforall (econst "misnamed_rec" lnil) ([x] (esort (lvar liz)))) ([x] (eforall (eapp x (econst "misnamed_rec.mk" lnil)) ([y] (eforall (econst "misnamed_rec" lnil) ([z] (eapp x z))))))) (esort misnamed_rec_not_rec/type-wf-sort)
   = (defeq/forall
       (defeq/forall
         (defeq/const
           misnamed_rec/decl
           (inst-expr/sort (lvl-inst/succ lvl-inst/zero)))
         ([x] ([h] defeq/sort-refl)))
       ([x]
         ([h]
           (defeq/forall
             (defeq/app
               h
               (defeq/const
                 misnamed_rec_mk/decl
                 (inst-expr/const lvls-inst/nil)))
             ([y]
               ([h1]
                 (defeq/forall
                   (defeq/const
                     misnamed_rec/decl
                     (inst-expr/sort (lvl-inst/succ lvl-inst/zero)))
                   ([z] ([h2] (defeq/app h h2)))))))))).

%%% HOLE: recursor misnamed_rec.not_rec — name does not follow <inductive>.rec convention
misnamed_rec_not_rec/decl : declared "misnamed_rec.not_rec" (eforall (eforall (econst "misnamed_rec" lnil) ([x] (esort (lvar liz)))) ([x] (eforall (eapp x (econst "misnamed_rec.mk" lnil)) ([y] (eforall (econst "misnamed_rec" lnil) ([z] (eapp x z))))))) irec.
