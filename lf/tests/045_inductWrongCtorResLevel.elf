%%% Expected outcome: reject
%%% An inductive with a constructor with wrong level parameters in result (they are swapped)
%% inductive inductWrongCtorResLevel
%abbrev inductWrongCtorResLevel/type-wf :
   {u1 : lvl} {u2 : lvl} defeq (eforall (esort lzero) ([x] (eforall (esort lzero) ([y] (esort (lsucc lzero)))))) (eforall (esort lzero) ([x] (eforall (esort lzero) ([y] (esort (lsucc lzero)))))) (esort (limax (lsucc lzero) (limax (lsucc lzero) (lsucc (lsucc lzero)))))
   = [u1] [u2] (defeq/forall (defeq/sort-refl-at lzero) ([x] [y] (defeq/forall (defeq/sort-refl-at lzero) ([z] [w] (defeq/sort-refl-at (lsucc lzero)))))).

inductWrongCtorResLevel/decl : {u1 : lvl} {u2 : lvl} declared "inductWrongCtorResLevel" (lcons u1 (lcons u2 lnil))
   (eforall (esort lzero) ([x] (eforall (esort lzero) ([y] (esort (lsucc lzero))))))
   indt
   (dkind-ok/indt (inductWrongCtorResLevel/type-wf u1 u2)).

%% inductive ctor inductWrongCtorResLevel.mk
inductWrongCtorResLevel_mk/type-wf :
   {u1 : lvl} {u2 : lvl} defeq (eforall (esort lzero) ([x] (eforall (esort lzero) ([y] (eapp (eapp (econst "inductWrongCtorResLevel" (lcons u2 (lcons u1 lnil))) x) y))))) (eforall (esort lzero) ([x] (eforall (esort lzero) ([y] (eapp (eapp (econst "inductWrongCtorResLevel" (lcons u2 (lcons u1 lnil))) x) y))))) (esort (limax (lsucc lzero) (limax (lsucc lzero) (lsucc lzero))))
   = [u1] [u2] (defeq/forall (defeq/sort-refl-at lzero) ([x] [y] (defeq/forall (defeq/sort-refl-at lzero) ([z] [w] (defeq/app (defeq/app (defeq/const (inductWrongCtorResLevel/decl u2 u1)) y) w))))).

inductWrongCtorResLevel_mk/decl : {u1 : lvl} {u2 : lvl} declared "inductWrongCtorResLevel.mk" (lcons u1 (lcons u2 lnil))
   (eforall (esort lzero) ([x] (eforall (esort lzero) ([y] (eapp (eapp (econst "inductWrongCtorResLevel" (lcons u2 (lcons u1 lnil))) x) y)))))
   ctor
   (dkind-ok/ctor (inductWrongCtorResLevel_mk/type-wf u1 u2)).

%% inductive recursor inductWrongCtorResLevel.rec
inductWrongCtorResLevel_rec/type-wf :
   defeq (esort lzero) (esort lzero) (esort (lsucc lzero))
   = (defeq/sort-refl-at lzero).

inductWrongCtorResLevel_rec/decl : declared "inductWrongCtorResLevel.rec" lnil
   (esort lzero)
   irec
   (dkind-ok/irec inductWrongCtorResLevel_rec/type-wf).

%mode declared +N +LS -T -DK -W.
%worlds () (declared _ _ _ _ _).
%unique declared +N +LS -1T -1DK *W.
