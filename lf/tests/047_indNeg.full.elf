%%% Expected outcome: reject
%%% The classic example of an inductive with negative recursive occurrence
%solve nonneg_0 : 0 >= 0.

%% inductive indNeg
indNeg/type-wf-sort : lvl
   = (lsucc (lsucc lzero)).

indNeg/type-wf : of (esort (lsucc lzero)) (esort indNeg/type-wf-sort)
   = defeq/sort-refl.

indNeg/ends-in-sort : ends-in-sort (esort (lsucc lzero))
   = ends-in-sort/sort.

indNeg/rec-name : name "indNeg.rec" (is-rec-for "indNeg").

indNeg/eisl : ends-in-sort-with-level (esort (lsucc lzero)) (lsucc lzero)
   = ends-in-sort-with-level/sort.

indNeg/clf : count-leading-foralls (esort (lsucc lzero)) liz
   = count-leading-foralls/zero.

indNeg/cnd : cnames-distinct (ccons "indNeg.mk" cnil)
   = (cnames-distinct/cons cnames-distinct/nil all-string-neq/nil).

indNeg/name : name "indNeg" (is-decl (esort (lsucc lzero)) (indt (ccons "indNeg.mk" cnil) liz)).

indNeg/decl : declared "indNeg" (esort (lsucc lzero)) (indt (ccons "indNeg.mk" cnil) liz)
   = declared/ok-indt indNeg/name indNeg/rec-name indNeg/clf indNeg/cnd (dkind-ok/indt indNeg/type-wf indNeg/ends-in-sort).

%% ctor indNeg.mk (of indNeg)
indNeg_mk/type-wf-sort : lvl
   = (limax (limax (lsucc lzero) (lsucc lzero)) (lsucc lzero)).

indNeg_mk/type-wf : of (eforall (eforall (econst "indNeg" lnil) ([x] (econst "indNeg" lnil))) ([x] (econst "indNeg" lnil))) (esort indNeg_mk/type-wf-sort)
   = (defeq/forall
       (defeq/forall
         (defeq/const
           indNeg/decl
           (inst-expr/sort (lvl-inst/succ lvl-inst/zero)))
         ([x]
           ([h]
             (defeq/const
               indNeg/decl
               (inst-expr/sort (lvl-inst/succ lvl-inst/zero))))))
       ([x]
         ([h]
           (defeq/const
             indNeg/decl
             (inst-expr/sort (lvl-inst/succ lvl-inst/zero)))))).

%%% HOLE
indNeg_mk/positivity : ctor-positive "indNeg" lnil (eforall (eforall (econst "indNeg" lnil) ([x] (econst "indNeg" lnil))) ([x] (econst "indNeg" lnil))).

indNeg_mk/cmem : cmem "indNeg.mk" (ccons "indNeg.mk" cnil)
   = cmem/here.

indNeg_mk/fuo : field-universes-ok-skip-params liz (eforall (eforall (econst "indNeg" lnil) ([x] (econst "indNeg" lnil))) ([x] (econst "indNeg" lnil))) (lsucc lzero)
   = (field-universes-ok-skip-params/start
       (field-universes-ok/forall
         (defeq/forall
           (defeq/const
             indNeg/decl
             (inst-expr/sort (lvl-inst/succ lvl-inst/zero)))
           ([x]
             ([h]
               (defeq/const
                 indNeg/decl
                 (inst-expr/sort (lvl-inst/succ lvl-inst/zero))))))
         (mleq/imax-lsL
           (mleq/sR
             (mleq/maxL
               (mleq/sL (mleq/self nonneg_0))
               (mleq/sL (mleq/self nonneg_0)))))
         ([x] ([h] (field-universes-ok/done not-forall/const))))).

indNeg_mk/name : name "indNeg.mk" (is-decl (eforall (eforall (econst "indNeg" lnil) ([x] (econst "indNeg" lnil))) ([x] (econst "indNeg" lnil))) (ctor "indNeg" liz)).

indNeg_mk/decl : declared "indNeg.mk" (eforall (eforall (econst "indNeg" lnil) ([x] (econst "indNeg" lnil))) ([x] (econst "indNeg" lnil))) (ctor "indNeg" liz)
   = declared/ok-ctor indNeg_mk/name indNeg/name indNeg_mk/cmem indNeg/eisl indNeg_mk/fuo (dkind-ok/ctor indNeg_mk/type-wf indNeg_mk/positivity).

%% recursor indNeg.rec
indNeg_rec/type-wf-sort : lvl
   = (lsucc lzero).

indNeg_rec/type-wf : of (esort lzero) (esort indNeg_rec/type-wf-sort)
   = defeq/sort-refl.

%%% HOLE: recursor indNeg.rec — non-enum shape (parametric/indexed inductive, or ctor with fields) — §3.1 canonical-schema only handles plain enums in phase 1
indNeg_rec/decl : declared "indNeg.rec" (esort lzero) (irec "indNeg").
