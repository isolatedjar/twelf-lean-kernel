%%% Expected outcome: reject
%%% The classic example of an inductive with negative recursive occurrence
%% inductive indNeg
indNeg/type-wf : of (esort (lsucc lzero)) (esort (lsucc (lsucc lzero)))
   = defeq/sort-refl.

indNeg/ends-in-sort : ends-in-sort (esort (lsucc lzero))
   = ends-in-sort/sort.

indNeg/rec-name : name "indNeg.rec" (is-rec-for "indNeg").

indNeg/eisl : ends-in-sort-with-level (esort (lsucc lzero)) (lsucc lzero)
   = ends-in-sort-with-level/sort.

indNeg/cnd : cnames-distinct (ccons "indNeg.mk" cnil)
   = (cnames-distinct/cons cnames-distinct/nil all-string-neq/nil).

indNeg/name : name "indNeg" (is-decl (esort (lsucc lzero)) (indt (ccons "indNeg.mk" cnil) z)).

indNeg/decl : declared "indNeg" (esort (lsucc lzero)) (indt (ccons "indNeg.mk" cnil) z)
   = declared/ok-indt indNeg/name indNeg/rec-name indNeg/cnd (dkind-ok/indt indNeg/type-wf indNeg/ends-in-sort).

%% ctor indNeg.mk (of indNeg)
indNeg_mk/type-wf : of (eforall (eforall (econst "indNeg" lnil) ([x] (econst "indNeg" lnil))) ([x] (econst "indNeg" lnil))) (esort (limax (limax (lsucc lzero) (lsucc lzero)) (lsucc lzero)))
   = (defeq/forall
       (defeq/forall
         (defeq/const
           indNeg/decl
           (inst-expr/sort (inst-lvl/succ inst-lvl/zero)))
         ([x]
           ([h]
             (defeq/const
               indNeg/decl
               (inst-expr/sort (inst-lvl/succ inst-lvl/zero))))))
       ([x]
         ([h]
           (defeq/const
             indNeg/decl
             (inst-expr/sort (inst-lvl/succ inst-lvl/zero)))))).

%%% HOLE
indNeg_mk/positivity : ctor-positive "indNeg" lnil (eforall (eforall (econst "indNeg" lnil) ([x] (econst "indNeg" lnil))) ([x] (econst "indNeg" lnil))).

indNeg_mk/cmem : cmem "indNeg.mk" (ccons "indNeg.mk" cnil)
   = cmem/here.

indNeg_mk/fuo : field-universes-ok (eforall (eforall (econst "indNeg" lnil) ([x] (econst "indNeg" lnil))) ([x] (econst "indNeg" lnil))) (lsucc lzero)
   = (field-universes-ok/forall
       (defeq/forall
         (defeq/const
           indNeg/decl
           (inst-expr/sort (inst-lvl/succ inst-lvl/zero)))
         ([x]
           ([h]
             (defeq/const
               indNeg/decl
               (inst-expr/sort (inst-lvl/succ inst-lvl/zero))))))
       (leq-lvl/imaxLs
         (leq-lvl/sR
           (leq-lvl/maxL
             (leq-lvl/sL leq-lvl/self)
             (leq-lvl/imaxLs
               (leq-lvl/maxL
                 (leq-lvl/sL leq-lvl/self)
                 (leq-lvl/sL leq-lvl/self))))))
       ([x] ([h] (field-universes-ok/done not-forall/const)))).

indNeg_mk/name : name "indNeg.mk" (is-decl (eforall (eforall (econst "indNeg" lnil) ([x] (econst "indNeg" lnil))) ([x] (econst "indNeg" lnil))) (ctor "indNeg" z)).

indNeg_mk/decl : declared "indNeg.mk" (eforall (eforall (econst "indNeg" lnil) ([x] (econst "indNeg" lnil))) ([x] (econst "indNeg" lnil))) (ctor "indNeg" z)
   = declared/ok-ctor indNeg_mk/name indNeg/name indNeg_mk/cmem indNeg/eisl indNeg_mk/fuo (dkind-ok/ctor indNeg_mk/type-wf indNeg_mk/positivity).

