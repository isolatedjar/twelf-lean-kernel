%%% Expected outcome: reject
%%% The classic example of an inductive with negative recursive occurrence
%% inductive indNeg
indNeg/type-wf-sort : lvl
   = (lsucc (lsucc lzero)).

indNeg/type-wf : defeq (esort (lsucc lzero)) (esort (lsucc lzero)) (esort indNeg/type-wf-sort)
   = defeq/sort-refl.

indNeg/ends-in-sort : ends-in-sort (esort (lsucc lzero))
   = ends-in-sort/sort.

indNeg/rec-name : name "indNeg.rec" (is-rec-for "indNeg").

indNeg/name : name "indNeg" (is-decl (esort (lsucc lzero)) indt).

indNeg/decl : declared "indNeg" (esort (lsucc lzero)) indt
   = declared/ok indNeg/name (dkind-ok/indt indNeg/type-wf indNeg/ends-in-sort).

%% ctor indNeg.mk (of indNeg)
indNeg_mk/type-wf-sort : lvl
   = (limax (limax (lsucc lzero) (lsucc lzero)) (lsucc lzero)).

indNeg_mk/type-wf : defeq (eforall (eforall (econst "indNeg" lnil) ([x] (econst "indNeg" lnil))) ([x] (econst "indNeg" lnil))) (eforall (eforall (econst "indNeg" lnil) ([x] (econst "indNeg" lnil))) ([x] (econst "indNeg" lnil))) (esort indNeg_mk/type-wf-sort)
   = (defeq/forall (defeq/forall (defeq/const indNeg/decl (inst-expr/sort (lvl-inst/succ lvl-inst/zero))) ([x] ([h] (defeq/const indNeg/decl (inst-expr/sort (lvl-inst/succ lvl-inst/zero)))))) ([x] ([h] (defeq/const indNeg/decl (inst-expr/sort (lvl-inst/succ lvl-inst/zero)))))).

%%% HOLE
indNeg_mk/positivity : ctor-positive "indNeg" lnil (eforall (eforall (econst "indNeg" lnil) ([x] (econst "indNeg" lnil))) ([x] (econst "indNeg" lnil))).

indNeg_mk/name : name "indNeg.mk" (is-decl (eforall (eforall (econst "indNeg" lnil) ([x] (econst "indNeg" lnil))) ([x] (econst "indNeg" lnil))) ctor).

indNeg_mk/decl : declared "indNeg.mk" (eforall (eforall (econst "indNeg" lnil) ([x] (econst "indNeg" lnil))) ([x] (econst "indNeg" lnil))) ctor
   = declared/ok indNeg_mk/name (dkind-ok/ctor indNeg_mk/type-wf indNeg_mk/positivity).

%% recursor indNeg.rec
indNeg_rec/type-wf-sort : lvl
   = (lsucc lzero).

indNeg_rec/type-wf : defeq (esort lzero) (esort lzero) (esort indNeg_rec/type-wf-sort)
   = defeq/sort-refl.

indNeg_rec/decl : declared "indNeg.rec" (esort lzero) irec
   = declared/ok-irec indNeg/rec-name (dkind-ok/irec indNeg_rec/type-wf).

