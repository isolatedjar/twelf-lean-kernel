%%% Expected outcome: accept
%%% Some level computation
%solve nonneg_0 : 0 >= 0.

%% def levelComp1
levelComp1/type-wf-sort : lvl
   = (lsucc (lsucc lzero)).

levelComp1/type-wf : defeq (esort (lsucc lzero)) (esort (lsucc lzero)) (esort levelComp1/type-wf-sort)
   = defeq/sort-refl.

levelComp1/value-typed : defeq (esort (limax (lsucc lzero) lzero)) (esort (limax (lsucc lzero) lzero)) (esort (lsucc lzero))
   = (defeq/conv (defeq/sort-eq (lvl-eq/le (mleq/sL (mleq/imax-lzL (mleq/sR (mleq/self nonneg_0)))) (mleq/sL (mleq/sR (mleq/lz nonneg_0))))) defeq/sort-refl).

levelComp1/name : name "levelComp1" (is-decl (esort (lsucc lzero)) (defn (esort (limax (lsucc lzero) lzero)))).

levelComp1/decl : declared "levelComp1" (esort (lsucc lzero)) (defn (esort (limax (lsucc lzero) lzero)))
   = declared/ok levelComp1/name (dkind-ok/defn levelComp1/type-wf levelComp1/value-typed).
