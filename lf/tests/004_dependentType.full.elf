%%% Expected outcome: accept
%%% Dependent type (forall)
%% def dependentType
dependentType/type-wf : of (esort lzero) (esort (lsucc lzero))
   = defeq/sort-refl.

dependentType/value-typed : of (eforall (esort lzero) ([x] x)) (esort lzero)
   = (defeq/conv
       (defeq/sort-eq (eq-lvl/le leq-lvl/lz (leq-lvl/imaxLz leq-lvl/self)))
       (defeq/forall defeq/sort-refl ([x] ([h] h)))).

dependentType/name : name "dependentType" (is-decl (esort lzero) (defn (eforall (esort lzero) ([x] x)))).

dependentType/decl : declared "dependentType" (esort lzero) (defn (eforall (esort lzero) ([x] x)))
   = declared/ok dependentType/name dkind-non-inductive/defn (dkind-ok/defn dependentType/type-wf dependentType/value-typed).
