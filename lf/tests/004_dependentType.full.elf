%%% Expected outcome: accept
%%% Dependent type (forall)
%% def dependentType
%%% HOLE
dependentType/type-wf-sort : lvl.

%%% HOLE
dependentType/type-wf : defeq (esort lzero) (esort lzero) (esort dependentType/type-wf-sort).

%%% HOLE
dependentType/value-typed : defeq (eforall (esort lzero) ([x] x)) (eforall (esort lzero) ([x] x)) (esort lzero).

dependentType/name : name "dependentType" (is-decl (esort lzero) (defn (eforall (esort lzero) ([x] x)))).

dependentType/decl : declared "dependentType" (esort lzero) (defn (eforall (esort lzero) ([x] x)))
   = declared/ok dependentType/name (dkind-ok/defn dependentType/type-wf dependentType/value-typed).

