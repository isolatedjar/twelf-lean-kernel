%%% Expected outcome: reject
%%% A definition and a recursor with the same name
%% def dup_rec_def.rec
%%% HOLE
dup_rec_def_rec/type-wf-sort : lvl.

%%% HOLE
dup_rec_def_rec/type-wf : defeq (esort (lsucc lzero)) (esort (lsucc lzero)) (esort dup_rec_def_rec/type-wf-sort).

%%% HOLE
dup_rec_def_rec/value-typed : defeq (esort lzero) (esort lzero) (esort (lsucc lzero)).

dup_rec_def_rec/decl : declared "dup_rec_def.rec" lnil
   (esort (lsucc lzero))
   (defn (esort lzero))
   (dkind-ok/defn dup_rec_def_rec/type-wf dup_rec_def_rec/value-typed).

%% inductive dup_rec_def
%%% HOLE
dup_rec_def/type-wf-sort : lvl.

%%% HOLE
dup_rec_def/type-wf : defeq (esort (lsucc lzero)) (esort (lsucc lzero)) (esort dup_rec_def/type-wf-sort).

%%% HOLE
dup_rec_def/ends-in-sort : ends-in-sort (esort (lsucc lzero)).

dup_rec_def/decl : declared "dup_rec_def" lnil
   (esort (lsucc lzero))
   indt
   (dkind-ok/indt dup_rec_def/type-wf dup_rec_def/ends-in-sort).

%% ctor dup_rec_def.mk (of dup_rec_def)
%%% HOLE
dup_rec_def_mk/type-wf-sort : lvl.

%%% HOLE
dup_rec_def_mk/type-wf : defeq (econst "dup_rec_def" lnil) (econst "dup_rec_def" lnil) (esort dup_rec_def_mk/type-wf-sort).

%%% HOLE
dup_rec_def_mk/positivity : ctor-positive "dup_rec_def" lnil (econst "dup_rec_def" lnil).

dup_rec_def_mk/decl : declared "dup_rec_def.mk" lnil
   (econst "dup_rec_def" lnil)
   ctor
   (dkind-ok/ctor dup_rec_def_mk/type-wf dup_rec_def_mk/positivity).

%% recursor dup_rec_def.rec
%%% HOLE
dup_rec_def_rec/type-wf-sort : {u : lvl} lvl.

%%% HOLE
dup_rec_def_rec/type-wf : {u : lvl} defeq (eforall (eforall (econst "dup_rec_def" lnil) ([x] (esort u))) ([x] (eforall (eapp x (econst "dup_rec_def.mk" lnil)) ([y] (eforall (econst "dup_rec_def" lnil) ([z] (eapp x z))))))) (eforall (eforall (econst "dup_rec_def" lnil) ([x] (esort u))) ([x] (eforall (eapp x (econst "dup_rec_def.mk" lnil)) ([y] (eforall (econst "dup_rec_def" lnil) ([z] (eapp x z))))))) (esort (dup_rec_def_rec/type-wf-sort u)).

dup_rec_def_rec/decl : {u : lvl} declared "dup_rec_def.rec" (lcons u lnil)
   (eforall (eforall (econst "dup_rec_def" lnil) ([x] (esort u))) ([x] (eforall (eapp x (econst "dup_rec_def.mk" lnil)) ([y] (eforall (econst "dup_rec_def" lnil) ([z] (eapp x z)))))))
   irec
   (dkind-ok/irec (dup_rec_def_rec/type-wf u)).

