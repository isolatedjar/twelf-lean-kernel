%%% Render-only view of: 066_existsRec
%%% Inductive predicates eliminate into Prop if they have one constructors and it carries data.
%% inductive Exists
%%% HOLE
Exists/type-wf-sort : {u : lvl} lvl.

%%% HOLE
Exists/type-wf : {u : lvl} defeq (eforall (esort u) ([x] (eforall (eforall x ([y] (esort lzero))) ([y] (esort lzero))))) (eforall (esort u) ([x] (eforall (eforall x ([y] (esort lzero))) ([y] (esort lzero))))) (esort (Exists/type-wf-sort u)).

%%% HOLE
Exists/ends-in-sort : {u : lvl} ends-in-sort (eforall (esort u) ([x] (eforall (eforall x ([y] (esort lzero))) ([y] (esort lzero))))).

Exists/name : {u : lvl} name "Exists" (is-decl (lcons u lnil) (eforall (esort u) ([x] (eforall (eforall x ([y] (esort lzero))) ([y] (esort lzero))))) indt).

Exists/decl : {u : lvl} declared "Exists" (lcons u lnil)
   (eforall (esort u) ([x] (eforall (eforall x ([y] (esort lzero))) ([y] (esort lzero)))))
   indt
   (Exists/name u)
   (dkind-ok/indt (Exists/type-wf u) (Exists/ends-in-sort u)).

