%%% Render-only view of: 010_nonTypeType
%%% The type of a declaration has to be a type, not some other expression
%% def constType
constType/render-type : expr =
   (eforall (esort (lsucc lzero)) ([x] (eforall (esort (lsucc lzero)) ([y] (esort (lsucc lzero)))))).
constType/render-value : expr =
   (elam (esort (lsucc lzero)) ([x] (elam (esort (lsucc lzero)) ([y] x)))).

%% def nonTypeType
nonTypeType/render-type : expr =
   (econst "constType" lnil).
nonTypeType/render-value : expr =
   (esort lzero).

