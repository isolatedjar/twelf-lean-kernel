%% inductive Prod
%%% HOLE
Prod/type-wf-sort : lvl.

%%% HOLE
Prod/type-wf : of (eforall (esort (lsucc (lvar liz))) ([x] (eforall (esort (lsucc (lvar (lis liz)))) ([y] (esort (lmax (lsucc (lvar liz)) (lsucc (lvar (lis liz))))))))) (esort Prod/type-wf-sort).

%%% HOLE
Prod/ends-in-sort : ends-in-sort (eforall (esort (lsucc (lvar liz))) ([x] (eforall (esort (lsucc (lvar (lis liz)))) ([y] (esort (lmax (lsucc (lvar liz)) (lsucc (lvar (lis liz))))))))).

Prod/rec-name : name "Prod.rec" (is-rec-for "Prod").

Prod/eisl : ends-in-sort-with-level (eforall (esort (lsucc (lvar liz))) ([x] (eforall (esort (lsucc (lvar (lis liz)))) ([y] (esort (lmax (lsucc (lvar liz)) (lsucc (lvar (lis liz))))))))) (lmax (lsucc (lvar liz)) (lsucc (lvar (lis liz))))
   = (ends-in-sort-with-level/forall
       ([x]
         (ends-in-sort-with-level/forall ([y] ends-in-sort-with-level/sort)))).

Prod/clf : count-leading-foralls (eforall (esort (lsucc (lvar liz))) ([x] (eforall (esort (lsucc (lvar (lis liz)))) ([y] (esort (lmax (lsucc (lvar liz)) (lsucc (lvar (lis liz))))))))) (lis (lis liz))
   = (count-leading-foralls/succ
       ([x] (count-leading-foralls/succ ([y] count-leading-foralls/zero)))).

Prod/cnd : cnames-distinct (ccons "Prod.mk" cnil)
   = (cnames-distinct/cons cnames-distinct/nil all-string-neq/nil).

Prod/name : name "Prod" (is-decl
  (eforall (esort (lsucc (lvar liz))) ([x] (eforall (esort (lsucc (lvar (lis liz)))) ([y] (esort (lmax (lsucc (lvar liz)) (lsucc (lvar (lis liz)))))))))
  (indt (ccons "Prod.mk" cnil) (lis (lis liz)))).

Prod/decl : declared "Prod"
  (eforall (esort (lsucc (lvar liz))) ([x] (eforall (esort (lsucc (lvar (lis liz)))) ([y] (esort (lmax (lsucc (lvar liz)) (lsucc (lvar (lis liz)))))))))
  (indt (ccons "Prod.mk" cnil) (lis (lis liz)))
   = declared/ok-indt Prod/name Prod/rec-name Prod/clf Prod/cnd (dkind-ok/indt Prod/type-wf Prod/ends-in-sort).

