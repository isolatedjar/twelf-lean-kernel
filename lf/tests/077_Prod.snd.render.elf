Prod/eisl : ends-in-sort-with-level (eforall (esort (lsucc (lvar z))) ([x] (eforall (esort (lsucc (lvar (s z)))) ([y] (esort (lmax (lsucc (lvar z)) (lsucc (lvar (s z))))))))) (lmax (lsucc (lvar z)) (lsucc (lvar (s z))))
