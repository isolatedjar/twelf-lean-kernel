%%% Render-only view of: 050_indNegReducible
%%% When checking inductives, we expect the kernel to **not** reduce the type of the constructor parameters
%%% further than head normal form. Recursive occurrences nested inside the head normal form are considered
%%% negative occurrences, even if they could be reduced to disappear.
%% def constType
%%% HOLE
constType/type-wf : defeq (eforall (esort (lsucc lzero)) ([x] (eforall (esort (lsucc lzero)) ([y] (esort (lsucc lzero)))))) (eforall (esort (lsucc lzero)) ([x] (eforall (esort (lsucc lzero)) ([y] (esort (lsucc lzero)))))) (esort lzero).

%%% HOLE
constType/value-typed : defeq (elam (esort (lsucc lzero)) ([x] (elam (esort (lsucc lzero)) ([y] x)))) (elam (esort (lsucc lzero)) ([x] (elam (esort (lsucc lzero)) ([y] x)))) (eforall (esort (lsucc lzero)) ([x] (eforall (esort (lsucc lzero)) ([y] (esort (lsucc lzero)))))).

constType/decl : declared "constType" lnil
   (eforall (esort (lsucc lzero)) ([x] (eforall (esort (lsucc lzero)) ([y] (esort (lsucc lzero))))))
   (defn (elam (esort (lsucc lzero)) ([x] (elam (esort (lsucc lzero)) ([y] x)))))
   (dkind-ok/defn constType/type-wf constType/value-typed).

%% axiom aType
%%% HOLE
aType/type-wf : defeq (esort (lsucc lzero)) (esort (lsucc lzero)) (esort lzero).

aType/decl : declared "aType" lnil
   (esort (lsucc lzero))
   ax
   (dkind-ok/ax aType/type-wf).

%% inductive indNegReducible
%%% HOLE
indNegReducible/type-wf : defeq (esort (lsucc lzero)) (esort (lsucc lzero)) (esort lzero).

%%% HOLE
indNegReducible/ends-in-sort : ends-in-sort (esort (lsucc lzero)).

indNegReducible/decl : declared "indNegReducible" lnil
