%%% Expected outcome: accept
%%% Inductive predicates eliminate into Prop if they have more than one constructor.
%% inductive BoolProp
BoolProp/type-wf-sort : lvl
   = (lsucc lzero).

BoolProp/type-wf : of (esort lzero) (esort BoolProp/type-wf-sort)
   = defeq/sort-refl.

BoolProp/ends-in-sort : ends-in-sort (esort lzero)
   = ends-in-sort/sort.

BoolProp/rec-name : name "BoolProp.rec" (is-rec-for "BoolProp").

BoolProp/name : name "BoolProp" (is-decl (esort lzero) indt).

BoolProp/decl : declared "BoolProp" (esort lzero) indt
   = declared/ok BoolProp/name (dkind-ok/indt BoolProp/type-wf BoolProp/ends-in-sort).

%% ctor BoolProp.a (of BoolProp)
BoolProp_a/type-wf-sort : lvl
   = lzero.

BoolProp_a/type-wf : of (econst "BoolProp" lnil) (esort BoolProp_a/type-wf-sort)
   = (defeq/const BoolProp/decl (inst-expr/sort lvl-inst/zero)).

BoolProp_a/positivity : ctor-positive "BoolProp" lnil (econst "BoolProp" lnil)
   = (ctor-positive/intro ([S] S) (ctor-spine/result applies-self/refl)).

BoolProp_a/name : name "BoolProp.a" (is-decl (econst "BoolProp" lnil) ctor).

BoolProp_a/decl : declared "BoolProp.a" (econst "BoolProp" lnil) ctor
   = declared/ok BoolProp_a/name (dkind-ok/ctor BoolProp_a/type-wf BoolProp_a/positivity).

%% ctor BoolProp.b (of BoolProp)
BoolProp_b/type-wf-sort : lvl
   = lzero.

BoolProp_b/type-wf : of (econst "BoolProp" lnil) (esort BoolProp_b/type-wf-sort)
   = (defeq/const BoolProp/decl (inst-expr/sort lvl-inst/zero)).

BoolProp_b/positivity : ctor-positive "BoolProp" lnil (econst "BoolProp" lnil)
   = (ctor-positive/intro ([S] S) (ctor-spine/result applies-self/refl)).

BoolProp_b/name : name "BoolProp.b" (is-decl (econst "BoolProp" lnil) ctor).

BoolProp_b/decl : declared "BoolProp.b" (econst "BoolProp" lnil) ctor
   = declared/ok BoolProp_b/name (dkind-ok/ctor BoolProp_b/type-wf BoolProp_b/positivity).

%% recursor BoolProp.rec
BoolProp_rec/type-wf-sort : lvl
   = (limax (limax lzero (lsucc lzero)) (limax lzero (limax lzero (limax lzero lzero)))).

BoolProp_rec/type-wf : of (eforall (eforall (econst "BoolProp" lnil) ([x] (esort lzero))) ([x] (eforall (eapp x (econst "BoolProp.a" lnil)) ([y] (eforall (eapp x (econst "BoolProp.b" lnil)) ([z] (eforall (econst "BoolProp" lnil) ([w] (eapp x w))))))))) (esort BoolProp_rec/type-wf-sort)
   = (defeq/forall (defeq/forall (defeq/const BoolProp/decl (inst-expr/sort lvl-inst/zero)) ([x] ([h] defeq/sort-refl))) ([x] ([h] (defeq/forall (defeq/app h (defeq/const BoolProp_a/decl (inst-expr/const lvls-inst/nil))) ([y] ([h1] (defeq/forall (defeq/app h (defeq/const BoolProp_b/decl (inst-expr/const lvls-inst/nil))) ([z] ([h2] (defeq/forall (defeq/const BoolProp/decl (inst-expr/sort lvl-inst/zero)) ([w] ([h3] (defeq/app h h3))))))))))))).

BoolProp_rec/decl : declared "BoolProp.rec" (eforall (eforall (econst "BoolProp" lnil) ([x] (esort lzero))) ([x] (eforall (eapp x (econst "BoolProp.a" lnil)) ([y] (eforall (eapp x (econst "BoolProp.b" lnil)) ([z] (eforall (econst "BoolProp" lnil) ([w] (eapp x w))))))))) irec
   = declared/ok-irec BoolProp/rec-name (dkind-ok/irec BoolProp_rec/type-wf).

%% def boolPropRec
boolPropRec/type-wf-sort : lvl
   = (limax (limax lzero (lsucc lzero)) (limax lzero (limax lzero (limax lzero lzero)))).

boolPropRec/type-wf : of (eforall (eforall (econst "BoolProp" lnil) ([x] (esort lzero))) ([x] (eforall (eapp x (econst "BoolProp.a" lnil)) ([y] (eforall (eapp x (econst "BoolProp.b" lnil)) ([z] (eforall (econst "BoolProp" lnil) ([w] (eapp x w))))))))) (esort boolPropRec/type-wf-sort)
   = (defeq/forall (defeq/forall (defeq/const BoolProp/decl (inst-expr/sort lvl-inst/zero)) ([x] ([h] defeq/sort-refl))) ([x] ([h] (defeq/forall (defeq/app h (defeq/const BoolProp_a/decl (inst-expr/const lvls-inst/nil))) ([y] ([h1] (defeq/forall (defeq/app h (defeq/const BoolProp_b/decl (inst-expr/const lvls-inst/nil))) ([z] ([h2] (defeq/forall (defeq/const BoolProp/decl (inst-expr/sort lvl-inst/zero)) ([w] ([h3] (defeq/app h h3))))))))))))).

boolPropRec/value-typed : of (econst "BoolProp.rec" lnil) (eforall (eforall (econst "BoolProp" lnil) ([x] (esort lzero))) ([x] (eforall (eapp x (econst "BoolProp.a" lnil)) ([y] (eforall (eapp x (econst "BoolProp.b" lnil)) ([z] (eforall (econst "BoolProp" lnil) ([w] (eapp x w)))))))))
   = (defeq/const BoolProp_rec/decl (inst-expr/forall (inst-expr/forall (inst-expr/const lvls-inst/nil) ([x] ([h] (inst-expr/sort lvl-inst/zero)))) ([x] ([h] (inst-expr/forall (inst-expr/app h (inst-expr/const lvls-inst/nil)) ([y] ([h1] (inst-expr/forall (inst-expr/app h (inst-expr/const lvls-inst/nil)) ([z] ([h2] (inst-expr/forall (inst-expr/const lvls-inst/nil) ([w] ([h3] (inst-expr/app h h3)))))))))))))).

boolPropRec/name : name "boolPropRec" (is-decl (eforall (eforall (econst "BoolProp" lnil) ([x] (esort lzero))) ([x] (eforall (eapp x (econst "BoolProp.a" lnil)) ([y] (eforall (eapp x (econst "BoolProp.b" lnil)) ([z] (eforall (econst "BoolProp" lnil) ([w] (eapp x w))))))))) (defn (econst "BoolProp.rec" lnil))).

boolPropRec/decl : declared "boolPropRec" (eforall (eforall (econst "BoolProp" lnil) ([x] (esort lzero))) ([x] (eforall (eapp x (econst "BoolProp.a" lnil)) ([y] (eforall (eapp x (econst "BoolProp.b" lnil)) ([z] (eforall (econst "BoolProp" lnil) ([w] (eapp x w))))))))) (defn (econst "BoolProp.rec" lnil))
   = declared/ok boolPropRec/name (dkind-ok/defn boolPropRec/type-wf boolPropRec/value-typed).
