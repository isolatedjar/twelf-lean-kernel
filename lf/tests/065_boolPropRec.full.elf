%%% Expected outcome: accept
%%% Inductive predicates eliminate into Prop if they have more than one constructor.
sneq/0 : string-neq "BoolProp.a" "BoolProp.b".

%% inductive BoolProp
BoolProp/type-wf-sort : lvl
   = (lsucc lzero).

BoolProp/type-wf : of (esort lzero) (esort BoolProp/type-wf-sort)
   = defeq/sort-refl.

BoolProp/ends-in-sort : ends-in-sort (esort lzero)
   = ends-in-sort/sort.

BoolProp/rec-name : name "BoolProp.rec" (is-rec-for "BoolProp").

BoolProp/clf : count-leading-foralls (esort lzero) liz
   = (count-leading-foralls/zero not-forall/sort).

BoolProp/cnd : cnames-distinct (ccons "BoolProp.a" (ccons "BoolProp.b" cnil))
   = (cnames-distinct/cons
       (cnames-distinct/cons cnames-distinct/nil all-string-neq/nil)
       (all-string-neq/cons sneq/0 all-string-neq/nil)).

BoolProp/name : name "BoolProp" (is-decl (esort lzero) (indt (ccons "BoolProp.a" (ccons "BoolProp.b" cnil)) liz)).

BoolProp/decl : declared "BoolProp" (esort lzero) (indt (ccons "BoolProp.a" (ccons "BoolProp.b" cnil)) liz)
   = declared/ok-indt BoolProp/name BoolProp/rec-name BoolProp/clf BoolProp/cnd (dkind-ok/indt BoolProp/type-wf BoolProp/ends-in-sort).

%% ctor BoolProp.a (of BoolProp)
BoolProp_a/type-wf-sort : lvl
   = lzero.

BoolProp_a/type-wf : of (econst "BoolProp" lnil) (esort BoolProp_a/type-wf-sort)
   = (defeq/const BoolProp/decl (inst-expr/sort lvl-inst/zero)).

BoolProp_a/positivity : ctor-positive "BoolProp" lnil (econst "BoolProp" lnil)
   = (ctor-positive/intro ([S] S) (ctor-spine/result applies-self/refl)).

BoolProp_a/eisl : ends-in-sort-with-level (esort lzero) lzero
   = ends-in-sort-with-level/sort.

BoolProp_a/cmem : cmem "BoolProp.a" (ccons "BoolProp.a" (ccons "BoolProp.b" cnil))
   = cmem/here.

%%% HOLE: BoolProp_a/fuo — prover for field-universes-ok-skip-params not yet implemented
BoolProp_a/fuo : field-universes-ok-skip-params liz (econst "BoolProp" lnil) lzero.

BoolProp_a/name : name "BoolProp.a" (is-decl (econst "BoolProp" lnil) (ctor "BoolProp" liz)).

BoolProp_a/decl : declared "BoolProp.a" (econst "BoolProp" lnil) (ctor "BoolProp" liz)
   = declared/ok-ctor BoolProp_a/name BoolProp/name BoolProp_a/cmem BoolProp_a/eisl BoolProp_a/fuo (dkind-ok/ctor BoolProp_a/type-wf BoolProp_a/positivity).

%% ctor BoolProp.b (of BoolProp)
BoolProp_b/type-wf-sort : lvl
   = lzero.

BoolProp_b/type-wf : of (econst "BoolProp" lnil) (esort BoolProp_b/type-wf-sort)
   = (defeq/const BoolProp/decl (inst-expr/sort lvl-inst/zero)).

BoolProp_b/positivity : ctor-positive "BoolProp" lnil (econst "BoolProp" lnil)
   = (ctor-positive/intro ([S] S) (ctor-spine/result applies-self/refl)).

BoolProp_b/eisl : ends-in-sort-with-level (esort lzero) lzero
   = ends-in-sort-with-level/sort.

BoolProp_b/cmem : cmem "BoolProp.b" (ccons "BoolProp.a" (ccons "BoolProp.b" cnil))
   = (cmem/there cmem/here).

%%% HOLE: BoolProp_b/fuo — prover for field-universes-ok-skip-params not yet implemented
BoolProp_b/fuo : field-universes-ok-skip-params liz (econst "BoolProp" lnil) lzero.

BoolProp_b/name : name "BoolProp.b" (is-decl (econst "BoolProp" lnil) (ctor "BoolProp" (lis liz))).

BoolProp_b/decl : declared "BoolProp.b" (econst "BoolProp" lnil) (ctor "BoolProp" (lis liz))
   = declared/ok-ctor BoolProp_b/name BoolProp/name BoolProp_b/cmem BoolProp_b/eisl BoolProp_b/fuo (dkind-ok/ctor BoolProp_b/type-wf BoolProp_b/positivity).

%% recursor BoolProp.rec
BoolProp_rec/type-wf-sort : lvl
   = (limax
       (limax lzero (lsucc lzero))
       (limax lzero (limax lzero (limax lzero lzero)))).

BoolProp_rec/type-wf : of
  (eforall (eforall (econst "BoolProp" lnil) ([x] (esort lzero)))
    ([x] (eforall (eapp x (econst "BoolProp.a" lnil)) ([y] (eforall (eapp x (econst "BoolProp.b" lnil)) ([z] (eforall (econst "BoolProp" lnil) ([w] (eapp x w)))))))))
  (esort BoolProp_rec/type-wf-sort)
   = (defeq/forall
       (defeq/forall
         (defeq/const BoolProp/decl (inst-expr/sort lvl-inst/zero))
         ([x] ([h] defeq/sort-refl)))
       ([x]
         ([h]
           (defeq/forall
             (defeq/app
               h
               (defeq/const BoolProp_a/decl (inst-expr/const lvls-inst/nil)))
             ([y]
               ([h1]
                 (defeq/forall
                   (defeq/app
                     h
                     (defeq/const
                       BoolProp_b/decl
                       (inst-expr/const lvls-inst/nil)))
                   ([z]
                     ([h2]
                       (defeq/forall
                         (defeq/const
                           BoolProp/decl
                           (inst-expr/sort lvl-inst/zero))
                         ([w] ([h3] (defeq/app h h3))))))))))))).

BoolProp_rec/decl : declared "BoolProp.rec"
  (eforall (eforall (econst "BoolProp" lnil) ([x] (esort lzero)))
    ([x] (eforall (eapp x (econst "BoolProp.a" lnil)) ([y] (eforall (eapp x (econst "BoolProp.b" lnil)) ([z] (eforall (econst "BoolProp" lnil) ([w] (eapp x w)))))))))
  (irec "BoolProp")
   = declared/ok-irec BoolProp/rec-name (dkind-ok/irec BoolProp_rec/type-wf).

%% def boolPropRec
boolPropRec/type-wf-sort : lvl
   = (limax
       (limax lzero (lsucc lzero))
       (limax lzero (limax lzero (limax lzero lzero)))).

boolPropRec/type-wf : of
  (eforall (eforall (econst "BoolProp" lnil) ([x] (esort lzero)))
    ([x] (eforall (eapp x (econst "BoolProp.a" lnil)) ([y] (eforall (eapp x (econst "BoolProp.b" lnil)) ([z] (eforall (econst "BoolProp" lnil) ([w] (eapp x w)))))))))
  (esort boolPropRec/type-wf-sort)
   = (defeq/forall
       (defeq/forall
         (defeq/const BoolProp/decl (inst-expr/sort lvl-inst/zero))
         ([x] ([h] defeq/sort-refl)))
       ([x]
         ([h]
           (defeq/forall
             (defeq/app
               h
               (defeq/const BoolProp_a/decl (inst-expr/const lvls-inst/nil)))
             ([y]
               ([h1]
                 (defeq/forall
                   (defeq/app
                     h
                     (defeq/const
                       BoolProp_b/decl
                       (inst-expr/const lvls-inst/nil)))
                   ([z]
                     ([h2]
                       (defeq/forall
                         (defeq/const
                           BoolProp/decl
                           (inst-expr/sort lvl-inst/zero))
                         ([w] ([h3] (defeq/app h h3))))))))))))).

boolPropRec/value-typed : of
  (econst "BoolProp.rec" lnil)
  (eforall (eforall (econst "BoolProp" lnil) ([x] (esort lzero)))
    ([x] (eforall (eapp x (econst "BoolProp.a" lnil)) ([y] (eforall (eapp x (econst "BoolProp.b" lnil)) ([z] (eforall (econst "BoolProp" lnil) ([w] (eapp x w)))))))))
   = (defeq/const
       BoolProp_rec/decl
       (inst-expr/forall
         (inst-expr/forall
           (inst-expr/const lvls-inst/nil)
           ([x] ([h] (inst-expr/sort lvl-inst/zero))))
         ([x]
           ([h]
             (inst-expr/forall
               (inst-expr/app h (inst-expr/const lvls-inst/nil))
               ([y]
                 ([h1]
                   (inst-expr/forall
                     (inst-expr/app h (inst-expr/const lvls-inst/nil))
                     ([z]
                       ([h2]
                         (inst-expr/forall
                           (inst-expr/const lvls-inst/nil)
                           ([w] ([h3] (inst-expr/app h h3)))))))))))))).

boolPropRec/name : name "boolPropRec" (is-decl
  (eforall (eforall (econst "BoolProp" lnil) ([x] (esort lzero)))
    ([x] (eforall (eapp x (econst "BoolProp.a" lnil)) ([y] (eforall (eapp x (econst "BoolProp.b" lnil)) ([z] (eforall (econst "BoolProp" lnil) ([w] (eapp x w)))))))))
  (defn (econst "BoolProp.rec" lnil))).

boolPropRec/decl : declared "boolPropRec"
  (eforall (eforall (econst "BoolProp" lnil) ([x] (esort lzero)))
    ([x] (eforall (eapp x (econst "BoolProp.a" lnil)) ([y] (eforall (eapp x (econst "BoolProp.b" lnil)) ([z] (eforall (econst "BoolProp" lnil) ([w] (eapp x w)))))))))
  (defn (econst "BoolProp.rec" lnil))
   = declared/ok boolPropRec/name (dkind-ok/defn boolPropRec/type-wf boolPropRec/value-typed).
