%%% Render-only view of: level-imax-distrib-mxr
%%% Universe-level completeness divergence: the imax-over-max distribution
%%% `imax u (max v w) = max (imax u v) (imax u w)` holds in EVERY valuation, but
%%% Lean's official kernel does not decide it (its level defeq is an incomplete
%%% syntactic algorithm, not a complete decision procedure for the semantic order).
%%% 
%%% We inject, bypassing the elaborator/kernel,
%%%   axiom A : Sort (max (imax u v) (imax u w))     -- distributed form
%%%   def   f : Sort (imax u (max v w)) := A         -- un-distributed form
%%% so checking `f` forces the comparison `imax u (max v w) ≟ max (imax u v) (imax u w)`.
%%% 
%%% Observed (2026-06-03): the OFFICIAL C++ kernel REJECTS; lean4lean (the
%%% formally-verified kernel), nanoda, rpylean, mini, and the Twelf kernel all
%%% ACCEPT.  Since the levels are genuinely equal, `accept` is the type-theoretic
%%% ground truth and the official kernel is the lone (sound-but-incomplete) outlier.
%%% 
%%% In the Twelf kernel this exercises the `mleq/imax-mxL` and `mleq/imax-mxR`
%%% level-comparison rules — the latter is otherwise untouched by the test corpus.
%% axiom A
%%% HOLE
A/type-wf : of (esort (lmax (limax (lvar z) (lvar (s z))) (limax (lvar z) (lvar (s (s z)))))) (esort _).

A/name : name "A" (is-decl (esort (lmax (limax (lvar z) (lvar (s z))) (limax (lvar z) (lvar (s (s z)))))) ax).

A/decl : declared "A" (esort (lmax (limax (lvar z) (lvar (s z))) (limax (lvar z) (lvar (s (s z)))))) ax
   = declared/ok A/name dkind-non-inductive/ax (dkind-ok/ax A/type-wf).

%% def f
%%% HOLE
f/type-wf : of (esort (limax (lvar z) (lmax (lvar (s z)) (lvar (s (s z)))))) (esort _).

%%% HOLE
f/value-typed : of (econst "A" (lcons (lvar z) (lcons (lvar (s z)) (lcons (lvar (s (s z))) lnil)))) (esort (limax (lvar z) (lmax (lvar (s z)) (lvar (s (s z)))))).

f/name : name "f" (is-decl (esort (limax (lvar z) (lmax (lvar (s z)) (lvar (s (s z)))))) (defn (econst "A" (lcons (lvar z) (lcons (lvar (s z)) (lcons (lvar (s (s z))) lnil)))))).

f/decl : declared "f" (esort (limax (lvar z) (lmax (lvar (s z)) (lvar (s (s z)))))) (defn (econst "A" (lcons (lvar z) (lcons (lvar (s z)) (lcons (lvar (s (s z))) lnil)))))
   = declared/ok f/name dkind-non-inductive/defn (dkind-ok/defn f/type-wf f/value-typed).
