%%% Expected outcome: accept
%%% A simple product type
%solve nonneg_0 : 0 >= 0.

sneq/0 : string-neq "Bool.false" "Bool.true".
sneq/1 : string-neq "Bool" "TwoBool".

%% inductive Bool
Bool/type-wf-sort : lvl
   = (lsucc (lsucc lzero)).

Bool/type-wf : of (esort (lsucc lzero)) (esort Bool/type-wf-sort)
   = defeq/sort-refl.

Bool/ends-in-sort : ends-in-sort (esort (lsucc lzero))
   = ends-in-sort/sort.

Bool/rec-name : name "Bool.rec" (is-rec-for "Bool").

Bool/eisl : ends-in-sort-with-level (esort (lsucc lzero)) (lsucc lzero)
   = ends-in-sort-with-level/sort.

Bool/cnd : cnames-distinct (ccons "Bool.false" (ccons "Bool.true" cnil))
   = (cnames-distinct/cons
       (cnames-distinct/cons cnames-distinct/nil all-string-neq/nil)
       (all-string-neq/cons sneq/0 all-string-neq/nil)).

Bool/name : name "Bool" (is-decl (esort (lsucc lzero)) (indt (ccons "Bool.false" (ccons "Bool.true" cnil)) liz)).

Bool/decl : declared "Bool" (esort (lsucc lzero)) (indt (ccons "Bool.false" (ccons "Bool.true" cnil)) liz)
   = declared/ok-indt Bool/name Bool/rec-name Bool/cnd (dkind-ok/indt Bool/type-wf Bool/ends-in-sort).

%% ctor Bool.false (of Bool)
Bool_false/type-wf-sort : lvl
   = (lsucc lzero).

Bool_false/type-wf : of (econst "Bool" lnil) (esort Bool_false/type-wf-sort)
   = (defeq/const Bool/decl (inst-expr/sort (lvl-inst/succ lvl-inst/zero))).

Bool_false/positivity : ctor-positive "Bool" lnil (econst "Bool" lnil)
   = (ctor-positive/intro ([S] S) (ctor-spine/result applies-self/refl)).

Bool_false/cmem : cmem "Bool.false" (ccons "Bool.false" (ccons "Bool.true" cnil))
   = cmem/here.

Bool_false/fuo : field-universes-ok (econst "Bool" lnil) (lsucc lzero)
   = (field-universes-ok/done not-forall/const).

Bool_false/name : name "Bool.false" (is-decl (econst "Bool" lnil) (ctor "Bool" liz)).

Bool_false/decl : declared "Bool.false" (econst "Bool" lnil) (ctor "Bool" liz)
   = declared/ok-ctor Bool_false/name Bool/name Bool_false/cmem Bool/eisl Bool_false/fuo (dkind-ok/ctor Bool_false/type-wf Bool_false/positivity).

%% ctor Bool.true (of Bool)
Bool_true/type-wf-sort : lvl
   = (lsucc lzero).

Bool_true/type-wf : of (econst "Bool" lnil) (esort Bool_true/type-wf-sort)
   = (defeq/const Bool/decl (inst-expr/sort (lvl-inst/succ lvl-inst/zero))).

Bool_true/positivity : ctor-positive "Bool" lnil (econst "Bool" lnil)
   = (ctor-positive/intro ([S] S) (ctor-spine/result applies-self/refl)).

Bool_true/cmem : cmem "Bool.true" (ccons "Bool.false" (ccons "Bool.true" cnil))
   = (cmem/there cmem/here).

Bool_true/fuo : field-universes-ok (econst "Bool" lnil) (lsucc lzero)
   = (field-universes-ok/done not-forall/const).

Bool_true/name : name "Bool.true" (is-decl (econst "Bool" lnil) (ctor "Bool" (lis liz))).

Bool_true/decl : declared "Bool.true" (econst "Bool" lnil) (ctor "Bool" (lis liz))
   = declared/ok-ctor Bool_true/name Bool/name Bool_true/cmem Bool/eisl Bool_true/fuo (dkind-ok/ctor Bool_true/type-wf Bool_true/positivity).

%% recursor Bool.rec (TCB-derived; informational only)
%%   level params: u
%%   type:   (eforall (eforall (econst "Bool" lnil) ([x] (esort (lvar liz)))) ([x] (eforall (eapp x (econst "Bool.false" lnil)) ([y] (eforall (eapp x (econst "Bool.true" lnil)) ([z] (eforall (econst "Bool" lnil) ([w] (eapp x w)))))))))
%%   rules:
%%     Bool.rec … Bool.false … = (elam (eforall (econst "Bool" lnil) ([x] (esort (lvar liz)))) ([x] (elam (eapp x (econst "Bool.false" lnil)) ([y] (elam (eapp x (econst "Bool.true" lnil)) ([z] y))))))   (0 fields)
%%     Bool.rec … Bool.true … = (elam (eforall (econst "Bool" lnil) ([x] (esort (lvar liz)))) ([x] (elam (eapp x (econst "Bool.false" lnil)) ([y] (elam (eapp x (econst "Bool.true" lnil)) ([z] z))))))   (0 fields)

%% inductive TwoBool
TwoBool/type-wf-sort : lvl
   = (lsucc (lsucc lzero)).

TwoBool/type-wf : of (esort (lsucc lzero)) (esort TwoBool/type-wf-sort)
   = defeq/sort-refl.

TwoBool/ends-in-sort : ends-in-sort (esort (lsucc lzero))
   = ends-in-sort/sort.

TwoBool/rec-name : name "TwoBool.rec" (is-rec-for "TwoBool").

TwoBool/eisl : ends-in-sort-with-level (esort (lsucc lzero)) (lsucc lzero)
   = ends-in-sort-with-level/sort.

TwoBool/cnd : cnames-distinct (ccons "TwoBool.mk" cnil)
   = (cnames-distinct/cons cnames-distinct/nil all-string-neq/nil).

TwoBool/name : name "TwoBool" (is-decl (esort (lsucc lzero)) (indt (ccons "TwoBool.mk" cnil) liz)).

TwoBool/decl : declared "TwoBool" (esort (lsucc lzero)) (indt (ccons "TwoBool.mk" cnil) liz)
   = declared/ok-indt TwoBool/name TwoBool/rec-name TwoBool/cnd (dkind-ok/indt TwoBool/type-wf TwoBool/ends-in-sort).

%% ctor TwoBool.mk (of TwoBool)
TwoBool_mk/type-wf-sort : lvl
   = (limax (lsucc lzero) (limax (lsucc lzero) (lsucc lzero))).

TwoBool_mk/type-wf : of (eforall (econst "Bool" lnil) ([x] (eforall (econst "Bool" lnil) ([y] (econst "TwoBool" lnil))))) (esort TwoBool_mk/type-wf-sort)
   = (defeq/forall
       (defeq/const Bool/decl (inst-expr/sort (lvl-inst/succ lvl-inst/zero)))
       ([x]
         ([h]
           (defeq/forall
             (defeq/const
               Bool/decl
               (inst-expr/sort (lvl-inst/succ lvl-inst/zero)))
             ([y]
               ([h1]
                 (defeq/const
                   TwoBool/decl
                   (inst-expr/sort (lvl-inst/succ lvl-inst/zero))))))))).

TwoBool_mk/positivity : ctor-positive "TwoBool" lnil (eforall (econst "Bool" lnil) ([x] (eforall (econst "Bool" lnil) ([y] (econst "TwoBool" lnil)))))
   = (ctor-positive/intro ([S] (eforall (econst "Bool" lnil) ([x] (eforall (econst "Bool" lnil) ([y] S))))) (ctor-spine/arg
       (strict-pos/no-occur (econst "Bool" lnil) (no-self-ref/const sneq/1))
       ([x]
         ([y]
           (ctor-spine/arg
             (strict-pos/no-occur
               (econst "Bool" lnil)
               (no-self-ref/const sneq/1))
             ([z] ([w] (ctor-spine/result applies-self/refl)))))))).

TwoBool_mk/cmem : cmem "TwoBool.mk" (ccons "TwoBool.mk" cnil)
   = cmem/here.

TwoBool_mk/fuo : field-universes-ok (eforall (econst "Bool" lnil) ([x] (eforall (econst "Bool" lnil) ([y] (econst "TwoBool" lnil))))) (lsucc lzero)
   = (field-universes-ok/forall
       (defeq/const Bool/decl (inst-expr/sort (lvl-inst/succ lvl-inst/zero)))
       (mleq/imax-lsL
         (mleq/sR
           (mleq/maxL
             (mleq/sL (mleq/self nonneg_0))
             (mleq/sL (mleq/self nonneg_0)))))
       ([x]
         ([h]
           (field-universes-ok/forall
             (defeq/const
               Bool/decl
               (inst-expr/sort (lvl-inst/succ lvl-inst/zero)))
             (mleq/imax-lsL
               (mleq/sR
                 (mleq/maxL
                   (mleq/sL (mleq/self nonneg_0))
                   (mleq/sL (mleq/self nonneg_0)))))
             ([y] ([h1] (field-universes-ok/done not-forall/const))))))).

TwoBool_mk/name : name "TwoBool.mk" (is-decl (eforall (econst "Bool" lnil) ([x] (eforall (econst "Bool" lnil) ([y] (econst "TwoBool" lnil))))) (ctor "TwoBool" liz)).

TwoBool_mk/decl : declared "TwoBool.mk" (eforall (econst "Bool" lnil) ([x] (eforall (econst "Bool" lnil) ([y] (econst "TwoBool" lnil))))) (ctor "TwoBool" liz)
   = declared/ok-ctor TwoBool_mk/name TwoBool/name TwoBool_mk/cmem TwoBool/eisl TwoBool_mk/fuo (dkind-ok/ctor TwoBool_mk/type-wf TwoBool_mk/positivity).

%% recursor TwoBool.rec (TCB-derived; informational only)
%%   level params: u
%%   type:   (eforall (eforall (econst "TwoBool" lnil) ([x] (esort (lvar liz)))) ([x] (eforall (eforall (econst "Bool" lnil) ([y] (eforall (econst "Bool" lnil) ([z] (eapp x (eapp (eapp (econst "TwoBool.mk" lnil) y) z)))))) ([y] (eforall (econst "TwoBool" lnil) ([z] (eapp x z)))))))
%%   rules:
%%     TwoBool.rec … TwoBool.mk … = (elam (eforall (econst "TwoBool" lnil) ([x] (esort (lvar liz)))) ([x] (elam (eforall (econst "Bool" lnil) ([y] (eforall (econst "Bool" lnil) ([z] (eapp x (eapp (eapp (econst "TwoBool.mk" lnil) y) z)))))) ([y] (elam (econst "Bool" lnil) ([z] (elam (econst "Bool" lnil) ([w] (eapp (eapp y z) w)))))))))   (2 fields)

%% def twoBool
twoBool/type-wf-sort : lvl
   = (lsucc (lsucc lzero)).

twoBool/type-wf : of (esort (lsucc lzero)) (esort twoBool/type-wf-sort)
   = defeq/sort-refl.

twoBool/value-typed : of (econst "TwoBool" lnil) (esort (lsucc lzero))
   = (defeq/const TwoBool/decl (inst-expr/sort (lvl-inst/succ lvl-inst/zero))).

twoBool/name : name "twoBool" (is-decl (esort (lsucc lzero)) (defn (econst "TwoBool" lnil))).

twoBool/decl : declared "twoBool" (esort (lsucc lzero)) (defn (econst "TwoBool" lnil))
   = declared/ok twoBool/name dkind-non-inductive/defn (dkind-ok/defn twoBool/type-wf twoBool/value-typed).
