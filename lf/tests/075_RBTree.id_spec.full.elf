%% ctor N.succ (of N)
N_succ/type-wf-sort : lvl
   = (limax (lsucc lzero) (lsucc lzero)).

N_succ/type-wf : of (eforall (econst "N" lnil) ([x] (econst "N" lnil))) (esort N_succ/type-wf-sort)
   = (defeq/forall
       (defeq/const N/decl (inst-expr/sort (lvl-inst/succ lvl-inst/zero)))
       ([x]
         ([h]
           (defeq/const
             N/decl
             (inst-expr/sort (lvl-inst/succ lvl-inst/zero)))))).

N_succ/positivity : ctor-positive "N" lnil (eforall (econst "N" lnil) ([x] (econst "N" lnil)))
   = (ctor-positive/intro ([S] (eforall S ([x] S))) (ctor-spine/arg
       (strict-pos/head applies-self/refl)
       ([x] ([y] (ctor-spine/result applies-self/refl))))).

N_succ/eisl : ends-in-sort-with-level (esort (lsucc lzero)) (lsucc lzero)
   = ends-in-sort-with-level/sort.

N_succ/cmem : cmem "N.succ" (ccons "N.zero" (ccons "N.succ" cnil))
   = (cmem/there cmem/here).

N_succ/fuo : field-universes-ok-skip-params liz (eforall (econst "N" lnil) ([x] (econst "N" lnil))) (lsucc lzero)
   = (field-universes-ok-skip-params/start
       (field-universes-ok/forall
         (defeq/const N/decl (inst-expr/sort (lvl-inst/succ lvl-inst/zero)))
         (mleq/self nonneg_0)
         ([x] ([h] (field-universes-ok/done not-forall/const))))).

N_succ/name : name "N.succ" (is-decl (eforall (econst "N" lnil) ([x] (econst "N" lnil))) (ctor "N" (lis liz))).

N_succ/decl : declared "N.succ" (eforall (econst "N" lnil) ([x] (econst "N" lnil))) (ctor "N" (lis liz))
   = declared/ok-ctor N_succ/name N/name N_succ/cmem N_succ/eisl N_succ/fuo (dkind-ok/ctor N_succ/type-wf N_succ/positivity).

%% recursor N.rec
N_rec/type-wf-sort : lvl
   = (limax
       (limax (lsucc lzero) (lsucc (lvar liz)))
       (limax
         (lvar liz)
         (limax
           (limax (lsucc lzero) (limax (lvar liz) (lvar liz)))
           (limax (lsucc lzero) (lvar liz))))).

N_rec/type-wf : of
  (eforall (eforall (econst "N" lnil) ([x] (esort (lvar liz))))
    ([x]
      (eforall (eapp x (econst "N.zero" lnil))
        ([y] (eforall (eforall (econst "N" lnil) ([z] (eforall (eapp x z) ([w] (eapp x (eapp (econst "N.succ" lnil) z)))))) ([z] (eforall (econst "N" lnil) ([w] (eapp x w)))))))))
  (esort N_rec/type-wf-sort)
   = (defeq/forall
       (defeq/forall
         (defeq/const N/decl (inst-expr/sort (lvl-inst/succ lvl-inst/zero)))
         ([x] ([h] defeq/sort-refl)))
       ([x]
         ([h]
           (defeq/forall
             (defeq/app
               h
               (defeq/const N_zero/decl (inst-expr/const lvls-inst/nil)))
             ([y]
               ([h1]
                 (defeq/forall
                   (defeq/forall
                     (defeq/const
                       N/decl
                       (inst-expr/sort (lvl-inst/succ lvl-inst/zero)))
                     ([z]
                       ([h2]
                         (defeq/forall
                           (defeq/app h h2)
                           ([w]
                             ([h3]
                               (defeq/app
                                 h
                                 (defeq/app
                                   (defeq/const
                                     N_succ/decl
                                     (inst-expr/forall
                                       (inst-expr/const lvls-inst/nil)
                                       ([x]
                                         ([h]
                                           (inst-expr/const lvls-inst/nil)))))
                                   h2))))))))
                   ([z]
                     ([h2]
                       (defeq/forall
                         (defeq/const
                           N/decl
                           (inst-expr/sort (lvl-inst/succ lvl-inst/zero)))
                         ([w] ([h3] (defeq/app h h3))))))))))))).

N_rec/decl : declared "N.rec"
  (eforall (eforall (econst "N" lnil) ([x] (esort (lvar liz))))
    ([x]
      (eforall (eapp x (econst "N.zero" lnil))
        ([y] (eforall (eforall (econst "N" lnil) ([z] (eforall (eapp x z) ([w] (eapp x (eapp (econst "N.succ" lnil) z)))))) ([z] (eforall (econst "N" lnil) ([w] (eapp x w)))))))))
  (irec "N")
   = declared/ok-irec N/rec-name (dkind-ok/irec N_rec/type-wf).

%% inductive RBTree
RBTree/type-wf-sort : lvl
   = (limax
       (lsucc (lsucc (lvar liz)))
       (limax (lsucc lzero) (limax (lsucc lzero) (lsucc (lsucc (lvar liz)))))).

RBTree/type-wf : of (eforall (esort (lsucc (lvar liz))) ([x] (eforall (econst "Color" lnil) ([y] (eforall (econst "N" lnil) ([z] (esort (lsucc (lvar liz))))))))) (esort RBTree/type-wf-sort)
   = (defeq/forall
       defeq/sort-refl
       ([x]
         ([h]
           (defeq/forall
             (defeq/const
               Color/decl
               (inst-expr/sort (lvl-inst/succ lvl-inst/zero)))
             ([y]
               ([h1]
                 (defeq/forall
                   (defeq/const
                     N/decl
                     (inst-expr/sort (lvl-inst/succ lvl-inst/zero)))
                   ([z] ([h2] defeq/sort-refl))))))))).

RBTree/ends-in-sort : ends-in-sort (eforall (esort (lsucc (lvar liz))) ([x] (eforall (econst "Color" lnil) ([y] (eforall (econst "N" lnil) ([z] (esort (lsucc (lvar liz)))))))))
   = (ends-in-sort/forall
       ([x]
         (ends-in-sort/forall
           ([y] (ends-in-sort/forall ([z] ends-in-sort/sort)))))).

RBTree/rec-name : name "RBTree.rec" (is-rec-for "RBTree").

RBTree/clf : count-leading-foralls (eforall (esort (lsucc (lvar liz))) ([x] (eforall (econst "Color" lnil) ([y] (eforall (econst "N" lnil) ([z] (esort (lsucc (lvar liz))))))))) (lis liz)
   = (count-leading-foralls/succ ([x] count-leading-foralls/zero)).

RBTree/cnd : cnames-distinct (ccons "RBTree.leaf" (ccons "RBTree.red" (ccons "RBTree.black" cnil)))
   = (cnames-distinct/cons
       (cnames-distinct/cons
         (cnames-distinct/cons cnames-distinct/nil all-string-neq/nil)
         (all-string-neq/cons sneq/2 all-string-neq/nil))
       (all-string-neq/cons
         sneq/4
         (all-string-neq/cons sneq/3 all-string-neq/nil))).

RBTree/name : name "RBTree" (is-decl
  (eforall (esort (lsucc (lvar liz))) ([x] (eforall (econst "Color" lnil) ([y] (eforall (econst "N" lnil) ([z] (esort (lsucc (lvar liz)))))))))
  (indt (ccons "RBTree.leaf" (ccons "RBTree.red" (ccons "RBTree.black" cnil))) (lis liz))).

RBTree/decl : declared "RBTree"
  (eforall (esort (lsucc (lvar liz))) ([x] (eforall (econst "Color" lnil) ([y] (eforall (econst "N" lnil) ([z] (esort (lsucc (lvar liz)))))))))
  (indt (ccons "RBTree.leaf" (ccons "RBTree.red" (ccons "RBTree.black" cnil))) (lis liz))
   = declared/ok-indt RBTree/name RBTree/rec-name RBTree/clf RBTree/cnd (dkind-ok/indt RBTree/type-wf RBTree/ends-in-sort).

%% ctor RBTree.leaf (of RBTree)
RBTree_leaf/type-wf-sort : lvl
   = (limax (lsucc (lsucc (lvar liz))) (lsucc (lvar liz))).

RBTree_leaf/type-wf : of (eforall (esort (lsucc (lvar liz))) ([x] (eapp (eapp (eapp (econst "RBTree" (lcons (lvar liz) lnil)) x) (econst "Color.b" lnil)) (econst "N.zero" lnil)))) (esort RBTree_leaf/type-wf-sort)
   = (defeq/forall
       defeq/sort-refl
       ([x]
         ([h]
           (defeq/app
             (defeq/app
               (defeq/app
                 (defeq/const
                   RBTree/decl
                   (inst-expr/forall
                     (inst-expr/sort
                       (lvl-inst/succ (lvl-inst/var lvl-nth/zero)))
                     ([x]
                       ([h]
                         (inst-expr/forall
                           (inst-expr/const lvls-inst/nil)
                           ([y]
                             ([h1]
                               (inst-expr/forall
                                 (inst-expr/const lvls-inst/nil)
                                 ([z]
                                   ([h2]
                                     (inst-expr/sort
                                       (lvl-inst/succ
                                         (lvl-inst/var lvl-nth/zero)))))))))))))
                 h)
               (defeq/const Color_b/decl (inst-expr/const lvls-inst/nil)))
             (defeq/const N_zero/decl (inst-expr/const lvls-inst/nil)))))).

RBTree_leaf/positivity : ctor-positive "RBTree" (lcons (lvar liz) lnil) (eforall (esort (lsucc (lvar liz))) ([x] (eapp (eapp (eapp (econst "RBTree" (lcons (lvar liz) lnil)) x) (econst "Color.b" lnil)) (econst "N.zero" lnil))))
   = (ctor-positive/intro ([S] (eforall (esort (lsucc (lvar liz))) ([x] (eapp (eapp (eapp S x) (econst "Color.b" lnil)) (econst "N.zero" lnil))))) (ctor-spine/arg
       (strict-pos/no-occur (esort (lsucc (lvar liz))) no-self-ref/sort)
       ([x]
         ([y]
           (ctor-spine/result
             (applies-self/app
               (applies-self/app (applies-self/app applies-self/refl)))))))).

RBTree_leaf/eisl : ends-in-sort-with-level (eforall (esort (lsucc (lvar liz))) ([x] (eforall (econst "Color" lnil) ([y] (eforall (econst "N" lnil) ([z] (esort (lsucc (lvar liz))))))))) (lsucc (lvar liz))
   = (ends-in-sort-with-level/forall
       ([x]
         (ends-in-sort-with-level/forall
           ([y]
             (ends-in-sort-with-level/forall
               ([z] ends-in-sort-with-level/sort)))))).

RBTree_leaf/cmem : cmem "RBTree.leaf" (ccons "RBTree.leaf" (ccons "RBTree.red" (ccons "RBTree.black" cnil)))
   = cmem/here.

RBTree_leaf/fuo : field-universes-ok-skip-params (lis liz) (eforall (esort (lsucc (lvar liz))) ([x] (eapp (eapp (eapp (econst "RBTree" (lcons (lvar liz) lnil)) x) (econst "Color.b" lnil)) (econst "N.zero" lnil)))) (lsucc (lvar liz))
   = (field-universes-ok-skip-params/skip
       ([x]
         ([h]
           (field-universes-ok-skip-params/start
             (field-universes-ok/done not-forall/app))))).

RBTree_leaf/name : name "RBTree.leaf" (is-decl
  (eforall (esort (lsucc (lvar liz))) ([x] (eapp (eapp (eapp (econst "RBTree" (lcons (lvar liz) lnil)) x) (econst "Color.b" lnil)) (econst "N.zero" lnil))))
  (ctor "RBTree" liz)).

RBTree_leaf/decl : declared "RBTree.leaf" (eforall (esort (lsucc (lvar liz))) ([x] (eapp (eapp (eapp (econst "RBTree" (lcons (lvar liz) lnil)) x) (econst "Color.b" lnil)) (econst "N.zero" lnil)))) (ctor "RBTree" liz)
   = declared/ok-ctor RBTree_leaf/name RBTree/name RBTree_leaf/cmem RBTree_leaf/eisl RBTree_leaf/fuo (dkind-ok/ctor RBTree_leaf/type-wf RBTree_leaf/positivity).

%% ctor RBTree.red (of RBTree)
RBTree_red/type-wf-sort : lvl
   = (limax
       (lsucc (lsucc (lvar liz)))
       (limax
         (lsucc lzero)
         (limax
           (lsucc (lvar liz))
           (limax
             (lsucc (lvar liz))
             (limax (lsucc (lvar liz)) (lsucc (lvar liz))))))).

RBTree_red/type-wf : of
  (eforall (esort (lsucc (lvar liz)))
    ([x]
      (eforall (econst "N" lnil)
        ([y]
          (eforall (eapp (eapp (eapp (econst "RBTree" (lcons (lvar liz) lnil)) x) (econst "Color.b" lnil)) y)
            ([z]
              (eforall x
                ([w]
                  (eforall (eapp (eapp (eapp (econst "RBTree" (lcons (lvar liz) lnil)) x) (econst "Color.b" lnil)) y)
                    ([x1] (eapp (eapp (eapp (econst "RBTree" (lcons (lvar liz) lnil)) x) (econst "Color.r" lnil)) y)))))))))))
  (esort RBTree_red/type-wf-sort)
   = (defeq/forall
       defeq/sort-refl
       ([x]
         ([h]
           (defeq/forall
             (defeq/const N/decl (inst-expr/sort (lvl-inst/succ lvl-inst/zero)))
             ([y]
               ([h1]
                 (defeq/forall
                   (defeq/app
                     (defeq/app
                       (defeq/app
                         (defeq/const
                           RBTree/decl
                           (inst-expr/forall
                             (inst-expr/sort
                               (lvl-inst/succ (lvl-inst/var lvl-nth/zero)))
                             ([x]
                               ([h]
                                 (inst-expr/forall
                                   (inst-expr/const lvls-inst/nil)
                                   ([y]
                                     ([h1]
                                       (inst-expr/forall
                                         (inst-expr/const lvls-inst/nil)
                                         ([z]
                                           ([h2]
                                             (inst-expr/sort
                                               (lvl-inst/succ
                                                 (lvl-inst/var
                                                   lvl-nth/zero)))))))))))))
                         h)
                       (defeq/const
                         Color_b/decl
                         (inst-expr/const lvls-inst/nil)))
                     h1)
                   ([z]
                     ([h2]
                       (defeq/forall
                         h
                         ([w]
                           ([h3]
                             (defeq/forall
                               (defeq/app
                                 (defeq/app
                                   (defeq/app
                                     (defeq/const
                                       RBTree/decl
                                       (inst-expr/forall
                                         (inst-expr/sort
                                           (lvl-inst/succ
                                             (lvl-inst/var lvl-nth/zero)))
                                         ([x]
                                           ([h]
                                             (inst-expr/forall
                                               (inst-expr/const lvls-inst/nil)
                                               ([y]
                                                 ([h1]
                                                   (inst-expr/forall
                                                     (inst-expr/const
                                                       lvls-inst/nil)
                                                     ([z]
