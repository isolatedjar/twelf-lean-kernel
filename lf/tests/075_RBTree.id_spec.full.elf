RBTree_leaf/name : name "RBTree.leaf" (is-decl (eforall (esort (lsucc (lvar z))) ([x] (eapp (eapp (eapp (econst "RBTree" (lcons (lvar z) lnil)) x) (econst "Color.b" lnil)) (econst "N.zero" lnil)))) (ctor "RBTree" z)).

