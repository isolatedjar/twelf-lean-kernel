%% inductive RBTree
RBTree/type-wf : of
  (eforall (esort (lsucc (lvar z))) ([x] (eforall (econst "Color" lnil) ([y] (eforall (econst "N" lnil) ([w] (esort (lsucc (lvar z)))))))))
  (esort (limax (lsucc (lsucc (lvar z))) (limax (lsucc lzero) (limax (lsucc lzero) (lsucc (lsucc (lvar z)))))))
   = (defeq/forall
       defeq/sort-refl
       ([x]
         ([h]
           (defeq/forall
             (defeq/const
               Color/decl
               (inst-expr/sort (inst-lvl/succ inst-lvl/zero)))
             ([y]
               ([h1]
                 (defeq/forall
                   (defeq/const
                     N/decl
                     (inst-expr/sort (inst-lvl/succ inst-lvl/zero)))
                   ([w] ([h2] defeq/sort-refl))))))))).

RBTree/ends-in-sort : ends-in-sort (eforall (esort (lsucc (lvar z))) ([x] (eforall (econst "Color" lnil) ([y] (eforall (econst "N" lnil) ([w] (esort (lsucc (lvar z)))))))))
   = (ends-in-sort/forall
       ([x]
         (ends-in-sort/forall
           ([y] (ends-in-sort/forall ([w] ends-in-sort/sort)))))).

RBTree/rec-name : name "RBTree.rec" (is-rec-for "RBTree").

RBTree/eisl : ends-in-sort-with-level (eforall (esort (lsucc (lvar z))) ([x] (eforall (econst "Color" lnil) ([y] (eforall (econst "N" lnil) ([w] (esort (lsucc (lvar z))))))))) (lsucc (lvar z))
   = (ends-in-sort-with-level/forall
       ([x]
         (ends-in-sort-with-level/forall
           ([y]
             (ends-in-sort-with-level/forall
               ([w] ends-in-sort-with-level/sort)))))).

RBTree/cnd : cnames-distinct (ccons "RBTree.leaf" (ccons "RBTree.red" (ccons "RBTree.black" cnil)))
   = (cnames-distinct/cons
       (cnames-distinct/cons
         (cnames-distinct/cons cnames-distinct/nil all-string-neq/nil)
         (all-string-neq/cons sneq/2 all-string-neq/nil))
       (all-string-neq/cons
         sneq/4
         (all-string-neq/cons sneq/3 all-string-neq/nil))).

RBTree/name : name "RBTree" (is-decl
  (eforall (esort (lsucc (lvar z))) ([x] (eforall (econst "Color" lnil) ([y] (eforall (econst "N" lnil) ([w] (esort (lsucc (lvar z)))))))))
  (indt (ccons "RBTree.leaf" (ccons "RBTree.red" (ccons "RBTree.black" cnil))) (s z))).

RBTree/decl : declared "RBTree"
  (eforall (esort (lsucc (lvar z))) ([x] (eforall (econst "Color" lnil) ([y] (eforall (econst "N" lnil) ([w] (esort (lsucc (lvar z)))))))))
  (indt (ccons "RBTree.leaf" (ccons "RBTree.red" (ccons "RBTree.black" cnil))) (s z))
   = declared/ok-indt RBTree/name RBTree/rec-name RBTree/cnd (dkind-ok/indt RBTree/type-wf RBTree/ends-in-sort).

%% ctor RBTree.leaf (of RBTree)
RBTree_leaf/type-wf : of
  (eforall (esort (lsucc (lvar z))) ([x] (eapp (eapp (eapp (econst "RBTree" (lcons (lvar z) lnil)) x) (econst "Color.b" lnil)) (econst "N.zero" lnil))))
  (esort (limax (lsucc (lsucc (lvar z))) (lsucc (lvar z))))
   = (defeq/forall
       defeq/sort-refl
       ([x]
         ([h]
           (defeq/app
             (defeq/app
               (defeq/app
                 (defeq/const
                   RBTree/decl
                   (inst-expr/forall
                     (inst-expr/sort (inst-lvl/succ (inst-lvl/var nth-lvl/z)))
                     ([x]
                       ([h]
                         (inst-expr/forall
                           (inst-expr/const inst-lvls/nil)
                           ([y]
                             ([h1]
                               (inst-expr/forall
                                 (inst-expr/const inst-lvls/nil)
                                 ([w]
                                   ([h2]
                                     (inst-expr/sort
                                       (inst-lvl/succ
                                         (inst-lvl/var nth-lvl/z)))))))))))))
                 h)
               (defeq/const Color_b/decl (inst-expr/const inst-lvls/nil)))
             (defeq/const N_zero/decl (inst-expr/const inst-lvls/nil)))))).

RBTree_leaf/positivity : ctor-positive "RBTree" (lcons (lvar z) lnil) (eforall (esort (lsucc (lvar z))) ([x] (eapp (eapp (eapp (econst "RBTree" (lcons (lvar z) lnil)) x) (econst "Color.b" lnil)) (econst "N.zero" lnil))))
   = (ctor-positive/intro ([S] (eforall (esort (lsucc (lvar z))) ([x] (eapp (eapp (eapp S x) (econst "Color.b" lnil)) (econst "N.zero" lnil))))) (ctor-spine/arg
       (strict-pos/no-occur (esort (lsucc (lvar z))) no-self-ref/sort)
       ([x]
         ([y]
           (ctor-spine/result
             (applies-self/app
               (applies-self/app (applies-self/app applies-self/refl)))))))).

RBTree_leaf/cmem : cmem "RBTree.leaf" (ccons "RBTree.leaf" (ccons "RBTree.red" (ccons "RBTree.black" cnil)))
   = cmem/here.

