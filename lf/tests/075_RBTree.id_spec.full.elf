%%% Expected outcome: accept
%%% Reduction behavior of `RBTree.rec`
sneq/0 : string-neq "Color.r" "Color.b".
sneq/1 : string-neq "N.zero" "N.succ".
sneq/2 : string-neq "RBTree.red" "RBTree.black".
sneq/3 : string-neq "RBTree.leaf" "RBTree.black".
sneq/4 : string-neq "RBTree.leaf" "RBTree.red".
sneq/5 : string-neq "N" "RBTree".
sneq/6 : string-neq "Color" "RBTree".

%% inductive Color
Color/type-wf : of (esort (lsucc lzero)) (esort (lsucc (lsucc lzero)))
   = defeq/sort-refl.

Color/ends-in-sort : ends-in-sort (esort (lsucc lzero))
   = ends-in-sort/sort.

Color/rec-name : name "Color.rec" (is-rec-for "Color").

Color/eisl : ends-in-sort-with-level (esort (lsucc lzero)) (lsucc lzero)
   = ends-in-sort-with-level/sort.

Color/cnd : cnames-distinct (ccons "Color.r" (ccons "Color.b" cnil))
   = (cnames-distinct/cons
       (cnames-distinct/cons cnames-distinct/nil all-string-neq/nil)
       (all-string-neq/cons sneq/0 all-string-neq/nil)).

Color/name : name "Color" (is-decl (esort (lsucc lzero)) (indt (ccons "Color.r" (ccons "Color.b" cnil)) z)).

Color/decl : declared "Color" (esort (lsucc lzero)) (indt (ccons "Color.r" (ccons "Color.b" cnil)) z)
   = declared/ok-indt Color/name Color/rec-name Color/cnd (dkind-ok/indt Color/type-wf Color/ends-in-sort).

%% ctor Color.r (of Color)
Color_r/type-wf : of (econst "Color" lnil) (esort (lsucc lzero))
   = (defeq/const Color/decl (inst-expr/sort (inst-lvl/succ inst-lvl/zero))).

Color_r/positivity : ctor-positive "Color" lnil (econst "Color" lnil)
   = (ctor-positive/intro ([S] S) (ctor-spine/result applies-self/refl)).

Color_r/cmem : cmem "Color.r" (ccons "Color.r" (ccons "Color.b" cnil))
   = cmem/here.

Color_r/fuo : field-universes-ok (econst "Color" lnil) (lsucc lzero)
   = (field-universes-ok/done not-forall/const).

Color_r/name : name "Color.r" (is-decl (econst "Color" lnil) (ctor "Color" z)).

Color_r/decl : declared "Color.r" (econst "Color" lnil) (ctor "Color" z)
   = declared/ok-ctor Color_r/name Color/name Color_r/cmem Color/eisl Color_r/fuo (dkind-ok/ctor Color_r/type-wf Color_r/positivity).

%% ctor Color.b (of Color)
Color_b/type-wf : of (econst "Color" lnil) (esort (lsucc lzero))
   = (defeq/const Color/decl (inst-expr/sort (inst-lvl/succ inst-lvl/zero))).

Color_b/positivity : ctor-positive "Color" lnil (econst "Color" lnil)
   = (ctor-positive/intro ([S] S) (ctor-spine/result applies-self/refl)).

Color_b/cmem : cmem "Color.b" (ccons "Color.r" (ccons "Color.b" cnil))
   = (cmem/there cmem/here).

Color_b/fuo : field-universes-ok (econst "Color" lnil) (lsucc lzero)
   = (field-universes-ok/done not-forall/const).

Color_b/name : name "Color.b" (is-decl (econst "Color" lnil) (ctor "Color" (s z))).

Color_b/decl : declared "Color.b" (econst "Color" lnil) (ctor "Color" (s z))
   = declared/ok-ctor Color_b/name Color/name Color_b/cmem Color/eisl Color_b/fuo (dkind-ok/ctor Color_b/type-wf Color_b/positivity).

%% recursor Color.rec (TCB-derived; informational only)
%%   level params: u
%%   type:   (eforall (eforall (econst "Color" lnil) ([x] (esort (lvar z)))) ([x] (eforall (eapp x (econst "Color.r" lnil)) ([y] (eforall (eapp x (econst "Color.b" lnil)) ([w] (eforall (econst "Color" lnil) ([v] (eapp x v)))))))))
%%   rules:
%%     Color.rec … Color.r … = (elam (eforall (econst "Color" lnil) ([x] (esort (lvar z)))) ([x] (elam (eapp x (econst "Color.r" lnil)) ([y] (elam (eapp x (econst "Color.b" lnil)) ([w] y))))))   (0 fields)
%%     Color.rec … Color.b … = (elam (eforall (econst "Color" lnil) ([x] (esort (lvar z)))) ([x] (elam (eapp x (econst "Color.r" lnil)) ([y] (elam (eapp x (econst "Color.b" lnil)) ([w] w))))))   (0 fields)

%% inductive N
N/type-wf : of (esort (lsucc lzero)) (esort (lsucc (lsucc lzero)))
   = defeq/sort-refl.

N/ends-in-sort : ends-in-sort (esort (lsucc lzero))
