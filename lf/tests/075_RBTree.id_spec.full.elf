Color_b/fuo : field-universes-ok-skip-params liz (econst "Color" lnil) (lsucc lzero)
   = (field-universes-ok-skip-params/start
       (field-universes-ok/done not-forall/const)).

Color_b/name : name "Color.b" (is-decl (econst "Color" lnil) (ctor "Color" (lis liz))).

Color_b/decl : declared "Color.b" (econst "Color" lnil) (ctor "Color" (lis liz))
   = declared/ok-ctor Color_b/name Color/name Color_b/cmem Color_b/eisl Color_b/fuo (dkind-ok/ctor Color_b/type-wf Color_b/positivity).

%% recursor Color.rec
Color_rec/type-wf-sort : lvl
   = (limax
       (limax (lsucc lzero) (lsucc (lvar liz)))
       (limax (lvar liz) (limax (lvar liz) (limax (lsucc lzero) (lvar liz))))).

Color_rec/type-wf : of
  (eforall (eforall (econst "Color" lnil) ([x] (esort (lvar liz))))
    ([x] (eforall (eapp x (econst "Color.r" lnil)) ([y] (eforall (eapp x (econst "Color.b" lnil)) ([z] (eforall (econst "Color" lnil) ([w] (eapp x w)))))))))
  (esort Color_rec/type-wf-sort)
   = (defeq/forall
       (defeq/forall
         (defeq/const Color/decl (inst-expr/sort (lvl-inst/succ lvl-inst/zero)))
         ([x] ([h] defeq/sort-refl)))
       ([x]
         ([h]
           (defeq/forall
             (defeq/app
               h
               (defeq/const Color_r/decl (inst-expr/const lvls-inst/nil)))
             ([y]
               ([h1]
                 (defeq/forall
                   (defeq/app
                     h
                     (defeq/const Color_b/decl (inst-expr/const lvls-inst/nil)))
                   ([z]
                     ([h2]
                       (defeq/forall
                         (defeq/const
                           Color/decl
                           (inst-expr/sort (lvl-inst/succ lvl-inst/zero)))
                         ([w] ([h3] (defeq/app h h3))))))))))))).

Color_rec/decl : declared "Color.rec"
  (eforall (eforall (econst "Color" lnil) ([x] (esort (lvar liz))))
    ([x] (eforall (eapp x (econst "Color.r" lnil)) ([y] (eforall (eapp x (econst "Color.b" lnil)) ([z] (eforall (econst "Color" lnil) ([w] (eapp x w)))))))))
  (irec "Color")
   = declared/ok-irec Color/rec-name (dkind-ok/irec Color_rec/type-wf).

%% inductive N
N/type-wf-sort : lvl
   = (lsucc (lsucc lzero)).

N/type-wf : of (esort (lsucc lzero)) (esort N/type-wf-sort)
   = defeq/sort-refl.

N/ends-in-sort : ends-in-sort (esort (lsucc lzero))
