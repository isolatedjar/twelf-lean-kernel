%% ctor N.zero (of N)
N_zero/type-wf : of (econst "N" lnil) (esort (lsucc lzero))
   = (defeq/const N/decl (inst-expr/sort (inst-lvl/succ inst-lvl/zero))).

N_zero/positivity : ctor-positive "N" lnil (econst "N" lnil)
   = (ctor-positive/intro ([S] S) (ctor-spine/result applies-self/refl)).

N_zero/cmem : cmem "N.zero" (ccons "N.zero" (ccons "N.succ" cnil))
   = cmem/here.

N_zero/fuo : field-universes-ok (econst "N" lnil) (lsucc lzero)
   = (field-universes-ok/done not-forall/const).

