E_a/name : name "E.a" (is-decl (econst "E" lnil) (ctor "E" z)).

E_a/decl : declared "E.a" (econst "E" lnil) (ctor "E" z)
   = declared/ok-ctor E_a/name E/name E_a/cmem E/eisl E_a/fuo (dkind-ok/ctor E_a/type-wf E_a/positivity).

