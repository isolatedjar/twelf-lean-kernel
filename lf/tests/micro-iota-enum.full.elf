%% recursor E.rec (TCB-derived; informational only)
%%   level params: u
%%   type:   (eforall (eforall (econst "E" lnil) ([x] (esort (lvar z)))) ([x] (eforall (eapp x (econst "E.a" lnil)) ([y] (eforall (eapp x (econst "E.b" lnil)) ([w] (eforall (econst "E" lnil) ([v] (eapp x v)))))))))
%%   rules:
%%     E.rec … E.a … = (elam (eforall (econst "E" lnil) ([x] (esort (lvar z)))) ([x] (elam (eapp x (econst "E.a" lnil)) ([y] (elam (eapp x (econst "E.b" lnil)) ([w] y))))))   (0 fields)
%%     E.rec … E.b … = (elam (eforall (econst "E" lnil) ([x] (esort (lvar z)))) ([x] (elam (eapp x (econst "E.a" lnil)) ([y] (elam (eapp x (econst "E.b" lnil)) ([w] w))))))   (0 fields)

%% def rfl
rfl/type-wf : of (eforall (esort (lvar z)) ([x] (eforall x ([y] (eapp (eapp (eapp (econst "Eq" (lcons (lvar z) lnil)) x) y) y))))) (esort (limax (lsucc (lvar z)) (limax (lvar z) lzero)))
   = (defeq/forall
       defeq/sort-refl
       ([x]
         ([h]
           (defeq/forall
             h
             ([y]
               ([h1]
                 (defeq/app
                   (defeq/app
                     (defeq/app
                       (defeq/const
                         Eq/decl
                         (inst-expr/forall
                           (inst-expr/sort (inst-lvl/var nth-lvl/z))
                           ([x]
                             ([h]
                               (inst-expr/forall
                                 h
                                 ([y]
                                   ([h1]
                                     (inst-expr/forall
                                       h
                                       ([w]
                                         ([h2]
                                           (inst-expr/sort
                                             inst-lvl/zero)))))))))))
                       h)
                     h1)
                   h1))))))).

rfl/value-typed : of
  (elam (esort (lvar z)) ([x] (elam x ([y] (eapp (eapp (econst "Eq.refl" (lcons (lvar z) lnil)) x) y)))))
  (eforall (esort (lvar z)) ([x] (eforall x ([y] (eapp (eapp (eapp (econst "Eq" (lcons (lvar z) lnil)) x) y) y)))))
   = (defeq/lam
       defeq/sort-refl
       ([x]
         ([h]
           (defeq/lam
             h
             ([y]
               ([h1]
                 (defeq/app
                   (defeq/app
                     (defeq/const
                       Eq_refl/decl
                       (inst-expr/forall
                         (inst-expr/sort (inst-lvl/var nth-lvl/z))
                         ([x]
                           ([h]
                             (inst-expr/forall
                               h
                               ([y]
                                 ([h1]
                                   (inst-expr/app
                                     (inst-expr/app
                                       (inst-expr/app
                                         (inst-expr/const
                                           (inst-lvls/cons
                                             inst-lvls/nil
                                             (inst-lvl/var nth-lvl/z)))
                                         h)
                                       h1)
                                     h1))))))))
                     h)
                   h1))))))).

rfl/name : name "rfl" (is-decl
  (eforall (esort (lvar z)) ([x] (eforall x ([y] (eapp (eapp (eapp (econst "Eq" (lcons (lvar z) lnil)) x) y) y)))))
  (defn (elam (esort (lvar z)) ([x] (elam x ([y] (eapp (eapp (econst "Eq.refl" (lcons (lvar z) lnil)) x) y))))))).

rfl/decl : declared "rfl"
  (eforall (esort (lvar z)) ([x] (eforall x ([y] (eapp (eapp (eapp (econst "Eq" (lcons (lvar z) lnil)) x) y) y)))))
  (defn (elam (esort (lvar z)) ([x] (elam x ([y] (eapp (eapp (econst "Eq.refl" (lcons (lvar z) lnil)) x) y))))))
   = declared/ok rfl/name dkind-non-inductive/defn (dkind-ok/defn rfl/type-wf rfl/value-typed).

%% thm iotaEnum
iotaEnum/type-wf : of
  (eapp (eapp (eapp (econst "Eq" (lcons (lsucc lzero) lnil)) (econst "Bool" lnil))
    (eapp (eapp (eapp (eapp (econst "E.rec" (lcons (lsucc lzero) lnil)) (elam (econst "E" lnil) ([x] (econst "Bool" lnil)))) (econst "Bool.true" lnil)) (econst "Bool.false" lnil))
      (econst "E.a" lnil)))
    (econst "Bool.true" lnil))
  (esort lzero)
   = (defeq/app
       (defeq/app
         (defeq/app
           (defeq/const
             Eq/decl
             (inst-expr/forall
               (inst-expr/sort (inst-lvl/var nth-lvl/z))
               ([x]
                 ([h]
                   (inst-expr/forall
                     h
                     ([y]
                       ([h1]
                         (inst-expr/forall
                           h
                           ([w] ([h2] (inst-expr/sort inst-lvl/zero)))))))))))
           (defeq/const
             Bool/decl
             (inst-expr/sort (inst-lvl/succ inst-lvl/zero))))
         (defeq/conv
           (defeq/trans
             (defeq/beta
               ([x]
                 ([h]
                   (defeq/const
                     Bool/decl
                     (inst-expr/sort (inst-lvl/succ inst-lvl/zero)))))
               (defeq/const E_a/decl (inst-expr/const inst-lvls/nil)))
             (defeq/const
               Bool/decl
               (inst-expr/sort (inst-lvl/succ inst-lvl/zero))))
           (defeq/app
             (defeq/app
               (defeq/app
                 (defeq/app
                   (defeq/const
                     (rec-derived-declared
                       (rec-derived/enum
                         E/decl
                         E/rec-name
                         (enum-rec-type/intro
                           ([x]
                             ([h]
                               (enum-rec-body/minor
                                 ([y]
                                   ([h1]
                                     (enum-rec-body/minor
                                       ([w] ([h2] enum-rec-body/done)))))))))
                         E/eisl
                         (le-eligible/non-prop leq-lvl/self))
                       E/rec-name)
                     (inst-expr/forall
                       (inst-expr/forall
                         (inst-expr/const inst-lvls/nil)
                         ([x] ([h] (inst-expr/sort (inst-lvl/var nth-lvl/z)))))
                       ([x]
                         ([h]
                           (inst-expr/forall
                             (inst-expr/app h (inst-expr/const inst-lvls/nil))
                             ([y]
                               ([h1]
                                 (inst-expr/forall
                                   (inst-expr/app
                                     h
                                     (inst-expr/const inst-lvls/nil))
                                   ([w]
                                     ([h2]
                                       (inst-expr/forall
                                         (inst-expr/const inst-lvls/nil)
                                         ([v]
                                           ([h3]
                                             (inst-expr/app h h3))))))))))))))
                   (defeq/lam
                     (defeq/const
                       E/decl
                       (inst-expr/sort (inst-lvl/succ inst-lvl/zero)))
                     ([x]
                       ([h]
                         (defeq/const
                           Bool/decl
                           (inst-expr/sort (inst-lvl/succ inst-lvl/zero)))))))
                 (defeq/conv
                   (defeq/trans
                     (defeq/const
                       Bool/decl
                       (inst-expr/sort (inst-lvl/succ inst-lvl/zero)))
                     (defeq/symm
                       (defeq/beta
                         ([x]
                           ([h]
                             (defeq/const
                               Bool/decl
                               (inst-expr/sort (inst-lvl/succ inst-lvl/zero)))))
                         (defeq/const
                           E_a/decl
                           (inst-expr/const inst-lvls/nil)))))
                   (defeq/const
                     Bool_true/decl
                     (inst-expr/const inst-lvls/nil))))
               (defeq/conv
                 (defeq/trans
                   (defeq/const
                     Bool/decl
                     (inst-expr/sort (inst-lvl/succ inst-lvl/zero)))
                   (defeq/symm
                     (defeq/beta
                       ([x]
                         ([h]
                           (defeq/const
                             Bool/decl
                             (inst-expr/sort (inst-lvl/succ inst-lvl/zero)))))
                       (defeq/const E_b/decl (inst-expr/const inst-lvls/nil)))))
                 (defeq/const Bool_false/decl (inst-expr/const inst-lvls/nil))))
             (defeq/const E_a/decl (inst-expr/const inst-lvls/nil)))))
       (defeq/const Bool_true/decl (inst-expr/const inst-lvls/nil))).

%%% HOLE
iotaEnum/value-typed : of
  (eapp (eapp (econst "rfl" (lcons (lsucc lzero) lnil)) (econst "Bool" lnil))
    (eapp (eapp (eapp (eapp (econst "E.rec" (lcons (lsucc lzero) lnil)) (elam (econst "E" lnil) ([x] (econst "Bool" lnil)))) (econst "Bool.true" lnil)) (econst "Bool.false" lnil))
      (econst "E.a" lnil)))
  (eapp (eapp (eapp (econst "Eq" (lcons (lsucc lzero) lnil)) (econst "Bool" lnil))
    (eapp (eapp (eapp (eapp (econst "E.rec" (lcons (lsucc lzero) lnil)) (elam (econst "E" lnil) ([x] (econst "Bool" lnil)))) (econst "Bool.true" lnil)) (econst "Bool.false" lnil))
      (econst "E.a" lnil)))
    (econst "Bool.true" lnil)).

iotaEnum/name : name "iotaEnum" (is-decl
  (eapp (eapp (eapp (econst "Eq" (lcons (lsucc lzero) lnil)) (econst "Bool" lnil))
    (eapp (eapp (eapp (eapp (econst "E.rec" (lcons (lsucc lzero) lnil)) (elam (econst "E" lnil) ([x] (econst "Bool" lnil)))) (econst "Bool.true" lnil)) (econst "Bool.false" lnil))
