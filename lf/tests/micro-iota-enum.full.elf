%% ctor E.a (of E)
E_a/type-wf : of (econst "E" lnil) (esort (lsucc lzero))
   = (defeq/const E/decl (inst-expr/sort (inst-lvl/succ inst-lvl/zero))).

E_a/positivity : ctor-positive "E" lnil (econst "E" lnil)
   = (ctor-positive/intro ([S] S) (ctor-spine/result applies-self/refl)).

E_a/cmem : cmem "E.a" (ccons "E.a" (ccons "E.b" cnil))
   = cmem/here.

E_a/fuo : field-universes-ok (econst "E" lnil) (lsucc lzero)
