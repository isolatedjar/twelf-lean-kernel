E/name : name "E" (is-decl (esort (lsucc lzero)) (indt (ccons "E.a" (ccons "E.b" cnil)) z)).

E/decl : declared "E" (esort (lsucc lzero)) (indt (ccons "E.a" (ccons "E.b" cnil)) z)
