%%% Expected outcome: reject
%%% Regression test for undefined behavior in `lazy_delta_reduction_step` in the official kernel
%%% 
%%% In the function `lazy_delta_reduction_step`, the official kernel expects `unfold_definition`
%%% to always succeed. However, if the constant has an incorrect number of level parameters, it
%%% actually fails, which leads to memory corruption in `lazy_delta_reduction_step`.
%%% 
%%% This test is to check that the official kernel and also other kernels that closely follow the
%%% logic of the official kernel correctly handle this unfolding failure.
%%% 
%%% The issue in the official kernel was originally reported as <https://github.com/leanprover/lean4/issues/10577>.
%solve nonneg_0 : 0 >= 0.

%% inductive Nat
Nat/type-wf-sort : lvl
   = (lsucc (lsucc lzero)).

Nat/type-wf : of (esort (lsucc lzero)) (esort Nat/type-wf-sort)
   = defeq/sort-refl.

Nat/ends-in-sort : ends-in-sort (esort (lsucc lzero))
   = ends-in-sort/sort.

Nat/rec-name : name "Nat.rec" (is-rec-for "Nat").

Nat/name : name "Nat" (is-decl (esort (lsucc lzero)) indt).

Nat/decl : declared "Nat" (esort (lsucc lzero)) indt
   = declared/ok Nat/name (dkind-ok/indt Nat/type-wf Nat/ends-in-sort).

%% ctor Nat.zero (of Nat)
Nat_zero/type-wf-sort : lvl
   = (lsucc lzero).

Nat_zero/type-wf : of (econst "Nat" lnil) (esort Nat_zero/type-wf-sort)
   = (defeq/const Nat/decl (inst-expr/sort (lvl-inst/succ lvl-inst/zero))).

Nat_zero/positivity : ctor-positive "Nat" lnil (econst "Nat" lnil)
   = (ctor-positive/intro ([S] S) (ctor-spine/result applies-self/refl)).

Nat_zero/eisl : ends-in-sort-with-level (esort (lsucc lzero)) (lsucc lzero)
   = ends-in-sort-with-level/sort.

%%% HOLE: Nat_zero/fuo — prover for field-universes-ok-skip-params not yet implemented
Nat_zero/fuo : field-universes-ok-skip-params liz (econst "Nat" lnil) (lsucc lzero).

Nat_zero/name : name "Nat.zero" (is-decl (econst "Nat" lnil) ctor).

Nat_zero/decl : declared "Nat.zero" (econst "Nat" lnil) ctor
   = declared/ok Nat_zero/name (dkind-ok/ctor Nat_zero/type-wf Nat_zero/positivity Nat/decl Nat_zero/eisl Nat_zero/fuo).

%% ctor Nat.succ (of Nat)
Nat_succ/type-wf-sort : lvl
   = (limax (lsucc lzero) (lsucc lzero)).

Nat_succ/type-wf : of (eforall (econst "Nat" lnil) ([x] (econst "Nat" lnil))) (esort Nat_succ/type-wf-sort)
   = (defeq/forall
       (defeq/const Nat/decl (inst-expr/sort (lvl-inst/succ lvl-inst/zero)))
       ([x]
         ([h]
           (defeq/const
             Nat/decl
             (inst-expr/sort (lvl-inst/succ lvl-inst/zero)))))).

Nat_succ/positivity : ctor-positive "Nat" lnil (eforall (econst "Nat" lnil) ([x] (econst "Nat" lnil)))
   = (ctor-positive/intro ([S] (eforall S ([x] S))) (ctor-spine/arg
       (strict-pos/head applies-self/refl)
       ([x] ([y] (ctor-spine/result applies-self/refl))))).

Nat_succ/eisl : ends-in-sort-with-level (esort (lsucc lzero)) (lsucc lzero)
   = ends-in-sort-with-level/sort.

%%% HOLE: Nat_succ/fuo — prover for field-universes-ok-skip-params not yet implemented
Nat_succ/fuo : field-universes-ok-skip-params liz (eforall (econst "Nat" lnil) ([x] (econst "Nat" lnil))) (lsucc lzero).

Nat_succ/name : name "Nat.succ" (is-decl (eforall (econst "Nat" lnil) ([x] (econst "Nat" lnil))) ctor).

Nat_succ/decl : declared "Nat.succ" (eforall (econst "Nat" lnil) ([x] (econst "Nat" lnil))) ctor
   = declared/ok Nat_succ/name (dkind-ok/ctor Nat_succ/type-wf Nat_succ/positivity Nat/decl Nat_succ/eisl Nat_succ/fuo).

%% recursor Nat.rec
Nat_rec/type-wf-sort : lvl
   = (limax
       (limax (lsucc lzero) (lsucc (lvar liz)))
       (limax
         (lvar liz)
         (limax
           (limax (lsucc lzero) (limax (lvar liz) (lvar liz)))
           (limax (lsucc lzero) (lvar liz))))).

Nat_rec/type-wf : of (eforall (eforall (econst "Nat" lnil) ([x] (esort (lvar liz))))
                    ([x]
                      (eforall (eapp x (econst "Nat.zero" lnil))
                        ([y]
                          (eforall (eforall (econst "Nat" lnil) ([z] (eforall (eapp x z) ([w] (eapp x (eapp (econst "Nat.succ" lnil) z))))))
                            ([z] (eforall (econst "Nat" lnil) ([w] (eapp x w))))))))) (esort Nat_rec/type-wf-sort)
   = (defeq/forall
       (defeq/forall
         (defeq/const Nat/decl (inst-expr/sort (lvl-inst/succ lvl-inst/zero)))
         ([x] ([h] defeq/sort-refl)))
       ([x]
         ([h]
           (defeq/forall
             (defeq/app
               h
               (defeq/const Nat_zero/decl (inst-expr/const lvls-inst/nil)))
             ([y]
               ([h1]
                 (defeq/forall
                   (defeq/forall
                     (defeq/const
                       Nat/decl
                       (inst-expr/sort (lvl-inst/succ lvl-inst/zero)))
                     ([z]
                       ([h2]
                         (defeq/forall
                           (defeq/app h h2)
                           ([w]
                             ([h3]
                               (defeq/app
                                 h
                                 (defeq/app
                                   (defeq/const
                                     Nat_succ/decl
                                     (inst-expr/forall
                                       (inst-expr/const lvls-inst/nil)
                                       ([x]
                                         ([h]
                                           (inst-expr/const lvls-inst/nil)))))
                                   h2))))))))
                   ([z]
                     ([h2]
                       (defeq/forall
                         (defeq/const
                           Nat/decl
                           (inst-expr/sort (lvl-inst/succ lvl-inst/zero)))
                         ([w] ([h3] (defeq/app h h3))))))))))))).

Nat_rec/decl : declared "Nat.rec" (eforall (eforall (econst "Nat" lnil) ([x] (esort (lvar liz)))) ([x] (eforall (eapp x (econst "Nat.zero" lnil)) ([y] (eforall (eforall (econst "Nat" lnil) ([z] (eforall (eapp x z) ([w] (eapp x (eapp (econst "Nat.succ" lnil) z)))))) ([z] (eforall (econst "Nat" lnil) ([w] (eapp x w))))))))) irec
   = declared/ok-irec Nat/rec-name (dkind-ok/irec Nat_rec/type-wf).

%% inductive Eq
Eq/type-wf-sort : lvl
   = (limax
       (lsucc (lvar liz))
       (limax (lvar liz) (limax (lvar liz) (lsucc lzero)))).

Eq/type-wf : of (eforall (esort (lvar liz)) ([x] (eforall x ([y] (eforall x ([z] (esort lzero))))))) (esort Eq/type-wf-sort)
   = (defeq/forall
       defeq/sort-refl
       ([x]
         ([h]
           (defeq/forall
             h
             ([y] ([h1] (defeq/forall h ([z] ([h2] defeq/sort-refl))))))))).

Eq/ends-in-sort : ends-in-sort (eforall (esort (lvar liz)) ([x] (eforall x ([y] (eforall x ([z] (esort lzero)))))))
   = (ends-in-sort/forall
       ([x]
         (ends-in-sort/forall
           ([y] (ends-in-sort/forall ([z] ends-in-sort/sort)))))).

Eq/rec-name : name "Eq.rec" (is-rec-for "Eq").

Eq/name : name "Eq" (is-decl (eforall (esort (lvar liz)) ([x] (eforall x ([y] (eforall x ([z] (esort lzero))))))) indt).

Eq/decl : declared "Eq" (eforall (esort (lvar liz)) ([x] (eforall x ([y] (eforall x ([z] (esort lzero))))))) indt
   = declared/ok Eq/name (dkind-ok/indt Eq/type-wf Eq/ends-in-sort).

%% ctor Eq.refl (of Eq)
Eq_refl/type-wf-sort : lvl
   = (limax (lsucc (lvar liz)) (limax (lvar liz) lzero)).

Eq_refl/type-wf : of (eforall (esort (lvar liz)) ([x] (eforall x ([y] (eapp (eapp (eapp (econst "Eq" (lcons (lvar liz) lnil)) x) y) y))))) (esort Eq_refl/type-wf-sort)
   = (defeq/forall
       defeq/sort-refl
       ([x]
         ([h]
           (defeq/forall
             h
             ([y]
               ([h1]
                 (defeq/app
                   (defeq/app
                     (defeq/app
                       (defeq/const
                         Eq/decl
                         (inst-expr/forall
                           (inst-expr/sort (lvl-inst/var lvl-nth/zero))
                           ([x]
                             ([h]
                               (inst-expr/forall
                                 h
                                 ([y]
                                   ([h1]
                                     (inst-expr/forall
                                       h
                                       ([z]
                                         ([h2]
                                           (inst-expr/sort
                                             lvl-inst/zero)))))))))))
                       h)
                     h1)
                   h1))))))).

Eq_refl/positivity : ctor-positive "Eq" (lcons (lvar liz) lnil) (eforall (esort (lvar liz)) ([x] (eforall x ([y] (eapp (eapp (eapp (econst "Eq" (lcons (lvar liz) lnil)) x) y) y)))))
   = (ctor-positive/intro ([S] (eforall (esort (lvar liz)) ([x] (eforall x ([y] (eapp (eapp (eapp S x) y) y)))))) (ctor-spine/arg
       (strict-pos/no-occur (esort (lvar liz)) no-self-ref/sort)
       ([x]
         ([y]
           (ctor-spine/arg
             (strict-pos/no-occur x y)
             ([z]
               ([w]
                 (ctor-spine/result
                   (applies-self/app
                     (applies-self/app
                       (applies-self/app applies-self/refl))))))))))).

Eq_refl/eisl : ends-in-sort-with-level (eforall (esort (lvar liz)) ([x] (eforall x ([y] (eforall x ([z] (esort lzero))))))) lzero
   = (ends-in-sort-with-level/forall
       ([x]
         (ends-in-sort-with-level/forall
           ([y]
             (ends-in-sort-with-level/forall
               ([z] ends-in-sort-with-level/sort)))))).

%%% HOLE: Eq_refl/fuo — prover for field-universes-ok-skip-params not yet implemented
Eq_refl/fuo : field-universes-ok-skip-params (lis (lis liz)) (eforall (esort (lvar liz)) ([x] (eforall x ([y] (eapp (eapp (eapp (econst "Eq" (lcons (lvar liz) lnil)) x) y) y))))) lzero.

Eq_refl/name : name "Eq.refl" (is-decl (eforall (esort (lvar liz)) ([x] (eforall x ([y] (eapp (eapp (eapp (econst "Eq" (lcons (lvar liz) lnil)) x) y) y))))) ctor).

Eq_refl/decl : declared "Eq.refl" (eforall (esort (lvar liz)) ([x] (eforall x ([y] (eapp (eapp (eapp (econst "Eq" (lcons (lvar liz) lnil)) x) y) y))))) ctor
   = declared/ok Eq_refl/name (dkind-ok/ctor Eq_refl/type-wf Eq_refl/positivity Eq/decl Eq_refl/eisl Eq_refl/fuo).

%% recursor Eq.rec
Eq_rec/type-wf-sort : lvl
   = (limax
       (lsucc (lvar (lis liz)))
       (limax
         (lvar (lis liz))
         (limax
           (limax (lvar (lis liz)) (limax lzero (lsucc (lvar liz))))
           (limax
             (lvar liz)
             (limax (lvar (lis liz)) (limax lzero (lvar liz))))))).

Eq_rec/type-wf : of (eforall (esort (lvar (lis liz)))
                   ([x]
                     (eforall x
                       ([y]
                         (eforall (eforall x ([z] (eforall (eapp (eapp (eapp (econst "Eq" (lcons (lvar (lis liz)) lnil)) x) y) z) ([w] (esort (lvar liz))))))
                           ([z]
                             (eforall (eapp (eapp z y) (eapp (eapp (econst "Eq.refl" (lcons (lvar (lis liz)) lnil)) x) y))
                               ([w]
                                 (eforall x ([x1] (eforall (eapp (eapp (eapp (econst "Eq" (lcons (lvar (lis liz)) lnil)) x) y) x1) ([y1] (eapp (eapp z x1) y1))))))))))))) (esort Eq_rec/type-wf-sort)
   = (defeq/forall
       defeq/sort-refl
       ([x]
         ([h]
           (defeq/forall
             h
             ([y]
               ([h1]
                 (defeq/forall
                   (defeq/forall
                     h
                     ([z]
                       ([h2]
                         (defeq/forall
                           (defeq/app
                             (defeq/app
                               (defeq/app
                                 (defeq/const
                                   Eq/decl
                                   (inst-expr/forall
                                     (inst-expr/sort
                                       (lvl-inst/var lvl-nth/zero))
                                     ([x]
                                       ([h]
                                         (inst-expr/forall
                                           h
                                           ([y]
                                             ([h1]
                                               (inst-expr/forall
                                                 h
                                                 ([z]
                                                   ([h2]
                                                     (inst-expr/sort
                                                       lvl-inst/zero)))))))))))
                                 h)
                               h1)
                             h2)
                           ([w] ([h3] defeq/sort-refl))))))
                   ([z]
                     ([h2]
                       (defeq/forall
                         (defeq/app
                           (defeq/app h2 h1)
                           (defeq/app
                             (defeq/app
                               (defeq/const
                                 Eq_refl/decl
                                 (inst-expr/forall
                                   (inst-expr/sort (lvl-inst/var lvl-nth/zero))
                                   ([x]
                                     ([h]
                                       (inst-expr/forall
                                         h
                                         ([y]
                                           ([h1]
                                             (inst-expr/app
                                               (inst-expr/app
                                                 (inst-expr/app
                                                   (inst-expr/const
                                                     (lvls-inst/cons
                                                       (lvl-inst/var
                                                         lvl-nth/zero)
                                                       lvls-inst/nil))
                                                   h)
                                                 h1)
                                               h1))))))))
                               h)
                             h1))
                         ([w]
                           ([h3]
                             (defeq/forall
                               h
                               ([x1]
                                 ([h4]
                                   (defeq/forall
                                     (defeq/app
                                       (defeq/app
                                         (defeq/app
                                           (defeq/const
                                             Eq/decl
                                             (inst-expr/forall
                                               (inst-expr/sort
                                                 (lvl-inst/var lvl-nth/zero))
                                               ([x]
                                                 ([h]
                                                   (inst-expr/forall
                                                     h
                                                     ([y]
                                                       ([h1]
                                                         (inst-expr/forall
                                                           h
                                                           ([z]
                                                             ([h2]
                                                               (inst-expr/sort
                                                                 lvl-inst/zero)))))))))))
                                           h)
                                         h1)
                                       h4)
                                     ([y1]
                                       ([h5]
                                         (defeq/app
                                           (defeq/app h2 h4)
                                           h5))))))))))))))))))).

Eq_rec/decl : declared "Eq.rec" (eforall (esort (lvar (lis liz))) ([x] (eforall x ([y] (eforall (eforall x ([z] (eforall (eapp (eapp (eapp (econst "Eq" (lcons (lvar (lis liz)) lnil)) x) y) z) ([w] (esort (lvar liz)))))) ([z] (eforall (eapp (eapp z y) (eapp (eapp (econst "Eq.refl" (lcons (lvar (lis liz)) lnil)) x) y)) ([w] (eforall x ([x1] (eforall (eapp (eapp (eapp (econst "Eq" (lcons (lvar (lis liz)) lnil)) x) y) x1) ([y1] (eapp (eapp z x1) y1))))))))))))) irec
   = declared/ok-irec Eq/rec-name (dkind-ok/irec Eq_rec/type-wf).

%% inductive False
False/type-wf-sort : lvl
   = (lsucc lzero).

False/type-wf : of (esort lzero) (esort False/type-wf-sort)
   = defeq/sort-refl.

False/ends-in-sort : ends-in-sort (esort lzero)
   = ends-in-sort/sort.

False/rec-name : name "False.rec" (is-rec-for "False").

False/name : name "False" (is-decl (esort lzero) indt).

False/decl : declared "False" (esort lzero) indt
   = declared/ok False/name (dkind-ok/indt False/type-wf False/ends-in-sort).

%% recursor False.rec
False_rec/type-wf-sort : lvl
   = (limax (limax lzero (lsucc (lvar liz))) (limax lzero (lvar liz))).

False_rec/type-wf : of (eforall (eforall (econst "False" lnil) ([x] (esort (lvar liz)))) ([x] (eforall (econst "False" lnil) ([y] (eapp x y))))) (esort False_rec/type-wf-sort)
   = (defeq/forall
       (defeq/forall
         (defeq/const False/decl (inst-expr/sort lvl-inst/zero))
         ([x] ([h] defeq/sort-refl)))
       ([x]
         ([h]
           (defeq/forall
             (defeq/const False/decl (inst-expr/sort lvl-inst/zero))
             ([y] ([h1] (defeq/app h h1))))))).

False_rec/decl : declared "False.rec" (eforall (eforall (econst "False" lnil) ([x] (esort (lvar liz)))) ([x] (eforall (econst "False" lnil) ([y] (eapp x y))))) irec
   = declared/ok-irec False/rec-name (dkind-ok/irec False_rec/type-wf).

%% def Not
Not/type-wf-sort : lvl
   = (limax (lsucc lzero) (lsucc lzero)).

Not/type-wf : of (eforall (esort lzero) ([x] (esort lzero))) (esort Not/type-wf-sort)
   = (defeq/forall defeq/sort-refl ([x] ([h] defeq/sort-refl))).

Not/value-typed : of (elam (esort lzero) ([x] (eforall x ([y] (econst "False" lnil))))) (eforall (esort lzero) ([x] (esort lzero)))
   = (defeq/conv
       (defeq/forall
         (defeq/sort-eq lvl-eq/refl)
         ([x]
           ([h]
             (defeq/sort-eq
               (lvl-eq/le
                 (mleq/imax-lzL (mleq/self nonneg_0))
                 (mleq/lz nonneg_0))))))
       (defeq/lam
         defeq/sort-refl
         ([x]
           ([h]
             (defeq/forall
               h
               ([y]
                 ([h1]
                   (defeq/const
                     False/decl
                     (inst-expr/sort lvl-inst/zero))))))))).

Not/name : name "Not" (is-decl (eforall (esort lzero) ([x] (esort lzero))) (defn (elam (esort lzero) ([x] (eforall x ([y] (econst "False" lnil))))))).

Not/decl : declared "Not" (eforall (esort lzero) ([x] (esort lzero))) (defn (elam (esort lzero) ([x] (eforall x ([y] (econst "False" lnil))))))
   = declared/ok Not/name (dkind-ok/defn Not/type-wf Not/value-typed).

%% def Ne
Ne/type-wf-sort : lvl
   = (limax
       (lsucc (lvar liz))
       (limax (lvar liz) (limax (lvar liz) (lsucc lzero)))).

Ne/type-wf : of (eforall (esort (lvar liz)) ([x] (eforall x ([y] (eforall x ([z] (esort lzero))))))) (esort Ne/type-wf-sort)
   = (defeq/forall
       defeq/sort-refl
       ([x]
         ([h]
           (defeq/forall
             h
             ([y] ([h1] (defeq/forall h ([z] ([h2] defeq/sort-refl))))))))).

Ne/value-typed : of (elam (esort (lvar liz))
                   ([x]
                     (elam x
                       ([y]
                         (elam x
                           ([z]
                             (eapp (econst "Not" lnil)
                               (eapp (eapp (eapp (econst "Eq" (lcons (lvar liz) lnil)) x) y) z)))))))) (eforall (esort (lvar liz)) ([x] (eforall x ([y] (eforall x ([z] (esort lzero)))))))
   = (defeq/lam
       defeq/sort-refl
       ([x]
         ([h]
           (defeq/lam
             h
             ([y]
               ([h1]
                 (defeq/lam
                   h
                   ([z]
                     ([h2]
                       (defeq/app
                         (defeq/const
                           Not/decl
                           (inst-expr/forall
                             (inst-expr/sort lvl-inst/zero)
                             ([x] ([h] (inst-expr/sort lvl-inst/zero)))))
                         (defeq/app
                           (defeq/app
                             (defeq/app
                               (defeq/const
                                 Eq/decl
                                 (inst-expr/forall
                                   (inst-expr/sort (lvl-inst/var lvl-nth/zero))
                                   ([x]
                                     ([h]
                                       (inst-expr/forall
                                         h
                                         ([y]
                                           ([h1]
                                             (inst-expr/forall
                                               h
                                               ([z]
                                                 ([h2]
                                                   (inst-expr/sort
                                                     lvl-inst/zero)))))))))))
                               h)
                             h1)
                           h2))))))))))).

Ne/name : name "Ne" (is-decl (eforall (esort (lvar liz)) ([x] (eforall x ([y] (eforall x ([z] (esort lzero))))))) (defn (elam (esort (lvar liz)) ([x] (elam x ([y] (elam x ([z] (eapp (econst "Not" lnil) (eapp (eapp (eapp (econst "Eq" (lcons (lvar liz) lnil)) x) y) z)))))))))).

Ne/decl : declared "Ne" (eforall (esort (lvar liz)) ([x] (eforall x ([y] (eforall x ([z] (esort lzero))))))) (defn (elam (esort (lvar liz)) ([x] (elam x ([y] (elam x ([z] (eapp (econst "Not" lnil) (eapp (eapp (eapp (econst "Eq" (lcons (lvar liz) lnil)) x) y) z)))))))))
   = declared/ok Ne/name (dkind-ok/defn Ne/type-wf Ne/value-typed).

%% inductive True
True/type-wf-sort : lvl
   = (lsucc lzero).

True/type-wf : of (esort lzero) (esort True/type-wf-sort)
   = defeq/sort-refl.

True/ends-in-sort : ends-in-sort (esort lzero)
