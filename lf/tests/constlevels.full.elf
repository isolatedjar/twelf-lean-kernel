                     (leq-lvl/maxL
                       (leq-lvl/imaxLz leq-lvl/self)
                       (leq-lvl/imaxLz leq-lvl/self)))))))))
       (defeq/forall
         defeq/sort-refl
         ([x]
           ([h]
             (defeq/forall
               h
               ([y]
                 ([h1]
                   (defeq/forall
                     h
                     ([w]
                       ([h2]
                         (defeq/forall
                           (defeq/app
                             (defeq/app
                               (defeq/app
                                 (defeq/const
                                   Eq/decl
                                   (inst-expr/forall
                                     (inst-expr/sort (inst-lvl/var nth-lvl/z))
                                     ([x]
