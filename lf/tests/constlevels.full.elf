Ne/value-typed : of
  (elam (esort (lvar z)) ([x] (elam x ([y] (elam x ([w] (eapp (econst "Not" lnil) (eapp (eapp (eapp (econst "Eq" (lcons (lvar z) lnil)) x) y) w))))))))
  (eforall (esort (lvar z)) ([x] (eforall x ([y] (eforall x ([w] (esort lzero)))))))
   = (defeq/lam
       defeq/sort-refl
       ([x]
         ([h]
           (defeq/lam
             h
             ([y]
               ([h1]
                 (defeq/lam
                   h
                   ([w]
                     ([h2]
                       (defeq/app
                         (defeq/const
                           Not/decl
                           (inst-expr/forall
                             (inst-expr/sort inst-lvl/zero)
                             ([x] ([h] (inst-expr/sort inst-lvl/zero)))))
                         (defeq/app
                           (defeq/app
                             (defeq/app
                               (defeq/const
                                 Eq/decl
                                 (inst-expr/forall
                                   (inst-expr/sort (inst-lvl/var nth-lvl/z))
                                   ([x]
                                     ([h]
                                       (inst-expr/forall
                                         h
                                         ([y]
                                           ([h1]
                                             (inst-expr/forall
                                               h
                                               ([w]
                                                 ([h2]
                                                   (inst-expr/sort
                                                     inst-lvl/zero)))))))))))
                               h)
                             h1)
                           h2))))))))))).

Ne/name : name "Ne" (is-decl
  (eforall (esort (lvar z)) ([x] (eforall x ([y] (eforall x ([w] (esort lzero)))))))
  (defn (elam (esort (lvar z)) ([x] (elam x ([y] (elam x ([w] (eapp (econst "Not" lnil) (eapp (eapp (eapp (econst "Eq" (lcons (lvar z) lnil)) x) y) w)))))))))).

