%% def Not
Not/type-wf-sort : lvl
   = (limax (lsucc lzero) (lsucc lzero)).

Not/type-wf : of (eforall (esort lzero) ([x] (esort lzero))) (esort Not/type-wf-sort)
   = (defeq/forall defeq/sort-refl ([x] ([h] defeq/sort-refl))).

Not/value-typed : of (elam (esort lzero) ([x] (eforall x ([y] (econst "False" lnil))))) (eforall (esort lzero) ([x] (esort lzero)))
   = (defeq/conv
       (defeq/forall
         (defeq/sort-eq lvl-eq/refl)
         ([x]
           ([h]
             (defeq/sort-eq
               (lvl-eq/le
                 (mleq/imax-lzL (mleq/self nonneg_0))
                 (mleq/lz nonneg_0))))))
       (defeq/lam
         defeq/sort-refl
         ([x]
           ([h]
             (defeq/forall
               h
               ([y]
                 ([h1]
                   (defeq/const
                     False/decl
                     (inst-expr/sort lvl-inst/zero))))))))).

Not/name : name "Not" (is-decl (eforall (esort lzero) ([x] (esort lzero))) (defn (elam (esort lzero) ([x] (eforall x ([y] (econst "False" lnil))))))).

Not/decl : declared "Not" (eforall (esort lzero) ([x] (esort lzero))) (defn (elam (esort lzero) ([x] (eforall x ([y] (econst "False" lnil))))))
   = declared/ok Not/name dkind-non-inductive/defn (dkind-ok/defn Not/type-wf Not/value-typed).

%% def Ne
Ne/type-wf-sort : lvl
   = (limax
       (lsucc (lvar liz))
       (limax (lvar liz) (limax (lvar liz) (lsucc lzero)))).

Ne/type-wf : of (eforall (esort (lvar liz)) ([x] (eforall x ([y] (eforall x ([z] (esort lzero))))))) (esort Ne/type-wf-sort)
   = (defeq/forall
       defeq/sort-refl
       ([x]
         ([h]
           (defeq/forall
             h
             ([y] ([h1] (defeq/forall h ([z] ([h2] defeq/sort-refl))))))))).

Ne/value-typed : of
  (elam (esort (lvar liz)) ([x] (elam x ([y] (elam x ([z] (eapp (econst "Not" lnil) (eapp (eapp (eapp (econst "Eq" (lcons (lvar liz) lnil)) x) y) z))))))))
  (eforall (esort (lvar liz)) ([x] (eforall x ([y] (eforall x ([z] (esort lzero)))))))
   = (defeq/lam
       defeq/sort-refl
       ([x]
         ([h]
           (defeq/lam
             h
             ([y]
               ([h1]
                 (defeq/lam
                   h
                   ([z]
                     ([h2]
                       (defeq/app
                         (defeq/const
                           Not/decl
                           (inst-expr/forall
                             (inst-expr/sort lvl-inst/zero)
                             ([x] ([h] (inst-expr/sort lvl-inst/zero)))))
                         (defeq/app
                           (defeq/app
                             (defeq/app
                               (defeq/const
                                 Eq/decl
                                 (inst-expr/forall
                                   (inst-expr/sort (lvl-inst/var lvl-nth/zero))
                                   ([x]
                                     ([h]
                                       (inst-expr/forall
                                         h
                                         ([y]
                                           ([h1]
                                             (inst-expr/forall
                                               h
                                               ([z]
                                                 ([h2]
                                                   (inst-expr/sort
                                                     lvl-inst/zero)))))))))))
                               h)
                             h1)
                           h2))))))))))).

Ne/name : name "Ne" (is-decl
  (eforall (esort (lvar liz)) ([x] (eforall x ([y] (eforall x ([z] (esort lzero)))))))
  (defn (elam (esort (lvar liz)) ([x] (elam x ([y] (elam x ([z] (eapp (econst "Not" lnil) (eapp (eapp (eapp (econst "Eq" (lcons (lvar liz) lnil)) x) y) z)))))))))).

Ne/decl : declared "Ne"
  (eforall (esort (lvar liz)) ([x] (eforall x ([y] (eforall x ([z] (esort lzero)))))))
  (defn (elam (esort (lvar liz)) ([x] (elam x ([y] (elam x ([z] (eapp (econst "Not" lnil) (eapp (eapp (eapp (econst "Eq" (lcons (lvar liz) lnil)) x) y) z)))))))))
   = declared/ok Ne/name dkind-non-inductive/defn (dkind-ok/defn Ne/type-wf Ne/value-typed).

