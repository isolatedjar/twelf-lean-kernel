               (inst-expr/sort (inst-lvl/var nth-lvl/z))
               ([x]
                 ([h]
                   (inst-expr/forall
                     h
                     ([y]
                       ([h1]
                         (inst-expr/forall
                           h
                           ([w] ([h2] (inst-expr/sort inst-lvl/zero)))))))))))
           defeq/sort-refl)
         (defeq/const False/decl (inst-expr/sort inst-lvl/zero)))
       (defeq/const True/decl (inst-expr/sort inst-lvl/zero))).

