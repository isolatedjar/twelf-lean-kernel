%%% Expected outcome: reject
%%% Regression test for undefined behavior in `lazy_delta_reduction_step` in the official kernel
%%% 
%%% In the function `lazy_delta_reduction_step`, the official kernel expects `unfold_definition`
%%% to always succeed. However, if the constant has an incorrect number of level parameters, it
%%% actually fails, which leads to memory corruption in `lazy_delta_reduction_step`.
%%% 
%%% This test is to check that the official kernel and also other kernels that closely follow the
%%% logic of the official kernel correctly handle this unfolding failure.
%%% 
%%% The issue in the official kernel was originally reported as <https://github.com/leanprover/lean4/issues/10577>.
%solve nonneg_0 : 0 >= 0.

sneq/0 : string-neq "Nat.zero" "Nat.succ".

%% inductive Nat
Nat/type-wf-sort : lvl
   = (lsucc (lsucc lzero)).

Nat/type-wf : of (esort (lsucc lzero)) (esort Nat/type-wf-sort)
   = defeq/sort-refl.

Nat/ends-in-sort : ends-in-sort (esort (lsucc lzero))
   = ends-in-sort/sort.

Nat/rec-name : name "Nat.rec" (is-rec-for "Nat").

Nat/eisl : ends-in-sort-with-level (esort (lsucc lzero)) (lsucc lzero)
   = ends-in-sort-with-level/sort.

Nat/cnd : cnames-distinct (ccons "Nat.zero" (ccons "Nat.succ" cnil))
   = (cnames-distinct/cons
       (cnames-distinct/cons cnames-distinct/nil all-string-neq/nil)
       (all-string-neq/cons sneq/0 all-string-neq/nil)).

Nat/name : name "Nat" (is-decl (esort (lsucc lzero)) (indt (ccons "Nat.zero" (ccons "Nat.succ" cnil)) liz)).

Nat/decl : declared "Nat" (esort (lsucc lzero)) (indt (ccons "Nat.zero" (ccons "Nat.succ" cnil)) liz)
   = declared/ok-indt Nat/name Nat/rec-name Nat/cnd (dkind-ok/indt Nat/type-wf Nat/ends-in-sort).

%% ctor Nat.zero (of Nat)
Nat_zero/type-wf-sort : lvl
   = (lsucc lzero).

Nat_zero/type-wf : of (econst "Nat" lnil) (esort Nat_zero/type-wf-sort)
   = (defeq/const Nat/decl (inst-expr/sort (lvl-inst/succ lvl-inst/zero))).

Nat_zero/positivity : ctor-positive "Nat" lnil (econst "Nat" lnil)
   = (ctor-positive/intro ([S] S) (ctor-spine/result applies-self/refl)).

Nat_zero/cmem : cmem "Nat.zero" (ccons "Nat.zero" (ccons "Nat.succ" cnil))
   = cmem/here.

Nat_zero/fuo : field-universes-ok (econst "Nat" lnil) (lsucc lzero)
   = (field-universes-ok/done not-forall/const).

Nat_zero/name : name "Nat.zero" (is-decl (econst "Nat" lnil) (ctor "Nat" liz)).

Nat_zero/decl : declared "Nat.zero" (econst "Nat" lnil) (ctor "Nat" liz)
   = declared/ok-ctor Nat_zero/name Nat/name Nat_zero/cmem Nat/eisl Nat_zero/fuo (dkind-ok/ctor Nat_zero/type-wf Nat_zero/positivity).

%% ctor Nat.succ (of Nat)
Nat_succ/type-wf-sort : lvl
   = (limax (lsucc lzero) (lsucc lzero)).

Nat_succ/type-wf : of (eforall (econst "Nat" lnil) ([x] (econst "Nat" lnil))) (esort Nat_succ/type-wf-sort)
   = (defeq/forall
       (defeq/const Nat/decl (inst-expr/sort (lvl-inst/succ lvl-inst/zero)))
       ([x]
         ([h]
           (defeq/const
             Nat/decl
             (inst-expr/sort (lvl-inst/succ lvl-inst/zero)))))).

Nat_succ/positivity : ctor-positive "Nat" lnil (eforall (econst "Nat" lnil) ([x] (econst "Nat" lnil)))
   = (ctor-positive/intro ([S] (eforall S ([x] S))) (ctor-spine/arg
       (strict-pos/head applies-self/refl)
       ([x] ([y] (ctor-spine/result applies-self/refl))))).

Nat_succ/cmem : cmem "Nat.succ" (ccons "Nat.zero" (ccons "Nat.succ" cnil))
   = (cmem/there cmem/here).

Nat_succ/fuo : field-universes-ok (eforall (econst "Nat" lnil) ([x] (econst "Nat" lnil))) (lsucc lzero)
   = (field-universes-ok/forall
       (defeq/const Nat/decl (inst-expr/sort (lvl-inst/succ lvl-inst/zero)))
       (mleq/imax-lsL
         (mleq/sR
           (mleq/maxL
             (mleq/sL (mleq/self nonneg_0))
             (mleq/sL (mleq/self nonneg_0)))))
       ([x] ([h] (field-universes-ok/done not-forall/const)))).

Nat_succ/name : name "Nat.succ" (is-decl (eforall (econst "Nat" lnil) ([x] (econst "Nat" lnil))) (ctor "Nat" (lis liz))).

Nat_succ/decl : declared "Nat.succ" (eforall (econst "Nat" lnil) ([x] (econst "Nat" lnil))) (ctor "Nat" (lis liz))
   = declared/ok-ctor Nat_succ/name Nat/name Nat_succ/cmem Nat/eisl Nat_succ/fuo (dkind-ok/ctor Nat_succ/type-wf Nat_succ/positivity).

%% recursor Nat.rec (TCB-derived; informational only)
%%   level params: u
%%   type:   (eforall (eforall (econst "Nat" lnil) ([x] (esort (lvar liz)))) ([x] (eforall (eapp x (econst "Nat.zero" lnil)) ([y] (eforall (eforall (econst "Nat" lnil) ([z] (eforall (eapp x z) ([w] (eapp x (eapp (econst "Nat.succ" lnil) z)))))) ([z] (eforall (econst "Nat" lnil) ([w] (eapp x w)))))))))
%%   rules:
%%     Nat.rec … Nat.zero … = (elam (eforall (econst "Nat" lnil) ([x] (esort (lvar liz)))) ([x] (elam (eapp x (econst "Nat.zero" lnil)) ([y] (elam (eforall (econst "Nat" lnil) ([z] (eforall (eapp x z) ([w] (eapp x (eapp (econst "Nat.succ" lnil) z)))))) ([z] y))))))   (0 fields)
%%     Nat.rec … Nat.succ … = (elam (eforall (econst "Nat" lnil) ([x] (esort (lvar liz)))) ([x] (elam (eapp x (econst "Nat.zero" lnil)) ([y] (elam (eforall (econst "Nat" lnil) ([z] (eforall (eapp x z) ([w] (eapp x (eapp (econst "Nat.succ" lnil) z)))))) ([z] (elam (econst "Nat" lnil) ([w] (eapp (eapp z w) (eapp (eapp (eapp (eapp (econst "Nat.rec" (lcons (lvar liz) lnil)) x) y) z) w))))))))))   (1 fields)

%% inductive Eq
Eq/type-wf-sort : lvl
   = (limax
       (lsucc (lvar liz))
       (limax (lvar liz) (limax (lvar liz) (lsucc lzero)))).

Eq/type-wf : of (eforall (esort (lvar liz)) ([x] (eforall x ([y] (eforall x ([z] (esort lzero))))))) (esort Eq/type-wf-sort)
   = (defeq/forall
       defeq/sort-refl
       ([x]
         ([h]
           (defeq/forall
             h
             ([y] ([h1] (defeq/forall h ([z] ([h2] defeq/sort-refl))))))))).

Eq/ends-in-sort : ends-in-sort (eforall (esort (lvar liz)) ([x] (eforall x ([y] (eforall x ([z] (esort lzero)))))))
   = (ends-in-sort/forall
       ([x]
         (ends-in-sort/forall
           ([y] (ends-in-sort/forall ([z] ends-in-sort/sort)))))).

Eq/rec-name : name "Eq.rec" (is-rec-for "Eq").

Eq/eisl : ends-in-sort-with-level (eforall (esort (lvar liz)) ([x] (eforall x ([y] (eforall x ([z] (esort lzero))))))) lzero
   = (ends-in-sort-with-level/forall
       ([x]
         (ends-in-sort-with-level/forall
           ([y]
             (ends-in-sort-with-level/forall
               ([z] ends-in-sort-with-level/sort)))))).

Eq/cnd : cnames-distinct (ccons "Eq.refl" cnil)
   = (cnames-distinct/cons cnames-distinct/nil all-string-neq/nil).

Eq/name : name "Eq" (is-decl (eforall (esort (lvar liz)) ([x] (eforall x ([y] (eforall x ([z] (esort lzero))))))) (indt (ccons "Eq.refl" cnil) (lis (lis liz)))).

Eq/decl : declared "Eq" (eforall (esort (lvar liz)) ([x] (eforall x ([y] (eforall x ([z] (esort lzero))))))) (indt (ccons "Eq.refl" cnil) (lis (lis liz)))
   = declared/ok-indt Eq/name Eq/rec-name Eq/cnd (dkind-ok/indt Eq/type-wf Eq/ends-in-sort).

%% ctor Eq.refl (of Eq)
Eq_refl/type-wf-sort : lvl
   = (limax (lsucc (lvar liz)) (limax (lvar liz) lzero)).

Eq_refl/type-wf : of (eforall (esort (lvar liz)) ([x] (eforall x ([y] (eapp (eapp (eapp (econst "Eq" (lcons (lvar liz) lnil)) x) y) y))))) (esort Eq_refl/type-wf-sort)
   = (defeq/forall
       defeq/sort-refl
       ([x]
         ([h]
           (defeq/forall
             h
             ([y]
               ([h1]
                 (defeq/app
                   (defeq/app
                     (defeq/app
                       (defeq/const
                         Eq/decl
                         (inst-expr/forall
                           (inst-expr/sort (lvl-inst/var lvl-nth/zero))
                           ([x]
                             ([h]
                               (inst-expr/forall
                                 h
                                 ([y]
                                   ([h1]
                                     (inst-expr/forall
                                       h
                                       ([z]
                                         ([h2]
                                           (inst-expr/sort
                                             lvl-inst/zero)))))))))))
                       h)
                     h1)
                   h1))))))).

Eq_refl/positivity : ctor-positive "Eq" (lcons (lvar liz) lnil) (eforall (esort (lvar liz)) ([x] (eforall x ([y] (eapp (eapp (eapp (econst "Eq" (lcons (lvar liz) lnil)) x) y) y)))))
   = (ctor-positive/intro ([S] (eforall (esort (lvar liz)) ([x] (eforall x ([y] (eapp (eapp (eapp S x) y) y)))))) (ctor-spine/arg
       (strict-pos/no-occur (esort (lvar liz)) no-self-ref/sort)
       ([x]
         ([y]
           (ctor-spine/arg
             (strict-pos/no-occur x y)
             ([z]
               ([w]
                 (ctor-spine/result
                   (applies-self/app
                     (applies-self/app
                       (applies-self/app applies-self/refl))))))))))).

Eq_refl/cmem : cmem "Eq.refl" (ccons "Eq.refl" cnil)
   = cmem/here.

Eq_refl/fuo : field-universes-ok (eforall (esort (lvar liz)) ([x] (eforall x ([y] (eapp (eapp (eapp (econst "Eq" (lcons (lvar liz) lnil)) x) y) y))))) lzero
   = (field-universes-ok/forall
       defeq/sort-refl
       (mleq/imax-lzL (mleq/self nonneg_0))
       ([x]
         ([h]
           (field-universes-ok/forall
             h
             (mleq/imax-lzL (mleq/self nonneg_0))
             ([y] ([h1] (field-universes-ok/done not-forall/app))))))).

Eq_refl/name : name "Eq.refl" (is-decl (eforall (esort (lvar liz)) ([x] (eforall x ([y] (eapp (eapp (eapp (econst "Eq" (lcons (lvar liz) lnil)) x) y) y))))) (ctor "Eq" liz)).

Eq_refl/decl : declared "Eq.refl" (eforall (esort (lvar liz)) ([x] (eforall x ([y] (eapp (eapp (eapp (econst "Eq" (lcons (lvar liz) lnil)) x) y) y))))) (ctor "Eq" liz)
   = declared/ok-ctor Eq_refl/name Eq/name Eq_refl/cmem Eq/eisl Eq_refl/fuo (dkind-ok/ctor Eq_refl/type-wf Eq_refl/positivity).

%% recursor Eq.rec (TCB-derived; informational only)
%%   level params: u u_1
%%   type:   (eforall (esort (lvar (lis liz))) ([x] (eforall x ([y] (eforall (eforall x ([z] (eforall (eapp (eapp (eapp (econst "Eq" (lcons (lvar (lis liz)) lnil)) x) y) z) ([w] (esort (lvar liz)))))) ([z] (eforall (eapp (eapp z y) (eapp (eapp (econst "Eq.refl" (lcons (lvar (lis liz)) lnil)) x) y)) ([w] (eforall x ([x1] (eforall (eapp (eapp (eapp (econst "Eq" (lcons (lvar (lis liz)) lnil)) x) y) x1) ([y1] (eapp (eapp z x1) y1)))))))))))))
%%   rules:
%%     Eq.rec … Eq.refl … = (elam (esort (lvar (lis liz))) ([x] (elam x ([y] (elam (eforall x ([z] (eforall (eapp (eapp (eapp (econst "Eq" (lcons (lvar (lis liz)) lnil)) x) y) z) ([w] (esort (lvar liz)))))) ([z] (elam (eapp (eapp z y) (eapp (eapp (econst "Eq.refl" (lcons (lvar (lis liz)) lnil)) x) y)) ([w] w))))))))   (0 fields)
%%   K-like reduction: yes

