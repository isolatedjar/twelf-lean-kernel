%%% Expected outcome: accept
%%% Some level computation
%% def levelComp2
levelComp2/type-wf-sort : lvl
   = (lsucc (lsucc (lsucc lzero))).

levelComp2/type-wf : defeq (esort (lsucc (lsucc lzero))) (esort (lsucc (lsucc lzero))) (esort levelComp2/type-wf-sort)
   = defeq/sort-refl.

levelComp2/value-typed : defeq (esort (limax lzero (lsucc lzero))) (esort (limax lzero (lsucc lzero))) (esort (lsucc (lsucc lzero)))
   = (defeq/conv (defeq/sort-eq (lvl-eq/trans (lvl-eq/lsucc-cong lvl-eq/imax-succ) (lvl-eq/trans (lvl-eq/lsucc-cong lvl-eq/max-zero-l) lvl-eq/refl))) defeq/sort-refl).

levelComp2/name : name "levelComp2" (is-decl (esort (lsucc (lsucc lzero))) (defn (esort (limax lzero (lsucc lzero))))).

levelComp2/decl : declared "levelComp2" (esort (lsucc (lsucc lzero))) (defn (esort (limax lzero (lsucc lzero))))
   = declared/ok levelComp2/name (dkind-ok/defn levelComp2/type-wf levelComp2/value-typed).

