       ([x]
         ([h]
           (defeq/forall
             (defeq/const
               Bool/decl
               (inst-expr/sort (lvl-inst/succ lvl-inst/zero)))
             ([y]
               ([h1]
                 (defeq/forall
                   (defeq/const
                     Bool/decl
                     (inst-expr/sort (lvl-inst/succ lvl-inst/zero)))
                   ([z] ([h2] defeq/sort-refl))))))))).

SortElimProp2/ends-in-sort : ends-in-sort (eforall (econst "Bool" lnil) ([x] (eforall (econst "Bool" lnil) ([y] (eforall (econst "Bool" lnil) ([z] (esort lzero)))))))
   = (ends-in-sort/forall
       ([x]
         (ends-in-sort/forall
           ([y] (ends-in-sort/forall ([z] ends-in-sort/sort)))))).

SortElimProp2/rec-name : name "SortElimProp2.rec" (is-rec-for "SortElimProp2").

SortElimProp2/eisl : ends-in-sort-with-level (eforall (econst "Bool" lnil) ([x] (eforall (econst "Bool" lnil) ([y] (eforall (econst "Bool" lnil) ([z] (esort lzero))))))) lzero
   = (ends-in-sort-with-level/forall
       ([x]
         (ends-in-sort-with-level/forall
           ([y]
             (ends-in-sort-with-level/forall
               ([z] ends-in-sort-with-level/sort)))))).

SortElimProp2/clf : count-leading-foralls (eforall (econst "Bool" lnil) ([x] (eforall (econst "Bool" lnil) ([y] (eforall (econst "Bool" lnil) ([z] (esort lzero))))))) (lis liz)
   = (count-leading-foralls/succ ([x] count-leading-foralls/zero)).

SortElimProp2/cnd : cnames-distinct (ccons "SortElimProp2.mk" cnil)
   = (cnames-distinct/cons cnames-distinct/nil all-string-neq/nil).

SortElimProp2/name : name "SortElimProp2" (is-decl
  (eforall (econst "Bool" lnil) ([x] (eforall (econst "Bool" lnil) ([y] (eforall (econst "Bool" lnil) ([z] (esort lzero)))))))
  (indt (ccons "SortElimProp2.mk" cnil) (lis liz))).

SortElimProp2/decl : declared "SortElimProp2" (eforall (econst "Bool" lnil) ([x] (eforall (econst "Bool" lnil) ([y] (eforall (econst "Bool" lnil) ([z] (esort lzero))))))) (indt (ccons "SortElimProp2.mk" cnil) (lis liz))
   = declared/ok-indt SortElimProp2/name SortElimProp2/rec-name SortElimProp2/clf SortElimProp2/cnd (dkind-ok/indt SortElimProp2/type-wf SortElimProp2/ends-in-sort).

