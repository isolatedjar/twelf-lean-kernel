                                       (inst-expr/const inst-lvls/nil)
                                       ([y]
                                         ([h1]
                                           (inst-expr/forall
                                             (inst-expr/const inst-lvls/nil)
                                             ([w]
                                               ([h2]
                                                 (inst-expr/sort
                                                   inst-lvl/zero)))))))))))
                             h)
                           h2)
                         (defeq/app
                           (defeq/app
                             (defeq/const
                               id/decl
                               (inst-expr/forall
                                 (inst-expr/sort (inst-lvl/var nth-lvl/z))
                                 ([x]
                                   ([h] (inst-expr/forall h ([y] ([h1] h)))))))
                             (defeq/const
                               Bool/decl
                               (inst-expr/sort (inst-lvl/succ inst-lvl/zero))))
                           h1))))))))))).

SortElimProp2_mk/positivity : ctor-positive "SortElimProp2" lnil (eforall (econst "Bool" lnil) ([x] (eforall (econst "Bool" lnil) ([y] (eforall (econst "Bool" lnil) ([w] (eapp (eapp (eapp (econst "SortElimProp2" lnil) x) w) (eapp (eapp (econst "id" (lcons (lsucc lzero) lnil)) (econst "Bool" lnil)) y))))))))
   = (ctor-positive/intro ([S] (eforall (econst "Bool" lnil) ([x] (eforall (econst "Bool" lnil) ([y] (eforall (econst "Bool" lnil) ([w] (eapp (eapp (eapp S x) w) (eapp (eapp (econst "id" (lcons (lsucc lzero) lnil)) (econst "Bool" lnil)) y))))))))) (ctor-spine/arg
       (strict-pos/no-occur (econst "Bool" lnil) (no-self-ref/const sneq/1))
       ([x]
         ([y]
           (ctor-spine/arg
             (strict-pos/no-occur
               (econst "Bool" lnil)
               (no-self-ref/const sneq/1))
             ([w]
               ([v]
                 (ctor-spine/arg
                   (strict-pos/no-occur
                     (econst "Bool" lnil)
                     (no-self-ref/const sneq/1))
                   ([x1]
                     ([y1]
                       (ctor-spine/result
                         (applies-self/app
                           (applies-self/app
                             (applies-self/app applies-self/refl)))))))))))))).

SortElimProp2_mk/cmem : cmem "SortElimProp2.mk" (ccons "SortElimProp2.mk" cnil)
   = cmem/here.

SortElimProp2_mk/fuo : field-universes-ok (eforall (econst "Bool" lnil) ([x] (eforall (econst "Bool" lnil) ([y] (eforall (econst "Bool" lnil) ([w] (eapp (eapp (eapp (econst "SortElimProp2" lnil) x) w) (eapp (eapp (econst "id" (lcons (lsucc lzero) lnil)) (econst "Bool" lnil)) y)))))))) lzero
   = (field-universes-ok/forall
       (defeq/const Bool/decl (inst-expr/sort (inst-lvl/succ inst-lvl/zero)))
       (leq-lvl/imaxLz leq-lvl/self)
       ([x]
         ([h]
           (field-universes-ok/forall
             (defeq/const
               Bool/decl
               (inst-expr/sort (inst-lvl/succ inst-lvl/zero)))
             (leq-lvl/imaxLz leq-lvl/self)
             ([y]
               ([h1]
                 (field-universes-ok/forall
                   (defeq/const
                     Bool/decl
                     (inst-expr/sort (inst-lvl/succ inst-lvl/zero)))
                   (leq-lvl/imaxLz leq-lvl/self)
                   ([w] ([h2] (field-universes-ok/done not-forall/app)))))))))).

SortElimProp2_mk/name : name "SortElimProp2.mk" (is-decl
  (eforall (econst "Bool" lnil)
    ([x]
      (eforall (econst "Bool" lnil)
        ([y] (eforall (econst "Bool" lnil) ([w] (eapp (eapp (eapp (econst "SortElimProp2" lnil) x) w) (eapp (eapp (econst "id" (lcons (lsucc lzero) lnil)) (econst "Bool" lnil)) y))))))))
