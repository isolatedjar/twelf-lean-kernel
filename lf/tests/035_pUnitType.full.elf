%%% Expected outcome: accept
%%% Level-polymorphic unit type
%% inductive PUnit
PUnit/type-wf-sort : lvl
   = (lsucc (lvar liz)).

PUnit/type-wf : defeq (esort (lvar liz)) (esort (lvar liz)) (esort PUnit/type-wf-sort)
   = defeq/sort-refl.

PUnit/ends-in-sort : ends-in-sort (esort (lvar liz))
   = ends-in-sort/sort.

PUnit/rec-name : name "PUnit.rec" (is-rec-for "PUnit").

PUnit/name : name "PUnit" (is-decl (esort (lvar liz)) indt).

PUnit/decl : declared "PUnit" (esort (lvar liz)) indt
   = declared/ok PUnit/name (dkind-ok/indt PUnit/type-wf PUnit/ends-in-sort).

%% ctor PUnit.unit (of PUnit)
PUnit_unit/type-wf-sort : lvl
   = (lvar liz).

PUnit_unit/type-wf : defeq (econst "PUnit" (lcons (lvar liz) lnil)) (econst "PUnit" (lcons (lvar liz) lnil)) (esort PUnit_unit/type-wf-sort)
   = (defeq/const PUnit/decl (inst-expr/sort (lvl-inst/var lvl-nth/zero))).

PUnit_unit/positivity : ctor-positive "PUnit" (lcons (lvar liz) lnil) (econst "PUnit" (lcons (lvar liz) lnil))
   = (ctor-positive/intro ([S] S) (ctor-spine/result applies-self/refl)).

PUnit_unit/name : name "PUnit.unit" (is-decl (econst "PUnit" (lcons (lvar liz) lnil)) ctor).

PUnit_unit/decl : declared "PUnit.unit" (econst "PUnit" (lcons (lvar liz) lnil)) ctor
   = declared/ok PUnit_unit/name (dkind-ok/ctor PUnit_unit/type-wf PUnit_unit/positivity).

%% recursor PUnit.rec
PUnit_rec/type-wf-sort : lvl
   = (limax (limax (lvar (lis liz)) (lsucc (lvar liz))) (limax (lvar liz) (limax (lvar (lis liz)) (lvar liz)))).

PUnit_rec/type-wf : defeq (eforall (eforall (econst "PUnit" (lcons (lvar (lis liz)) lnil)) ([x] (esort (lvar liz)))) ([x] (eforall (eapp x (econst "PUnit.unit" (lcons (lvar (lis liz)) lnil))) ([y] (eforall (econst "PUnit" (lcons (lvar (lis liz)) lnil)) ([z] (eapp x z))))))) (eforall (eforall (econst "PUnit" (lcons (lvar (lis liz)) lnil)) ([x] (esort (lvar liz)))) ([x] (eforall (eapp x (econst "PUnit.unit" (lcons (lvar (lis liz)) lnil))) ([y] (eforall (econst "PUnit" (lcons (lvar (lis liz)) lnil)) ([z] (eapp x z))))))) (esort PUnit_rec/type-wf-sort)
   = (defeq/forall (defeq/forall (defeq/const PUnit/decl (inst-expr/sort (lvl-inst/var lvl-nth/zero))) ([x] ([h] defeq/sort-refl))) ([x] ([h] (defeq/forall (defeq/app h (defeq/const PUnit_unit/decl (inst-expr/const (lvls-inst/cons (lvl-inst/var lvl-nth/zero) lvls-inst/nil)))) ([y] ([h1] (defeq/forall (defeq/const PUnit/decl (inst-expr/sort (lvl-inst/var lvl-nth/zero))) ([z] ([h2] (defeq/app h h2)))))))))).

PUnit_rec/decl : declared "PUnit.rec" (eforall (eforall (econst "PUnit" (lcons (lvar (lis liz)) lnil)) ([x] (esort (lvar liz)))) ([x] (eforall (eapp x (econst "PUnit.unit" (lcons (lvar (lis liz)) lnil))) ([y] (eforall (econst "PUnit" (lcons (lvar (lis liz)) lnil)) ([z] (eapp x z))))))) irec
   = declared/ok-irec PUnit/rec-name (dkind-ok/irec PUnit_rec/type-wf).

%% def pUnitType
pUnitType/type-wf-sort : lvl
   = (lsucc (lsucc lzero)).

pUnitType/type-wf : defeq (esort (lsucc lzero)) (esort (lsucc lzero)) (esort pUnitType/type-wf-sort)
   = defeq/sort-refl.

pUnitType/value-typed : defeq (econst "PUnit" (lcons (lsucc lzero) lnil)) (econst "PUnit" (lcons (lsucc lzero) lnil)) (esort (lsucc lzero))
   = (defeq/const PUnit/decl (inst-expr/sort (lvl-inst/var lvl-nth/zero))).

pUnitType/name : name "pUnitType" (is-decl (esort (lsucc lzero)) (defn (econst "PUnit" (lcons (lsucc lzero) lnil)))).

pUnitType/decl : declared "pUnitType" (esort (lsucc lzero)) (defn (econst "PUnit" (lcons (lsucc lzero) lnil)))
   = declared/ok pUnitType/name (dkind-ok/defn pUnitType/type-wf pUnitType/value-typed).
