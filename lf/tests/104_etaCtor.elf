   = (defeq/forall (defeq/const Bool/decl) ([x] [y] (defeq/forall (defeq/const True/decl) ([z] [w] (defeq/const T/decl))))).

T_mk/positivity :
   ctor-positive "T" lnil (eforall (econst "Bool" lnil) ([x] (eforall (econst "True" lnil) ([y] (econst "T" lnil)))))
   = (ctor-positive/intro ([S] (eforall (econst "Bool" lnil) ([x] (eforall (econst "True" lnil) ([y] S))))) (ctor-spine/arg (strict-pos/no-occur (econst "Bool" lnil)) ([_y0] (ctor-spine/arg (strict-pos/no-occur (econst "True" lnil)) ([_y1] (ctor-spine/result applies-self/refl)))))).

T_mk/decl : declared "T.mk" lnil
   (eforall (econst "Bool" lnil) ([x] (eforall (econst "True" lnil) ([y] (econst "T" lnil)))))
