%%% Expected outcome: reject
%%% Corner case for function eta:
%%% Does a defeq between a partially applied constructor trigger eta expansion?
%%% 
%%% Taking the official kernel as the specification, the answer is no.
%%% See <https://github.com/leanprover/lean4/issues/12520> for a discussion.
%% inductive True
True/type-wf :
   defeq (esort lzero) (esort lzero) (esort (lsucc lzero))
   = (defeq/sort-refl-at lzero).

True/ends-in-sort :
   ends-in-sort (esort lzero)
   = ends-in-sort/sort.

True/decl : declared "True" lnil
   (esort lzero)
   indt
   (dkind-ok/indt True/type-wf True/ends-in-sort).

%% inductive ctor True.intro
True_intro/type-wf :
   defeq (econst "True" lnil) (econst "True" lnil) (esort lzero)
   = (defeq/const True/decl).

True_intro/positivity :
   ctor-positive "True" lnil (econst "True" lnil)
   = (ctor-positive/intro ([S] S) (ctor-spine/result applies-self/refl)).

True_intro/decl : declared "True.intro" lnil
   (econst "True" lnil)
   ctor
   (dkind-ok/ctor True_intro/type-wf True_intro/positivity).

%% inductive recursor True.rec
True_rec/type-wf :
   {u : lvl} defeq (eforall (eforall (econst "True" lnil) ([x] (esort u))) ([x] (eforall (eapp x (econst "True.intro" lnil)) ([y] (eforall (econst "True" lnil) ([z] (eapp x z))))))) (eforall (eforall (econst "True" lnil) ([x] (esort u))) ([x] (eforall (eapp x (econst "True.intro" lnil)) ([y] (eforall (econst "True" lnil) ([z] (eapp x z))))))) (esort (limax (limax lzero (lsucc u)) (limax u (limax lzero u))))
   = [u] (defeq/forall (defeq/forall (defeq/const True/decl) ([x] [y] (defeq/sort-refl-at u))) ([x] [y] (defeq/forall (defeq/app y (defeq/const True_intro/decl)) ([z] [w] (defeq/forall (defeq/const True/decl) ([x1] [y1] (defeq/app y y1))))))).

True_rec/decl : {u : lvl} declared "True.rec" (lcons u lnil)
   (eforall (eforall (econst "True" lnil) ([x] (esort u))) ([x] (eforall (eapp x (econst "True.intro" lnil)) ([y] (eforall (econst "True" lnil) ([z] (eapp x z)))))))
   irec
   (dkind-ok/irec (True_rec/type-wf u)).

%% stage-1 enum iota helpers: True
True/as-enum : {u : lvl}
   enum-rec-type
      (eforall (eforall (econst "True" lnil) ([x] (esort u))) ([M] (eforall (eapp M (econst "True.intro" lnil)) ([x] (eforall (econst "True" lnil) ([t] (eapp M t)))))))
      "True" lnil (ccons "True.intro" cnil) u
   = [u] enum-rec-type/intro ([M] [hM] (enum-rec-body/minor ([m1] [hm1] enum-rec-body/done))).

True_intro/iota : {u : lvl}
   defeq M M (eforall (econst "True" lnil) ([x] (esort u)))
   -> defeq Mp1 Mp1 (eapp M (econst "True.intro" lnil))
   -> defeq (eapp (eapp (eapp (econst "True.rec" (lcons u lnil)) M) Mp1) (econst "True.intro" lnil)) Mp1 (eapp M (econst "True.intro" lnil))
   = [u] [hM] [hMp1]
     defeq/extra (defeq/iota-enum-1 (True_rec/decl u) True_intro/decl (True/as-enum u) hM hMp1).

