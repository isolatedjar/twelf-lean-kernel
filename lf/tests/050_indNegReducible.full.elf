%%% Expected outcome: reject
%%% When checking inductives, we expect the kernel to **not** reduce the type of the constructor parameters
%%% further than head normal form. Recursive occurrences nested inside the head normal form are considered
%%% negative occurrences, even if they could be reduced to disappear.
%% def constType
constType/type-wf-sort : lvl
   = (limax (lsucc (lsucc lzero)) (limax (lsucc (lsucc lzero)) (lsucc (lsucc lzero)))).

constType/type-wf : defeq (eforall (esort (lsucc lzero)) ([x] (eforall (esort (lsucc lzero)) ([y] (esort (lsucc lzero)))))) (eforall (esort (lsucc lzero)) ([x] (eforall (esort (lsucc lzero)) ([y] (esort (lsucc lzero)))))) (esort constType/type-wf-sort)
   = (defeq/forall defeq/sort-refl ([x] ([h] (defeq/forall defeq/sort-refl ([y] ([h1] defeq/sort-refl)))))).

constType/value-typed : defeq (elam (esort (lsucc lzero)) ([x] (elam (esort (lsucc lzero)) ([y] x)))) (elam (esort (lsucc lzero)) ([x] (elam (esort (lsucc lzero)) ([y] x)))) (eforall (esort (lsucc lzero)) ([x] (eforall (esort (lsucc lzero)) ([y] (esort (lsucc lzero))))))
   = (defeq/lam defeq/sort-refl ([x] ([h] (defeq/lam defeq/sort-refl ([y] ([h1] h)))))).

constType/name : name "constType" (is-decl (eforall (esort (lsucc lzero)) ([x] (eforall (esort (lsucc lzero)) ([y] (esort (lsucc lzero)))))) (defn (elam (esort (lsucc lzero)) ([x] (elam (esort (lsucc lzero)) ([y] x)))))).

constType/decl : declared "constType" (eforall (esort (lsucc lzero)) ([x] (eforall (esort (lsucc lzero)) ([y] (esort (lsucc lzero)))))) (defn (elam (esort (lsucc lzero)) ([x] (elam (esort (lsucc lzero)) ([y] x)))))
   = declared/ok constType/name (dkind-ok/defn constType/type-wf constType/value-typed).

%% axiom aType
aType/type-wf-sort : lvl
   = (lsucc (lsucc lzero)).

aType/type-wf : defeq (esort (lsucc lzero)) (esort (lsucc lzero)) (esort aType/type-wf-sort)
   = defeq/sort-refl.

aType/name : name "aType" (is-decl (esort (lsucc lzero)) ax).

aType/decl : declared "aType" (esort (lsucc lzero)) ax
   = declared/ok aType/name (dkind-ok/ax aType/type-wf).

%% inductive indNegReducible
indNegReducible/type-wf-sort : lvl
   = (lsucc (lsucc lzero)).

indNegReducible/type-wf : defeq (esort (lsucc lzero)) (esort (lsucc lzero)) (esort indNegReducible/type-wf-sort)
   = defeq/sort-refl.

indNegReducible/ends-in-sort : ends-in-sort (esort (lsucc lzero))
   = ends-in-sort/sort.

indNegReducible/rec-name : name "indNegReducible.rec" (is-rec-for "indNegReducible").

indNegReducible/name : name "indNegReducible" (is-decl (esort (lsucc lzero)) indt).

indNegReducible/decl : declared "indNegReducible" (esort (lsucc lzero)) indt
   = declared/ok indNegReducible/name (dkind-ok/indt indNegReducible/type-wf indNegReducible/ends-in-sort).

%% ctor indNegReducible.mk (of indNegReducible)
indNegReducible_mk/type-wf-sort : lvl
   = (limax (limax (lsucc lzero) (lsucc lzero)) (lsucc lzero)).

indNegReducible_mk/type-wf : defeq (eforall (eforall (eapp (eapp (econst "constType" lnil) (econst "aType" lnil)) (econst "indNegReducible" lnil)) ([x] (econst "indNegReducible" lnil))) ([x] (econst "indNegReducible" lnil))) (eforall (eforall (eapp (eapp (econst "constType" lnil) (econst "aType" lnil)) (econst "indNegReducible" lnil)) ([x] (econst "indNegReducible" lnil))) ([x] (econst "indNegReducible" lnil))) (esort indNegReducible_mk/type-wf-sort)
   = (defeq/forall (defeq/forall (defeq/app (defeq/app (defeq/const constType/decl (inst-expr/forall (inst-expr/sort (lvl-inst/succ lvl-inst/zero)) ([x] ([h] (inst-expr/forall (inst-expr/sort (lvl-inst/succ lvl-inst/zero)) ([y] ([h1] (inst-expr/sort (lvl-inst/succ lvl-inst/zero))))))))) (defeq/const aType/decl (inst-expr/sort (lvl-inst/succ lvl-inst/zero)))) (defeq/const indNegReducible/decl (inst-expr/sort (lvl-inst/succ lvl-inst/zero)))) ([x] ([h] (defeq/const indNegReducible/decl (inst-expr/sort (lvl-inst/succ lvl-inst/zero)))))) ([x] ([h] (defeq/const indNegReducible/decl (inst-expr/sort (lvl-inst/succ lvl-inst/zero)))))).

%%% HOLE
indNegReducible_mk/positivity : ctor-positive "indNegReducible" lnil (eforall (eforall (eapp (eapp (econst "constType" lnil) (econst "aType" lnil)) (econst "indNegReducible" lnil)) ([x] (econst "indNegReducible" lnil))) ([x] (econst "indNegReducible" lnil))).

indNegReducible_mk/name : name "indNegReducible.mk" (is-decl (eforall (eforall (eapp (eapp (econst "constType" lnil) (econst "aType" lnil)) (econst "indNegReducible" lnil)) ([x] (econst "indNegReducible" lnil))) ([x] (econst "indNegReducible" lnil))) ctor).

indNegReducible_mk/decl : declared "indNegReducible.mk" (eforall (eforall (eapp (eapp (econst "constType" lnil) (econst "aType" lnil)) (econst "indNegReducible" lnil)) ([x] (econst "indNegReducible" lnil))) ([x] (econst "indNegReducible" lnil))) ctor
   = declared/ok indNegReducible_mk/name (dkind-ok/ctor indNegReducible_mk/type-wf indNegReducible_mk/positivity).

%% recursor indNegReducible.rec
indNegReducible_rec/type-wf-sort : lvl
   = (lsucc lzero).

indNegReducible_rec/type-wf : defeq (esort lzero) (esort lzero) (esort indNegReducible_rec/type-wf-sort)
   = defeq/sort-refl.

indNegReducible_rec/decl : declared "indNegReducible.rec" (esort lzero) irec
   = declared/ok-irec indNegReducible/rec-name (dkind-ok/irec indNegReducible_rec/type-wf).
