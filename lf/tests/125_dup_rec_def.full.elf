%%% Expected outcome: reject
%%% A definition and a recursor with the same name
%% def dup_rec_def.rec
dup_rec_def_rec/type-wf-sort : lvl
   = (lsucc (lsucc lzero)).

dup_rec_def_rec/type-wf : of (esort (lsucc lzero)) (esort dup_rec_def_rec/type-wf-sort)
   = defeq/sort-refl.

dup_rec_def_rec/value-typed : of (esort lzero) (esort (lsucc lzero))
   = defeq/sort-refl.

dup_rec_def_rec/name : name "dup_rec_def.rec" (is-decl (esort (lsucc lzero)) (defn (esort lzero))).

dup_rec_def_rec/decl : declared "dup_rec_def.rec" (esort (lsucc lzero)) (defn (esort lzero))
   = declared/ok dup_rec_def_rec/name (dkind-ok/defn dup_rec_def_rec/type-wf dup_rec_def_rec/value-typed).

%% inductive dup_rec_def
dup_rec_def/type-wf-sort : lvl
   = (lsucc (lsucc lzero)).

dup_rec_def/type-wf : of (esort (lsucc lzero)) (esort dup_rec_def/type-wf-sort)
   = defeq/sort-refl.

dup_rec_def/ends-in-sort : ends-in-sort (esort (lsucc lzero))
   = ends-in-sort/sort.

dup_rec_def/rec-name : name "dup_rec_def.rec" (is-rec-for "dup_rec_def").

dup_rec_def/name : name "dup_rec_def" (is-decl (esort (lsucc lzero)) indt).

dup_rec_def/decl : declared "dup_rec_def" (esort (lsucc lzero)) indt
   = declared/ok dup_rec_def/name (dkind-ok/indt dup_rec_def/type-wf dup_rec_def/ends-in-sort).

%% ctor dup_rec_def.mk (of dup_rec_def)
dup_rec_def_mk/type-wf-sort : lvl
   = (lsucc lzero).

dup_rec_def_mk/type-wf : of (econst "dup_rec_def" lnil) (esort dup_rec_def_mk/type-wf-sort)
   = (defeq/const
       dup_rec_def/decl
       (inst-expr/sort (lvl-inst/succ lvl-inst/zero))).

dup_rec_def_mk/positivity : ctor-positive "dup_rec_def" lnil (econst "dup_rec_def" lnil)
   = (ctor-positive/intro ([S] S) (ctor-spine/result applies-self/refl)).

dup_rec_def_mk/name : name "dup_rec_def.mk" (is-decl (econst "dup_rec_def" lnil) ctor).

dup_rec_def_mk/decl : declared "dup_rec_def.mk" (econst "dup_rec_def" lnil) ctor
   = declared/ok dup_rec_def_mk/name (dkind-ok/ctor dup_rec_def_mk/type-wf dup_rec_def_mk/positivity).

%% recursor dup_rec_def.rec
dup_rec_def_rec/type-wf-sort : lvl
   = (limax
       (limax (lsucc lzero) (lsucc (lvar liz)))
       (limax (lvar liz) (limax (lsucc lzero) (lvar liz)))).

dup_rec_def_rec/type-wf : of (eforall (eforall (econst "dup_rec_def" lnil) ([x] (esort (lvar liz)))) ([x] (eforall (eapp x (econst "dup_rec_def.mk" lnil)) ([y] (eforall (econst "dup_rec_def" lnil) ([z] (eapp x z))))))) (esort dup_rec_def_rec/type-wf-sort)
   = (defeq/forall
       (defeq/forall
         (defeq/const
           dup_rec_def/decl
           (inst-expr/sort (lvl-inst/succ lvl-inst/zero)))
         ([x] ([h] defeq/sort-refl)))
       ([x]
         ([h]
           (defeq/forall
             (defeq/app
               h
               (defeq/const
                 dup_rec_def_mk/decl
                 (inst-expr/const lvls-inst/nil)))
             ([y]
               ([h1]
                 (defeq/forall
                   (defeq/const
                     dup_rec_def/decl
                     (inst-expr/sort (lvl-inst/succ lvl-inst/zero)))
                   ([z] ([h2] (defeq/app h h2)))))))))).

dup_rec_def_rec/decl : declared "dup_rec_def.rec" (eforall (eforall (econst "dup_rec_def" lnil) ([x] (esort (lvar liz)))) ([x] (eforall (eapp x (econst "dup_rec_def.mk" lnil)) ([y] (eforall (econst "dup_rec_def" lnil) ([z] (eapp x z))))))) irec
   = declared/ok-irec dup_rec_def/rec-name (dkind-ok/irec dup_rec_def_rec/type-wf).
