%%% Expected outcome: accept
%%% A simple enumeration inductive type
%% inductive Bool
%%% HOLE
Bool/type-wf : defeq (esort (lsucc lzero)) (esort (lsucc lzero)) (esort lzero).

%%% HOLE
Bool/ends-in-sort : ends-in-sort (esort (lsucc lzero)).

Bool/decl : declared "Bool" lnil
   (esort (lsucc lzero))
   indt
   (dkind-ok/indt Bool/type-wf Bool/ends-in-sort).

%% ctor Bool.false (of Bool)
%%% HOLE
Bool_false/type-wf : defeq (econst "Bool" lnil) (econst "Bool" lnil) (esort lzero).

%%% HOLE
Bool_false/positivity : ctor-positive "Bool" lnil (econst "Bool" lnil).

Bool_false/decl : declared "Bool.false" lnil
   (econst "Bool" lnil)
   ctor
   (dkind-ok/ctor Bool_false/type-wf Bool_false/positivity).

%% ctor Bool.true (of Bool)
%%% HOLE
Bool_true/type-wf : defeq (econst "Bool" lnil) (econst "Bool" lnil) (esort lzero).

%%% HOLE
Bool_true/positivity : ctor-positive "Bool" lnil (econst "Bool" lnil).

Bool_true/decl : declared "Bool.true" lnil
   (econst "Bool" lnil)
   ctor
   (dkind-ok/ctor Bool_true/type-wf Bool_true/positivity).

%% recursor Bool.rec
%%% HOLE
Bool_rec/type-wf : {u : lvl} defeq (eforall (eforall (econst "Bool" lnil) ([x] (esort u))) ([x] (eforall (eapp x (econst "Bool.false" lnil)) ([y] (eforall (eapp x (econst "Bool.true" lnil)) ([z] (eforall (econst "Bool" lnil) ([w] (eapp x w))))))))) (eforall (eforall (econst "Bool" lnil) ([x] (esort u))) ([x] (eforall (eapp x (econst "Bool.false" lnil)) ([y] (eforall (eapp x (econst "Bool.true" lnil)) ([z] (eforall (econst "Bool" lnil) ([w] (eapp x w))))))))) (esort lzero).

Bool_rec/decl : {u : lvl} declared "Bool.rec" (lcons u lnil)
   (eforall (eforall (econst "Bool" lnil) ([x] (esort u))) ([x] (eforall (eapp x (econst "Bool.false" lnil)) ([y] (eforall (eapp x (econst "Bool.true" lnil)) ([z] (eforall (econst "Bool" lnil) ([w] (eapp x w)))))))))
   irec
   (dkind-ok/irec (Bool_rec/type-wf u)).

%% def boolType
%%% HOLE
boolType/type-wf : defeq (esort (lsucc lzero)) (esort (lsucc lzero)) (esort lzero).

%%% HOLE
boolType/value-typed : defeq (econst "Bool" lnil) (econst "Bool" lnil) (esort (lsucc lzero)).

boolType/decl : declared "boolType" lnil
   (esort (lsucc lzero))
   (defn (econst "Bool" lnil))
   (dkind-ok/defn boolType/type-wf boolType/value-typed).

