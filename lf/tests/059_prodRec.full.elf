%%% Expected outcome: accept
%%% Asserting the type of the generated recursor
%% inductive Prod
Prod/type-wf-sort : lvl
   = (limax
       (lsucc (lsucc (lvar liz)))
       (limax
         (lsucc (lsucc (lvar (lis liz))))
         (lsucc (lmax (lsucc (lvar liz)) (lsucc (lvar (lis liz))))))).

Prod/type-wf : of (eforall (esort (lsucc (lvar liz))) ([x] (eforall (esort (lsucc (lvar (lis liz)))) ([y] (esort (lmax (lsucc (lvar liz)) (lsucc (lvar (lis liz))))))))) (esort Prod/type-wf-sort)
   = (defeq/forall
       defeq/sort-refl
       ([x] ([h] (defeq/forall defeq/sort-refl ([y] ([h1] defeq/sort-refl)))))).

Prod/ends-in-sort : ends-in-sort (eforall (esort (lsucc (lvar liz))) ([x] (eforall (esort (lsucc (lvar (lis liz)))) ([y] (esort (lmax (lsucc (lvar liz)) (lsucc (lvar (lis liz)))))))))
   = (ends-in-sort/forall ([x] (ends-in-sort/forall ([y] ends-in-sort/sort)))).

Prod/rec-name : name "Prod.rec" (is-rec-for "Prod").

Prod/eisl : ends-in-sort-with-level (eforall (esort (lsucc (lvar liz))) ([x] (eforall (esort (lsucc (lvar (lis liz)))) ([y] (esort (lmax (lsucc (lvar liz)) (lsucc (lvar (lis liz))))))))) (lmax (lsucc (lvar liz)) (lsucc (lvar (lis liz))))
   = (ends-in-sort-with-level/forall
       ([x]
         (ends-in-sort-with-level/forall ([y] ends-in-sort-with-level/sort)))).

Prod/cnd : cnames-distinct (ccons "Prod.mk" cnil)
   = (cnames-distinct/cons cnames-distinct/nil all-string-neq/nil).

Prod/name : name "Prod" (is-decl
  (eforall (esort (lsucc (lvar liz))) ([x] (eforall (esort (lsucc (lvar (lis liz)))) ([y] (esort (lmax (lsucc (lvar liz)) (lsucc (lvar (lis liz)))))))))
  (indt (ccons "Prod.mk" cnil) (lis (lis liz)))).

Prod/decl : declared "Prod"
  (eforall (esort (lsucc (lvar liz))) ([x] (eforall (esort (lsucc (lvar (lis liz)))) ([y] (esort (lmax (lsucc (lvar liz)) (lsucc (lvar (lis liz)))))))))
  (indt (ccons "Prod.mk" cnil) (lis (lis liz)))
   = declared/ok-indt Prod/name Prod/rec-name Prod/cnd (dkind-ok/indt Prod/type-wf Prod/ends-in-sort).

%% ctor Prod.mk (of Prod)
Prod_mk/type-wf-sort : lvl
   = (limax
       (lsucc (lsucc (lvar liz)))
       (limax
         (lsucc (lsucc (lvar (lis liz))))
         (limax
           (lsucc (lvar liz))
           (limax
             (lsucc (lvar (lis liz)))
             (lmax (lsucc (lvar liz)) (lsucc (lvar (lis liz)))))))).

Prod_mk/type-wf : of
  (eforall (esort (lsucc (lvar liz)))
    ([x] (eforall (esort (lsucc (lvar (lis liz)))) ([y] (eforall x ([z] (eforall y ([w] (eapp (eapp (econst "Prod" (lcons (lvar liz) (lcons (lvar (lis liz)) lnil))) x) y)))))))))
  (esort Prod_mk/type-wf-sort)
   = (defeq/forall
       defeq/sort-refl
       ([x]
         ([h]
           (defeq/forall
             defeq/sort-refl
             ([y]
               ([h1]
                 (defeq/forall
                   h
                   ([z]
                     ([h2]
                       (defeq/forall
                         h1
                         ([w]
                           ([h3]
                             (defeq/app
                               (defeq/app
                                 (defeq/const
                                   Prod/decl
                                   (inst-expr/forall
                                     (inst-expr/sort
                                       (lvl-inst/succ
                                         (lvl-inst/var lvl-nth/zero)))
                                     ([x]
                                       ([h]
                                         (inst-expr/forall
                                           (inst-expr/sort
                                             (lvl-inst/succ
                                               (lvl-inst/var
                                                 (lvl-nth/succ lvl-nth/zero))))
                                           ([y]
                                             ([h1]
                                               (inst-expr/sort
                                                 (lvl-inst/max
                                                   (lvl-inst/succ
                                                     (lvl-inst/var
                                                       lvl-nth/zero))
                                                   (lvl-inst/succ
                                                     (lvl-inst/var
                                                       (lvl-nth/succ
                                                         lvl-nth/zero))))))))))))
                                 h)
                               h1))))))))))))).

Prod_mk/positivity : ctor-positive "Prod" (lcons (lvar liz) (lcons (lvar (lis liz)) lnil)) (eforall (esort (lsucc (lvar liz))) ([x] (eforall (esort (lsucc (lvar (lis liz)))) ([y] (eforall x ([z] (eforall y ([w] (eapp (eapp (econst "Prod" (lcons (lvar liz) (lcons (lvar (lis liz)) lnil))) x) y)))))))))
   = (ctor-positive/intro ([S] (eforall (esort (lsucc (lvar liz))) ([x] (eforall (esort (lsucc (lvar (lis liz)))) ([y] (eforall x ([z] (eforall y ([w] (eapp (eapp S x) y)))))))))) (ctor-spine/arg
       (strict-pos/no-occur (esort (lsucc (lvar liz))) no-self-ref/sort)
       ([x]
         ([y]
           (ctor-spine/arg
             (strict-pos/no-occur
               (esort (lsucc (lvar (lis liz))))
               no-self-ref/sort)
             ([z]
               ([w]
                 (ctor-spine/arg
                   (strict-pos/no-occur x y)
                   ([x1]
                     ([y1]
                       (ctor-spine/arg
                         (strict-pos/no-occur z w)
                         ([z1]
                           ([w1]
                             (ctor-spine/result
                               (applies-self/app
                                 (applies-self/app
                                   applies-self/refl)))))))))))))))).

Prod_mk/cmem : cmem "Prod.mk" (ccons "Prod.mk" cnil)
   = cmem/here.

%%% HOLE: Prod_mk/fuo
Prod_mk/fuo : field-universes-ok (eforall (esort (lsucc (lvar liz))) ([x] (eforall (esort (lsucc (lvar (lis liz)))) ([y] (eforall x ([z] (eforall y ([w] (eapp (eapp (econst "Prod" (lcons (lvar liz) (lcons (lvar (lis liz)) lnil))) x) y))))))))) (lmax (lsucc (lvar liz)) (lsucc (lvar (lis liz)))).

Prod_mk/name : name "Prod.mk" (is-decl
  (eforall (esort (lsucc (lvar liz)))
    ([x] (eforall (esort (lsucc (lvar (lis liz)))) ([y] (eforall x ([z] (eforall y ([w] (eapp (eapp (econst "Prod" (lcons (lvar liz) (lcons (lvar (lis liz)) lnil))) x) y)))))))))
  (ctor "Prod" liz)).

Prod_mk/decl : declared "Prod.mk"
  (eforall (esort (lsucc (lvar liz)))
    ([x] (eforall (esort (lsucc (lvar (lis liz)))) ([y] (eforall x ([z] (eforall y ([w] (eapp (eapp (econst "Prod" (lcons (lvar liz) (lcons (lvar (lis liz)) lnil))) x) y)))))))))
  (ctor "Prod" liz)
   = declared/ok-ctor Prod_mk/name Prod/name Prod_mk/cmem Prod/eisl Prod_mk/fuo (dkind-ok/ctor Prod_mk/type-wf Prod_mk/positivity).

%% recursor Prod.rec (TCB-derived; informational only)
%%   level params: u_1 u v
%%   type:   (eforall (esort (lsucc (lvar (lis liz)))) ([x] (eforall (esort (lsucc (lvar (lis (lis liz))))) ([y] (eforall (eforall (eapp (eapp (econst "Prod" (lcons (lvar (lis liz)) (lcons (lvar (lis (lis liz))) lnil))) x) y) ([z] (esort (lvar liz)))) ([z] (eforall (eforall x ([w] (eforall y ([x1] (eapp z (eapp (eapp (eapp (eapp (econst "Prod.mk" (lcons (lvar (lis liz)) (lcons (lvar (lis (lis liz))) lnil))) x) y) w) x1)))))) ([w] (eforall (eapp (eapp (econst "Prod" (lcons (lvar (lis liz)) (lcons (lvar (lis (lis liz))) lnil))) x) y) ([x1] (eapp z x1)))))))))))
%%   rules:
%%     Prod.rec … Prod.mk … = (elam (esort (lsucc (lvar (lis liz)))) ([x] (elam (esort (lsucc (lvar (lis (lis liz))))) ([y] (elam (eforall (eapp (eapp (econst "Prod" (lcons (lvar (lis liz)) (lcons (lvar (lis (lis liz))) lnil))) x) y) ([z] (esort (lvar liz)))) ([z] (elam (eforall x ([w] (eforall y ([x1] (eapp z (eapp (eapp (eapp (eapp (econst "Prod.mk" (lcons (lvar (lis liz)) (lcons (lvar (lis (lis liz))) lnil))) x) y) w) x1)))))) ([w] (elam x ([x1] (elam y ([y1] (eapp (eapp w x1) y1)))))))))))))   (2 fields)

%% def prodRec
prodRec/type-wf-sort : lvl
   = (limax
       (lsucc (lsucc (lvar liz)))
       (limax
         (lsucc (lsucc (lvar (lis liz))))
         (limax
           (limax
             (lmax (lsucc (lvar liz)) (lsucc (lvar (lis liz))))
             (lsucc (lvar liz)))
           (limax
             (limax
               (lsucc (lvar liz))
               (limax (lsucc (lvar (lis liz))) (lvar liz)))
             (limax
               (lmax (lsucc (lvar liz)) (lsucc (lvar (lis liz))))
               (lvar liz)))))).

prodRec/type-wf : of
  (eforall (esort (lsucc (lvar liz)))
    ([x]
      (eforall (esort (lsucc (lvar (lis liz))))
        ([y]
          (eforall (eforall (eapp (eapp (econst "Prod" (lcons (lvar liz) (lcons (lvar (lis liz)) lnil))) x) y) ([z] (esort (lvar liz))))
            ([z]
              (eforall (eforall x ([w] (eforall y ([x1] (eapp z (eapp (eapp (eapp (eapp (econst "Prod.mk" (lcons (lvar liz) (lcons (lvar (lis liz)) lnil))) x) y) w) x1))))))
                ([w] (eforall (eapp (eapp (econst "Prod" (lcons (lvar liz) (lcons (lvar (lis liz)) lnil))) x) y) ([x1] (eapp z x1)))))))))))
  (esort prodRec/type-wf-sort)
   = (defeq/forall
       defeq/sort-refl
       ([x]
         ([h]
           (defeq/forall
             defeq/sort-refl
             ([y]
               ([h1]
                 (defeq/forall
                   (defeq/forall
                     (defeq/app
                       (defeq/app
                         (defeq/const
                           Prod/decl
                           (inst-expr/forall
                             (inst-expr/sort
                               (lvl-inst/succ (lvl-inst/var lvl-nth/zero)))
                             ([x]
                               ([h]
                                 (inst-expr/forall
                                   (inst-expr/sort
                                     (lvl-inst/succ
                                       (lvl-inst/var
                                         (lvl-nth/succ lvl-nth/zero))))
                                   ([y]
                                     ([h1]
                                       (inst-expr/sort
                                         (lvl-inst/max
                                           (lvl-inst/succ
                                             (lvl-inst/var lvl-nth/zero))
                                           (lvl-inst/succ
                                             (lvl-inst/var
                                               (lvl-nth/succ
                                                 lvl-nth/zero))))))))))))
                         h)
                       h1)
                     ([z] ([h2] defeq/sort-refl)))
                   ([z]
                     ([h2]
                       (defeq/forall
                         (defeq/forall
                           h
                           ([w]
                             ([h3]
                               (defeq/forall
                                 h1
                                 ([x1]
                                   ([h4]
                                     (defeq/app
                                       h2
                                       (defeq/app
                                         (defeq/app
                                           (defeq/app
                                             (defeq/app
                                               (defeq/const
                                                 Prod_mk/decl
                                                 (inst-expr/forall
                                                   (inst-expr/sort
                                                     (lvl-inst/succ
                                                       (lvl-inst/var
                                                         lvl-nth/zero)))
                                                   ([x]
                                                     ([h]
                                                       (inst-expr/forall
                                                         (inst-expr/sort
                                                           (lvl-inst/succ
                                                             (lvl-inst/var
                                                               (lvl-nth/succ
                                                                 lvl-nth/zero))))
                                                         ([y]
                                                           ([h1]
                                                             (inst-expr/forall
                                                               h
                                                               ([z]
                                                                 ([h2]
                                                                   (inst-expr/forall
                                                                     h1
                                                                     ([w]
                                                                       ([h3]
                                                                         (inst-expr/app
                                                                           (inst-expr/app
                                                                             (inst-expr/const
                                                                               (lvls-inst/cons
                                                                                 (lvl-inst/var
                                                                                   lvl-nth/zero)
                                                                                 (lvls-inst/cons
                                                                                   (lvl-inst/var
                                                                                     (lvl-nth/succ
                                                                                       lvl-nth/zero))
                                                                                   lvls-inst/nil)))
                                                                             h)
                                                                           h1))))))))))))))
                                               h)
                                             h1)
                                           h3)
                                         h4))))))))
                         ([w]
                           ([h3]
                             (defeq/forall
                               (defeq/app
                                 (defeq/app
                                   (defeq/const
                                     Prod/decl
                                     (inst-expr/forall
                                       (inst-expr/sort
                                         (lvl-inst/succ
                                           (lvl-inst/var lvl-nth/zero)))
                                       ([x]
                                         ([h]
                                           (inst-expr/forall
                                             (inst-expr/sort
                                               (lvl-inst/succ
                                                 (lvl-inst/var
                                                   (lvl-nth/succ
                                                     lvl-nth/zero))))
                                             ([y]
                                               ([h1]
                                                 (inst-expr/sort
                                                   (lvl-inst/max
                                                     (lvl-inst/succ
                                                       (lvl-inst/var
                                                         lvl-nth/zero))
                                                     (lvl-inst/succ
                                                       (lvl-inst/var
                                                         (lvl-nth/succ
                                                           lvl-nth/zero))))))))))))
                                   h)
                                 h1)
                               ([x1] ([h4] (defeq/app h2 h4)))))))))))))))).

%%% HOLE
prodRec/value-typed : of
  (econst "Prod.rec" (lcons (lvar liz) (lcons (lvar liz) (lcons (lvar (lis liz)) lnil))))
  (eforall (esort (lsucc (lvar liz)))
    ([x]
      (eforall (esort (lsucc (lvar (lis liz))))
        ([y]
          (eforall (eforall (eapp (eapp (econst "Prod" (lcons (lvar liz) (lcons (lvar (lis liz)) lnil))) x) y) ([z] (esort (lvar liz))))
            ([z]
              (eforall (eforall x ([w] (eforall y ([x1] (eapp z (eapp (eapp (eapp (eapp (econst "Prod.mk" (lcons (lvar liz) (lcons (lvar (lis liz)) lnil))) x) y) w) x1))))))
                ([w] (eforall (eapp (eapp (econst "Prod" (lcons (lvar liz) (lcons (lvar (lis liz)) lnil))) x) y) ([x1] (eapp z x1))))))))))).

prodRec/name : name "prodRec" (is-decl
  (eforall (esort (lsucc (lvar liz)))
    ([x]
      (eforall (esort (lsucc (lvar (lis liz))))
        ([y]
          (eforall (eforall (eapp (eapp (econst "Prod" (lcons (lvar liz) (lcons (lvar (lis liz)) lnil))) x) y) ([z] (esort (lvar liz))))
            ([z]
              (eforall (eforall x ([w] (eforall y ([x1] (eapp z (eapp (eapp (eapp (eapp (econst "Prod.mk" (lcons (lvar liz) (lcons (lvar (lis liz)) lnil))) x) y) w) x1))))))
                ([w] (eforall (eapp (eapp (econst "Prod" (lcons (lvar liz) (lcons (lvar (lis liz)) lnil))) x) y) ([x1] (eapp z x1)))))))))))
  (defn (econst "Prod.rec" (lcons (lvar liz) (lcons (lvar liz) (lcons (lvar (lis liz)) lnil)))))).

prodRec/decl : declared "prodRec"
  (eforall (esort (lsucc (lvar liz)))
    ([x]
      (eforall (esort (lsucc (lvar (lis liz))))
        ([y]
          (eforall (eforall (eapp (eapp (econst "Prod" (lcons (lvar liz) (lcons (lvar (lis liz)) lnil))) x) y) ([z] (esort (lvar liz))))
            ([z]
              (eforall (eforall x ([w] (eforall y ([x1] (eapp z (eapp (eapp (eapp (eapp (econst "Prod.mk" (lcons (lvar liz) (lcons (lvar (lis liz)) lnil))) x) y) w) x1))))))
                ([w] (eforall (eapp (eapp (econst "Prod" (lcons (lvar liz) (lcons (lvar (lis liz)) lnil))) x) y) ([x1] (eapp z x1)))))))))))
  (defn (econst "Prod.rec" (lcons (lvar liz) (lcons (lvar liz) (lcons (lvar (lis liz)) lnil)))))
   = declared/ok prodRec/name dkind-non-inductive/defn (dkind-ok/defn prodRec/type-wf prodRec/value-typed).
