PProd_fst/value-typed : of (elam (esort (lvar liz))
                          ([x]
                            (elam (esort (lvar (lis liz)))
                              ([y]
                                (elam (eapp (eapp (econst "PProd" (lcons (lvar liz) (lcons (lvar (lis liz)) lnil))) x) y)
                                  ([z]
                                    (eproj "PProd" 0
                                      z))))))) (eforall (esort (lvar liz))
                          ([x] (eforall (esort (lvar (lis liz))) ([y] (eforall (eapp (eapp (econst "PProd" (lcons (lvar liz) (lcons (lvar (lis liz)) lnil))) x) y) ([z] x)))))).

PProd_fst/name : name "PProd.fst" (is-decl (eforall (esort (lvar liz))
                                             ([x] (eforall (esort (lvar (lis liz))) ([y] (eforall (eapp (eapp (econst "PProd" (lcons (lvar liz) (lcons (lvar (lis liz)) lnil))) x) y) ([z] x)))))) (defn (elam (esort (lvar liz)) ([x] (elam (esort (lvar (lis liz))) ([y] (elam (eapp (eapp (econst "PProd" (lcons (lvar liz) (lcons (lvar (lis liz)) lnil))) x) y) ([z] (eproj "PProd" 0 z))))))))).

PProd_fst/decl : declared "PProd.fst" (eforall (esort (lvar liz))
                                        ([x] (eforall (esort (lvar (lis liz))) ([y] (eforall (eapp (eapp (econst "PProd" (lcons (lvar liz) (lcons (lvar (lis liz)) lnil))) x) y) ([z] x)))))) (defn (elam (esort (lvar liz)) ([x] (elam (esort (lvar (lis liz))) ([y] (elam (eapp (eapp (econst "PProd" (lcons (lvar liz) (lcons (lvar (lis liz)) lnil))) x) y) ([z] (eproj "PProd" 0 z))))))))
   = declared/ok PProd_fst/name (dkind-ok/defn PProd_fst/type-wf PProd_fst/value-typed).

