PProd_fst/type-wf : of (eforall (esort (lvar liz))
                      ([x]
                        (eforall (esort (lvar (lis liz))) ([y] (eforall (eapp (eapp (econst "PProd" (lcons (lvar liz) (lcons (lvar (lis liz)) lnil))) x) y) ([z] x)))))) (esort PProd_fst/type-wf-sort)
   = (defeq/forall
       defeq/sort-refl
       ([x]
         ([h]
           (defeq/forall
             defeq/sort-refl
             ([y]
               ([h1]
                 (defeq/forall
                   (defeq/app
                     (defeq/app
                       (defeq/const
                         PProd/decl
                         (inst-expr/forall
                           (inst-expr/sort (lvl-inst/var lvl-nth/zero))
                           ([x]
                             ([h]
                               (inst-expr/forall
                                 (inst-expr/sort
                                   (lvl-inst/var (lvl-nth/succ lvl-nth/zero)))
                                 ([y]
                                   ([h1]
                                     (inst-expr/sort
                                       (lvl-inst/max
                                         (lvl-inst/max
                                           (lvl-inst/succ lvl-inst/zero)
                                           (lvl-inst/var lvl-nth/zero))
                                         (lvl-inst/var
                                           (lvl-nth/succ lvl-nth/zero)))))))))))
                       h)
                     h1)
                   ([z] ([h2] h))))))))).

