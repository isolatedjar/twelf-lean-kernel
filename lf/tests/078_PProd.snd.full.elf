           (defeq/forall
             defeq/sort-refl
             ([y]
               ([h1]
                 (defeq/forall
                   (defeq/app
                     (defeq/app
                       (defeq/const
                         PProd/decl
                         (inst-expr/forall
                           (inst-expr/sort (inst-lvl/var nth-lvl/z))
                           ([x]
                             ([h]
                               (inst-expr/forall
                                 (inst-expr/sort
                                   (inst-lvl/var (nth-lvl/s nth-lvl/z)))
                                 ([y]
                                   ([h1]
                                     (inst-expr/sort
                                       (inst-lvl/max
                                         (inst-lvl/var (nth-lvl/s nth-lvl/z))
                                         (inst-lvl/max
                                           (inst-lvl/var nth-lvl/z)
                                           (inst-lvl/succ
                                             inst-lvl/zero)))))))))))
                       h)
