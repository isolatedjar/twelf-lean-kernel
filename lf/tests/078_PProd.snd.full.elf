  (defn (elam (esort (lvar z)) ([x] (elam (esort (lvar (s z))) ([y] (elam (eapp (eapp (econst "PProd" (lcons (lvar z) (lcons (lvar (s z)) lnil))) x) y) ([w] (eproj "PProd" 1 w))))))))
