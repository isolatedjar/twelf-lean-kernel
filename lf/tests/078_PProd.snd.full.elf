                   ([w] ([h2] h1))))))))).

%%% HOLE
PProd_snd/value-typed : of
  (elam (esort (lvar z)) ([x] (elam (esort (lvar (s z))) ([y] (elam (eapp (eapp (econst "PProd" (lcons (lvar z) (lcons (lvar (s z)) lnil))) x) y) ([w] (eproj "PProd" 1 w)))))))
  (eforall (esort (lvar z)) ([x] (eforall (esort (lvar (s z))) ([y] (eforall (eapp (eapp (econst "PProd" (lcons (lvar z) (lcons (lvar (s z)) lnil))) x) y) ([w] y)))))).

PProd_snd/name : name "PProd.snd" (is-decl
  (eforall (esort (lvar z)) ([x] (eforall (esort (lvar (s z))) ([y] (eforall (eapp (eapp (econst "PProd" (lcons (lvar z) (lcons (lvar (s z)) lnil))) x) y) ([w] y))))))
