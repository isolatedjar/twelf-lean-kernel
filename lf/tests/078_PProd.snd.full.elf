  (esort (limax (lsucc (lvar z)) (limax (lsucc (lvar (s z))) (limax (lmax (lmax (lsucc lzero) (lvar z)) (lvar (s z))) (lvar (s z))))))
   = (defeq/forall
       defeq/sort-refl
       ([x]
