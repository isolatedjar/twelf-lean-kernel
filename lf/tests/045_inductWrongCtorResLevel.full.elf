inductWrongCtorResLevel_mk/positivity : ctor-positive "inductWrongCtorResLevel" (lcons (lvar z) (lcons (lvar (s z)) lnil)) (eforall (esort lzero) ([x] (eforall (esort lzero) ([y] (eapp (eapp (econst "inductWrongCtorResLevel" (lcons (lvar (s z)) (lcons (lvar z) lnil))) x) y))))).

