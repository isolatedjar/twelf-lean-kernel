%%% Expected outcome: reject
%%% An inductive with a constructor with wrong level parameters in result (they are swapped)
%% inductive inductWrongCtorResLevel
inductWrongCtorResLevel/type-wf-sort : lvl
   = (limax (lsucc lzero) (limax (lsucc lzero) (lsucc (lsucc lzero)))).

inductWrongCtorResLevel/type-wf : of (eforall (esort lzero) ([x] (eforall (esort lzero) ([y] (esort (lsucc lzero)))))) (esort inductWrongCtorResLevel/type-wf-sort)
   = (defeq/forall
       defeq/sort-refl
       ([x] ([h] (defeq/forall defeq/sort-refl ([y] ([h1] defeq/sort-refl)))))).

inductWrongCtorResLevel/ends-in-sort : ends-in-sort (eforall (esort lzero) ([x] (eforall (esort lzero) ([y] (esort (lsucc lzero))))))
   = (ends-in-sort/forall ([x] (ends-in-sort/forall ([y] ends-in-sort/sort)))).

inductWrongCtorResLevel/rec-name : name "inductWrongCtorResLevel.rec" (is-rec-for "inductWrongCtorResLevel").

inductWrongCtorResLevel/clf : count-leading-foralls (eforall (esort lzero) ([x] (eforall (esort lzero) ([y] (esort (lsucc lzero)))))) (lis (lis liz))
   = (count-leading-foralls/succ
       ([x] (count-leading-foralls/succ ([y] count-leading-foralls/zero)))).

inductWrongCtorResLevel/cnd : cnames-distinct (ccons "inductWrongCtorResLevel.mk" cnil)
   = (cnames-distinct/cons cnames-distinct/nil all-string-neq/nil).

inductWrongCtorResLevel/name : name "inductWrongCtorResLevel" (is-decl (eforall (esort lzero) ([x] (eforall (esort lzero) ([y] (esort (lsucc lzero)))))) (indt (ccons "inductWrongCtorResLevel.mk" cnil) (lis (lis liz)))).

inductWrongCtorResLevel/decl : declared "inductWrongCtorResLevel" (eforall (esort lzero) ([x] (eforall (esort lzero) ([y] (esort (lsucc lzero)))))) (indt (ccons "inductWrongCtorResLevel.mk" cnil) (lis (lis liz)))
   = declared/ok-indt inductWrongCtorResLevel/name inductWrongCtorResLevel/rec-name inductWrongCtorResLevel/clf inductWrongCtorResLevel/cnd (dkind-ok/indt inductWrongCtorResLevel/type-wf inductWrongCtorResLevel/ends-in-sort).

%% ctor inductWrongCtorResLevel.mk (of inductWrongCtorResLevel)
inductWrongCtorResLevel_mk/type-wf-sort : lvl
   = (limax (lsucc lzero) (limax (lsucc lzero) (lsucc lzero))).

inductWrongCtorResLevel_mk/type-wf : of
  (eforall (esort lzero) ([x] (eforall (esort lzero) ([y] (eapp (eapp (econst "inductWrongCtorResLevel" (lcons (lvar (lis liz)) (lcons (lvar liz) lnil))) x) y)))))
  (esort inductWrongCtorResLevel_mk/type-wf-sort)
   = (defeq/forall
       defeq/sort-refl
       ([x]
         ([h]
           (defeq/forall
             defeq/sort-refl
             ([y]
               ([h1]
                 (defeq/app
                   (defeq/app
                     (defeq/const
                       inductWrongCtorResLevel/decl
                       (inst-expr/forall
                         (inst-expr/sort lvl-inst/zero)
                         ([x]
                           ([h]
                             (inst-expr/forall
                               (inst-expr/sort lvl-inst/zero)
                               ([y]
                                 ([h1]
                                   (inst-expr/sort
                                     (lvl-inst/succ lvl-inst/zero)))))))))
                     h)
                   h1))))))).

%%% HOLE
inductWrongCtorResLevel_mk/positivity : ctor-positive "inductWrongCtorResLevel" (lcons (lvar liz) (lcons (lvar (lis liz)) lnil)) (eforall (esort lzero) ([x] (eforall (esort lzero) ([y] (eapp (eapp (econst "inductWrongCtorResLevel" (lcons (lvar (lis liz)) (lcons (lvar liz) lnil))) x) y))))).

inductWrongCtorResLevel_mk/eisl : ends-in-sort-with-level (eforall (esort lzero) ([x] (eforall (esort lzero) ([y] (esort (lsucc lzero)))))) (lsucc lzero)
   = (ends-in-sort-with-level/forall
       ([x]
         (ends-in-sort-with-level/forall ([y] ends-in-sort-with-level/sort)))).

inductWrongCtorResLevel_mk/cmem : cmem "inductWrongCtorResLevel.mk" (ccons "inductWrongCtorResLevel.mk" cnil)
   = cmem/here.

inductWrongCtorResLevel_mk/fuo : field-universes-ok-skip-params (lis (lis liz)) (eforall (esort lzero) ([x] (eforall (esort lzero) ([y] (eapp (eapp (econst "inductWrongCtorResLevel" (lcons (lvar (lis liz)) (lcons (lvar liz) lnil))) x) y))))) (lsucc lzero)
   = (field-universes-ok-skip-params/skip
       ([x]
         ([h]
           (field-universes-ok-skip-params/skip
             ([y]
               ([h1]
                 (field-universes-ok-skip-params/start
                   (field-universes-ok/done not-forall/app)))))))).

inductWrongCtorResLevel_mk/name : name "inductWrongCtorResLevel.mk" (is-decl
  (eforall (esort lzero) ([x] (eforall (esort lzero) ([y] (eapp (eapp (econst "inductWrongCtorResLevel" (lcons (lvar (lis liz)) (lcons (lvar liz) lnil))) x) y)))))
  (ctor "inductWrongCtorResLevel" liz)).

inductWrongCtorResLevel_mk/decl : declared "inductWrongCtorResLevel.mk"
  (eforall (esort lzero) ([x] (eforall (esort lzero) ([y] (eapp (eapp (econst "inductWrongCtorResLevel" (lcons (lvar (lis liz)) (lcons (lvar liz) lnil))) x) y)))))
  (ctor "inductWrongCtorResLevel" liz)
   = declared/ok-ctor inductWrongCtorResLevel_mk/name inductWrongCtorResLevel/name inductWrongCtorResLevel_mk/cmem inductWrongCtorResLevel_mk/eisl inductWrongCtorResLevel_mk/fuo (dkind-ok/ctor inductWrongCtorResLevel_mk/type-wf inductWrongCtorResLevel_mk/positivity).

%% recursor inductWrongCtorResLevel.rec
inductWrongCtorResLevel_rec/type-wf-sort : lvl
   = (lsucc lzero).

inductWrongCtorResLevel_rec/type-wf : of (esort lzero) (esort inductWrongCtorResLevel_rec/type-wf-sort)
   = defeq/sort-refl.

inductWrongCtorResLevel_rec/decl : declared "inductWrongCtorResLevel.rec" (esort lzero) (irec "inductWrongCtorResLevel")
   = declared/ok-irec inductWrongCtorResLevel/rec-name (dkind-ok/irec inductWrongCtorResLevel_rec/type-wf).
