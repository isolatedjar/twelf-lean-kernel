%%% An inductive with a constructor with wrong level parameters in result (they are swapped)
%% inductive inductWrongCtorResLevel
inductWrongCtorResLevel/type-wf : of (eforall (esort lzero) ([x] (eforall (esort lzero) ([y] (esort (lsucc lzero)))))) (esort (limax (lsucc lzero) (limax (lsucc lzero) (lsucc (lsucc lzero)))))
   = (defeq/forall
       defeq/sort-refl
       ([x] ([h] (defeq/forall defeq/sort-refl ([y] ([h1] defeq/sort-refl)))))).

inductWrongCtorResLevel/ends-in-sort : ends-in-sort (eforall (esort lzero) ([x] (eforall (esort lzero) ([y] (esort (lsucc lzero))))))
   = (ends-in-sort/forall ([x] (ends-in-sort/forall ([y] ends-in-sort/sort)))).

inductWrongCtorResLevel/rec-name : name "inductWrongCtorResLevel.rec" (is-rec-for "inductWrongCtorResLevel").

inductWrongCtorResLevel/eisl : ends-in-sort-with-level (eforall (esort lzero) ([x] (eforall (esort lzero) ([y] (esort (lsucc lzero)))))) (lsucc lzero)
