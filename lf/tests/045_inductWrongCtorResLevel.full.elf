%%% Expected outcome: reject
%%% An inductive with a constructor with wrong level parameters in result (they are swapped)
%% inductive inductWrongCtorResLevel
inductWrongCtorResLevel/type-wf-sort : lvl
   = (limax (lsucc lzero) (limax (lsucc lzero) (lsucc (lsucc lzero)))).

inductWrongCtorResLevel/type-wf : of (eforall (esort lzero) ([x] (eforall (esort lzero) ([y] (esort (lsucc lzero)))))) (esort inductWrongCtorResLevel/type-wf-sort)
   = (defeq/forall
       defeq/sort-refl
       ([x] ([h] (defeq/forall defeq/sort-refl ([y] ([h1] defeq/sort-refl)))))).

inductWrongCtorResLevel/ends-in-sort : ends-in-sort (eforall (esort lzero) ([x] (eforall (esort lzero) ([y] (esort (lsucc lzero))))))
   = (ends-in-sort/forall ([x] (ends-in-sort/forall ([y] ends-in-sort/sort)))).

inductWrongCtorResLevel/rec-name : name "inductWrongCtorResLevel.rec" (is-rec-for "inductWrongCtorResLevel").

inductWrongCtorResLevel/name : name "inductWrongCtorResLevel" (is-decl (eforall (esort lzero) ([x] (eforall (esort lzero) ([y] (esort (lsucc lzero)))))) indt).

inductWrongCtorResLevel/decl : declared "inductWrongCtorResLevel" (eforall (esort lzero) ([x] (eforall (esort lzero) ([y] (esort (lsucc lzero)))))) indt
   = declared/ok inductWrongCtorResLevel/name (dkind-ok/indt inductWrongCtorResLevel/type-wf inductWrongCtorResLevel/ends-in-sort).

%% ctor inductWrongCtorResLevel.mk (of inductWrongCtorResLevel)
inductWrongCtorResLevel_mk/type-wf-sort : lvl
   = (limax (lsucc lzero) (limax (lsucc lzero) (lsucc lzero))).

inductWrongCtorResLevel_mk/type-wf : of (eforall (esort lzero)
                                       ([x]
                                         (eforall (esort lzero)
                                           ([y]
                                             (eapp (eapp (econst "inductWrongCtorResLevel" (lcons (lvar (lis liz)) (lcons (lvar liz) lnil))) x) y))))) (esort inductWrongCtorResLevel_mk/type-wf-sort)
   = (defeq/forall
       defeq/sort-refl
       ([x]
         ([h]
           (defeq/forall
             defeq/sort-refl
             ([y]
               ([h1]
                 (defeq/app
                   (defeq/app
                     (defeq/const
                       inductWrongCtorResLevel/decl
                       (inst-expr/forall
                         (inst-expr/sort lvl-inst/zero)
                         ([x]
                           ([h]
                             (inst-expr/forall
                               (inst-expr/sort lvl-inst/zero)
                               ([y]
                                 ([h1]
                                   (inst-expr/sort
                                     (lvl-inst/succ lvl-inst/zero)))))))))
                     h)
                   h1))))))).

%%% HOLE
inductWrongCtorResLevel_mk/positivity : ctor-positive "inductWrongCtorResLevel" (lcons (lvar liz) (lcons (lvar (lis liz)) lnil)) (eforall (esort lzero) ([x] (eforall (esort lzero) ([y] (eapp (eapp (econst "inductWrongCtorResLevel" (lcons (lvar (lis liz)) (lcons (lvar liz) lnil))) x) y))))).

inductWrongCtorResLevel_mk/eisl : ends-in-sort-with-level (eforall (esort lzero) ([x] (eforall (esort lzero) ([y] (esort (lsucc lzero)))))) (lsucc lzero)
   = (ends-in-sort-with-level/forall
       ([x]
         (ends-in-sort-with-level/forall ([y] ends-in-sort-with-level/sort)))).

%%% HOLE: inductWrongCtorResLevel_mk/fuo — prover for field-universes-ok-skip-params not yet implemented
inductWrongCtorResLevel_mk/fuo : field-universes-ok-skip-params (lis (lis liz)) (eforall (esort lzero) ([x] (eforall (esort lzero) ([y] (eapp (eapp (econst "inductWrongCtorResLevel" (lcons (lvar (lis liz)) (lcons (lvar liz) lnil))) x) y))))) (lsucc lzero).

inductWrongCtorResLevel_mk/name : name "inductWrongCtorResLevel.mk" (is-decl (eforall (esort lzero)
                                                                               ([x]
                                                                                 (eforall (esort lzero)
                                                                                   ([y] (eapp (eapp (econst "inductWrongCtorResLevel" (lcons (lvar (lis liz)) (lcons (lvar liz) lnil))) x) y))))) ctor).

inductWrongCtorResLevel_mk/decl : declared "inductWrongCtorResLevel.mk" (eforall (esort lzero)
                                                                          ([x]
                                                                            (eforall (esort lzero)
                                                                              ([y] (eapp (eapp (econst "inductWrongCtorResLevel" (lcons (lvar (lis liz)) (lcons (lvar liz) lnil))) x) y))))) ctor
   = declared/ok inductWrongCtorResLevel_mk/name (dkind-ok/ctor inductWrongCtorResLevel_mk/type-wf inductWrongCtorResLevel_mk/positivity inductWrongCtorResLevel/decl inductWrongCtorResLevel_mk/eisl inductWrongCtorResLevel_mk/fuo).

%% recursor inductWrongCtorResLevel.rec
inductWrongCtorResLevel_rec/type-wf-sort : lvl
   = (lsucc lzero).

inductWrongCtorResLevel_rec/type-wf : of (esort lzero) (esort inductWrongCtorResLevel_rec/type-wf-sort)
   = defeq/sort-refl.

inductWrongCtorResLevel_rec/decl : declared "inductWrongCtorResLevel.rec" (esort lzero) irec
   = declared/ok-irec inductWrongCtorResLevel/rec-name (dkind-ok/irec inductWrongCtorResLevel_rec/type-wf).
