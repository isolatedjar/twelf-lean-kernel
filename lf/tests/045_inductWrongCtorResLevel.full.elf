inductWrongCtorResLevel/cnd : cnames-distinct (ccons "inductWrongCtorResLevel.mk" cnil)
   = (cnames-distinct/cons cnames-distinct/nil all-string-neq/nil).

inductWrongCtorResLevel/name : name "inductWrongCtorResLevel" (is-decl (eforall (esort lzero) ([x] (eforall (esort lzero) ([y] (esort (lsucc lzero)))))) (indt (ccons "inductWrongCtorResLevel.mk" cnil) (s (s z)))).

inductWrongCtorResLevel/decl : declared "inductWrongCtorResLevel" (eforall (esort lzero) ([x] (eforall (esort lzero) ([y] (esort (lsucc lzero)))))) (indt (ccons "inductWrongCtorResLevel.mk" cnil) (s (s z)))
   = declared/ok-indt inductWrongCtorResLevel/name inductWrongCtorResLevel/rec-name inductWrongCtorResLevel/cnd (dkind-ok/indt inductWrongCtorResLevel/type-wf inductWrongCtorResLevel/ends-in-sort).

%% ctor inductWrongCtorResLevel.mk (of inductWrongCtorResLevel)
inductWrongCtorResLevel_mk/type-wf : of
  (eforall (esort lzero) ([x] (eforall (esort lzero) ([y] (eapp (eapp (econst "inductWrongCtorResLevel" (lcons (lvar (s z)) (lcons (lvar z) lnil))) x) y)))))
  (esort (limax (lsucc lzero) (limax (lsucc lzero) (lsucc lzero))))
   = (defeq/forall
       defeq/sort-refl
       ([x]
         ([h]
           (defeq/forall
             defeq/sort-refl
             ([y]
               ([h1]
                 (defeq/app
                   (defeq/app
                     (defeq/const
                       inductWrongCtorResLevel/decl
                       (inst-expr/forall
                         (inst-expr/sort inst-lvl/zero)
                         ([x]
                           ([h]
                             (inst-expr/forall
                               (inst-expr/sort inst-lvl/zero)
                               ([y]
                                 ([h1]
                                   (inst-expr/sort
                                     (inst-lvl/succ inst-lvl/zero)))))))))
                     h)
                   h1))))))).

