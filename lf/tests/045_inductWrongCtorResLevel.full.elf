inductWrongCtorResLevel_mk/fuo : field-universes-ok (eforall (esort lzero) ([x] (eforall (esort lzero) ([y] (eapp (eapp (econst "inductWrongCtorResLevel" (lcons (lvar (s z)) (lcons (lvar z) lnil))) x) y))))) (lsucc lzero)
