%%% Expected outcome: accept
%%% Projection reductions
%solve nonneg_0 : 0 >= 0.

sneq/0 : string-neq "Bool.false" "Bool.true".

%% inductive Eq
Eq/type-wf-sort : lvl
   = (limax
       (lsucc (lvar liz))
       (limax (lvar liz) (limax (lvar liz) (lsucc lzero)))).

Eq/type-wf : of (eforall (esort (lvar liz)) ([x] (eforall x ([y] (eforall x ([z] (esort lzero))))))) (esort Eq/type-wf-sort)
   = (defeq/forall
       defeq/sort-refl
       ([x]
         ([h]
           (defeq/forall
             h
             ([y] ([h1] (defeq/forall h ([z] ([h2] defeq/sort-refl))))))))).

Eq/ends-in-sort : ends-in-sort (eforall (esort (lvar liz)) ([x] (eforall x ([y] (eforall x ([z] (esort lzero)))))))
   = (ends-in-sort/forall
       ([x]
         (ends-in-sort/forall
           ([y] (ends-in-sort/forall ([z] ends-in-sort/sort)))))).

Eq/rec-name : name "Eq.rec" (is-rec-for "Eq").

Eq/eisl : ends-in-sort-with-level (eforall (esort (lvar liz)) ([x] (eforall x ([y] (eforall x ([z] (esort lzero))))))) lzero
   = (ends-in-sort-with-level/forall
       ([x]
         (ends-in-sort-with-level/forall
           ([y]
             (ends-in-sort-with-level/forall
               ([z] ends-in-sort-with-level/sort)))))).

Eq/cnd : cnames-distinct (ccons "Eq.refl" cnil)
   = (cnames-distinct/cons cnames-distinct/nil all-string-neq/nil).

Eq/name : name "Eq" (is-decl (eforall (esort (lvar liz)) ([x] (eforall x ([y] (eforall x ([z] (esort lzero))))))) (indt (ccons "Eq.refl" cnil) (lis (lis liz)))).

Eq/decl : declared "Eq" (eforall (esort (lvar liz)) ([x] (eforall x ([y] (eforall x ([z] (esort lzero))))))) (indt (ccons "Eq.refl" cnil) (lis (lis liz)))
   = declared/ok-indt Eq/name Eq/rec-name Eq/cnd (dkind-ok/indt Eq/type-wf Eq/ends-in-sort).

%% ctor Eq.refl (of Eq)
Eq_refl/type-wf-sort : lvl
   = (limax (lsucc (lvar liz)) (limax (lvar liz) lzero)).

Eq_refl/type-wf : of (eforall (esort (lvar liz)) ([x] (eforall x ([y] (eapp (eapp (eapp (econst "Eq" (lcons (lvar liz) lnil)) x) y) y))))) (esort Eq_refl/type-wf-sort)
   = (defeq/forall
       defeq/sort-refl
       ([x]
         ([h]
           (defeq/forall
             h
             ([y]
               ([h1]
                 (defeq/app
                   (defeq/app
                     (defeq/app
                       (defeq/const
                         Eq/decl
                         (inst-expr/forall
                           (inst-expr/sort (lvl-inst/var lvl-nth/zero))
                           ([x]
                             ([h]
                               (inst-expr/forall
                                 h
                                 ([y]
                                   ([h1]
                                     (inst-expr/forall
                                       h
                                       ([z]
                                         ([h2]
                                           (inst-expr/sort
                                             lvl-inst/zero)))))))))))
                       h)
                     h1)
                   h1))))))).

Eq_refl/positivity : ctor-positive "Eq" (lcons (lvar liz) lnil) (eforall (esort (lvar liz)) ([x] (eforall x ([y] (eapp (eapp (eapp (econst "Eq" (lcons (lvar liz) lnil)) x) y) y)))))
   = (ctor-positive/intro ([S] (eforall (esort (lvar liz)) ([x] (eforall x ([y] (eapp (eapp (eapp S x) y) y)))))) (ctor-spine/arg
       (strict-pos/no-occur (esort (lvar liz)) no-self-ref/sort)
       ([x]
         ([y]
           (ctor-spine/arg
             (strict-pos/no-occur x y)
             ([z]
               ([w]
                 (ctor-spine/result
                   (applies-self/app
                     (applies-self/app
                       (applies-self/app applies-self/refl))))))))))).

Eq_refl/cmem : cmem "Eq.refl" (ccons "Eq.refl" cnil)
   = cmem/here.

Eq_refl/fuo : field-universes-ok (eforall (esort (lvar liz)) ([x] (eforall x ([y] (eapp (eapp (eapp (econst "Eq" (lcons (lvar liz) lnil)) x) y) y))))) lzero
   = (field-universes-ok/forall
       defeq/sort-refl
       (mleq/imax-lzL (mleq/self nonneg_0))
       ([x]
         ([h]
           (field-universes-ok/forall
             h
             (mleq/imax-lzL (mleq/self nonneg_0))
             ([y] ([h1] (field-universes-ok/done not-forall/app))))))).

Eq_refl/name : name "Eq.refl" (is-decl (eforall (esort (lvar liz)) ([x] (eforall x ([y] (eapp (eapp (eapp (econst "Eq" (lcons (lvar liz) lnil)) x) y) y))))) (ctor "Eq" liz)).

Eq_refl/decl : declared "Eq.refl" (eforall (esort (lvar liz)) ([x] (eforall x ([y] (eapp (eapp (eapp (econst "Eq" (lcons (lvar liz) lnil)) x) y) y))))) (ctor "Eq" liz)
   = declared/ok-ctor Eq_refl/name Eq/name Eq_refl/cmem Eq/eisl Eq_refl/fuo (dkind-ok/ctor Eq_refl/type-wf Eq_refl/positivity).

%% recursor Eq.rec (TCB-derived; informational only)
%%   level params: u u_1
%%   type:   (eforall (esort (lvar (lis liz))) ([x] (eforall x ([y] (eforall (eforall x ([z] (eforall (eapp (eapp (eapp (econst "Eq" (lcons (lvar (lis liz)) lnil)) x) y) z) ([w] (esort (lvar liz)))))) ([z] (eforall (eapp (eapp z y) (eapp (eapp (econst "Eq.refl" (lcons (lvar (lis liz)) lnil)) x) y)) ([w] (eforall x ([x1] (eforall (eapp (eapp (eapp (econst "Eq" (lcons (lvar (lis liz)) lnil)) x) y) x1) ([y1] (eapp (eapp z x1) y1)))))))))))))
%%   rules:
%%     Eq.rec … Eq.refl … = (elam (esort (lvar (lis liz))) ([x] (elam x ([y] (elam (eforall x ([z] (eforall (eapp (eapp (eapp (econst "Eq" (lcons (lvar (lis liz)) lnil)) x) y) z) ([w] (esort (lvar liz)))))) ([z] (elam (eapp (eapp z y) (eapp (eapp (econst "Eq.refl" (lcons (lvar (lis liz)) lnil)) x) y)) ([w] w))))))))   (0 fields)
%%   K-like reduction: yes

%% inductive Bool
Bool/type-wf-sort : lvl
   = (lsucc (lsucc lzero)).

Bool/type-wf : of (esort (lsucc lzero)) (esort Bool/type-wf-sort)
   = defeq/sort-refl.

Bool/ends-in-sort : ends-in-sort (esort (lsucc lzero))
   = ends-in-sort/sort.

Bool/rec-name : name "Bool.rec" (is-rec-for "Bool").

Bool/eisl : ends-in-sort-with-level (esort (lsucc lzero)) (lsucc lzero)
   = ends-in-sort-with-level/sort.

Bool/cnd : cnames-distinct (ccons "Bool.false" (ccons "Bool.true" cnil))
   = (cnames-distinct/cons
       (cnames-distinct/cons cnames-distinct/nil all-string-neq/nil)
       (all-string-neq/cons sneq/0 all-string-neq/nil)).

Bool/name : name "Bool" (is-decl (esort (lsucc lzero)) (indt (ccons "Bool.false" (ccons "Bool.true" cnil)) liz)).

Bool/decl : declared "Bool" (esort (lsucc lzero)) (indt (ccons "Bool.false" (ccons "Bool.true" cnil)) liz)
   = declared/ok-indt Bool/name Bool/rec-name Bool/cnd (dkind-ok/indt Bool/type-wf Bool/ends-in-sort).

%% ctor Bool.false (of Bool)
Bool_false/type-wf-sort : lvl
   = (lsucc lzero).

Bool_false/type-wf : of (econst "Bool" lnil) (esort Bool_false/type-wf-sort)
   = (defeq/const Bool/decl (inst-expr/sort (lvl-inst/succ lvl-inst/zero))).

Bool_false/positivity : ctor-positive "Bool" lnil (econst "Bool" lnil)
   = (ctor-positive/intro ([S] S) (ctor-spine/result applies-self/refl)).

Bool_false/cmem : cmem "Bool.false" (ccons "Bool.false" (ccons "Bool.true" cnil))
   = cmem/here.

Bool_false/fuo : field-universes-ok (econst "Bool" lnil) (lsucc lzero)
   = (field-universes-ok/done not-forall/const).

Bool_false/name : name "Bool.false" (is-decl (econst "Bool" lnil) (ctor "Bool" liz)).

Bool_false/decl : declared "Bool.false" (econst "Bool" lnil) (ctor "Bool" liz)
   = declared/ok-ctor Bool_false/name Bool/name Bool_false/cmem Bool/eisl Bool_false/fuo (dkind-ok/ctor Bool_false/type-wf Bool_false/positivity).

%% ctor Bool.true (of Bool)
Bool_true/type-wf-sort : lvl
   = (lsucc lzero).

Bool_true/type-wf : of (econst "Bool" lnil) (esort Bool_true/type-wf-sort)
   = (defeq/const Bool/decl (inst-expr/sort (lvl-inst/succ lvl-inst/zero))).

Bool_true/positivity : ctor-positive "Bool" lnil (econst "Bool" lnil)
   = (ctor-positive/intro ([S] S) (ctor-spine/result applies-self/refl)).

Bool_true/cmem : cmem "Bool.true" (ccons "Bool.false" (ccons "Bool.true" cnil))
   = (cmem/there cmem/here).

Bool_true/fuo : field-universes-ok (econst "Bool" lnil) (lsucc lzero)
   = (field-universes-ok/done not-forall/const).

Bool_true/name : name "Bool.true" (is-decl (econst "Bool" lnil) (ctor "Bool" (lis liz))).

Bool_true/decl : declared "Bool.true" (econst "Bool" lnil) (ctor "Bool" (lis liz))
   = declared/ok-ctor Bool_true/name Bool/name Bool_true/cmem Bool/eisl Bool_true/fuo (dkind-ok/ctor Bool_true/type-wf Bool_true/positivity).

%% recursor Bool.rec (TCB-derived; informational only)
%%   level params: u
%%   type:   (eforall (eforall (econst "Bool" lnil) ([x] (esort (lvar liz)))) ([x] (eforall (eapp x (econst "Bool.false" lnil)) ([y] (eforall (eapp x (econst "Bool.true" lnil)) ([z] (eforall (econst "Bool" lnil) ([w] (eapp x w)))))))))
%%   rules:
%%     Bool.rec … Bool.false … = (elam (eforall (econst "Bool" lnil) ([x] (esort (lvar liz)))) ([x] (elam (eapp x (econst "Bool.false" lnil)) ([y] (elam (eapp x (econst "Bool.true" lnil)) ([z] y))))))   (0 fields)
%%     Bool.rec … Bool.true … = (elam (eforall (econst "Bool" lnil) ([x] (esort (lvar liz)))) ([x] (elam (eapp x (econst "Bool.false" lnil)) ([y] (elam (eapp x (econst "Bool.true" lnil)) ([z] z))))))   (0 fields)

%% inductive Prod
Prod/type-wf-sort : lvl
   = (limax
       (lsucc (lsucc (lvar liz)))
       (limax
         (lsucc (lsucc (lvar (lis liz))))
         (lsucc (lmax (lsucc (lvar liz)) (lsucc (lvar (lis liz))))))).

Prod/type-wf : of (eforall (esort (lsucc (lvar liz))) ([x] (eforall (esort (lsucc (lvar (lis liz)))) ([y] (esort (lmax (lsucc (lvar liz)) (lsucc (lvar (lis liz))))))))) (esort Prod/type-wf-sort)
   = (defeq/forall
       defeq/sort-refl
       ([x] ([h] (defeq/forall defeq/sort-refl ([y] ([h1] defeq/sort-refl)))))).

Prod/ends-in-sort : ends-in-sort (eforall (esort (lsucc (lvar liz))) ([x] (eforall (esort (lsucc (lvar (lis liz)))) ([y] (esort (lmax (lsucc (lvar liz)) (lsucc (lvar (lis liz)))))))))
   = (ends-in-sort/forall ([x] (ends-in-sort/forall ([y] ends-in-sort/sort)))).

Prod/rec-name : name "Prod.rec" (is-rec-for "Prod").

Prod/eisl : ends-in-sort-with-level (eforall (esort (lsucc (lvar liz))) ([x] (eforall (esort (lsucc (lvar (lis liz)))) ([y] (esort (lmax (lsucc (lvar liz)) (lsucc (lvar (lis liz))))))))) (lmax (lsucc (lvar liz)) (lsucc (lvar (lis liz))))
   = (ends-in-sort-with-level/forall
       ([x]
         (ends-in-sort-with-level/forall ([y] ends-in-sort-with-level/sort)))).

Prod/cnd : cnames-distinct (ccons "Prod.mk" cnil)
   = (cnames-distinct/cons cnames-distinct/nil all-string-neq/nil).

Prod/name : name "Prod" (is-decl
  (eforall (esort (lsucc (lvar liz))) ([x] (eforall (esort (lsucc (lvar (lis liz)))) ([y] (esort (lmax (lsucc (lvar liz)) (lsucc (lvar (lis liz)))))))))
  (indt (ccons "Prod.mk" cnil) (lis (lis liz)))).

Prod/decl : declared "Prod"
  (eforall (esort (lsucc (lvar liz))) ([x] (eforall (esort (lsucc (lvar (lis liz)))) ([y] (esort (lmax (lsucc (lvar liz)) (lsucc (lvar (lis liz)))))))))
  (indt (ccons "Prod.mk" cnil) (lis (lis liz)))
   = declared/ok-indt Prod/name Prod/rec-name Prod/cnd (dkind-ok/indt Prod/type-wf Prod/ends-in-sort).

%% ctor Prod.mk (of Prod)
Prod_mk/type-wf-sort : lvl
   = (limax
       (lsucc (lsucc (lvar liz)))
       (limax
         (lsucc (lsucc (lvar (lis liz))))
         (limax
           (lsucc (lvar liz))
           (limax
             (lsucc (lvar (lis liz)))
             (lmax (lsucc (lvar liz)) (lsucc (lvar (lis liz)))))))).

Prod_mk/type-wf : of
  (eforall (esort (lsucc (lvar liz)))
    ([x] (eforall (esort (lsucc (lvar (lis liz)))) ([y] (eforall x ([z] (eforall y ([w] (eapp (eapp (econst "Prod" (lcons (lvar liz) (lcons (lvar (lis liz)) lnil))) x) y)))))))))
  (esort Prod_mk/type-wf-sort)
   = (defeq/forall
       defeq/sort-refl
       ([x]
         ([h]
           (defeq/forall
             defeq/sort-refl
             ([y]
               ([h1]
                 (defeq/forall
                   h
                   ([z]
                     ([h2]
                       (defeq/forall
                         h1
                         ([w]
                           ([h3]
                             (defeq/app
                               (defeq/app
                                 (defeq/const
                                   Prod/decl
                                   (inst-expr/forall
                                     (inst-expr/sort
                                       (lvl-inst/succ
                                         (lvl-inst/var lvl-nth/zero)))
                                     ([x]
                                       ([h]
                                         (inst-expr/forall
                                           (inst-expr/sort
                                             (lvl-inst/succ
                                               (lvl-inst/var
                                                 (lvl-nth/succ lvl-nth/zero))))
                                           ([y]
                                             ([h1]
                                               (inst-expr/sort
                                                 (lvl-inst/max
                                                   (lvl-inst/succ
                                                     (lvl-inst/var
                                                       lvl-nth/zero))
                                                   (lvl-inst/succ
                                                     (lvl-inst/var
                                                       (lvl-nth/succ
                                                         lvl-nth/zero))))))))))))
                                 h)
                               h1))))))))))))).

Prod_mk/positivity : ctor-positive "Prod" (lcons (lvar liz) (lcons (lvar (lis liz)) lnil)) (eforall (esort (lsucc (lvar liz))) ([x] (eforall (esort (lsucc (lvar (lis liz)))) ([y] (eforall x ([z] (eforall y ([w] (eapp (eapp (econst "Prod" (lcons (lvar liz) (lcons (lvar (lis liz)) lnil))) x) y)))))))))
   = (ctor-positive/intro ([S] (eforall (esort (lsucc (lvar liz))) ([x] (eforall (esort (lsucc (lvar (lis liz)))) ([y] (eforall x ([z] (eforall y ([w] (eapp (eapp S x) y)))))))))) (ctor-spine/arg
       (strict-pos/no-occur (esort (lsucc (lvar liz))) no-self-ref/sort)
       ([x]
         ([y]
           (ctor-spine/arg
             (strict-pos/no-occur
               (esort (lsucc (lvar (lis liz))))
               no-self-ref/sort)
             ([z]
               ([w]
                 (ctor-spine/arg
                   (strict-pos/no-occur x y)
                   ([x1]
                     ([y1]
                       (ctor-spine/arg
                         (strict-pos/no-occur z w)
                         ([z1]
                           ([w1]
                             (ctor-spine/result
                               (applies-self/app
                                 (applies-self/app
                                   applies-self/refl)))))))))))))))).

Prod_mk/cmem : cmem "Prod.mk" (ccons "Prod.mk" cnil)
   = cmem/here.

%%% HOLE: Prod_mk/fuo
Prod_mk/fuo : field-universes-ok (eforall (esort (lsucc (lvar liz))) ([x] (eforall (esort (lsucc (lvar (lis liz)))) ([y] (eforall x ([z] (eforall y ([w] (eapp (eapp (econst "Prod" (lcons (lvar liz) (lcons (lvar (lis liz)) lnil))) x) y))))))))) (lmax (lsucc (lvar liz)) (lsucc (lvar (lis liz)))).

Prod_mk/name : name "Prod.mk" (is-decl
  (eforall (esort (lsucc (lvar liz)))
    ([x] (eforall (esort (lsucc (lvar (lis liz)))) ([y] (eforall x ([z] (eforall y ([w] (eapp (eapp (econst "Prod" (lcons (lvar liz) (lcons (lvar (lis liz)) lnil))) x) y)))))))))
  (ctor "Prod" liz)).

Prod_mk/decl : declared "Prod.mk"
  (eforall (esort (lsucc (lvar liz)))
    ([x] (eforall (esort (lsucc (lvar (lis liz)))) ([y] (eforall x ([z] (eforall y ([w] (eapp (eapp (econst "Prod" (lcons (lvar liz) (lcons (lvar (lis liz)) lnil))) x) y)))))))))
  (ctor "Prod" liz)
   = declared/ok-ctor Prod_mk/name Prod/name Prod_mk/cmem Prod/eisl Prod_mk/fuo (dkind-ok/ctor Prod_mk/type-wf Prod_mk/positivity).

%% recursor Prod.rec (TCB-derived; informational only)
%%   level params: u_1 u v
%%   type:   (eforall (esort (lsucc (lvar (lis liz)))) ([x] (eforall (esort (lsucc (lvar (lis (lis liz))))) ([y] (eforall (eforall (eapp (eapp (econst "Prod" (lcons (lvar (lis liz)) (lcons (lvar (lis (lis liz))) lnil))) x) y) ([z] (esort (lvar liz)))) ([z] (eforall (eforall x ([w] (eforall y ([x1] (eapp z (eapp (eapp (eapp (eapp (econst "Prod.mk" (lcons (lvar (lis liz)) (lcons (lvar (lis (lis liz))) lnil))) x) y) w) x1)))))) ([w] (eforall (eapp (eapp (econst "Prod" (lcons (lvar (lis liz)) (lcons (lvar (lis (lis liz))) lnil))) x) y) ([x1] (eapp z x1)))))))))))
%%   rules:
%%     Prod.rec … Prod.mk … = (elam (esort (lsucc (lvar (lis liz)))) ([x] (elam (esort (lsucc (lvar (lis (lis liz))))) ([y] (elam (eforall (eapp (eapp (econst "Prod" (lcons (lvar (lis liz)) (lcons (lvar (lis (lis liz))) lnil))) x) y) ([z] (esort (lvar liz)))) ([z] (elam (eforall x ([w] (eforall y ([x1] (eapp z (eapp (eapp (eapp (eapp (econst "Prod.mk" (lcons (lvar (lis liz)) (lcons (lvar (lis (lis liz))) lnil))) x) y) w) x1)))))) ([w] (elam x ([x1] (elam y ([y1] (eapp (eapp w x1) y1)))))))))))))   (2 fields)

%% def Prod.snd
Prod_snd/type-wf-sort : lvl
   = (limax
       (lsucc (lsucc (lvar liz)))
       (limax
         (lsucc (lsucc (lvar (lis liz))))
         (limax
           (lmax (lsucc (lvar liz)) (lsucc (lvar (lis liz))))
           (lsucc (lvar (lis liz)))))).

Prod_snd/type-wf : of
  (eforall (esort (lsucc (lvar liz))) ([x] (eforall (esort (lsucc (lvar (lis liz)))) ([y] (eforall (eapp (eapp (econst "Prod" (lcons (lvar liz) (lcons (lvar (lis liz)) lnil))) x) y) ([z] y))))))
  (esort Prod_snd/type-wf-sort)
   = (defeq/forall
       defeq/sort-refl
       ([x]
         ([h]
           (defeq/forall
             defeq/sort-refl
             ([y]
               ([h1]
                 (defeq/forall
                   (defeq/app
                     (defeq/app
                       (defeq/const
                         Prod/decl
                         (inst-expr/forall
                           (inst-expr/sort
                             (lvl-inst/succ (lvl-inst/var lvl-nth/zero)))
                           ([x]
                             ([h]
                               (inst-expr/forall
                                 (inst-expr/sort
                                   (lvl-inst/succ
                                     (lvl-inst/var
                                       (lvl-nth/succ lvl-nth/zero))))
                                 ([y]
                                   ([h1]
                                     (inst-expr/sort
                                       (lvl-inst/max
                                         (lvl-inst/succ
                                           (lvl-inst/var lvl-nth/zero))
                                         (lvl-inst/succ
                                           (lvl-inst/var
                                             (lvl-nth/succ
                                               lvl-nth/zero))))))))))))
                       h)
                     h1)
                   ([z] ([h2] h1))))))))).

