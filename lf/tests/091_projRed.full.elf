                 (inst-expr/forall
                   (inst-expr/sort (lvl-inst/succ (lvl-inst/var lvl-nth/zero)))
                   ([x]
                     ([h]
                       (inst-expr/forall
                         (inst-expr/sort
                           (lvl-inst/succ
                             (lvl-inst/var (lvl-nth/succ lvl-nth/zero))))
                         ([y]
                           ([h1]
                             (inst-expr/forall
                               (inst-expr/app
                                 (inst-expr/app
                                   (inst-expr/const
                                     (lvls-inst/cons
                                       (lvl-inst/var lvl-nth/zero)
                                       (lvls-inst/cons
                                         (lvl-inst/var
                                           (lvl-nth/succ lvl-nth/zero))
                                         lvls-inst/nil)))
                                   h)
                                 h1)
                               ([z] ([h2] h1))))))))))
               (defeq/const
                 Bool/decl
                 (inst-expr/sort (lvl-inst/succ lvl-inst/zero))))
             (defeq/const
               Bool/decl
               (inst-expr/sort (lvl-inst/succ lvl-inst/zero))))
           (defeq/app
             (defeq/app
               (defeq/app
                 (defeq/app
                   (defeq/const
                     Prod_mk/decl
                     (inst-expr/forall
                       (inst-expr/sort
                         (lvl-inst/succ (lvl-inst/var lvl-nth/zero)))
                       ([x]
                         ([h]
                           (inst-expr/forall
                             (inst-expr/sort
                               (lvl-inst/succ
                                 (lvl-inst/var (lvl-nth/succ lvl-nth/zero))))
                             ([y]
                               ([h1]
                                 (inst-expr/forall
                                   h
                                   ([z]
                                     ([h2]
                                       (inst-expr/forall
                                         h1
                                         ([w]
                                           ([h3]
                                             (inst-expr/app
                                               (inst-expr/app
                                                 (inst-expr/const
                                                   (lvls-inst/cons
                                                     (lvl-inst/var lvl-nth/zero)
                                                     (lvls-inst/cons
                                                       (lvl-inst/var
                                                         (lvl-nth/succ
                                                           lvl-nth/zero))
                                                       lvls-inst/nil)))
                                                 h)
                                               h1))))))))))))))
                   (defeq/const
                     Bool/decl
                     (inst-expr/sort (lvl-inst/succ lvl-inst/zero))))
                 (defeq/const
                   Bool/decl
                   (inst-expr/sort (lvl-inst/succ lvl-inst/zero))))
               (defeq/const Bool_true/decl (inst-expr/const lvls-inst/nil)))
             (defeq/const Bool_false/decl (inst-expr/const lvls-inst/nil)))))
       (defeq/const Bool_false/decl (inst-expr/const lvls-inst/nil))).

