%%% Expected outcome: accept
%%% Type checking a non-dependent let
%% def letType
letType/type-wf-sort : lvl
   = (lsucc (lsucc lzero)).

letType/type-wf : of (esort (lsucc lzero)) (esort letType/type-wf-sort)
   = defeq/sort-refl.

letType/value-typed : of (eapp (elam (esort (lsucc lzero)) ([x] x)) (esort lzero)) (esort (lsucc lzero))
   = (defeq/app (defeq/lam defeq/sort-refl ([x] ([h] h))) defeq/sort-refl).

letType/name : name "letType" (is-decl (esort (lsucc lzero)) (defn (eapp (elam (esort (lsucc lzero)) ([x] x)) (esort lzero)))).

letType/decl : declared "letType" (esort (lsucc lzero)) (defn (eapp (elam (esort (lsucc lzero)) ([x] x)) (esort lzero)))
   = declared/ok letType/name dkind-non-inductive/defn (dkind-ok/defn letType/type-wf letType/value-typed).
