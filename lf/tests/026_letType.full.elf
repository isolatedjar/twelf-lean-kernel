%%% Expected outcome: accept
%%% Type checking a non-dependent let
%% def letType
letType/type-wf-sort : lvl
   = (lsucc (lsucc lzero)).

letType/type-wf : defeq (esort (lsucc lzero)) (esort (lsucc lzero)) (esort letType/type-wf-sort)
   = defeq/sort-refl.

%%% HOLE
letType/value-typed : defeq (eapp (elam (esort (lsucc lzero)) ([x] x)) (esort lzero)) (eapp (elam (esort (lsucc lzero)) ([x] x)) (esort lzero)) (esort (lsucc lzero)).

letType/name : name "letType" (is-decl (esort (lsucc lzero)) (defn (eapp (elam (esort (lsucc lzero)) ([x] x)) (esort lzero)))).

letType/decl : declared "letType" (esort (lsucc lzero)) (defn (eapp (elam (esort (lsucc lzero)) ([x] x)) (esort lzero)))
   = declared/ok letType/name (dkind-ok/defn letType/type-wf letType/value-typed).

