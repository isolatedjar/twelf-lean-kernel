%% def rfl
rfl/type-wf-sort : lvl
   = (limax (lsucc (lvar liz)) (limax (lvar liz) lzero)).

rfl/type-wf : of (eforall (esort (lvar liz)) ([x] (eforall x ([y] (eapp (eapp (eapp (econst "Eq" (lcons (lvar liz) lnil)) x) y) y))))) (esort rfl/type-wf-sort)
   = (defeq/forall
       defeq/sort-refl
       ([x]
         ([h]
           (defeq/forall
             h
             ([y]
               ([h1]
                 (defeq/app
                   (defeq/app
                     (defeq/app
                       (defeq/const
                         Eq/decl
                         (inst-expr/forall
                           (inst-expr/sort (lvl-inst/var lvl-nth/zero))
                           ([x]
                             ([h]
                               (inst-expr/forall
                                 h
                                 ([y]
                                   ([h1]
                                     (inst-expr/forall
                                       h
                                       ([z]
                                         ([h2]
                                           (inst-expr/sort
                                             lvl-inst/zero)))))))))))
                       h)
                     h1)
                   h1))))))).

rfl/value-typed : of
  (elam (esort (lvar liz)) ([x] (elam x ([y] (eapp (eapp (econst "Eq.refl" (lcons (lvar liz) lnil)) x) y)))))
  (eforall (esort (lvar liz)) ([x] (eforall x ([y] (eapp (eapp (eapp (econst "Eq" (lcons (lvar liz) lnil)) x) y) y)))))
   = (defeq/lam
       defeq/sort-refl
       ([x]
         ([h]
           (defeq/lam
             h
             ([y]
               ([h1]
                 (defeq/app
                   (defeq/app
                     (defeq/const
                       Eq_refl/decl
                       (inst-expr/forall
                         (inst-expr/sort (lvl-inst/var lvl-nth/zero))
                         ([x]
                           ([h]
                             (inst-expr/forall
                               h
                               ([y]
                                 ([h1]
                                   (inst-expr/app
                                     (inst-expr/app
                                       (inst-expr/app
                                         (inst-expr/const
                                           (lvls-inst/cons
                                             (lvl-inst/var lvl-nth/zero)
                                             lvls-inst/nil))
                                         h)
                                       h1)
                                     h1))))))))
                     h)
                   h1))))))).

rfl/name : name "rfl" (is-decl
  (eforall (esort (lvar liz)) ([x] (eforall x ([y] (eapp (eapp (eapp (econst "Eq" (lcons (lvar liz) lnil)) x) y) y)))))
  (defn (elam (esort (lvar liz)) ([x] (elam x ([y] (eapp (eapp (econst "Eq.refl" (lcons (lvar liz) lnil)) x) y))))))).

rfl/decl : declared "rfl"
  (eforall (esort (lvar liz)) ([x] (eforall x ([y] (eapp (eapp (eapp (econst "Eq" (lcons (lvar liz) lnil)) x) y) y)))))
  (defn (elam (esort (lvar liz)) ([x] (elam x ([y] (eapp (eapp (econst "Eq.refl" (lcons (lvar liz) lnil)) x) y))))))
   = declared/ok rfl/name dkind-non-inductive/defn (dkind-ok/defn rfl/type-wf rfl/value-typed).

%% thm rtreeRecReduction
rtreeRecReduction/type-wf : of
  (eforall (econst "RTree" lnil)
    ([x]
      (eforall (econst "RTree" lnil)
        ([y]
          (eapp (eapp (eapp (econst "Eq" (lcons (lsucc lzero) lnil)) (econst "RTree" lnil))
            (eapp (econst "RTree.left" lnil)
              (eapp (econst "RTree.node" lnil)
                (elam (econst "Bool" lnil) ([z] (eapp (eapp (eapp (eapp (econst "Bool.rec" (lcons (lsucc lzero) lnil)) (elam (econst "Bool" lnil) ([w] (econst "RTree" lnil)))) y) x) z))))))
            x)))))
  (esort lzero)
   = (defeq/conv
       (defeq/sort-eq
         (lvl-eq/le
           (mleq/imax-imL
             (mleq/maxL
               (mleq/imax-lzL (mleq/self nonneg_0))
               (mleq/imax-lzL (mleq/self nonneg_0))))
           (mleq/lz nonneg_0)))
       (defeq/forall
         (defeq/const RTree/decl (inst-expr/sort (lvl-inst/succ lvl-inst/zero)))
         ([x]
           ([h]
             (defeq/forall
               (defeq/const
                 RTree/decl
                 (inst-expr/sort (lvl-inst/succ lvl-inst/zero)))
               ([y]
                 ([h1]
                   (defeq/app
                     (defeq/app
                       (defeq/app
                         (defeq/const
                           Eq/decl
                           (inst-expr/forall
                             (inst-expr/sort (lvl-inst/var lvl-nth/zero))
                             ([x]
                               ([h]
                                 (inst-expr/forall
                                   h
                                   ([y]
                                     ([h1]
                                       (inst-expr/forall
                                         h
                                         ([z]
                                           ([h2]
                                             (inst-expr/sort
                                               lvl-inst/zero)))))))))))
                         (defeq/const
                           RTree/decl
                           (inst-expr/sort (lvl-inst/succ lvl-inst/zero))))
                       (defeq/app
                         (defeq/const
                           RTree_left/decl
                           (inst-expr/forall
                             (inst-expr/const lvls-inst/nil)
                             ([x] ([h] (inst-expr/const lvls-inst/nil)))))
                         (defeq/app
                           (defeq/const
                             RTree_node/decl
                             (inst-expr/forall
                               (inst-expr/forall
                                 (inst-expr/const lvls-inst/nil)
                                 ([x] ([h] (inst-expr/const lvls-inst/nil))))
                               ([x] ([h] (inst-expr/const lvls-inst/nil)))))
                           (defeq/conv
                             (defeq/forall
                               (defeq/const
                                 Bool/decl
                                 (inst-expr/sort (lvl-inst/succ lvl-inst/zero)))
                               ([z]
                                 ([h2]
                                   (defeq/trans
                                     (defeq/beta
                                       ([w]
                                         ([h3]
                                           (defeq/const
                                             RTree/decl
                                             (inst-expr/sort
                                               (lvl-inst/succ lvl-inst/zero)))))
                                       h2)
                                     (defeq/const
                                       RTree/decl
                                       (inst-expr/sort
                                         (lvl-inst/succ lvl-inst/zero)))))))
                             (defeq/lam
                               (defeq/const
                                 Bool/decl
                                 (inst-expr/sort (lvl-inst/succ lvl-inst/zero)))
                               ([z]
                                 ([h2]
                                   (defeq/app
                                     (defeq/app
                                       (defeq/app
                                         (defeq/app
                                           (defeq/const
                                             (rec-derived-declared
                                               (rec-derived/enum
                                                 Bool/decl
                                                 Bool/rec-name
                                                 (enum-rec-type/intro
                                                   ([x]
                                                     ([h]
                                                       (enum-rec-body/minor
                                                         ([y]
                                                           ([h1]
                                                             (enum-rec-body/minor
                                                               ([z]
                                                                 ([h2]
                                                                   enum-rec-body/done)))))))))
                                                 Bool/eisl
                                                 (le-eligible/non-prop
                                                   (mleq/self nonneg_0)))
                                               Bool/rec-name)
                                             (inst-expr/forall
                                               (inst-expr/forall
                                                 (inst-expr/const lvls-inst/nil)
                                                 ([x]
                                                   ([h]
                                                     (inst-expr/sort
                                                       (lvl-inst/var
                                                         lvl-nth/zero)))))
                                               ([x]
                                                 ([h]
                                                   (inst-expr/forall
                                                     (inst-expr/app
                                                       h
                                                       (inst-expr/const
                                                         lvls-inst/nil))
                                                     ([y]
                                                       ([h1]
                                                         (inst-expr/forall
                                                           (inst-expr/app
                                                             h
                                                             (inst-expr/const
                                                               lvls-inst/nil))
                                                           ([z]
                                                             ([h2]
                                                               (inst-expr/forall
                                                                 (inst-expr/const
                                                                   lvls-inst/nil)
                                                                 ([w]
                                                                   ([h3]
                                                                     (inst-expr/app
                                                                       h
                                                                       h3))))))))))))))
                                           (defeq/lam
                                             (defeq/const
                                               Bool/decl
                                               (inst-expr/sort
                                                 (lvl-inst/succ lvl-inst/zero)))
                                             ([w]
                                               ([h3]
                                                 (defeq/const
                                                   RTree/decl
                                                   (inst-expr/sort
                                                     (lvl-inst/succ
                                                       lvl-inst/zero)))))))
                                         (defeq/conv
                                           (defeq/trans
                                             (defeq/const
                                               RTree/decl
                                               (inst-expr/sort
                                                 (lvl-inst/succ lvl-inst/zero)))
                                             (defeq/symm
                                               (defeq/beta
                                                 ([w]
                                                   ([h3]
                                                     (defeq/const
                                                       RTree/decl
                                                       (inst-expr/sort
                                                         (lvl-inst/succ
                                                           lvl-inst/zero)))))
                                                 (defeq/const
                                                   Bool_false/decl
                                                   (inst-expr/const
                                                     lvls-inst/nil)))))
                                           h1))
                                       (defeq/conv
                                         (defeq/trans
                                           (defeq/const
                                             RTree/decl
                                             (inst-expr/sort
                                               (lvl-inst/succ lvl-inst/zero)))
                                           (defeq/symm
                                             (defeq/beta
                                               ([w]
                                                 ([h3]
                                                   (defeq/const
                                                     RTree/decl
                                                     (inst-expr/sort
                                                       (lvl-inst/succ
                                                         lvl-inst/zero)))))
                                               (defeq/const
                                                 Bool_true/decl
                                                 (inst-expr/const
                                                   lvls-inst/nil)))))
                                         h))
                                     h2))))))))
                     h)))))))).

