%%   K-like reduction: yes

%% def RTree.left
RTree_left/type-wf : of (eforall (econst "RTree" lnil) ([x] (econst "RTree" lnil))) (esort (limax (lsucc lzero) (lsucc lzero)))
   = (defeq/forall
       (defeq/const RTree/decl (inst-expr/sort (inst-lvl/succ inst-lvl/zero)))
       ([x]
         ([h]
           (defeq/const
             RTree/decl
             (inst-expr/sort (inst-lvl/succ inst-lvl/zero)))))).

%%% HOLE
RTree_left/value-typed : of
  (elam (econst "RTree" lnil)
    ([x]
      (eapp (eapp (eapp (eapp (econst "RTree.rec" (lcons (lsucc lzero) lnil)) (elam (econst "RTree" lnil) ([y] (econst "RTree" lnil)))) (econst "RTree.leaf" lnil))
        (elam (eforall (econst "Bool" lnil) ([y] (econst "RTree" lnil)))
          ([y] (elam (eforall (econst "Bool" lnil) ([w] (eapp (elam (econst "RTree" lnil) ([v] (econst "RTree" lnil))) (eapp y w)))) ([w] (eapp y (econst "Bool.true" lnil)))))))
        x)))
  (eforall (econst "RTree" lnil) ([x] (econst "RTree" lnil))).

RTree_left/name : name "RTree.left" (is-decl
  (eforall (econst "RTree" lnil) ([x] (econst "RTree" lnil)))
  (defn (elam (econst "RTree" lnil) ([x] (eapp (eapp (eapp (eapp (econst "RTree.rec" (lcons (lsucc lzero) lnil)) (elam (econst "RTree" lnil) ([y] (econst "RTree" lnil)))) (econst "RTree.leaf" lnil)) (elam (eforall (econst "Bool" lnil) ([y] (econst "RTree" lnil))) ([y] (elam (eforall (econst "Bool" lnil) ([w] (eapp (elam (econst "RTree" lnil) ([v] (econst "RTree" lnil))) (eapp y w)))) ([w] (eapp y (econst "Bool.true" lnil))))))) x))))).

RTree_left/decl : declared "RTree.left"
  (eforall (econst "RTree" lnil) ([x] (econst "RTree" lnil)))
  (defn (elam (econst "RTree" lnil) ([x] (eapp (eapp (eapp (eapp (econst "RTree.rec" (lcons (lsucc lzero) lnil)) (elam (econst "RTree" lnil) ([y] (econst "RTree" lnil)))) (econst "RTree.leaf" lnil)) (elam (eforall (econst "Bool" lnil) ([y] (econst "RTree" lnil))) ([y] (elam (eforall (econst "Bool" lnil) ([w] (eapp (elam (econst "RTree" lnil) ([v] (econst "RTree" lnil))) (eapp y w)))) ([w] (eapp y (econst "Bool.true" lnil))))))) x))))
