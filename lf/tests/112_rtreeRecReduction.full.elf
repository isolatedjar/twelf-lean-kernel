%%% Expected outcome: accept
%%% Reduction behavior of `RTree.rec` on `RTree.mk`.
%solve nonneg_0 : 0 >= 0.

sneq/0 : string-neq "Bool.false" "Bool.true".
sneq/1 : string-neq "RTree.leaf" "RTree.node".
sneq/2 : string-neq "Bool" "RTree".

%% inductive Bool
Bool/type-wf-sort : lvl
   = (lsucc (lsucc lzero)).

Bool/type-wf : of (esort (lsucc lzero)) (esort Bool/type-wf-sort)
   = defeq/sort-refl.

Bool/ends-in-sort : ends-in-sort (esort (lsucc lzero))
   = ends-in-sort/sort.

Bool/rec-name : name "Bool.rec" (is-rec-for "Bool").

Bool/clf : count-leading-foralls (esort (lsucc lzero)) liz
   = count-leading-foralls/zero.

Bool/cnd : cnames-distinct (ccons "Bool.false" (ccons "Bool.true" cnil))
   = (cnames-distinct/cons
       (cnames-distinct/cons cnames-distinct/nil all-string-neq/nil)
       (all-string-neq/cons sneq/0 all-string-neq/nil)).

Bool/name : name "Bool" (is-decl (esort (lsucc lzero)) (indt (ccons "Bool.false" (ccons "Bool.true" cnil)) liz)).

Bool/decl : declared "Bool" (esort (lsucc lzero)) (indt (ccons "Bool.false" (ccons "Bool.true" cnil)) liz)
   = declared/ok-indt Bool/name Bool/rec-name Bool/clf Bool/cnd (dkind-ok/indt Bool/type-wf Bool/ends-in-sort).

%% ctor Bool.false (of Bool)
Bool_false/type-wf-sort : lvl
   = (lsucc lzero).

Bool_false/type-wf : of (econst "Bool" lnil) (esort Bool_false/type-wf-sort)
   = (defeq/const Bool/decl (inst-expr/sort (lvl-inst/succ lvl-inst/zero))).

Bool_false/positivity : ctor-positive "Bool" lnil (econst "Bool" lnil)
   = (ctor-positive/intro ([S] S) (ctor-spine/result applies-self/refl)).

Bool_false/eisl : ends-in-sort-with-level (esort (lsucc lzero)) (lsucc lzero)
   = ends-in-sort-with-level/sort.

Bool_false/cmem : cmem "Bool.false" (ccons "Bool.false" (ccons "Bool.true" cnil))
   = cmem/here.

Bool_false/fuo : field-universes-ok-skip-params liz (econst "Bool" lnil) (lsucc lzero)
   = (field-universes-ok-skip-params/start
       (field-universes-ok/done not-forall/const)).

Bool_false/name : name "Bool.false" (is-decl (econst "Bool" lnil) (ctor "Bool" liz)).

Bool_false/decl : declared "Bool.false" (econst "Bool" lnil) (ctor "Bool" liz)
   = declared/ok-ctor Bool_false/name Bool/name Bool_false/cmem Bool_false/eisl Bool_false/fuo (dkind-ok/ctor Bool_false/type-wf Bool_false/positivity).

%% ctor Bool.true (of Bool)
Bool_true/type-wf-sort : lvl
   = (lsucc lzero).

Bool_true/type-wf : of (econst "Bool" lnil) (esort Bool_true/type-wf-sort)
   = (defeq/const Bool/decl (inst-expr/sort (lvl-inst/succ lvl-inst/zero))).

Bool_true/positivity : ctor-positive "Bool" lnil (econst "Bool" lnil)
   = (ctor-positive/intro ([S] S) (ctor-spine/result applies-self/refl)).

Bool_true/eisl : ends-in-sort-with-level (esort (lsucc lzero)) (lsucc lzero)
   = ends-in-sort-with-level/sort.

Bool_true/cmem : cmem "Bool.true" (ccons "Bool.false" (ccons "Bool.true" cnil))
   = (cmem/there cmem/here).

Bool_true/fuo : field-universes-ok-skip-params liz (econst "Bool" lnil) (lsucc lzero)
   = (field-universes-ok-skip-params/start
       (field-universes-ok/done not-forall/const)).

Bool_true/name : name "Bool.true" (is-decl (econst "Bool" lnil) (ctor "Bool" (lis liz))).

Bool_true/decl : declared "Bool.true" (econst "Bool" lnil) (ctor "Bool" (lis liz))
   = declared/ok-ctor Bool_true/name Bool/name Bool_true/cmem Bool_true/eisl Bool_true/fuo (dkind-ok/ctor Bool_true/type-wf Bool_true/positivity).

%% recursor Bool.rec
Bool_rec/type-wf-sort : lvl
   = (limax
       (limax (lsucc lzero) (lsucc (lvar liz)))
       (limax (lvar liz) (limax (lvar liz) (limax (lsucc lzero) (lvar liz))))).

Bool_rec/type-wf : of
  (eforall (eforall (econst "Bool" lnil) ([x] (esort (lvar liz))))
    ([x] (eforall (eapp x (econst "Bool.false" lnil)) ([y] (eforall (eapp x (econst "Bool.true" lnil)) ([z] (eforall (econst "Bool" lnil) ([w] (eapp x w)))))))))
  (esort Bool_rec/type-wf-sort)
   = (defeq/forall
       (defeq/forall
         (defeq/const Bool/decl (inst-expr/sort (lvl-inst/succ lvl-inst/zero)))
         ([x] ([h] defeq/sort-refl)))
       ([x]
         ([h]
           (defeq/forall
             (defeq/app
               h
               (defeq/const Bool_false/decl (inst-expr/const lvls-inst/nil)))
             ([y]
               ([h1]
                 (defeq/forall
                   (defeq/app
                     h
                     (defeq/const
                       Bool_true/decl
                       (inst-expr/const lvls-inst/nil)))
                   ([z]
                     ([h2]
                       (defeq/forall
                         (defeq/const
                           Bool/decl
                           (inst-expr/sort (lvl-inst/succ lvl-inst/zero)))
                         ([w] ([h3] (defeq/app h h3))))))))))))).

Bool_rec/decl : declared "Bool.rec"
  (eforall (eforall (econst "Bool" lnil) ([x] (esort (lvar liz))))
    ([x] (eforall (eapp x (econst "Bool.false" lnil)) ([y] (eforall (eapp x (econst "Bool.true" lnil)) ([z] (eforall (econst "Bool" lnil) ([w] (eapp x w)))))))))
  (irec "Bool")
   = declared/ok-irec Bool/rec-name (dkind-ok/irec Bool_rec/type-wf).

%% inductive RTree
RTree/type-wf-sort : lvl
   = (lsucc (lsucc lzero)).

RTree/type-wf : of (esort (lsucc lzero)) (esort RTree/type-wf-sort)
   = defeq/sort-refl.

RTree/ends-in-sort : ends-in-sort (esort (lsucc lzero))
   = ends-in-sort/sort.

RTree/rec-name : name "RTree.rec" (is-rec-for "RTree").

RTree/clf : count-leading-foralls (esort (lsucc lzero)) liz
   = count-leading-foralls/zero.

RTree/cnd : cnames-distinct (ccons "RTree.leaf" (ccons "RTree.node" cnil))
   = (cnames-distinct/cons
       (cnames-distinct/cons cnames-distinct/nil all-string-neq/nil)
       (all-string-neq/cons sneq/1 all-string-neq/nil)).

RTree/name : name "RTree" (is-decl (esort (lsucc lzero)) (indt (ccons "RTree.leaf" (ccons "RTree.node" cnil)) liz)).

RTree/decl : declared "RTree" (esort (lsucc lzero)) (indt (ccons "RTree.leaf" (ccons "RTree.node" cnil)) liz)
   = declared/ok-indt RTree/name RTree/rec-name RTree/clf RTree/cnd (dkind-ok/indt RTree/type-wf RTree/ends-in-sort).

%% ctor RTree.leaf (of RTree)
RTree_leaf/type-wf-sort : lvl
   = (lsucc lzero).

RTree_leaf/type-wf : of (econst "RTree" lnil) (esort RTree_leaf/type-wf-sort)
   = (defeq/const RTree/decl (inst-expr/sort (lvl-inst/succ lvl-inst/zero))).

RTree_leaf/positivity : ctor-positive "RTree" lnil (econst "RTree" lnil)
   = (ctor-positive/intro ([S] S) (ctor-spine/result applies-self/refl)).

RTree_leaf/eisl : ends-in-sort-with-level (esort (lsucc lzero)) (lsucc lzero)
   = ends-in-sort-with-level/sort.

RTree_leaf/cmem : cmem "RTree.leaf" (ccons "RTree.leaf" (ccons "RTree.node" cnil))
   = cmem/here.

RTree_leaf/fuo : field-universes-ok-skip-params liz (econst "RTree" lnil) (lsucc lzero)
   = (field-universes-ok-skip-params/start
       (field-universes-ok/done not-forall/const)).

RTree_leaf/name : name "RTree.leaf" (is-decl (econst "RTree" lnil) (ctor "RTree" liz)).

RTree_leaf/decl : declared "RTree.leaf" (econst "RTree" lnil) (ctor "RTree" liz)
   = declared/ok-ctor RTree_leaf/name RTree/name RTree_leaf/cmem RTree_leaf/eisl RTree_leaf/fuo (dkind-ok/ctor RTree_leaf/type-wf RTree_leaf/positivity).

%% ctor RTree.node (of RTree)
RTree_node/type-wf-sort : lvl
   = (limax (limax (lsucc lzero) (lsucc lzero)) (lsucc lzero)).

RTree_node/type-wf : of (eforall (eforall (econst "Bool" lnil) ([x] (econst "RTree" lnil))) ([x] (econst "RTree" lnil))) (esort RTree_node/type-wf-sort)
   = (defeq/forall
       (defeq/forall
         (defeq/const Bool/decl (inst-expr/sort (lvl-inst/succ lvl-inst/zero)))
         ([x]
           ([h]
             (defeq/const
               RTree/decl
               (inst-expr/sort (lvl-inst/succ lvl-inst/zero))))))
       ([x]
         ([h]
           (defeq/const
             RTree/decl
             (inst-expr/sort (lvl-inst/succ lvl-inst/zero)))))).

RTree_node/positivity : ctor-positive "RTree" lnil (eforall (eforall (econst "Bool" lnil) ([x] (econst "RTree" lnil))) ([x] (econst "RTree" lnil)))
   = (ctor-positive/intro ([S] (eforall (eforall (econst "Bool" lnil) ([x] S)) ([x] S))) (ctor-spine/arg
       (strict-pos/forall
         (econst "Bool" lnil)
         (no-self-ref/const sneq/2)
         ([x] ([y] (strict-pos/head applies-self/refl))))
       ([x] ([y] (ctor-spine/result applies-self/refl))))).

RTree_node/eisl : ends-in-sort-with-level (esort (lsucc lzero)) (lsucc lzero)
   = ends-in-sort-with-level/sort.

RTree_node/cmem : cmem "RTree.node" (ccons "RTree.leaf" (ccons "RTree.node" cnil))
   = (cmem/there cmem/here).

RTree_node/fuo : field-universes-ok-skip-params liz (eforall (eforall (econst "Bool" lnil) ([x] (econst "RTree" lnil))) ([x] (econst "RTree" lnil))) (lsucc lzero)
   = (field-universes-ok-skip-params/start
       (field-universes-ok/forall
         (defeq/forall
           (defeq/const
             Bool/decl
             (inst-expr/sort (lvl-inst/succ lvl-inst/zero)))
           ([x]
             ([h]
               (defeq/const
                 RTree/decl
                 (inst-expr/sort (lvl-inst/succ lvl-inst/zero))))))
         (mleq/imax-lsL
           (mleq/sR
             (mleq/maxL
               (mleq/sL (mleq/self nonneg_0))
               (mleq/sL (mleq/self nonneg_0)))))
         ([x] ([h] (field-universes-ok/done not-forall/const))))).

RTree_node/name : name "RTree.node" (is-decl (eforall (eforall (econst "Bool" lnil) ([x] (econst "RTree" lnil))) ([x] (econst "RTree" lnil))) (ctor "RTree" (lis liz))).

RTree_node/decl : declared "RTree.node" (eforall (eforall (econst "Bool" lnil) ([x] (econst "RTree" lnil))) ([x] (econst "RTree" lnil))) (ctor "RTree" (lis liz))
   = declared/ok-ctor RTree_node/name RTree/name RTree_node/cmem RTree_node/eisl RTree_node/fuo (dkind-ok/ctor RTree_node/type-wf RTree_node/positivity).

%% recursor RTree.rec
RTree_rec/type-wf-sort : lvl
   = (limax
       (limax (lsucc lzero) (lsucc (lvar liz)))
       (limax
         (lvar liz)
         (limax
           (limax
             (limax (lsucc lzero) (lsucc lzero))
             (limax (limax (lsucc lzero) (lvar liz)) (lvar liz)))
           (limax (lsucc lzero) (lvar liz))))).

RTree_rec/type-wf : of
  (eforall (eforall (econst "RTree" lnil) ([x] (esort (lvar liz))))
    ([x]
      (eforall (eapp x (econst "RTree.leaf" lnil))
        ([y]
          (eforall (eforall (eforall (econst "Bool" lnil) ([z] (econst "RTree" lnil)))
            ([z] (eforall (eforall (econst "Bool" lnil) ([w] (eapp x (eapp z w)))) ([w] (eapp x (eapp (econst "RTree.node" lnil) z))))))
            ([z] (eforall (econst "RTree" lnil) ([w] (eapp x w)))))))))
  (esort RTree_rec/type-wf-sort)
   = (defeq/forall
       (defeq/forall
         (defeq/const RTree/decl (inst-expr/sort (lvl-inst/succ lvl-inst/zero)))
         ([x] ([h] defeq/sort-refl)))
       ([x]
         ([h]
           (defeq/forall
             (defeq/app
               h
               (defeq/const RTree_leaf/decl (inst-expr/const lvls-inst/nil)))
             ([y]
               ([h1]
                 (defeq/forall
                   (defeq/forall
                     (defeq/forall
                       (defeq/const
                         Bool/decl
                         (inst-expr/sort (lvl-inst/succ lvl-inst/zero)))
                       ([z]
                         ([h2]
                           (defeq/const
                             RTree/decl
                             (inst-expr/sort (lvl-inst/succ lvl-inst/zero))))))
                     ([z]
                       ([h2]
                         (defeq/forall
                           (defeq/forall
                             (defeq/const
                               Bool/decl
                               (inst-expr/sort (lvl-inst/succ lvl-inst/zero)))
                             ([w] ([h3] (defeq/app h (defeq/app h2 h3)))))
                           ([w]
                             ([h3]
                               (defeq/app
                                 h
                                 (defeq/app
                                   (defeq/const
                                     RTree_node/decl
                                     (inst-expr/forall
                                       (inst-expr/forall
                                         (inst-expr/const lvls-inst/nil)
                                         ([x]
                                           ([h]
                                             (inst-expr/const lvls-inst/nil))))
                                       ([x]
                                         ([h]
                                           (inst-expr/const lvls-inst/nil)))))
                                   h2))))))))
                   ([z]
                     ([h2]
                       (defeq/forall
                         (defeq/const
                           RTree/decl
                           (inst-expr/sort (lvl-inst/succ lvl-inst/zero)))
                         ([w] ([h3] (defeq/app h h3))))))))))))).

RTree_rec/decl : declared "RTree.rec"
  (eforall (eforall (econst "RTree" lnil) ([x] (esort (lvar liz))))
    ([x]
      (eforall (eapp x (econst "RTree.leaf" lnil))
        ([y]
          (eforall (eforall (eforall (econst "Bool" lnil) ([z] (econst "RTree" lnil)))
            ([z] (eforall (eforall (econst "Bool" lnil) ([w] (eapp x (eapp z w)))) ([w] (eapp x (eapp (econst "RTree.node" lnil) z))))))
            ([z] (eforall (econst "RTree" lnil) ([w] (eapp x w)))))))))
  (irec "RTree")
   = declared/ok-irec RTree/rec-name (dkind-ok/irec RTree_rec/type-wf).

%% inductive Eq
Eq/type-wf-sort : lvl
   = (limax
       (lsucc (lvar liz))
       (limax (lvar liz) (limax (lvar liz) (lsucc lzero)))).

Eq/type-wf : of (eforall (esort (lvar liz)) ([x] (eforall x ([y] (eforall x ([z] (esort lzero))))))) (esort Eq/type-wf-sort)
   = (defeq/forall
       defeq/sort-refl
       ([x]
         ([h]
           (defeq/forall
             h
             ([y] ([h1] (defeq/forall h ([z] ([h2] defeq/sort-refl))))))))).

Eq/ends-in-sort : ends-in-sort (eforall (esort (lvar liz)) ([x] (eforall x ([y] (eforall x ([z] (esort lzero)))))))
   = (ends-in-sort/forall
       ([x]
         (ends-in-sort/forall
           ([y] (ends-in-sort/forall ([z] ends-in-sort/sort)))))).

Eq/rec-name : name "Eq.rec" (is-rec-for "Eq").

Eq/clf : count-leading-foralls (eforall (esort (lvar liz)) ([x] (eforall x ([y] (eforall x ([z] (esort lzero))))))) (lis (lis liz))
   = (count-leading-foralls/succ
       ([x] (count-leading-foralls/succ ([y] count-leading-foralls/zero)))).

Eq/cnd : cnames-distinct (ccons "Eq.refl" cnil)
   = (cnames-distinct/cons cnames-distinct/nil all-string-neq/nil).

Eq/name : name "Eq" (is-decl (eforall (esort (lvar liz)) ([x] (eforall x ([y] (eforall x ([z] (esort lzero))))))) (indt (ccons "Eq.refl" cnil) (lis (lis liz)))).

Eq/decl : declared "Eq" (eforall (esort (lvar liz)) ([x] (eforall x ([y] (eforall x ([z] (esort lzero))))))) (indt (ccons "Eq.refl" cnil) (lis (lis liz)))
   = declared/ok-indt Eq/name Eq/rec-name Eq/clf Eq/cnd (dkind-ok/indt Eq/type-wf Eq/ends-in-sort).

%% ctor Eq.refl (of Eq)
Eq_refl/type-wf-sort : lvl
   = (limax (lsucc (lvar liz)) (limax (lvar liz) lzero)).

Eq_refl/type-wf : of (eforall (esort (lvar liz)) ([x] (eforall x ([y] (eapp (eapp (eapp (econst "Eq" (lcons (lvar liz) lnil)) x) y) y))))) (esort Eq_refl/type-wf-sort)
   = (defeq/forall
       defeq/sort-refl
       ([x]
         ([h]
           (defeq/forall
             h
             ([y]
               ([h1]
                 (defeq/app
                   (defeq/app
                     (defeq/app
                       (defeq/const
                         Eq/decl
                         (inst-expr/forall
                           (inst-expr/sort (lvl-inst/var lvl-nth/zero))
                           ([x]
                             ([h]
                               (inst-expr/forall
                                 h
                                 ([y]
                                   ([h1]
                                     (inst-expr/forall
                                       h
                                       ([z]
                                         ([h2]
                                           (inst-expr/sort
                                             lvl-inst/zero)))))))))))
                       h)
                     h1)
                   h1))))))).

Eq_refl/positivity : ctor-positive "Eq" (lcons (lvar liz) lnil) (eforall (esort (lvar liz)) ([x] (eforall x ([y] (eapp (eapp (eapp (econst "Eq" (lcons (lvar liz) lnil)) x) y) y)))))
   = (ctor-positive/intro ([S] (eforall (esort (lvar liz)) ([x] (eforall x ([y] (eapp (eapp (eapp S x) y) y)))))) (ctor-spine/arg
       (strict-pos/no-occur (esort (lvar liz)) no-self-ref/sort)
       ([x]
         ([y]
           (ctor-spine/arg
             (strict-pos/no-occur x y)
             ([z]
               ([w]
                 (ctor-spine/result
                   (applies-self/app
                     (applies-self/app
                       (applies-self/app applies-self/refl))))))))))).

Eq_refl/eisl : ends-in-sort-with-level (eforall (esort (lvar liz)) ([x] (eforall x ([y] (eforall x ([z] (esort lzero))))))) lzero
   = (ends-in-sort-with-level/forall
       ([x]
         (ends-in-sort-with-level/forall
           ([y]
             (ends-in-sort-with-level/forall
               ([z] ends-in-sort-with-level/sort)))))).

Eq_refl/cmem : cmem "Eq.refl" (ccons "Eq.refl" cnil)
   = cmem/here.

Eq_refl/fuo : field-universes-ok-skip-params (lis (lis liz)) (eforall (esort (lvar liz)) ([x] (eforall x ([y] (eapp (eapp (eapp (econst "Eq" (lcons (lvar liz) lnil)) x) y) y))))) lzero
   = (field-universes-ok-skip-params/skip
       ([x]
         ([h]
           (field-universes-ok-skip-params/skip
             ([y]
               ([h1]
                 (field-universes-ok-skip-params/start
                   (field-universes-ok/done not-forall/app)))))))).

Eq_refl/name : name "Eq.refl" (is-decl (eforall (esort (lvar liz)) ([x] (eforall x ([y] (eapp (eapp (eapp (econst "Eq" (lcons (lvar liz) lnil)) x) y) y))))) (ctor "Eq" liz)).

Eq_refl/decl : declared "Eq.refl" (eforall (esort (lvar liz)) ([x] (eforall x ([y] (eapp (eapp (eapp (econst "Eq" (lcons (lvar liz) lnil)) x) y) y))))) (ctor "Eq" liz)
   = declared/ok-ctor Eq_refl/name Eq/name Eq_refl/cmem Eq_refl/eisl Eq_refl/fuo (dkind-ok/ctor Eq_refl/type-wf Eq_refl/positivity).

%% recursor Eq.rec
Eq_rec/type-wf-sort : lvl
   = (limax
       (lsucc (lvar (lis liz)))
       (limax
         (lvar (lis liz))
         (limax
           (limax (lvar (lis liz)) (limax lzero (lsucc (lvar liz))))
           (limax
             (lvar liz)
             (limax (lvar (lis liz)) (limax lzero (lvar liz))))))).

Eq_rec/type-wf : of
  (eforall (esort (lvar (lis liz)))
    ([x]
      (eforall x
        ([y]
          (eforall (eforall x ([z] (eforall (eapp (eapp (eapp (econst "Eq" (lcons (lvar (lis liz)) lnil)) x) y) z) ([w] (esort (lvar liz))))))
            ([z]
              (eforall (eapp (eapp z y) (eapp (eapp (econst "Eq.refl" (lcons (lvar (lis liz)) lnil)) x) y))
                ([w] (eforall x ([x1] (eforall (eapp (eapp (eapp (econst "Eq" (lcons (lvar (lis liz)) lnil)) x) y) x1) ([y1] (eapp (eapp z x1) y1)))))))))))))
  (esort Eq_rec/type-wf-sort)
   = (defeq/forall
       defeq/sort-refl
       ([x]
         ([h]
           (defeq/forall
             h
             ([y]
               ([h1]
                 (defeq/forall
                   (defeq/forall
                     h
                     ([z]
                       ([h2]
                         (defeq/forall
                           (defeq/app
                             (defeq/app
                               (defeq/app
                                 (defeq/const
                                   Eq/decl
                                   (inst-expr/forall
                                     (inst-expr/sort
                                       (lvl-inst/var lvl-nth/zero))
                                     ([x]
                                       ([h]
                                         (inst-expr/forall
                                           h
                                           ([y]
                                             ([h1]
                                               (inst-expr/forall
                                                 h
                                                 ([z]
                                                   ([h2]
                                                     (inst-expr/sort
                                                       lvl-inst/zero)))))))))))
                                 h)
                               h1)
                             h2)
                           ([w] ([h3] defeq/sort-refl))))))
                   ([z]
                     ([h2]
                       (defeq/forall
                         (defeq/app
                           (defeq/app h2 h1)
                           (defeq/app
                             (defeq/app
                               (defeq/const
                                 Eq_refl/decl
                                 (inst-expr/forall
                                   (inst-expr/sort (lvl-inst/var lvl-nth/zero))
                                   ([x]
                                     ([h]
                                       (inst-expr/forall
                                         h
                                         ([y]
                                           ([h1]
                                             (inst-expr/app
                                               (inst-expr/app
                                                 (inst-expr/app
