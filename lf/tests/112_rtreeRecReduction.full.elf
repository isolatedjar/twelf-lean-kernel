%% def RTree.left
RTree_left/type-wf-sort : lvl
   = (limax (lsucc lzero) (lsucc lzero)).

RTree_left/type-wf : of (eforall (econst "RTree" lnil) ([x] (econst "RTree" lnil))) (esort RTree_left/type-wf-sort)
   = (defeq/forall
       (defeq/const RTree/decl (inst-expr/sort (lvl-inst/succ lvl-inst/zero)))
       ([x]
         ([h]
           (defeq/const
             RTree/decl
             (inst-expr/sort (lvl-inst/succ lvl-inst/zero)))))).

%%% HOLE
RTree_left/value-typed : of
  (elam (econst "RTree" lnil)
    ([x]
      (eapp (eapp (eapp (eapp (econst "RTree.rec" (lcons (lsucc lzero) lnil)) (elam (econst "RTree" lnil) ([y] (econst "RTree" lnil)))) (econst "RTree.leaf" lnil))
        (elam (eforall (econst "Bool" lnil) ([y] (econst "RTree" lnil)))
          ([y] (elam (eforall (econst "Bool" lnil) ([z] (eapp (elam (econst "RTree" lnil) ([w] (econst "RTree" lnil))) (eapp y z)))) ([z] (eapp y (econst "Bool.true" lnil)))))))
        x)))
  (eforall (econst "RTree" lnil) ([x] (econst "RTree" lnil))).

RTree_left/name : name "RTree.left" (is-decl
  (eforall (econst "RTree" lnil) ([x] (econst "RTree" lnil)))
  (defn (elam (econst "RTree" lnil) ([x] (eapp (eapp (eapp (eapp (econst "RTree.rec" (lcons (lsucc lzero) lnil)) (elam (econst "RTree" lnil) ([y] (econst "RTree" lnil)))) (econst "RTree.leaf" lnil)) (elam (eforall (econst "Bool" lnil) ([y] (econst "RTree" lnil))) ([y] (elam (eforall (econst "Bool" lnil) ([z] (eapp (elam (econst "RTree" lnil) ([w] (econst "RTree" lnil))) (eapp y z)))) ([z] (eapp y (econst "Bool.true" lnil))))))) x))))).

RTree_left/decl : declared "RTree.left"
  (eforall (econst "RTree" lnil) ([x] (econst "RTree" lnil)))
  (defn (elam (econst "RTree" lnil) ([x] (eapp (eapp (eapp (eapp (econst "RTree.rec" (lcons (lsucc lzero) lnil)) (elam (econst "RTree" lnil) ([y] (econst "RTree" lnil)))) (econst "RTree.leaf" lnil)) (elam (eforall (econst "Bool" lnil) ([y] (econst "RTree" lnil))) ([y] (elam (eforall (econst "Bool" lnil) ([z] (eapp (elam (econst "RTree" lnil) ([w] (econst "RTree" lnil))) (eapp y z)))) ([z] (eapp y (econst "Bool.true" lnil))))))) x))))
