%%% Expected outcome: accept
%%% A parametrized product type (with more general level parameters)
%solve nonneg_0 : 0 >= 0.

%% inductive PProd
PProd/type-wf-sort : lvl
   = (limax
       (lsucc (lvar liz))
       (limax
         (lsucc (lvar (lis liz)))
         (lsucc (lmax (lmax (lsucc lzero) (lvar liz)) (lvar (lis liz)))))).

PProd/type-wf : of (eforall (esort (lvar liz)) ([x] (eforall (esort (lvar (lis liz))) ([y] (esort (lmax (lmax (lsucc lzero) (lvar liz)) (lvar (lis liz)))))))) (esort PProd/type-wf-sort)
   = (defeq/forall
       defeq/sort-refl
       ([x] ([h] (defeq/forall defeq/sort-refl ([y] ([h1] defeq/sort-refl)))))).

PProd/ends-in-sort : ends-in-sort (eforall (esort (lvar liz)) ([x] (eforall (esort (lvar (lis liz))) ([y] (esort (lmax (lmax (lsucc lzero) (lvar liz)) (lvar (lis liz))))))))
   = (ends-in-sort/forall ([x] (ends-in-sort/forall ([y] ends-in-sort/sort)))).

PProd/rec-name : name "PProd.rec" (is-rec-for "PProd").

PProd/name : name "PProd" (is-decl (eforall (esort (lvar liz)) ([x] (eforall (esort (lvar (lis liz))) ([y] (esort (lmax (lmax (lsucc lzero) (lvar liz)) (lvar (lis liz)))))))) indt).

PProd/decl : declared "PProd" (eforall (esort (lvar liz)) ([x] (eforall (esort (lvar (lis liz))) ([y] (esort (lmax (lmax (lsucc lzero) (lvar liz)) (lvar (lis liz)))))))) indt
   = declared/ok PProd/name (dkind-ok/indt PProd/type-wf PProd/ends-in-sort).

%% ctor PProd.mk (of PProd)
PProd_mk/type-wf-sort : lvl
   = (limax
       (lsucc (lvar liz))
       (limax
         (lsucc (lvar (lis liz)))
         (limax
           (lvar liz)
           (limax
             (lvar (lis liz))
             (lmax (lmax (lsucc lzero) (lvar liz)) (lvar (lis liz))))))).

PProd_mk/type-wf : of (eforall (esort (lvar liz))
                     ([x]
                       (eforall (esort (lvar (lis liz)))
                         ([y] (eforall x ([z] (eforall y ([w] (eapp (eapp (econst "PProd" (lcons (lvar liz) (lcons (lvar (lis liz)) lnil))) x) y))))))))) (esort PProd_mk/type-wf-sort)
   = (defeq/forall
       defeq/sort-refl
       ([x]
         ([h]
           (defeq/forall
             defeq/sort-refl
             ([y]
               ([h1]
                 (defeq/forall
                   h
                   ([z]
                     ([h2]
                       (defeq/forall
                         h1
                         ([w]
                           ([h3]
                             (defeq/app
                               (defeq/app
                                 (defeq/const
                                   PProd/decl
                                   (inst-expr/forall
                                     (inst-expr/sort
                                       (lvl-inst/var lvl-nth/zero))
                                     ([x]
                                       ([h]
                                         (inst-expr/forall
                                           (inst-expr/sort
                                             (lvl-inst/var
                                               (lvl-nth/succ lvl-nth/zero)))
                                           ([y]
                                             ([h1]
                                               (inst-expr/sort
                                                 (lvl-inst/max
                                                   (lvl-inst/max
                                                     (lvl-inst/succ
                                                       lvl-inst/zero)
                                                     (lvl-inst/var
                                                       lvl-nth/zero))
                                                   (lvl-inst/var
                                                     (lvl-nth/succ
                                                       lvl-nth/zero)))))))))))
                                 h)
                               h1))))))))))))).

PProd_mk/positivity : ctor-positive "PProd" (lcons (lvar liz) (lcons (lvar (lis liz)) lnil)) (eforall (esort (lvar liz)) ([x] (eforall (esort (lvar (lis liz))) ([y] (eforall x ([z] (eforall y ([w] (eapp (eapp (econst "PProd" (lcons (lvar liz) (lcons (lvar (lis liz)) lnil))) x) y)))))))))
   = (ctor-positive/intro ([S] (eforall (esort (lvar liz)) ([x] (eforall (esort (lvar (lis liz))) ([y] (eforall x ([z] (eforall y ([w] (eapp (eapp S x) y)))))))))) (ctor-spine/arg
       (strict-pos/no-occur (esort (lvar liz)) no-self-ref/sort)
       ([x]
         ([y]
           (ctor-spine/arg
             (strict-pos/no-occur (esort (lvar (lis liz))) no-self-ref/sort)
             ([z]
               ([w]
                 (ctor-spine/arg
                   (strict-pos/no-occur x y)
                   ([x1]
                     ([y1]
                       (ctor-spine/arg
                         (strict-pos/no-occur z w)
                         ([z1]
                           ([w1]
                             (ctor-spine/result
                               (applies-self/app
                                 (applies-self/app
                                   applies-self/refl)))))))))))))))).

PProd_mk/eisl : ends-in-sort-with-level (eforall (esort (lvar liz)) ([x] (eforall (esort (lvar (lis liz))) ([y] (esort (lmax (lmax (lsucc lzero) (lvar liz)) (lvar (lis liz)))))))) (lmax (lmax (lsucc lzero) (lvar liz)) (lvar (lis liz)))
   = (ends-in-sort-with-level/forall
       ([x]
         (ends-in-sort-with-level/forall ([y] ends-in-sort-with-level/sort)))).

%%% HOLE: PProd_mk/fuo — prover for field-universes-ok-skip-params not yet implemented
PProd_mk/fuo : field-universes-ok-skip-params (lis (lis liz)) (eforall (esort (lvar liz)) ([x] (eforall (esort (lvar (lis liz))) ([y] (eforall x ([z] (eforall y ([w] (eapp (eapp (econst "PProd" (lcons (lvar liz) (lcons (lvar (lis liz)) lnil))) x) y))))))))) (lmax (lmax (lsucc lzero) (lvar liz)) (lvar (lis liz))).

PProd_mk/name : name "PProd.mk" (is-decl (eforall (esort (lvar liz)) ([x] (eforall (esort (lvar (lis liz))) ([y] (eforall x ([z] (eforall y ([w] (eapp (eapp (econst "PProd" (lcons (lvar liz) (lcons (lvar (lis liz)) lnil))) x) y))))))))) ctor).

PProd_mk/decl : declared "PProd.mk" (eforall (esort (lvar liz)) ([x] (eforall (esort (lvar (lis liz))) ([y] (eforall x ([z] (eforall y ([w] (eapp (eapp (econst "PProd" (lcons (lvar liz) (lcons (lvar (lis liz)) lnil))) x) y))))))))) ctor
   = declared/ok PProd_mk/name (dkind-ok/ctor PProd_mk/type-wf PProd_mk/positivity PProd/decl PProd_mk/eisl PProd_mk/fuo).

%% recursor PProd.rec
PProd_rec/type-wf-sort : lvl
   = (limax
       (lsucc (lvar (lis liz)))
       (limax
         (lsucc (lvar (lis (lis liz))))
         (limax
           (limax
             (lmax (lmax (lsucc lzero) (lvar (lis liz))) (lvar (lis (lis liz))))
             (lsucc (lvar liz)))
           (limax
             (limax (lvar (lis liz)) (limax (lvar (lis (lis liz))) (lvar liz)))
             (limax
               (lmax
                 (lmax (lsucc lzero) (lvar (lis liz)))
                 (lvar (lis (lis liz))))
               (lvar liz)))))).

PProd_rec/type-wf : of (eforall (esort (lvar (lis liz)))
                      ([x]
                        (eforall (esort (lvar (lis (lis liz))))
                          ([y]
                            (eforall (eforall (eapp (eapp (econst "PProd" (lcons (lvar (lis liz)) (lcons (lvar (lis (lis liz))) lnil))) x) y) ([z] (esort (lvar liz))))
                              ([z]
                                (eforall (eforall x
                                  ([w] (eforall y ([x1] (eapp z (eapp (eapp (eapp (eapp (econst "PProd.mk" (lcons (lvar (lis liz)) (lcons (lvar (lis (lis liz))) lnil))) x) y) w) x1))))))
                                  ([w]
                                    (eforall (eapp (eapp (econst "PProd" (lcons (lvar (lis liz)) (lcons (lvar (lis (lis liz))) lnil))) x) y) ([x1] (eapp z x1))))))))))) (esort PProd_rec/type-wf-sort)
   = (defeq/forall
       defeq/sort-refl
       ([x]
         ([h]
           (defeq/forall
             defeq/sort-refl
             ([y]
               ([h1]
                 (defeq/forall
                   (defeq/forall
                     (defeq/app
                       (defeq/app
                         (defeq/const
                           PProd/decl
                           (inst-expr/forall
                             (inst-expr/sort (lvl-inst/var lvl-nth/zero))
                             ([x]
                               ([h]
                                 (inst-expr/forall
                                   (inst-expr/sort
                                     (lvl-inst/var (lvl-nth/succ lvl-nth/zero)))
                                   ([y]
                                     ([h1]
                                       (inst-expr/sort
                                         (lvl-inst/max
                                           (lvl-inst/max
                                             (lvl-inst/succ lvl-inst/zero)
                                             (lvl-inst/var lvl-nth/zero))
                                           (lvl-inst/var
                                             (lvl-nth/succ
                                               lvl-nth/zero)))))))))))
                         h)
                       h1)
                     ([z] ([h2] defeq/sort-refl)))
                   ([z]
                     ([h2]
                       (defeq/forall
                         (defeq/forall
                           h
                           ([w]
                             ([h3]
                               (defeq/forall
                                 h1
                                 ([x1]
                                   ([h4]
                                     (defeq/app
                                       h2
                                       (defeq/app
                                         (defeq/app
                                           (defeq/app
                                             (defeq/app
                                               (defeq/const
                                                 PProd_mk/decl
                                                 (inst-expr/forall
                                                   (inst-expr/sort
                                                     (lvl-inst/var
                                                       lvl-nth/zero))
                                                   ([x]
                                                     ([h]
                                                       (inst-expr/forall
                                                         (inst-expr/sort
                                                           (lvl-inst/var
                                                             (lvl-nth/succ
                                                               lvl-nth/zero)))
                                                         ([y]
                                                           ([h1]
                                                             (inst-expr/forall
                                                               h
                                                               ([z]
                                                                 ([h2]
                                                                   (inst-expr/forall
                                                                     h1
                                                                     ([w]
                                                                       ([h3]
                                                                         (inst-expr/app
                                                                           (inst-expr/app
                                                                             (inst-expr/const
                                                                               (lvls-inst/cons
                                                                                 (lvl-inst/var
                                                                                   lvl-nth/zero)
                                                                                 (lvls-inst/cons
                                                                                   (lvl-inst/var
                                                                                     (lvl-nth/succ
                                                                                       lvl-nth/zero))
                                                                                   lvls-inst/nil)))
                                                                             h)
                                                                           h1))))))))))))))
                                               h)
                                             h1)
                                           h3)
                                         h4))))))))
                         ([w]
                           ([h3]
                             (defeq/forall
                               (defeq/app
                                 (defeq/app
                                   (defeq/const
                                     PProd/decl
                                     (inst-expr/forall
                                       (inst-expr/sort
                                         (lvl-inst/var lvl-nth/zero))
                                       ([x]
                                         ([h]
                                           (inst-expr/forall
                                             (inst-expr/sort
                                               (lvl-inst/var
                                                 (lvl-nth/succ lvl-nth/zero)))
                                             ([y]
                                               ([h1]
                                                 (inst-expr/sort
                                                   (lvl-inst/max
                                                     (lvl-inst/max
                                                       (lvl-inst/succ
                                                         lvl-inst/zero)
                                                       (lvl-inst/var
                                                         lvl-nth/zero))
                                                     (lvl-inst/var
                                                       (lvl-nth/succ
                                                         lvl-nth/zero)))))))))))
                                   h)
                                 h1)
                               ([x1] ([h4] (defeq/app h2 h4)))))))))))))))).

PProd_rec/decl : declared "PProd.rec" (eforall (esort (lvar (lis liz))) ([x] (eforall (esort (lvar (lis (lis liz)))) ([y] (eforall (eforall (eapp (eapp (econst "PProd" (lcons (lvar (lis liz)) (lcons (lvar (lis (lis liz))) lnil))) x) y) ([z] (esort (lvar liz)))) ([z] (eforall (eforall x ([w] (eforall y ([x1] (eapp z (eapp (eapp (eapp (eapp (econst "PProd.mk" (lcons (lvar (lis liz)) (lcons (lvar (lis (lis liz))) lnil))) x) y) w) x1)))))) ([w] (eforall (eapp (eapp (econst "PProd" (lcons (lvar (lis liz)) (lcons (lvar (lis (lis liz))) lnil))) x) y) ([x1] (eapp z x1))))))))))) irec
   = declared/ok-irec PProd/rec-name (dkind-ok/irec PProd_rec/type-wf).

%% def pprodType
pprodType/type-wf-sort : lvl
   = (limax
       (lsucc (lsucc lzero))
       (limax (lsucc (lsucc lzero)) (lsucc (lsucc lzero)))).

pprodType/type-wf : of (eforall (esort (lsucc lzero)) ([x] (eforall (esort (lsucc lzero)) ([y] (esort (lsucc lzero)))))) (esort pprodType/type-wf-sort)
   = (defeq/forall
       defeq/sort-refl
       ([x] ([h] (defeq/forall defeq/sort-refl ([y] ([h1] defeq/sort-refl)))))).

pprodType/value-typed : of (econst "PProd" (lcons (lsucc lzero) (lcons (lsucc lzero) lnil))) (eforall (esort (lsucc lzero)) ([x] (eforall (esort (lsucc lzero)) ([y] (esort (lsucc lzero))))))
   = (defeq/conv
       (defeq/forall
         (defeq/sort-eq lvl-eq/refl)
         ([x]
           ([h]
             (defeq/forall
               (defeq/sort-eq lvl-eq/refl)
               ([y]
                 ([h1]
                   (defeq/sort-eq
                     (lvl-eq/le
                       (mleq/sR
                         (mleq/maxL
                           (mleq/maxL
                             (mleq/sL (mleq/self nonneg_0))
                             (mleq/sL (mleq/self nonneg_0)))
                           (mleq/sL (mleq/self nonneg_0))))
                       (mleq/sL
                         (mleq/maxR-l
                           (mleq/maxR-l
                             (mleq/sR (mleq/self nonneg_0)))))))))))))
       (defeq/const
         PProd/decl
         (inst-expr/forall
           (inst-expr/sort (lvl-inst/var lvl-nth/zero))
           ([x]
             ([h]
               (inst-expr/forall
                 (inst-expr/sort (lvl-inst/var (lvl-nth/succ lvl-nth/zero)))
                 ([y]
                   ([h1]
                     (inst-expr/sort
                       (lvl-inst/max
                         (lvl-inst/max
                           (lvl-inst/succ lvl-inst/zero)
                           (lvl-inst/var lvl-nth/zero))
                         (lvl-inst/var (lvl-nth/succ lvl-nth/zero)))))))))))).

pprodType/name : name "pprodType" (is-decl (eforall (esort (lsucc lzero)) ([x] (eforall (esort (lsucc lzero)) ([y] (esort (lsucc lzero)))))) (defn (econst "PProd" (lcons (lsucc lzero) (lcons (lsucc lzero) lnil))))).

pprodType/decl : declared "pprodType" (eforall (esort (lsucc lzero)) ([x] (eforall (esort (lsucc lzero)) ([y] (esort (lsucc lzero)))))) (defn (econst "PProd" (lcons (lsucc lzero) (lcons (lsucc lzero) lnil))))
   = declared/ok pprodType/name (dkind-ok/defn pprodType/type-wf pprodType/value-typed).
