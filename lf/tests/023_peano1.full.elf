PN_lit0/value-typed : {u_1 : lvl} defeq (econst "PN.zero" (lcons u_1 lnil)) (econst "PN.zero" (lcons u_1 lnil)) (econst "PN" (lcons u_1 lnil)).

PN_lit0/name : {u_1 : lvl} name "PN.lit0" (is-decl (lcons u_1 lnil) (econst "PN" (lcons u_1 lnil)) (defn (econst "PN.zero" (lcons u_1 lnil)))).

