%% def PN.lit1
%%% HOLE
PN_lit1/type-wf-sort : {u_1 : lvl} lvl.

%%% HOLE
PN_lit1/type-wf : {u_1 : lvl} defeq (econst "PN" (lcons u_1 lnil)) (econst "PN" (lcons u_1 lnil)) (esort (PN_lit1/type-wf-sort u_1)).

%%% HOLE
PN_lit1/value-typed : {u_1 : lvl} defeq (eapp (econst "PN.succ" (lcons u_1 lnil)) (econst "PN.lit0" (lcons u_1 lnil))) (eapp (econst "PN.succ" (lcons u_1 lnil)) (econst "PN.lit0" (lcons u_1 lnil))) (econst "PN" (lcons u_1 lnil)).

