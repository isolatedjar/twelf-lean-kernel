PN_lit2/value-typed : {u_1 : lvl} defeq (eapp (econst "PN.succ" (lcons u_1 lnil)) (econst "PN.lit1" (lcons u_1 lnil))) (eapp (econst "PN.succ" (lcons u_1 lnil)) (econst "PN.lit1" (lcons u_1 lnil))) (econst "PN" (lcons u_1 lnil)).

