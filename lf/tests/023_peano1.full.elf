%% thm peano1
peano1/type-wf :
   {u : lvl} defeq (eforall (eforall (econst "PN" (lcons u lnil)) ([x] (esort lzero))) ([x] (eforall (eforall (econst "PN" (lcons u lnil)) ([y] (eapp x y))) ([y] (eapp x (econst "PN.lit2" (lcons u lnil))))))) (eforall (eforall (econst "PN" (lcons u lnil)) ([x] (esort lzero))) ([x] (eforall (eforall (econst "PN" (lcons u lnil)) ([y] (eapp x y))) ([y] (eapp x (econst "PN.lit2" (lcons u lnil))))))) (esort (limax (limax (limax (lsucc u) u) (lsucc lzero)) (limax (limax (limax (lsucc u) u) lzero) lzero)))
   = [u] (defeq/forall (defeq/forall (defeq/const (PN/decl u)) ([x] [y] (defeq/sort-refl-at lzero))) ([x] [y] (defeq/forall (defeq/forall (defeq/const (PN/decl u)) ([z] [w] (defeq/app y w))) ([z] [w] (defeq/app y (defeq/const (PN_lit2/decl u))))))).

peano1/value-typed :
   {u : lvl} defeq (elam (eforall (econst "PN" (lcons u lnil)) ([x] (esort lzero))) ([x] (elam (eforall (econst "PN" (lcons u lnil)) ([y] (eapp x y))) ([y] (eapp y (econst "PN.lit2" (lcons u lnil))))))) (elam (eforall (econst "PN" (lcons u lnil)) ([x] (esort lzero))) ([x] (elam (eforall (econst "PN" (lcons u lnil)) ([y] (eapp x y))) ([y] (eapp y (econst "PN.lit2" (lcons u lnil))))))) (eforall (eforall (econst "PN" (lcons u lnil)) ([x] (esort lzero))) ([x] (eforall (eforall (econst "PN" (lcons u lnil)) ([y] (eapp x y))) ([y] (eapp x (econst "PN.lit2" (lcons u lnil)))))))
   = [u] (defeq/lam (defeq/forall (defeq/const (PN/decl u)) ([x] [y] (defeq/sort-refl-at lzero))) ([x] [y] (defeq/lam (defeq/forall (defeq/const (PN/decl u)) ([z] [w] (defeq/app y w))) ([z] [w] (defeq/app w (defeq/const (PN_lit2/decl u))))))).

peano1/decl : {u : lvl} declared "peano1" (lcons u lnil)
   (eforall (eforall (econst "PN" (lcons u lnil)) ([x] (esort lzero))) ([x] (eforall (eforall (econst "PN" (lcons u lnil)) ([y] (eapp x y))) ([y] (eapp x (econst "PN.lit2" (lcons u lnil)))))))
   (thm (elam (eforall (econst "PN" (lcons u lnil)) ([x] (esort lzero))) ([x] (elam (eforall (econst "PN" (lcons u lnil)) ([y] (eapp x y))) ([y] (eapp y (econst "PN.lit2" (lcons u lnil))))))))
   (dkind-ok/thm (peano1/type-wf u) (peano1/value-typed u)).

