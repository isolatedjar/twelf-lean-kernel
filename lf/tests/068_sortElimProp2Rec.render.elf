%%% Render-only view of: 068_sortElimProp2Rec
%%% Inductive predicates eliminate into Sort if they have one constructors and it carries data, but the data is
%%% known from the type, e.g. a parameter or an index. However, it must occur directly in the result type,
%%% with no intervening reduction.
%% inductive Bool (numParams=0, numIndices=0)
Bool/render-type : expr =
   (esort (lsucc lzero)).

%% ctor Bool.false (induct=Bool, numFields=0)
Bool_false/render-type : expr =
   (econst "Bool" lnil).

%% ctor Bool.true (induct=Bool, numFields=0)
Bool_true/render-type : expr =
   (econst "Bool" lnil).

%% recursor Bool.rec (numMotives=1, numMinors=2, k=false)
Bool_rec/render-type : {u : lvl} expr =
   [u] (eforall (eforall (econst "Bool" lnil) ([x] (esort u))) ([x] (eforall (eapp x (econst "Bool.false" lnil)) ([y] (eforall (eapp x (econst "Bool.true" lnil)) ([z] (eforall (econst "Bool" lnil) ([w] (eapp x w))))))))).
%%   rec-rule for Bool.false (nfields=0)
Bool_rec/render-rule0-rhs : {u : lvl} expr =
   [u] (elam (eforall (econst "Bool" lnil) ([x] (esort u))) ([x] (elam (eapp x (econst "Bool.false" lnil)) ([y] (elam (eapp x (econst "Bool.true" lnil)) ([z] y)))))).
%%   rec-rule for Bool.true (nfields=0)
Bool_rec/render-rule1-rhs : {u : lvl} expr =
   [u] (elam (eforall (econst "Bool" lnil) ([x] (esort u))) ([x] (elam (eapp x (econst "Bool.false" lnil)) ([y] (elam (eapp x (econst "Bool.true" lnil)) ([z] z)))))).

%% def id
id/render-type : {u : lvl} expr =
   [u] (eforall (esort u) ([x] (eforall x ([y] x)))).
id/render-value : {u : lvl} expr =
   [u] (elam (esort u) ([x] (elam x ([y] y)))).

%% inductive SortElimProp2 (numParams=1, numIndices=2)
SortElimProp2/render-type : expr =
   (eforall (econst "Bool" lnil) ([x] (eforall (econst "Bool" lnil) ([y] (eforall (econst "Bool" lnil) ([z] (esort lzero))))))).

%% ctor SortElimProp2.mk (induct=SortElimProp2, numFields=2)
SortElimProp2_mk/render-type : expr =
   (eforall (econst "Bool" lnil) ([x] (eforall (econst "Bool" lnil) ([y] (eforall (econst "Bool" lnil) ([z] (eapp (eapp (eapp (econst "SortElimProp2" lnil) x) z) (eapp (eapp (econst "id" (lcons (lsucc lzero) lnil)) (econst "Bool" lnil)) y)))))))).

%% recursor SortElimProp2.rec (numMotives=1, numMinors=1, k=false)
SortElimProp2_rec/render-type : expr =
   (eforall (econst "Bool" lnil) ([x] (eforall (eforall (econst "Bool" lnil) ([y] (eforall (econst "Bool" lnil) ([z] (eforall (eapp (eapp (eapp (econst "SortElimProp2" lnil) x) y) z) ([w] (esort lzero))))))) ([y] (eforall (eforall (econst "Bool" lnil) ([z] (eforall (econst "Bool" lnil) ([w] (eapp (eapp (eapp y w) (eapp (eapp (econst "id" (lcons (lsucc lzero) lnil)) (econst "Bool" lnil)) z)) (eapp (eapp (eapp (econst "SortElimProp2.mk" lnil) x) z) w)))))) ([z] (eforall (econst "Bool" lnil) ([w] (eforall (econst "Bool" lnil) ([x1] (eforall (eapp (eapp (eapp (econst "SortElimProp2" lnil) x) w) x1) ([y1] (eapp (eapp (eapp y w) x1) y1))))))))))))).
%%   rec-rule for SortElimProp2.mk (nfields=2)
SortElimProp2_rec/render-rule0-rhs : expr =
   (elam (econst "Bool" lnil) ([x] (elam (eforall (econst "Bool" lnil) ([y] (eforall (econst "Bool" lnil) ([z] (eforall (eapp (eapp (eapp (econst "SortElimProp2" lnil) x) y) z) ([w] (esort lzero))))))) ([y] (elam (eforall (econst "Bool" lnil) ([z] (eforall (econst "Bool" lnil) ([w] (eapp (eapp (eapp y w) (eapp (eapp (econst "id" (lcons (lsucc lzero) lnil)) (econst "Bool" lnil)) z)) (eapp (eapp (eapp (econst "SortElimProp2.mk" lnil) x) z) w)))))) ([z] (elam (econst "Bool" lnil) ([w] (elam (econst "Bool" lnil) ([x1] (eapp (eapp z w) x1))))))))))).

%% def sortElimProp2Rec
sortElimProp2Rec/render-type : expr =
   (eforall (econst "Bool" lnil) ([x] (eforall (eforall (econst "Bool" lnil) ([y] (eforall (econst "Bool" lnil) ([z] (eforall (eapp (eapp (eapp (econst "SortElimProp2" lnil) x) y) z) ([w] (esort lzero))))))) ([y] (eforall (eforall (econst "Bool" lnil) ([z] (eforall (econst "Bool" lnil) ([w] (eapp (eapp (eapp y w) z) (eapp (eapp (eapp (econst "SortElimProp2.mk" lnil) x) z) w)))))) ([z] (eforall (econst "Bool" lnil) ([w] (eforall (econst "Bool" lnil) ([x1] (eforall (eapp (eapp (eapp (econst "SortElimProp2" lnil) x) w) x1) ([y1] (eapp (eapp (eapp y w) x1) y1))))))))))))).
sortElimProp2Rec/render-value : expr =
   (econst "SortElimProp2.rec" lnil).

