        ([y]
          (eforall (eforall (eforall (econst "Bool" lnil) ([z] (econst "RTree" lnil)))
            ([z] (eforall (eforall (econst "Bool" lnil) ([w] (eapp x (eapp z w)))) ([w] (eapp x (eapp (econst "RTree.node" lnil) z))))))
            ([z] (eforall (econst "RTree" lnil) ([w] (eapp x w)))))))))
