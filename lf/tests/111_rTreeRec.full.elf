%%% Expected outcome: accept
%%% Asserting the type of the generated recursor.
sneq/0 : string-neq "Bool.false" "Bool.true".
sneq/1 : string-neq "RTree.leaf" "RTree.node".
sneq/2 : string-neq "Bool" "RTree".

%% inductive Bool
Bool/type-wf : of (esort (lsucc lzero)) (esort (lsucc (lsucc lzero)))
   = defeq/sort-refl.

Bool/ends-in-sort : ends-in-sort (esort (lsucc lzero))
   = ends-in-sort/sort.

Bool/rec-name : name "Bool.rec" (is-rec-for "Bool").

Bool/eisl : ends-in-sort-with-level (esort (lsucc lzero)) (lsucc lzero)
   = ends-in-sort-with-level/sort.

Bool/cnd : cnames-distinct (ccons "Bool.false" (ccons "Bool.true" cnil))
   = (cnames-distinct/cons
       (cnames-distinct/cons cnames-distinct/nil all-string-neq/nil)
       (all-string-neq/cons sneq/0 all-string-neq/nil)).

Bool/name : name "Bool" (is-decl (esort (lsucc lzero)) (indt (ccons "Bool.false" (ccons "Bool.true" cnil)) z)).

Bool/decl : declared "Bool" (esort (lsucc lzero)) (indt (ccons "Bool.false" (ccons "Bool.true" cnil)) z)
   = declared/ok-indt Bool/name Bool/rec-name Bool/cnd (dkind-ok/indt Bool/type-wf Bool/ends-in-sort).

%% ctor Bool.false (of Bool)
Bool_false/type-wf : of (econst "Bool" lnil) (esort (lsucc lzero))
   = (defeq/const Bool/decl (inst-expr/sort (inst-lvl/succ inst-lvl/zero))).

Bool_false/positivity : ctor-positive "Bool" lnil (econst "Bool" lnil)
   = (ctor-positive/intro ([S] S) (ctor-spine/result applies-self/refl)).

Bool_false/cmem : cmem "Bool.false" (ccons "Bool.false" (ccons "Bool.true" cnil))
   = cmem/here.

Bool_false/fuo : field-universes-ok (econst "Bool" lnil) (lsucc lzero)
   = (field-universes-ok/done not-forall/const).

Bool_false/name : name "Bool.false" (is-decl (econst "Bool" lnil) (ctor "Bool" z)).

Bool_false/decl : declared "Bool.false" (econst "Bool" lnil) (ctor "Bool" z)
   = declared/ok-ctor Bool_false/name Bool/name Bool_false/cmem Bool/eisl Bool_false/fuo (dkind-ok/ctor Bool_false/type-wf Bool_false/positivity).

%% ctor Bool.true (of Bool)
Bool_true/type-wf : of (econst "Bool" lnil) (esort (lsucc lzero))
   = (defeq/const Bool/decl (inst-expr/sort (inst-lvl/succ inst-lvl/zero))).

Bool_true/positivity : ctor-positive "Bool" lnil (econst "Bool" lnil)
   = (ctor-positive/intro ([S] S) (ctor-spine/result applies-self/refl)).

Bool_true/cmem : cmem "Bool.true" (ccons "Bool.false" (ccons "Bool.true" cnil))
   = (cmem/there cmem/here).

Bool_true/fuo : field-universes-ok (econst "Bool" lnil) (lsucc lzero)
   = (field-universes-ok/done not-forall/const).

Bool_true/name : name "Bool.true" (is-decl (econst "Bool" lnil) (ctor "Bool" (s z))).

Bool_true/decl : declared "Bool.true" (econst "Bool" lnil) (ctor "Bool" (s z))
   = declared/ok-ctor Bool_true/name Bool/name Bool_true/cmem Bool/eisl Bool_true/fuo (dkind-ok/ctor Bool_true/type-wf Bool_true/positivity).

%% recursor Bool.rec (TCB-derived; informational only)
%%   level params: u
%%   type:   (eforall (eforall (econst "Bool" lnil) ([x] (esort (lvar z)))) ([x] (eforall (eapp x (econst "Bool.false" lnil)) ([y] (eforall (eapp x (econst "Bool.true" lnil)) ([w] (eforall (econst "Bool" lnil) ([v] (eapp x v)))))))))
%%   rules:
%%     Bool.rec … Bool.false … = (elam (eforall (econst "Bool" lnil) ([x] (esort (lvar z)))) ([x] (elam (eapp x (econst "Bool.false" lnil)) ([y] (elam (eapp x (econst "Bool.true" lnil)) ([w] y))))))   (0 fields)
%%     Bool.rec … Bool.true … = (elam (eforall (econst "Bool" lnil) ([x] (esort (lvar z)))) ([x] (elam (eapp x (econst "Bool.false" lnil)) ([y] (elam (eapp x (econst "Bool.true" lnil)) ([w] w))))))   (0 fields)

%% inductive RTree
RTree/type-wf : of (esort (lsucc lzero)) (esort (lsucc (lsucc lzero)))
   = defeq/sort-refl.

RTree/ends-in-sort : ends-in-sort (esort (lsucc lzero))
   = ends-in-sort/sort.

RTree/rec-name : name "RTree.rec" (is-rec-for "RTree").

RTree/eisl : ends-in-sort-with-level (esort (lsucc lzero)) (lsucc lzero)
   = ends-in-sort-with-level/sort.

RTree/cnd : cnames-distinct (ccons "RTree.leaf" (ccons "RTree.node" cnil))
   = (cnames-distinct/cons
       (cnames-distinct/cons cnames-distinct/nil all-string-neq/nil)
       (all-string-neq/cons sneq/1 all-string-neq/nil)).

RTree/name : name "RTree" (is-decl (esort (lsucc lzero)) (indt (ccons "RTree.leaf" (ccons "RTree.node" cnil)) z)).

RTree/decl : declared "RTree" (esort (lsucc lzero)) (indt (ccons "RTree.leaf" (ccons "RTree.node" cnil)) z)
   = declared/ok-indt RTree/name RTree/rec-name RTree/cnd (dkind-ok/indt RTree/type-wf RTree/ends-in-sort).

%% ctor RTree.leaf (of RTree)
RTree_leaf/type-wf : of (econst "RTree" lnil) (esort (lsucc lzero))
   = (defeq/const RTree/decl (inst-expr/sort (inst-lvl/succ inst-lvl/zero))).

RTree_leaf/positivity : ctor-positive "RTree" lnil (econst "RTree" lnil)
   = (ctor-positive/intro ([S] S) (ctor-spine/result applies-self/refl)).

RTree_leaf/cmem : cmem "RTree.leaf" (ccons "RTree.leaf" (ccons "RTree.node" cnil))
   = cmem/here.

RTree_leaf/fuo : field-universes-ok (econst "RTree" lnil) (lsucc lzero)
   = (field-universes-ok/done not-forall/const).

RTree_leaf/name : name "RTree.leaf" (is-decl (econst "RTree" lnil) (ctor "RTree" z)).

RTree_leaf/decl : declared "RTree.leaf" (econst "RTree" lnil) (ctor "RTree" z)
   = declared/ok-ctor RTree_leaf/name RTree/name RTree_leaf/cmem RTree/eisl RTree_leaf/fuo (dkind-ok/ctor RTree_leaf/type-wf RTree_leaf/positivity).

%% ctor RTree.node (of RTree)
RTree_node/type-wf : of (eforall (eforall (econst "Bool" lnil) ([x] (econst "RTree" lnil))) ([x] (econst "RTree" lnil))) (esort (limax (limax (lsucc lzero) (lsucc lzero)) (lsucc lzero)))
   = (defeq/forall
       (defeq/forall
         (defeq/const Bool/decl (inst-expr/sort (inst-lvl/succ inst-lvl/zero)))
         ([x]
           ([h]
             (defeq/const
               RTree/decl
               (inst-expr/sort (inst-lvl/succ inst-lvl/zero))))))
       ([x]
         ([h]
           (defeq/const
             RTree/decl
             (inst-expr/sort (inst-lvl/succ inst-lvl/zero)))))).

RTree_node/positivity : ctor-positive "RTree" lnil (eforall (eforall (econst "Bool" lnil) ([x] (econst "RTree" lnil))) ([x] (econst "RTree" lnil)))
   = (ctor-positive/intro ([S] (eforall (eforall (econst "Bool" lnil) ([x] S)) ([x] S))) (ctor-spine/arg
       (strict-pos/forall
         (econst "Bool" lnil)
         (no-self-ref/const sneq/2)
         ([x] ([y] (strict-pos/head applies-self/refl))))
       ([x] ([y] (ctor-spine/result applies-self/refl))))).

RTree_node/cmem : cmem "RTree.node" (ccons "RTree.leaf" (ccons "RTree.node" cnil))
   = (cmem/there cmem/here).

RTree_node/fuo : field-universes-ok (eforall (eforall (econst "Bool" lnil) ([x] (econst "RTree" lnil))) ([x] (econst "RTree" lnil))) (lsucc lzero)
   = (field-universes-ok/forall
       (defeq/forall
         (defeq/const Bool/decl (inst-expr/sort (inst-lvl/succ inst-lvl/zero)))
         ([x]
           ([h]
             (defeq/const
               RTree/decl
               (inst-expr/sort (inst-lvl/succ inst-lvl/zero))))))
       (leq-lvl/imaxLs
         (leq-lvl/sR
           (leq-lvl/maxL
             (leq-lvl/sL leq-lvl/self)
             (leq-lvl/imaxLs
               (leq-lvl/maxL
                 (leq-lvl/sL leq-lvl/self)
                 (leq-lvl/sL leq-lvl/self))))))
       ([x] ([h] (field-universes-ok/done not-forall/const)))).

RTree_node/name : name "RTree.node" (is-decl (eforall (eforall (econst "Bool" lnil) ([x] (econst "RTree" lnil))) ([x] (econst "RTree" lnil))) (ctor "RTree" (s z))).

RTree_node/decl : declared "RTree.node" (eforall (eforall (econst "Bool" lnil) ([x] (econst "RTree" lnil))) ([x] (econst "RTree" lnil))) (ctor "RTree" (s z))
   = declared/ok-ctor RTree_node/name RTree/name RTree_node/cmem RTree/eisl RTree_node/fuo (dkind-ok/ctor RTree_node/type-wf RTree_node/positivity).

%% recursor RTree.rec (TCB-derived; informational only)
%%   level params: u
%%   type:   (eforall (eforall (econst "RTree" lnil) ([x] (esort (lvar z)))) ([x] (eforall (eapp x (econst "RTree.leaf" lnil)) ([y] (eforall (eforall (eforall (econst "Bool" lnil) ([w] (econst "RTree" lnil))) ([w] (eforall (eforall (econst "Bool" lnil) ([v] (eapp x (eapp w v)))) ([v] (eapp x (eapp (econst "RTree.node" lnil) w)))))) ([w] (eforall (econst "RTree" lnil) ([v] (eapp x v)))))))))
%%   rules:
%%     RTree.rec … RTree.leaf … = (elam (eforall (econst "RTree" lnil) ([x] (esort (lvar z)))) ([x] (elam (eapp x (econst "RTree.leaf" lnil)) ([y] (elam (eforall (eforall (econst "Bool" lnil) ([w] (econst "RTree" lnil))) ([w] (eforall (eforall (econst "Bool" lnil) ([v] (eapp x (eapp w v)))) ([v] (eapp x (eapp (econst "RTree.node" lnil) w)))))) ([w] y))))))   (0 fields)
%%     RTree.rec … RTree.node … = (elam (eforall (econst "RTree" lnil) ([x] (esort (lvar z)))) ([x] (elam (eapp x (econst "RTree.leaf" lnil)) ([y] (elam (eforall (eforall (econst "Bool" lnil) ([w] (econst "RTree" lnil))) ([w] (eforall (eforall (econst "Bool" lnil) ([v] (eapp x (eapp w v)))) ([v] (eapp x (eapp (econst "RTree.node" lnil) w)))))) ([w] (elam (eforall (econst "Bool" lnil) ([v] (econst "RTree" lnil))) ([v] (eapp (eapp w v) (elam (econst "Bool" lnil) ([x1] (eapp (eapp (eapp (eapp (econst "RTree.rec" (lcons (lvar z) lnil)) x) y) w) (eapp v x1)))))))))))))   (1 fields)

%% def rTreeRec
rTreeRec/type-wf : of
  (eforall (eforall (econst "RTree" lnil) ([x] (esort (lvar z))))
    ([x]
      (eforall (eapp x (econst "RTree.leaf" lnil))
        ([y]
          (eforall (eforall (eforall (econst "Bool" lnil) ([w] (econst "RTree" lnil)))
            ([w] (eforall (eforall (econst "Bool" lnil) ([v] (eapp x (eapp w v)))) ([v] (eapp x (eapp (econst "RTree.node" lnil) w))))))
            ([w] (eforall (econst "RTree" lnil) ([v] (eapp x v)))))))))
  (esort (limax
    (limax (lsucc lzero) (lsucc (lvar z)))
    (limax (lvar z) (limax (limax (limax (lsucc lzero) (lsucc lzero)) (limax (limax (lsucc lzero) (lvar z)) (lvar z))) (limax (lsucc lzero) (lvar z))))))
   = (defeq/forall
       (defeq/forall
         (defeq/const RTree/decl (inst-expr/sort (inst-lvl/succ inst-lvl/zero)))
         ([x] ([h] defeq/sort-refl)))
       ([x]
         ([h]
           (defeq/forall
             (defeq/app
               h
               (defeq/const RTree_leaf/decl (inst-expr/const inst-lvls/nil)))
             ([y]
               ([h1]
                 (defeq/forall
                   (defeq/forall
                     (defeq/forall
                       (defeq/const
                         Bool/decl
                         (inst-expr/sort (inst-lvl/succ inst-lvl/zero)))
                       ([w]
                         ([h2]
                           (defeq/const
                             RTree/decl
                             (inst-expr/sort (inst-lvl/succ inst-lvl/zero))))))
                     ([w]
                       ([h2]
                         (defeq/forall
                           (defeq/forall
                             (defeq/const
                               Bool/decl
                               (inst-expr/sort (inst-lvl/succ inst-lvl/zero)))
                             ([v] ([h3] (defeq/app h (defeq/app h2 h3)))))
                           ([v]
                             ([h3]
                               (defeq/app
                                 h
                                 (defeq/app
                                   (defeq/const
                                     RTree_node/decl
                                     (inst-expr/forall
                                       (inst-expr/forall
                                         (inst-expr/const inst-lvls/nil)
                                         ([x]
                                           ([h]
                                             (inst-expr/const inst-lvls/nil))))
                                       ([x]
                                         ([h]
                                           (inst-expr/const inst-lvls/nil)))))
                                   h2))))))))
                   ([w]
                     ([h2]
                       (defeq/forall
                         (defeq/const
                           RTree/decl
                           (inst-expr/sort (inst-lvl/succ inst-lvl/zero)))
                         ([v] ([h3] (defeq/app h h3))))))))))))).

%%% HOLE
rTreeRec/value-typed : of
  (econst "RTree.rec" (lcons (lvar z) lnil))
  (eforall (eforall (econst "RTree" lnil) ([x] (esort (lvar z))))
    ([x]
      (eforall (eapp x (econst "RTree.leaf" lnil))
        ([y]
          (eforall (eforall (eforall (econst "Bool" lnil) ([w] (econst "RTree" lnil)))
            ([w] (eforall (eforall (econst "Bool" lnil) ([v] (eapp x (eapp w v)))) ([v] (eapp x (eapp (econst "RTree.node" lnil) w))))))
            ([w] (eforall (econst "RTree" lnil) ([v] (eapp x v))))))))).

rTreeRec/name : name "rTreeRec" (is-decl
  (eforall (eforall (econst "RTree" lnil) ([x] (esort (lvar z))))
    ([x]
      (eforall (eapp x (econst "RTree.leaf" lnil))
        ([y]
          (eforall (eforall (eforall (econst "Bool" lnil) ([w] (econst "RTree" lnil)))
            ([w] (eforall (eforall (econst "Bool" lnil) ([v] (eapp x (eapp w v)))) ([v] (eapp x (eapp (econst "RTree.node" lnil) w))))))
            ([w] (eforall (econst "RTree" lnil) ([v] (eapp x v)))))))))
  (defn (econst "RTree.rec" (lcons (lvar z) lnil)))).

rTreeRec/decl : declared "rTreeRec"
  (eforall (eforall (econst "RTree" lnil) ([x] (esort (lvar z))))
    ([x]
      (eforall (eapp x (econst "RTree.leaf" lnil))
        ([y]
          (eforall (eforall (eforall (econst "Bool" lnil) ([w] (econst "RTree" lnil)))
            ([w] (eforall (eforall (econst "Bool" lnil) ([v] (eapp x (eapp w v)))) ([v] (eapp x (eapp (econst "RTree.node" lnil) w))))))
            ([w] (eforall (econst "RTree" lnil) ([v] (eapp x v)))))))))
  (defn (econst "RTree.rec" (lcons (lvar z) lnil)))
   = declared/ok rTreeRec/name dkind-non-inductive/defn (dkind-ok/defn rTreeRec/type-wf rTreeRec/value-typed).
