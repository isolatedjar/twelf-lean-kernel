imax2/name : name "imax2" (is-decl (eforall (esort (lsucc lzero)) ([x] (esort (lsucc (lsucc lzero))))) (defn (elam (esort (lsucc lzero)) ([x] (eforall (esort (lsucc lzero)) ([y] x)))))).

imax2/decl : declared "imax2" (eforall (esort (lsucc lzero)) ([x] (esort (lsucc (lsucc lzero))))) (defn (elam (esort (lsucc lzero)) ([x] (eforall (esort (lsucc lzero)) ([y] x)))))
