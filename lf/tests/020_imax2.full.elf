%%% Expected outcome: accept
%%% Type inference for forall using imax
%solve nonneg_0 : 0 >= 0.
%solve nonneg_1 : 1 >= 0.

%% def imax2
imax2/type-wf-sort : lvl
   = (limax (lsucc (lsucc lzero)) (lsucc (lsucc (lsucc lzero)))).

imax2/type-wf : of (eforall (esort (lsucc lzero)) ([x] (esort (lsucc (lsucc lzero))))) (esort imax2/type-wf-sort)
   = (defeq/forall defeq/sort-refl ([x] ([h] defeq/sort-refl))).

imax2/value-typed : of (elam (esort (lsucc lzero)) ([x] (eforall (esort (lsucc lzero)) ([y] x)))) (eforall (esort (lsucc lzero)) ([x] (esort (lsucc (lsucc lzero)))))
   = (defeq/conv (defeq/forall (defeq/sort-eq lvl-eq/refl) ([x] ([h] (defeq/sort-eq (lvl-eq/le (mleq/imax-lsL (mleq/sR (mleq/sR (mleq/maxL (mleq/sL (mleq/sL (mleq/self nonneg_0))) (mleq/sL (mleq/self nonneg_1)))))) (mleq/sL (mleq/sL (mleq/imax-lsR (mleq/maxR-l (mleq/sR (mleq/sR (mleq/self nonneg_0)))))))))))) (defeq/lam defeq/sort-refl ([x] ([h] (defeq/forall defeq/sort-refl ([y] ([h1] h))))))).

imax2/name : name "imax2" (is-decl (eforall (esort (lsucc lzero)) ([x] (esort (lsucc (lsucc lzero))))) (defn (elam (esort (lsucc lzero)) ([x] (eforall (esort (lsucc lzero)) ([y] x)))))).

imax2/decl : declared "imax2" (eforall (esort (lsucc lzero)) ([x] (esort (lsucc (lsucc lzero))))) (defn (elam (esort (lsucc lzero)) ([x] (eforall (esort (lsucc lzero)) ([y] x)))))
   = declared/ok imax2/name (dkind-ok/defn imax2/type-wf imax2/value-typed).
