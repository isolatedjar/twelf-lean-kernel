   = [u] (defeq/forall (defeq/forall (defeq/const DupConCon/decl) ([x] [y] (defeq/sort-refl-at u))) ([x] [y] (defeq/forall (defeq/app y (defeq/const dup_ind_con_con_mk/decl)) ([z] [w] (defeq/forall (defeq/app y (defeq/const dup_ind_con_con_mk/decl)) ([x1] [y1] (defeq/forall (defeq/const DupConCon/decl) ([z1] [w1] (defeq/app y w1))))))))).

DupConCon_rec/decl : {u : lvl} declared "DupConCon.rec" (lcons u lnil)
