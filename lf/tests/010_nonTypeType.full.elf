%%% Expected outcome: reject
%%% The type of a declaration has to be a type, not some other expression
%% def constType
constType/type-wf-sort : lvl
   = (limax (lsucc (lsucc lzero)) (limax (lsucc (lsucc lzero)) (lsucc (lsucc lzero)))).

constType/type-wf : defeq (eforall (esort (lsucc lzero)) ([x] (eforall (esort (lsucc lzero)) ([y] (esort (lsucc lzero)))))) (eforall (esort (lsucc lzero)) ([x] (eforall (esort (lsucc lzero)) ([y] (esort (lsucc lzero)))))) (esort constType/type-wf-sort)
   = (defeq/forall defeq/sort-refl ([x] ([h] (defeq/forall defeq/sort-refl ([y] ([h1] defeq/sort-refl)))))).

constType/value-typed : defeq (elam (esort (lsucc lzero)) ([x] (elam (esort (lsucc lzero)) ([y] x)))) (elam (esort (lsucc lzero)) ([x] (elam (esort (lsucc lzero)) ([y] x)))) (eforall (esort (lsucc lzero)) ([x] (eforall (esort (lsucc lzero)) ([y] (esort (lsucc lzero))))))
   = (defeq/lam defeq/sort-refl ([x] ([h] (defeq/lam defeq/sort-refl ([y] ([h1] h)))))).

constType/name : name "constType" (is-decl (eforall (esort (lsucc lzero)) ([x] (eforall (esort (lsucc lzero)) ([y] (esort (lsucc lzero)))))) (defn (elam (esort (lsucc lzero)) ([x] (elam (esort (lsucc lzero)) ([y] x)))))).

constType/decl : declared "constType" (eforall (esort (lsucc lzero)) ([x] (eforall (esort (lsucc lzero)) ([y] (esort (lsucc lzero)))))) (defn (elam (esort (lsucc lzero)) ([x] (elam (esort (lsucc lzero)) ([y] x)))))
   = declared/ok constType/name (dkind-ok/defn constType/type-wf constType/value-typed).

%% def nonTypeType
%%% HOLE
nonTypeType/type-wf-sort : lvl.

%%% HOLE
nonTypeType/type-wf : defeq (econst "constType" lnil) (econst "constType" lnil) (esort nonTypeType/type-wf-sort).

%%% HOLE
nonTypeType/value-typed : defeq (esort lzero) (esort lzero) (econst "constType" lnil).

nonTypeType/name : name "nonTypeType" (is-decl (econst "constType" lnil) (defn (esort lzero))).

nonTypeType/decl : declared "nonTypeType" (econst "constType" lnil) (defn (esort lzero))
   = declared/ok nonTypeType/name (dkind-ok/defn nonTypeType/type-wf nonTypeType/value-typed).
