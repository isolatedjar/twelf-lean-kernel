                          (eforall (econst "N" lnil) ([z1] (eforall (eapp (eapp (eapp (econst "RBTree" (lcons (lvar (lis liz)) lnil)) x) y1) z1) ([w1] (eapp (eapp (eapp y y1) z1) w1)))))))))))))))))
  (irec "RBTree").

%% def rbTreeDef
rbTreeDef/type-wf-sort : lvl
   = (limax
       (lsucc (lsucc (lvar liz)))
       (limax (lsucc lzero) (limax (lsucc lzero) (lsucc (lsucc (lvar liz)))))).

rbTreeDef/type-wf : of (eforall (esort (lsucc (lvar liz))) ([x] (eforall (econst "Color" lnil) ([y] (eforall (econst "N" lnil) ([z] (esort (lsucc (lvar liz))))))))) (esort rbTreeDef/type-wf-sort)
   = (defeq/forall
       defeq/sort-refl
       ([x]
         ([h]
           (defeq/forall
             (defeq/const
               Color/decl
               (inst-expr/sort (lvl-inst/succ lvl-inst/zero)))
             ([y]
               ([h1]
                 (defeq/forall
                   (defeq/const
                     N/decl
                     (inst-expr/sort (lvl-inst/succ lvl-inst/zero)))
                   ([z] ([h2] defeq/sort-refl))))))))).

rbTreeDef/value-typed : of (econst "RBTree" (lcons (lvar liz) lnil)) (eforall (esort (lsucc (lvar liz))) ([x] (eforall (econst "Color" lnil) ([y] (eforall (econst "N" lnil) ([z] (esort (lsucc (lvar liz)))))))))
   = (defeq/const
       RBTree/decl
       (inst-expr/forall
         (inst-expr/sort (lvl-inst/succ (lvl-inst/var lvl-nth/zero)))
         ([x]
           ([h]
             (inst-expr/forall
               (inst-expr/const lvls-inst/nil)
               ([y]
                 ([h1]
                   (inst-expr/forall
                     (inst-expr/const lvls-inst/nil)
                     ([z]
                       ([h2]
                         (inst-expr/sort
                           (lvl-inst/succ
                             (lvl-inst/var lvl-nth/zero))))))))))))).

rbTreeDef/name : name "rbTreeDef" (is-decl
  (eforall (esort (lsucc (lvar liz))) ([x] (eforall (econst "Color" lnil) ([y] (eforall (econst "N" lnil) ([z] (esort (lsucc (lvar liz)))))))))
  (defn (econst "RBTree" (lcons (lvar liz) lnil)))).

rbTreeDef/decl : declared "rbTreeDef"
  (eforall (esort (lsucc (lvar liz))) ([x] (eforall (econst "Color" lnil) ([y] (eforall (econst "N" lnil) ([z] (esort (lsucc (lvar liz)))))))))
  (defn (econst "RBTree" (lcons (lvar liz) lnil)))
   = declared/ok rbTreeDef/name dkind-non-inductive/defn (dkind-ok/defn rbTreeDef/type-wf rbTreeDef/value-typed).
