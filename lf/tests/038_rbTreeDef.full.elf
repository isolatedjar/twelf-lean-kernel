%% recursor Color.rec (TCB-derived; informational only)
%%   level params: u
%%   type:   (eforall (eforall (econst "Color" lnil) ([x] (esort (lvar liz)))) ([x] (eforall (eapp x (econst "Color.r" lnil)) ([y] (eforall (eapp x (econst "Color.b" lnil)) ([z] (eforall (econst "Color" lnil) ([w] (eapp x w)))))))))
%%   rules:
%%     Color.rec … Color.r … = (elam (eforall (econst "Color" lnil) ([x] (esort (lvar liz)))) ([x] (elam (eapp x (econst "Color.r" lnil)) ([y] (elam (eapp x (econst "Color.b" lnil)) ([z] y))))))   (0 fields)
