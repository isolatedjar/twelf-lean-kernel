%%% Expected outcome: accept
%%% A recursive indexed data type
%solve nonneg_0 : 0 >= 0.

sneq/0 : string-neq "Color.r" "Color.b".
sneq/1 : string-neq "N.zero" "N.succ".
sneq/2 : string-neq "RBTree.red" "RBTree.black".
sneq/3 : string-neq "RBTree.leaf" "RBTree.black".
sneq/4 : string-neq "RBTree.leaf" "RBTree.red".
sneq/5 : string-neq "N" "RBTree".
sneq/6 : string-neq "Color" "RBTree".

%% inductive Color
Color/type-wf-sort : lvl
   = (lsucc (lsucc lzero)).

Color/type-wf : of (esort (lsucc lzero)) (esort Color/type-wf-sort)
   = defeq/sort-refl.

Color/ends-in-sort : ends-in-sort (esort (lsucc lzero))
   = ends-in-sort/sort.

Color/rec-name : name "Color.rec" (is-rec-for "Color").

Color/eisl : ends-in-sort-with-level (esort (lsucc lzero)) (lsucc lzero)
   = ends-in-sort-with-level/sort.

Color/clf : count-leading-foralls (esort (lsucc lzero)) liz
   = count-leading-foralls/zero.

Color/cnd : cnames-distinct (ccons "Color.r" (ccons "Color.b" cnil))
   = (cnames-distinct/cons
       (cnames-distinct/cons cnames-distinct/nil all-string-neq/nil)
       (all-string-neq/cons sneq/0 all-string-neq/nil)).

Color/name : name "Color" (is-decl (esort (lsucc lzero)) (indt (ccons "Color.r" (ccons "Color.b" cnil)) liz)).

Color/decl : declared "Color" (esort (lsucc lzero)) (indt (ccons "Color.r" (ccons "Color.b" cnil)) liz)
   = declared/ok-indt Color/name Color/rec-name Color/clf Color/cnd (dkind-ok/indt Color/type-wf Color/ends-in-sort).

