%% ctor RBTree.leaf (of RBTree)
RBTree_leaf/type-wf-sort : lvl
   = (limax (lsucc (lsucc (lvar liz))) (lsucc (lvar liz))).

RBTree_leaf/type-wf : of (eforall (esort (lsucc (lvar liz))) ([x] (eapp (eapp (eapp (econst "RBTree" (lcons (lvar liz) lnil)) x) (econst "Color.b" lnil)) (econst "N.zero" lnil)))) (esort RBTree_leaf/type-wf-sort)
   = (defeq/forall
       defeq/sort-refl
       ([x]
         ([h]
           (defeq/app
             (defeq/app
               (defeq/app
                 (defeq/const
                   RBTree/decl
                   (inst-expr/forall
                     (inst-expr/sort
                       (lvl-inst/succ (lvl-inst/var lvl-nth/zero)))
                     ([x]
                       ([h]
                         (inst-expr/forall
                           (inst-expr/const lvls-inst/nil)
                           ([y]
                             ([h1]
                               (inst-expr/forall
                                 (inst-expr/const lvls-inst/nil)
                                 ([z]
                                   ([h2]
                                     (inst-expr/sort
                                       (lvl-inst/succ
                                         (lvl-inst/var lvl-nth/zero)))))))))))))
                 h)
               (defeq/const Color_b/decl (inst-expr/const lvls-inst/nil)))
             (defeq/const N_zero/decl (inst-expr/const lvls-inst/nil)))))).

RBTree_leaf/positivity : ctor-positive "RBTree" (lcons (lvar liz) lnil) (eforall (esort (lsucc (lvar liz))) ([x] (eapp (eapp (eapp (econst "RBTree" (lcons (lvar liz) lnil)) x) (econst "Color.b" lnil)) (econst "N.zero" lnil))))
   = (ctor-positive/intro ([S] (eforall (esort (lsucc (lvar liz))) ([x] (eapp (eapp (eapp S x) (econst "Color.b" lnil)) (econst "N.zero" lnil))))) (ctor-spine/arg
       (strict-pos/no-occur (esort (lsucc (lvar liz))) no-self-ref/sort)
       ([x]
         ([y]
           (ctor-spine/result
             (applies-self/app
               (applies-self/app (applies-self/app applies-self/refl)))))))).

RBTree_leaf/cmem : cmem "RBTree.leaf" (ccons "RBTree.leaf" (ccons "RBTree.red" (ccons "RBTree.black" cnil)))
   = cmem/here.

%%% HOLE: RBTree_leaf/fuo
RBTree_leaf/fuo : field-universes-ok (eforall (esort (lsucc (lvar liz))) ([x] (eapp (eapp (eapp (econst "RBTree" (lcons (lvar liz) lnil)) x) (econst "Color.b" lnil)) (econst "N.zero" lnil)))) (lsucc (lvar liz)).

