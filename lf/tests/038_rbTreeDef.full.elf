%% recursor Color.rec
Color_rec/type-wf-sort : lvl
   = (limax
       (limax (lsucc lzero) (lsucc (lvar liz)))
       (limax (lvar liz) (limax (lvar liz) (limax (lsucc lzero) (lvar liz))))).

Color_rec/type-wf : of
  (eforall (eforall (econst "Color" lnil) ([x] (esort (lvar liz))))
    ([x] (eforall (eapp x (econst "Color.r" lnil)) ([y] (eforall (eapp x (econst "Color.b" lnil)) ([z] (eforall (econst "Color" lnil) ([w] (eapp x w)))))))))
  (esort Color_rec/type-wf-sort)
   = (defeq/forall
       (defeq/forall
         (defeq/const Color/decl (inst-expr/sort (lvl-inst/succ lvl-inst/zero)))
         ([x] ([h] defeq/sort-refl)))
       ([x]
         ([h]
           (defeq/forall
             (defeq/app
               h
               (defeq/const Color_r/decl (inst-expr/const lvls-inst/nil)))
             ([y]
               ([h1]
                 (defeq/forall
                   (defeq/app
                     h
                     (defeq/const Color_b/decl (inst-expr/const lvls-inst/nil)))
                   ([z]
                     ([h2]
                       (defeq/forall
                         (defeq/const
                           Color/decl
                           (inst-expr/sort (lvl-inst/succ lvl-inst/zero)))
                         ([w] ([h3] (defeq/app h h3))))))))))))).

Color_rec/ert : enum-rec-type (eforall (eforall (econst "Color" lnil) ([x] (esort (lvar liz)))) ([x] (eforall (eapp x (econst "Color.r" lnil)) ([y] (eforall (eapp x (econst "Color.b" lnil)) ([z] (eforall (econst "Color" lnil) ([w] (eapp x w))))))))) "Color" lnil (ccons "Color.r" (ccons "Color.b" cnil)) (lvar liz)
   = (enum-rec-type/intro
       ([x]
         ([h]
           (enum-rec-body/minor
             ([y]
               ([h1] (enum-rec-body/minor ([z] ([h2] enum-rec-body/done))))))))).

Color_rec/lee : le-eligible (lsucc lzero) (ccons "Color.r" (ccons "Color.b" cnil)) (lvar liz)
   = (le-eligible/non-prop (mleq/self nonneg_0)).

Color_rec/decl : declared "Color.rec"
  (eforall (eforall (econst "Color" lnil) ([x] (esort (lvar liz))))
    ([x] (eforall (eapp x (econst "Color.r" lnil)) ([y] (eforall (eapp x (econst "Color.b" lnil)) ([z] (eforall (econst "Color" lnil) ([w] (eapp x w)))))))))
