%% thm peano3
%%% HOLE
peano3/type-wf : of
  (eforall (eforall (econst "PN" (lcons (lvar z) lnil)) ([x] (esort lzero)))
    ([x] (eforall (eforall (econst "PN" (lcons (lvar z) lnil)) ([y] (eapp x y))) ([y] (eapp x (econst "PN.lit4" (lcons (lvar z) lnil)))))))
  (esort lzero).

%%% HOLE
peano3/value-typed : of
  (elam (eforall (econst "PN" (lcons (lvar z) lnil)) ([x] (esort lzero)))
    ([x]
      (elam (eforall (econst "PN" (lcons (lvar z) lnil)) ([y] (eapp x y)))
        ([y] (eapp y (eapp (eapp (econst "PN.mul" (lcons (lvar z) lnil)) (econst "PN.lit2" (lcons (lvar z) lnil))) (econst "PN.lit2" (lcons (lvar z) lnil))))))))
  (eforall (eforall (econst "PN" (lcons (lvar z) lnil)) ([x] (esort lzero)))
    ([x] (eforall (eforall (econst "PN" (lcons (lvar z) lnil)) ([y] (eapp x y))) ([y] (eapp x (econst "PN.lit4" (lcons (lvar z) lnil))))))).

