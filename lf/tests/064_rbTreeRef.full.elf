%%% Expected outcome: accept
%%% Asserting the type of the generated recursor
sneq/0 : string-neq "Color.r" "Color.b".
sneq/1 : string-neq "N.zero" "N.succ".
sneq/2 : string-neq "RBTree.red" "RBTree.black".
sneq/3 : string-neq "RBTree.leaf" "RBTree.black".
sneq/4 : string-neq "RBTree.leaf" "RBTree.red".
sneq/5 : string-neq "N" "RBTree".
sneq/6 : string-neq "Color" "RBTree".

