    ([x]
      (eforall (eforall (econst "Color" lnil) ([y] (eforall (econst "N" lnil) ([w] (eforall (eapp (eapp (eapp (econst "RBTree" (lcons (lvar z) lnil)) x) y) w) ([v] (esort (lvar z))))))))
        ([y]
          (eforall (eapp (eapp (eapp y (econst "Color.b" lnil)) (econst "N.zero" lnil)) (eapp (econst "RBTree.leaf" (lcons (lvar z) lnil)) x))
            ([w]
              (eforall (eforall (econst "N" lnil)
                ([v]
                  (eforall (eapp (eapp (eapp (econst "RBTree" (lcons (lvar z) lnil)) x) (econst "Color.b" lnil)) v)
                    ([x1]
                      (eforall x
                        ([y1]
                          (eforall (eapp (eapp (eapp (econst "RBTree" (lcons (lvar z) lnil)) x) (econst "Color.b" lnil)) v)
                            ([w1]
                              (eforall (eapp (eapp (eapp y (econst "Color.b" lnil)) v) x1)
                                ([v1]
                                  (eforall (eapp (eapp (eapp y (econst "Color.b" lnil)) v) w1)
                                    ([x2] (eapp (eapp (eapp y (econst "Color.r" lnil)) v) (eapp (eapp (eapp (eapp (eapp (econst "RBTree.red" (lcons (lvar z) lnil)) x) v) x1) y1) w1))))))))))))))
                ([v]
                  (eforall (eforall (econst "Color" lnil)
                    ([x1]
                      (eforall (econst "Color" lnil)
                        ([y1]
                          (eforall (econst "N" lnil)
                            ([w1]
                              (eforall (eapp (eapp (eapp (econst "RBTree" (lcons (lvar z) lnil)) x) x1) w1)
                                ([v1]
                                  (eforall x
                                    ([x2]
                                      (eforall (eapp (eapp (eapp (econst "RBTree" (lcons (lvar z) lnil)) x) y1) w1)
                                        ([y2]
                                          (eforall (eapp (eapp (eapp y x1) w1) v1)
                                            ([w2]
                                              (eforall (eapp (eapp (eapp y y1) w1) y2)
                                                ([v2]
                                                  (eapp (eapp (eapp y (econst "Color.b" lnil)) (eapp (econst "N.succ" lnil) w1))
                                                    (eapp (eapp (eapp (eapp (eapp (eapp (eapp (econst "RBTree.black" (lcons (lvar z) lnil)) x) x1) y1) w1) v1) x2) y2))))))))))))))))))
                    ([x1]
                      (eforall (econst "Color" lnil)
                        ([y1] (eforall (econst "N" lnil) ([w1] (eforall (eapp (eapp (eapp (econst "RBTree" (lcons (lvar z) lnil)) x) y1) w1) ([v1] (eapp (eapp (eapp y y1) w1) v1)))))))))))))))))
  (defn (econst "RBTree.rec" (lcons (lvar z) (lcons (lvar z) lnil))))).

