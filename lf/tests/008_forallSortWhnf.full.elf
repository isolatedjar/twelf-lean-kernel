%%% Expected outcome: accept
%%% The binding domain of a forall may need to be reduce before it is a sort
%solve nonneg_0 : 0 >= 0.

%% def id
id/type-wf-sort : lvl
   = (limax (lsucc (lvar liz)) (limax (lvar liz) (lvar liz))).

id/type-wf : defeq (eforall (esort (lvar liz)) ([x] (eforall x ([y] x)))) (eforall (esort (lvar liz)) ([x] (eforall x ([y] x)))) (esort id/type-wf-sort)
   = (defeq/forall defeq/sort-refl ([x] ([h] (defeq/forall h ([y] ([h1] h)))))).

id/value-typed : defeq (elam (esort (lvar liz)) ([x] (elam x ([y] y)))) (elam (esort (lvar liz)) ([x] (elam x ([y] y)))) (eforall (esort (lvar liz)) ([x] (eforall x ([y] x))))
   = (defeq/lam defeq/sort-refl ([x] ([h] (defeq/lam h ([y] ([h1] h1)))))).

id/name : name "id" (is-decl (eforall (esort (lvar liz)) ([x] (eforall x ([y] x)))) (defn (elam (esort (lvar liz)) ([x] (elam x ([y] y)))))).

id/decl : declared "id" (eforall (esort (lvar liz)) ([x] (eforall x ([y] x)))) (defn (elam (esort (lvar liz)) ([x] (elam x ([y] y)))))
   = declared/ok id/name (dkind-ok/defn id/type-wf id/value-typed).

%% def forallSortWhnf
forallSortWhnf/type-wf-sort : lvl
   = (lsucc lzero).

forallSortWhnf/type-wf : defeq (esort lzero) (esort lzero) (esort forallSortWhnf/type-wf-sort)
   = defeq/sort-refl.

forallSortWhnf/value-typed : defeq (eforall (eapp (eapp (econst "id" (lcons (lsucc (lsucc lzero)) lnil)) (esort (lsucc lzero))) (esort lzero)) ([x] (eforall x ([y] x)))) (eforall (eapp (eapp (econst "id" (lcons (lsucc (lsucc lzero)) lnil)) (esort (lsucc lzero))) (esort lzero)) ([x] (eforall x ([y] x)))) (esort lzero)
   = (defeq/conv (defeq/sort-eq (lvl-eq/le (mleq/imax-imL (mleq/maxL (mleq/imax-lzL (mleq/self nonneg_0)) (mleq/imax-lzL (mleq/self nonneg_0)))) (mleq/lz nonneg_0))) (defeq/forall (defeq/app (defeq/app (defeq/const id/decl (inst-expr/forall (inst-expr/sort (lvl-inst/var lvl-nth/zero)) ([x] ([h] (inst-expr/forall h ([y] ([h1] h))))))) defeq/sort-refl) defeq/sort-refl) ([x] ([h] (defeq/forall (defeq/conv (defeq/beta ([y] ([h1] h1)) defeq/sort-refl) (defeq/conv (defeq/app (defeq/beta ([y] ([h1] (defeq/lam h1 ([z] ([h2] h2))))) defeq/sort-refl) defeq/sort-refl) (defeq/conv (defeq/app (defeq/app (defeq/delta id/decl (inst-expr/forall (inst-expr/sort (lvl-inst/var lvl-nth/zero)) ([x] ([h] (inst-expr/forall h ([y] ([h1] h)))))) (inst-expr/lam (inst-expr/sort (lvl-inst/var lvl-nth/zero)) ([x] ([h] (inst-expr/lam h ([y] ([h1] h1))))))) defeq/sort-refl) defeq/sort-refl) h))) ([y] ([h1] (defeq/conv (defeq/beta ([z] ([h2] h2)) defeq/sort-refl) (defeq/conv (defeq/app (defeq/beta ([z] ([h2] (defeq/lam h2 ([w] ([h3] h3))))) defeq/sort-refl) defeq/sort-refl) (defeq/conv (defeq/app (defeq/app (defeq/delta id/decl (inst-expr/forall (inst-expr/sort (lvl-inst/var lvl-nth/zero)) ([x] ([h] (inst-expr/forall h ([y] ([h1] h)))))) (inst-expr/lam (inst-expr/sort (lvl-inst/var lvl-nth/zero)) ([x] ([h] (inst-expr/lam h ([y] ([h1] h1))))))) defeq/sort-refl) defeq/sort-refl) h)))))))))).

forallSortWhnf/name : name "forallSortWhnf" (is-decl (esort lzero) (defn (eforall (eapp (eapp (econst "id" (lcons (lsucc (lsucc lzero)) lnil)) (esort (lsucc lzero))) (esort lzero)) ([x] (eforall x ([y] x)))))).

forallSortWhnf/decl : declared "forallSortWhnf" (esort lzero) (defn (eforall (eapp (eapp (econst "id" (lcons (lsucc (lsucc lzero)) lnil)) (esort (lsucc lzero))) (esort lzero)) ([x] (eforall x ([y] x)))))
   = declared/ok forallSortWhnf/name (dkind-ok/defn forallSortWhnf/type-wf forallSortWhnf/value-typed).

