%%% Expected outcome: accept
%%% The binding domain of a forall may need to be reduce before it is a sort
%% def id
id/type-wf : of (eforall (esort (lvar z)) ([x] (eforall x ([y] x)))) (esort (limax (lsucc (lvar z)) (limax (lvar z) (lvar z))))
   = (defeq/forall defeq/sort-refl ([x] ([h] (defeq/forall h ([y] ([h1] h)))))).

id/value-typed : of (elam (esort (lvar z)) ([x] (elam x ([y] y)))) (eforall (esort (lvar z)) ([x] (eforall x ([y] x))))
   = (defeq/lam defeq/sort-refl ([x] ([h] (defeq/lam h ([y] ([h1] h1)))))).

id/name : name "id" (is-decl (eforall (esort (lvar z)) ([x] (eforall x ([y] x)))) (defn (elam (esort (lvar z)) ([x] (elam x ([y] y)))))).

id/decl : declared "id" (eforall (esort (lvar z)) ([x] (eforall x ([y] x)))) (defn (elam (esort (lvar z)) ([x] (elam x ([y] y)))))
   = declared/ok id/name dkind-non-inductive/defn (dkind-ok/defn id/type-wf id/value-typed).

%% def forallSortWhnf
forallSortWhnf/type-wf : of (esort lzero) (esort (lsucc lzero))
   = defeq/sort-refl.

forallSortWhnf/value-typed : of (eforall (eapp (eapp (econst "id" (lcons (lsucc (lsucc lzero)) lnil)) (esort (lsucc lzero))) (esort lzero)) ([x] (eforall x ([y] x)))) (esort lzero)
   = (defeq/conv
       (defeq/sort-eq
         (eq-lvl/le
           leq-lvl/lz
           (leq-lvl/imaxLi
             (leq-lvl/maxL
               (leq-lvl/imaxLz leq-lvl/self)
               (leq-lvl/imaxLz leq-lvl/self)))))
       (defeq/forall
         (defeq/app
           (defeq/app
             (defeq/const
               id/decl
               (inst-expr/forall
                 (inst-expr/sort (inst-lvl/var nth-lvl/z))
                 ([x] ([h] (inst-expr/forall h ([y] ([h1] h)))))))
             defeq/sort-refl)
           defeq/sort-refl)
         ([x]
           ([h]
             (defeq/forall
               (defeq/conv
                 (defeq/beta ([y] ([h1] h1)) defeq/sort-refl)
                 (defeq/conv
                   (defeq/app
                     (defeq/beta
                       ([y] ([h1] (defeq/lam h1 ([w] ([h2] h2)))))
                       defeq/sort-refl)
                     defeq/sort-refl)
                   (defeq/conv
                     (defeq/app
                       (defeq/app
                         (defeq/delta
                           id/decl
                           (inst-expr/forall
                             (inst-expr/sort (inst-lvl/var nth-lvl/z))
                             ([x] ([h] (inst-expr/forall h ([y] ([h1] h))))))
                           (inst-expr/lam
                             (inst-expr/sort (inst-lvl/var nth-lvl/z))
                             ([x] ([h] (inst-expr/lam h ([y] ([h1] h1)))))))
                         defeq/sort-refl)
                       defeq/sort-refl)
                     h)))
               ([y]
                 ([h1]
                   (defeq/conv
                     (defeq/beta ([w] ([h2] h2)) defeq/sort-refl)
                     (defeq/conv
                       (defeq/app
                         (defeq/beta
                           ([w] ([h2] (defeq/lam h2 ([v] ([h3] h3)))))
                           defeq/sort-refl)
                         defeq/sort-refl)
                       (defeq/conv
                         (defeq/app
                           (defeq/app
                             (defeq/delta
                               id/decl
                               (inst-expr/forall
                                 (inst-expr/sort (inst-lvl/var nth-lvl/z))
                                 ([x]
                                   ([h] (inst-expr/forall h ([y] ([h1] h))))))
                               (inst-expr/lam
                                 (inst-expr/sort (inst-lvl/var nth-lvl/z))
                                 ([x] ([h] (inst-expr/lam h ([y] ([h1] h1)))))))
                             defeq/sort-refl)
                           defeq/sort-refl)
                         h)))))))))).

forallSortWhnf/name : name "forallSortWhnf" (is-decl (esort lzero) (defn (eforall (eapp (eapp (econst "id" (lcons (lsucc (lsucc lzero)) lnil)) (esort (lsucc lzero))) (esort lzero)) ([x] (eforall x ([y] x)))))).

forallSortWhnf/decl : declared "forallSortWhnf" (esort lzero) (defn (eforall (eapp (eapp (econst "id" (lcons (lsucc (lsucc lzero)) lnil)) (esort (lsucc lzero))) (esort lzero)) ([x] (eforall x ([y] x)))))
   = declared/ok forallSortWhnf/name dkind-non-inductive/defn (dkind-ok/defn forallSortWhnf/type-wf forallSortWhnf/value-typed).
