%% inductive ctor Nat.succ
Nat_succ/type-wf :
   defeq (eforall (econst "Nat" lnil) ([x] (econst "Nat" lnil))) (eforall (econst "Nat" lnil) ([x] (econst "Nat" lnil))) (esort (limax (lsucc lzero) (lsucc lzero)))
   = (defeq/forall (defeq/const Nat/decl) ([x] [y] (defeq/const Nat/decl))).

Nat_succ/positivity :
   ctor-positive "Nat" lnil (eforall (econst "Nat" lnil) ([x] (econst "Nat" lnil)))
   = (ctor-positive/intro ([S] (eforall S ([x] S))) (ctor-spine/arg (strict-pos/head applies-self/refl) ([_y0] (ctor-spine/result applies-self/refl)))).

Nat_succ/decl : declared "Nat.succ" lnil
