%%% Expected outcome: reject
%%% Rejection: recursive occurrence on the *left* of an arrow,
%%% *behind further arrows* inside a constructor argument.
%%% 
%%% The constructor argument is a function type `Nat → (I → Nat)`.
%% inductive Nat
Nat/type-wf-sort : lvl
   = (lsucc (lsucc lzero)).

Nat/type-wf : defeq (esort (lsucc lzero)) (esort (lsucc lzero)) (esort Nat/type-wf-sort)
   = defeq/sort-refl.

%%% HOLE
Nat/ends-in-sort : ends-in-sort (esort (lsucc lzero)).

Nat/name : name "Nat" (is-decl (esort (lsucc lzero)) indt).

Nat/decl : declared "Nat" (esort (lsucc lzero)) indt
   = declared/ok Nat/name (dkind-ok/indt Nat/type-wf Nat/ends-in-sort).

%% ctor Nat.zero (of Nat)
%%% HOLE
Nat_zero/type-wf-sort : lvl.

%%% HOLE
Nat_zero/type-wf : defeq (econst "Nat" lnil) (econst "Nat" lnil) (esort Nat_zero/type-wf-sort).

%%% HOLE
Nat_zero/positivity : ctor-positive "Nat" lnil (econst "Nat" lnil).

Nat_zero/name : name "Nat.zero" (is-decl (econst "Nat" lnil) ctor).

Nat_zero/decl : declared "Nat.zero" (econst "Nat" lnil) ctor
   = declared/ok Nat_zero/name (dkind-ok/ctor Nat_zero/type-wf Nat_zero/positivity).

%% ctor Nat.succ (of Nat)
%%% HOLE
Nat_succ/type-wf-sort : lvl.

%%% HOLE
Nat_succ/type-wf : defeq (eforall (econst "Nat" lnil) ([x] (econst "Nat" lnil))) (eforall (econst "Nat" lnil) ([x] (econst "Nat" lnil))) (esort Nat_succ/type-wf-sort).

%%% HOLE
Nat_succ/positivity : ctor-positive "Nat" lnil (eforall (econst "Nat" lnil) ([x] (econst "Nat" lnil))).

Nat_succ/name : name "Nat.succ" (is-decl (eforall (econst "Nat" lnil) ([x] (econst "Nat" lnil))) ctor).

Nat_succ/decl : declared "Nat.succ" (eforall (econst "Nat" lnil) ([x] (econst "Nat" lnil))) ctor
   = declared/ok Nat_succ/name (dkind-ok/ctor Nat_succ/type-wf Nat_succ/positivity).

%% recursor Nat.rec
%%% HOLE
Nat_rec/type-wf-sort : lvl.

%%% HOLE
Nat_rec/type-wf : defeq (eforall (eforall (econst "Nat" lnil) ([x] (esort (lvar liz)))) ([x] (eforall (eapp x (econst "Nat.zero" lnil)) ([y] (eforall (eforall (econst "Nat" lnil) ([z] (eforall (eapp x z) ([w] (eapp x (eapp (econst "Nat.succ" lnil) z)))))) ([z] (eforall (econst "Nat" lnil) ([w] (eapp x w))))))))) (eforall (eforall (econst "Nat" lnil) ([x] (esort (lvar liz)))) ([x] (eforall (eapp x (econst "Nat.zero" lnil)) ([y] (eforall (eforall (econst "Nat" lnil) ([z] (eforall (eapp x z) ([w] (eapp x (eapp (econst "Nat.succ" lnil) z)))))) ([z] (eforall (econst "Nat" lnil) ([w] (eapp x w))))))))) (esort Nat_rec/type-wf-sort).

Nat_rec/name : name "Nat.rec" (is-decl (eforall (eforall (econst "Nat" lnil) ([x] (esort (lvar liz)))) ([x] (eforall (eapp x (econst "Nat.zero" lnil)) ([y] (eforall (eforall (econst "Nat" lnil) ([z] (eforall (eapp x z) ([w] (eapp x (eapp (econst "Nat.succ" lnil) z)))))) ([z] (eforall (econst "Nat" lnil) ([w] (eapp x w))))))))) irec).

Nat_rec/decl : declared "Nat.rec" (eforall (eforall (econst "Nat" lnil) ([x] (esort (lvar liz)))) ([x] (eforall (eapp x (econst "Nat.zero" lnil)) ([y] (eforall (eforall (econst "Nat" lnil) ([z] (eforall (eapp x z) ([w] (eapp x (eapp (econst "Nat.succ" lnil) z)))))) ([z] (eforall (econst "Nat" lnil) ([w] (eapp x w))))))))) irec
   = declared/ok Nat_rec/name (dkind-ok/irec Nat_rec/type-wf).

%% inductive reflOccLeft
reflOccLeft/type-wf-sort : lvl
   = (lsucc (lsucc lzero)).

reflOccLeft/type-wf : defeq (esort (lsucc lzero)) (esort (lsucc lzero)) (esort reflOccLeft/type-wf-sort)
   = defeq/sort-refl.

%%% HOLE
reflOccLeft/ends-in-sort : ends-in-sort (esort (lsucc lzero)).

reflOccLeft/name : name "reflOccLeft" (is-decl (esort (lsucc lzero)) indt).

reflOccLeft/decl : declared "reflOccLeft" (esort (lsucc lzero)) indt
   = declared/ok reflOccLeft/name (dkind-ok/indt reflOccLeft/type-wf reflOccLeft/ends-in-sort).

%% ctor reflOccLeft.mk (of reflOccLeft)
%%% HOLE
reflOccLeft_mk/type-wf-sort : lvl.

%%% HOLE
reflOccLeft_mk/type-wf : defeq (eforall (eforall (econst "Nat" lnil) ([x] (eforall (econst "reflOccLeft" lnil) ([y] (econst "Nat" lnil))))) ([x] (econst "reflOccLeft" lnil))) (eforall (eforall (econst "Nat" lnil) ([x] (eforall (econst "reflOccLeft" lnil) ([y] (econst "Nat" lnil))))) ([x] (econst "reflOccLeft" lnil))) (esort reflOccLeft_mk/type-wf-sort).

%%% HOLE
reflOccLeft_mk/positivity : ctor-positive "reflOccLeft" lnil (eforall (eforall (econst "Nat" lnil) ([x] (eforall (econst "reflOccLeft" lnil) ([y] (econst "Nat" lnil))))) ([x] (econst "reflOccLeft" lnil))).

reflOccLeft_mk/name : name "reflOccLeft.mk" (is-decl (eforall (eforall (econst "Nat" lnil) ([x] (eforall (econst "reflOccLeft" lnil) ([y] (econst "Nat" lnil))))) ([x] (econst "reflOccLeft" lnil))) ctor).

reflOccLeft_mk/decl : declared "reflOccLeft.mk" (eforall (eforall (econst "Nat" lnil) ([x] (eforall (econst "reflOccLeft" lnil) ([y] (econst "Nat" lnil))))) ([x] (econst "reflOccLeft" lnil))) ctor
   = declared/ok reflOccLeft_mk/name (dkind-ok/ctor reflOccLeft_mk/type-wf reflOccLeft_mk/positivity).

%% recursor reflOccLeft.rec
reflOccLeft_rec/type-wf-sort : lvl
   = (lsucc lzero).

reflOccLeft_rec/type-wf : defeq (esort lzero) (esort lzero) (esort reflOccLeft_rec/type-wf-sort)
   = defeq/sort-refl.

reflOccLeft_rec/name : name "reflOccLeft.rec" (is-decl (esort lzero) irec).

reflOccLeft_rec/decl : declared "reflOccLeft.rec" (esort lzero) irec
   = declared/ok reflOccLeft_rec/name (dkind-ok/irec reflOccLeft_rec/type-wf).

