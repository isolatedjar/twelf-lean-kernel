hole/ctor-positive : {N : name} {LS : lvls} {T : expr} ctor-positive N LS T.

%% inductive Nat
Nat/type-wf :
   defeq (esort (lsucc lzero)) (esort (lsucc lzero)) (esort (lsucc (lsucc lzero)))
   = (defeq/sort-refl-at (lsucc lzero)).

Nat/ends-in-sort :
   ends-in-sort (esort (lsucc lzero))
   = ends-in-sort/sort.

Nat/decl : declared "Nat" lnil
