%%% Expected outcome: reject
%%% Rejection: recursive occurrence on the *left* of an arrow,
%%% *behind further arrows* inside a constructor argument.
%%% 
%%% The constructor argument is a function type `Nat → (I → Nat)`.
%% inductive Nat
%%% HOLE
Nat/type-wf : defeq (esort (lsucc lzero)) (esort (lsucc lzero)) (esort lzero).

%%% HOLE
Nat/ends-in-sort : ends-in-sort (esort (lsucc lzero)).

Nat/decl : declared "Nat" lnil
   (esort (lsucc lzero))
   indt
   (dkind-ok/indt Nat/type-wf Nat/ends-in-sort).

%% ctor Nat.zero (of Nat)
%%% HOLE
Nat_zero/type-wf : defeq (econst "Nat" lnil) (econst "Nat" lnil) (esort lzero).

%%% HOLE
Nat_zero/positivity : ctor-positive "Nat" lnil (econst "Nat" lnil).

Nat_zero/decl : declared "Nat.zero" lnil
   (econst "Nat" lnil)
   ctor
   (dkind-ok/ctor Nat_zero/type-wf Nat_zero/positivity).

%% ctor Nat.succ (of Nat)
%%% HOLE
Nat_succ/type-wf : defeq (eforall (econst "Nat" lnil) ([x] (econst "Nat" lnil))) (eforall (econst "Nat" lnil) ([x] (econst "Nat" lnil))) (esort lzero).

%%% HOLE
Nat_succ/positivity : ctor-positive "Nat" lnil (eforall (econst "Nat" lnil) ([x] (econst "Nat" lnil))).

Nat_succ/decl : declared "Nat.succ" lnil
   (eforall (econst "Nat" lnil) ([x] (econst "Nat" lnil)))
   ctor
   (dkind-ok/ctor Nat_succ/type-wf Nat_succ/positivity).

%% recursor Nat.rec
%%% HOLE
Nat_rec/type-wf : {u : lvl} defeq (eforall (eforall (econst "Nat" lnil) ([x] (esort u))) ([x] (eforall (eapp x (econst "Nat.zero" lnil)) ([y] (eforall (eforall (econst "Nat" lnil) ([z] (eforall (eapp x z) ([w] (eapp x (eapp (econst "Nat.succ" lnil) z)))))) ([z] (eforall (econst "Nat" lnil) ([w] (eapp x w))))))))) (eforall (eforall (econst "Nat" lnil) ([x] (esort u))) ([x] (eforall (eapp x (econst "Nat.zero" lnil)) ([y] (eforall (eforall (econst "Nat" lnil) ([z] (eforall (eapp x z) ([w] (eapp x (eapp (econst "Nat.succ" lnil) z)))))) ([z] (eforall (econst "Nat" lnil) ([w] (eapp x w))))))))) (esort lzero).

Nat_rec/decl : {u : lvl} declared "Nat.rec" (lcons u lnil)
   (eforall (eforall (econst "Nat" lnil) ([x] (esort u))) ([x] (eforall (eapp x (econst "Nat.zero" lnil)) ([y] (eforall (eforall (econst "Nat" lnil) ([z] (eforall (eapp x z) ([w] (eapp x (eapp (econst "Nat.succ" lnil) z)))))) ([z] (eforall (econst "Nat" lnil) ([w] (eapp x w)))))))))
   irec
   (dkind-ok/irec (Nat_rec/type-wf u)).

%% inductive reflOccLeft
%%% HOLE
reflOccLeft/type-wf : defeq (esort (lsucc lzero)) (esort (lsucc lzero)) (esort lzero).

%%% HOLE
reflOccLeft/ends-in-sort : ends-in-sort (esort (lsucc lzero)).

reflOccLeft/decl : declared "reflOccLeft" lnil
   (esort (lsucc lzero))
   indt
   (dkind-ok/indt reflOccLeft/type-wf reflOccLeft/ends-in-sort).

%% ctor reflOccLeft.mk (of reflOccLeft)
%%% HOLE
reflOccLeft_mk/type-wf : defeq (eforall (eforall (econst "Nat" lnil) ([x] (eforall (econst "reflOccLeft" lnil) ([y] (econst "Nat" lnil))))) ([x] (econst "reflOccLeft" lnil))) (eforall (eforall (econst "Nat" lnil) ([x] (eforall (econst "reflOccLeft" lnil) ([y] (econst "Nat" lnil))))) ([x] (econst "reflOccLeft" lnil))) (esort lzero).

%%% HOLE
reflOccLeft_mk/positivity : ctor-positive "reflOccLeft" lnil (eforall (eforall (econst "Nat" lnil) ([x] (eforall (econst "reflOccLeft" lnil) ([y] (econst "Nat" lnil))))) ([x] (econst "reflOccLeft" lnil))).

reflOccLeft_mk/decl : declared "reflOccLeft.mk" lnil
   (eforall (eforall (econst "Nat" lnil) ([x] (eforall (econst "reflOccLeft" lnil) ([y] (econst "Nat" lnil))))) ([x] (econst "reflOccLeft" lnil)))
   ctor
   (dkind-ok/ctor reflOccLeft_mk/type-wf reflOccLeft_mk/positivity).

%% recursor reflOccLeft.rec
%%% HOLE
reflOccLeft_rec/type-wf : defeq (esort lzero) (esort lzero) (esort lzero).

reflOccLeft_rec/decl : declared "reflOccLeft.rec" lnil
   (esort lzero)
   irec
   (dkind-ok/irec reflOccLeft_rec/type-wf).

