%%% Render-only view of: level-imax-leq
%%% Proof of False via incorrect universe level comparison for `imax`.
%%% 
%%% A correct kernel must reject `leq(imax(u,v)+1, imax(u,v))`, since at `u=0, v=0` this becomes
%%% `leq(1, 0)` which is false. However, a checker that only compares the `imax` arguments
%%% structurally (without accounting for an accumulated successor offset) will incorrectly accept it.
%%% 
%%% This allows defining a universe-collapsing identity function
%%% `down.{u,v} : Sort (succ (imax u v)) → Sort (imax u v)`, which is used to cast between
%%% `True` and `False` via `Bool.rec` at `Sort (imax 0 0) = Prop`.
%%% 
%%% Nanoda incorrectly accepted this proof until it was [fixed](https://github.com/ammkrn/nanoda_lib/commit/12838995ca232ced05cd5218e4975d03c5c44316).
sneq/0 : string-neq "Bool.false" "Bool.true".

%% inductive False
%%% HOLE
False/type-wf-sort : lvl.

%%% HOLE
False/type-wf : of (esort lzero) (esort False/type-wf-sort).

%%% HOLE
False/ends-in-sort : ends-in-sort (esort lzero).

False/rec-name : name "False.rec" (is-rec-for "False").

False/eisl : ends-in-sort-with-level (esort lzero) lzero
   = ends-in-sort-with-level/sort.

False/cnd : cnames-distinct cnil
   = cnames-distinct/nil.

False/name : name "False" (is-decl (esort lzero) (indt cnil liz)).

False/decl : declared "False" (esort lzero) (indt cnil liz)
   = declared/ok-indt False/name False/rec-name False/cnd (dkind-ok/indt False/type-wf False/ends-in-sort).

%% recursor False.rec (TCB-derived; informational only)
%%   level params: u_1
%%   type:   (eforall (eforall (econst "False" lnil) ([x] (esort (lvar liz)))) ([x] (eforall (econst "False" lnil) ([y] (eapp x y)))))
%%   K-like reduction: yes

%% inductive True
%%% HOLE
True/type-wf-sort : lvl.

%%% HOLE
True/type-wf : of (esort lzero) (esort True/type-wf-sort).

%%% HOLE
True/ends-in-sort : ends-in-sort (esort lzero).

True/rec-name : name "True.rec" (is-rec-for "True").

True/eisl : ends-in-sort-with-level (esort lzero) lzero
   = ends-in-sort-with-level/sort.

True/cnd : cnames-distinct (ccons "True.intro" cnil)
   = (cnames-distinct/cons cnames-distinct/nil all-string-neq/nil).

True/name : name "True" (is-decl (esort lzero) (indt (ccons "True.intro" cnil) liz)).

True/decl : declared "True" (esort lzero) (indt (ccons "True.intro" cnil) liz)
   = declared/ok-indt True/name True/rec-name True/cnd (dkind-ok/indt True/type-wf True/ends-in-sort).

%% ctor True.intro (of True)
%%% HOLE
True_intro/type-wf-sort : lvl.

%%% HOLE
True_intro/type-wf : of (econst "True" lnil) (esort True_intro/type-wf-sort).

%%% HOLE
True_intro/positivity : ctor-positive "True" lnil (econst "True" lnil).

True_intro/cmem : cmem "True.intro" (ccons "True.intro" cnil)
   = cmem/here.

%%% HOLE: True_intro/fuo
True_intro/fuo : field-universes-ok (econst "True" lnil) lzero.

True_intro/name : name "True.intro" (is-decl (econst "True" lnil) (ctor "True" liz)).

True_intro/decl : declared "True.intro" (econst "True" lnil) (ctor "True" liz)
   = declared/ok-ctor True_intro/name True/name True_intro/cmem True/eisl True_intro/fuo (dkind-ok/ctor True_intro/type-wf True_intro/positivity).

%% recursor True.rec (TCB-derived; informational only)
%%   level params: u_1
%%   type:   (eforall (eforall (econst "True" lnil) ([x] (esort (lvar liz)))) ([x] (eforall (eapp x (econst "True.intro" lnil)) ([y] (eforall (econst "True" lnil) ([z] (eapp x z)))))))
%%   rules:
%%     True.rec … True.intro … = (elam (eforall (econst "True" lnil) ([x] (esort (lvar liz)))) ([x] (elam (eapp x (econst "True.intro" lnil)) ([y] y))))   (0 fields)
%%   K-like reduction: yes

%% inductive Bool
%%% HOLE
Bool/type-wf-sort : lvl.

%%% HOLE
Bool/type-wf : of (esort (lsucc lzero)) (esort Bool/type-wf-sort).

%%% HOLE
Bool/ends-in-sort : ends-in-sort (esort (lsucc lzero)).

Bool/rec-name : name "Bool.rec" (is-rec-for "Bool").

Bool/eisl : ends-in-sort-with-level (esort (lsucc lzero)) (lsucc lzero)
   = ends-in-sort-with-level/sort.

Bool/cnd : cnames-distinct (ccons "Bool.false" (ccons "Bool.true" cnil))
   = (cnames-distinct/cons
       (cnames-distinct/cons cnames-distinct/nil all-string-neq/nil)
       (all-string-neq/cons sneq/0 all-string-neq/nil)).

Bool/name : name "Bool" (is-decl (esort (lsucc lzero)) (indt (ccons "Bool.false" (ccons "Bool.true" cnil)) liz)).

Bool/decl : declared "Bool" (esort (lsucc lzero)) (indt (ccons "Bool.false" (ccons "Bool.true" cnil)) liz)
   = declared/ok-indt Bool/name Bool/rec-name Bool/cnd (dkind-ok/indt Bool/type-wf Bool/ends-in-sort).

%% ctor Bool.false (of Bool)
%%% HOLE
Bool_false/type-wf-sort : lvl.

%%% HOLE
Bool_false/type-wf : of (econst "Bool" lnil) (esort Bool_false/type-wf-sort).

%%% HOLE
Bool_false/positivity : ctor-positive "Bool" lnil (econst "Bool" lnil).

Bool_false/cmem : cmem "Bool.false" (ccons "Bool.false" (ccons "Bool.true" cnil))
   = cmem/here.

%%% HOLE: Bool_false/fuo
Bool_false/fuo : field-universes-ok (econst "Bool" lnil) (lsucc lzero).

Bool_false/name : name "Bool.false" (is-decl (econst "Bool" lnil) (ctor "Bool" liz)).

Bool_false/decl : declared "Bool.false" (econst "Bool" lnil) (ctor "Bool" liz)
   = declared/ok-ctor Bool_false/name Bool/name Bool_false/cmem Bool/eisl Bool_false/fuo (dkind-ok/ctor Bool_false/type-wf Bool_false/positivity).

%% ctor Bool.true (of Bool)
%%% HOLE
Bool_true/type-wf-sort : lvl.

%%% HOLE
Bool_true/type-wf : of (econst "Bool" lnil) (esort Bool_true/type-wf-sort).

%%% HOLE
Bool_true/positivity : ctor-positive "Bool" lnil (econst "Bool" lnil).

Bool_true/cmem : cmem "Bool.true" (ccons "Bool.false" (ccons "Bool.true" cnil))
   = (cmem/there cmem/here).

%%% HOLE: Bool_true/fuo
Bool_true/fuo : field-universes-ok (econst "Bool" lnil) (lsucc lzero).

Bool_true/name : name "Bool.true" (is-decl (econst "Bool" lnil) (ctor "Bool" (lis liz))).

Bool_true/decl : declared "Bool.true" (econst "Bool" lnil) (ctor "Bool" (lis liz))
   = declared/ok-ctor Bool_true/name Bool/name Bool_true/cmem Bool/eisl Bool_true/fuo (dkind-ok/ctor Bool_true/type-wf Bool_true/positivity).

%% recursor Bool.rec (TCB-derived; informational only)
%%   level params: u_1
%%   type:   (eforall (eforall (econst "Bool" lnil) ([x] (esort (lvar liz)))) ([x] (eforall (eapp x (econst "Bool.false" lnil)) ([y] (eforall (eapp x (econst "Bool.true" lnil)) ([z] (eforall (econst "Bool" lnil) ([w] (eapp x w)))))))))
%%   rules:
%%     Bool.rec … Bool.false … = (elam (eforall (econst "Bool" lnil) ([x] (esort (lvar liz)))) ([x] (elam (eapp x (econst "Bool.false" lnil)) ([y] (elam (eapp x (econst "Bool.true" lnil)) ([z] y))))))   (0 fields)
%%     Bool.rec … Bool.true … = (elam (eforall (econst "Bool" lnil) ([x] (esort (lvar liz)))) ([x] (elam (eapp x (econst "Bool.false" lnil)) ([y] (elam (eapp x (econst "Bool.true" lnil)) ([z] z))))))   (0 fields)

%% def down
%%% HOLE
down/type-wf-sort : lvl.

%%% HOLE
down/type-wf : of (eforall (esort (lsucc (limax (lvar liz) (lvar (lis liz))))) ([x] (esort (limax (lvar liz) (lvar (lis liz)))))) (esort down/type-wf-sort).

%%% HOLE
down/value-typed : of (elam (esort (lsucc (limax (lvar liz) (lvar (lis liz))))) ([x] x)) (eforall (esort (lsucc (limax (lvar liz) (lvar (lis liz))))) ([x] (esort (limax (lvar liz) (lvar (lis liz)))))).

down/name : name "down" (is-decl
  (eforall (esort (lsucc (limax (lvar liz) (lvar (lis liz))))) ([x] (esort (limax (lvar liz) (lvar (lis liz))))))
  (defn (elam (esort (lsucc (limax (lvar liz) (lvar (lis liz))))) ([x] x)))).

down/decl : declared "down"
  (eforall (esort (lsucc (limax (lvar liz) (lvar (lis liz))))) ([x] (esort (limax (lvar liz) (lvar (lis liz))))))
  (defn (elam (esort (lsucc (limax (lvar liz) (lvar (lis liz))))) ([x] x)))
   = declared/ok down/name dkind-non-inductive/defn (dkind-ok/defn down/type-wf down/value-typed).

%% def proof_of_false
%%% HOLE
proof_of_false/type-wf-sort : lvl.

%%% HOLE
proof_of_false/type-wf : of (econst "False" lnil) (esort proof_of_false/type-wf-sort).

%%% HOLE
proof_of_false/value-typed : of
  (eapp (eapp (eapp (elam (eapp (econst "down" (lcons lzero (lcons lzero lnil))) (econst "Bool" lnil))
    ([x]
      (elam (eapp (econst "down" (lcons lzero (lcons lzero lnil))) (econst "Bool" lnil))
        ([y]
          (elam (eapp (eapp (eapp (eapp (econst "Bool.rec" (lcons (lsucc lzero) lnil)) (elam (econst "Bool" lnil) ([z] (esort lzero)))) (econst "False" lnil)) (econst "True" lnil)) x)
            ([z]
              (eapp (elam (eapp (eapp (eapp (eapp (econst "Bool.rec" (lcons (lsucc lzero) lnil)) (elam (econst "Bool" lnil) ([w] (esort lzero)))) (econst "False" lnil)) (econst "True" lnil)) y)
                ([w] w))
                z)))))))
    (econst "Bool.true" lnil))
    (econst "Bool.false" lnil))
    (econst "True.intro" lnil))
  (econst "False" lnil).

proof_of_false/name : name "proof_of_false" (is-decl
  (econst "False" lnil)
  (defn (eapp (eapp (eapp (elam (eapp (econst "down" (lcons lzero (lcons lzero lnil))) (econst "Bool" lnil)) ([x] (elam (eapp (econst "down" (lcons lzero (lcons lzero lnil))) (econst "Bool" lnil)) ([y] (elam (eapp (eapp (eapp (eapp (econst "Bool.rec" (lcons (lsucc lzero) lnil)) (elam (econst "Bool" lnil) ([z] (esort lzero)))) (econst "False" lnil)) (econst "True" lnil)) x) ([z] (eapp (elam (eapp (eapp (eapp (eapp (econst "Bool.rec" (lcons (lsucc lzero) lnil)) (elam (econst "Bool" lnil) ([w] (esort lzero)))) (econst "False" lnil)) (econst "True" lnil)) y) ([w] w)) z))))))) (econst "Bool.true" lnil)) (econst "Bool.false" lnil)) (econst "True.intro" lnil)))).

proof_of_false/decl : declared "proof_of_false"
  (econst "False" lnil)
  (defn (eapp (eapp (eapp (elam (eapp (econst "down" (lcons lzero (lcons lzero lnil))) (econst "Bool" lnil)) ([x] (elam (eapp (econst "down" (lcons lzero (lcons lzero lnil))) (econst "Bool" lnil)) ([y] (elam (eapp (eapp (eapp (eapp (econst "Bool.rec" (lcons (lsucc lzero) lnil)) (elam (econst "Bool" lnil) ([z] (esort lzero)))) (econst "False" lnil)) (econst "True" lnil)) x) ([z] (eapp (elam (eapp (eapp (eapp (eapp (econst "Bool.rec" (lcons (lsucc lzero) lnil)) (elam (econst "Bool" lnil) ([w] (esort lzero)))) (econst "False" lnil)) (econst "True" lnil)) y) ([w] w)) z))))))) (econst "Bool.true" lnil)) (econst "Bool.false" lnil)) (econst "True.intro" lnil)))
   = declared/ok proof_of_false/name dkind-non-inductive/defn (dkind-ok/defn proof_of_false/type-wf proof_of_false/value-typed).
