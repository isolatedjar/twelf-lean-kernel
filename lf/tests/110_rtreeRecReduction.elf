%% inductive Bool
Bool/type-wf :
   defeq (esort (lsucc lzero)) (esort (lsucc lzero)) (esort (lsucc (lsucc lzero)))
   = (defeq/sort-refl-at (lsucc lzero)).

Bool/ends-in-sort :
   ends-in-sort (esort (lsucc lzero))
   = ends-in-sort/sort.

Bool/decl : declared "Bool" lnil
   (esort (lsucc lzero))
   indt
   (dkind-ok/indt Bool/type-wf Bool/ends-in-sort).

%% inductive ctor Bool.false
Bool_false/type-wf :
   defeq (econst "Bool" lnil) (econst "Bool" lnil) (esort (lsucc lzero))
   = (defeq/const Bool/decl).

Bool_false/positivity :
   ctor-positive "Bool" lnil (econst "Bool" lnil)
   = (ctor-positive/intro ([S] S) ([S] (ctor-spine/result applies-self/refl))).

Bool_false/decl : declared "Bool.false" lnil
   (econst "Bool" lnil)
   ctor
   (dkind-ok/ctor Bool_false/type-wf Bool_false/positivity).

%% inductive ctor Bool.true
Bool_true/type-wf :
   defeq (econst "Bool" lnil) (econst "Bool" lnil) (esort (lsucc lzero))
   = (defeq/const Bool/decl).

Bool_true/positivity :
   ctor-positive "Bool" lnil (econst "Bool" lnil)
