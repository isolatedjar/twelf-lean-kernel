%% inductive PropStructure
%abbrev PropStructure/type-wf :
   {u : lvl} {v : lvl} defeq (esort lzero) (esort lzero) (esort (lsucc lzero))
   = [u] [v] (defeq/sort-refl-at lzero).

%abbrev PropStructure/ends-in-sort :
   {u : lvl} {v : lvl} ends-in-sort (esort lzero)
   = [u] [v] ends-in-sort/sort.

PropStructure/decl : {u : lvl} {v : lvl} declared "PropStructure" (lcons u (lcons v lnil))
   (esort lzero)
   indt
   (dkind-ok/indt (PropStructure/type-wf u v) (PropStructure/ends-in-sort u v)).

