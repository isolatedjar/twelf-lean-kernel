%%% Expected outcome: accept
%%% Inductive predicates eliminate into Prop if they have one constructors and it carries data.
%% inductive Exists
Exists/type-wf-sort : lvl
   = (limax (lsucc (lvar liz)) (limax (limax (lvar liz) (lsucc lzero)) (lsucc lzero))).

Exists/type-wf : defeq (eforall (esort (lvar liz)) ([x] (eforall (eforall x ([y] (esort lzero))) ([y] (esort lzero))))) (eforall (esort (lvar liz)) ([x] (eforall (eforall x ([y] (esort lzero))) ([y] (esort lzero))))) (esort Exists/type-wf-sort)
   = (defeq/forall defeq/sort-refl ([x] ([h] (defeq/forall (defeq/forall h ([y] ([h1] defeq/sort-refl))) ([y] ([h1] defeq/sort-refl)))))).

%%% HOLE
Exists/ends-in-sort : ends-in-sort (eforall (esort (lvar liz)) ([x] (eforall (eforall x ([y] (esort lzero))) ([y] (esort lzero))))).

Exists/name : name "Exists" (is-decl (eforall (esort (lvar liz)) ([x] (eforall (eforall x ([y] (esort lzero))) ([y] (esort lzero))))) indt).

Exists/decl : declared "Exists" (eforall (esort (lvar liz)) ([x] (eforall (eforall x ([y] (esort lzero))) ([y] (esort lzero))))) indt
   = declared/ok Exists/name (dkind-ok/indt Exists/type-wf Exists/ends-in-sort).

%% ctor Exists.intro (of Exists)
%%% HOLE
Exists_intro/type-wf-sort : lvl.

%%% HOLE
Exists_intro/type-wf : defeq (eforall (esort (lvar liz)) ([x] (eforall (eforall x ([y] (esort lzero))) ([y] (eforall x ([z] (eforall (eapp y z) ([w] (eapp (eapp (econst "Exists" (lcons (lvar liz) lnil)) x) y))))))))) (eforall (esort (lvar liz)) ([x] (eforall (eforall x ([y] (esort lzero))) ([y] (eforall x ([z] (eforall (eapp y z) ([w] (eapp (eapp (econst "Exists" (lcons (lvar liz) lnil)) x) y))))))))) (esort Exists_intro/type-wf-sort).

%%% HOLE
Exists_intro/positivity : ctor-positive "Exists" (lcons (lvar liz) lnil) (eforall (esort (lvar liz)) ([x] (eforall (eforall x ([y] (esort lzero))) ([y] (eforall x ([z] (eforall (eapp y z) ([w] (eapp (eapp (econst "Exists" (lcons (lvar liz) lnil)) x) y))))))))).

Exists_intro/name : name "Exists.intro" (is-decl (eforall (esort (lvar liz)) ([x] (eforall (eforall x ([y] (esort lzero))) ([y] (eforall x ([z] (eforall (eapp y z) ([w] (eapp (eapp (econst "Exists" (lcons (lvar liz) lnil)) x) y))))))))) ctor).

Exists_intro/decl : declared "Exists.intro" (eforall (esort (lvar liz)) ([x] (eforall (eforall x ([y] (esort lzero))) ([y] (eforall x ([z] (eforall (eapp y z) ([w] (eapp (eapp (econst "Exists" (lcons (lvar liz) lnil)) x) y))))))))) ctor
   = declared/ok Exists_intro/name (dkind-ok/ctor Exists_intro/type-wf Exists_intro/positivity).

