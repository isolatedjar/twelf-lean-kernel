%%% Render-only view of: large-elim-param
%%% Proof of False via incorrect large elimination restriction.
%%% 
%%% If the check for whether a level is surely not zero is implemented wrong, in
%%% particular if it incorrectly returns true for params, we can create a
%%% universe-polymorphic
%%% ```
%%% inductive MyBool.{u} : Sort u | tt | ff
%%% ```
%%% where the recursor `MyBool.rec.{1,0}` can do large elimination of a `Prop`.
%%% Because of proof irrelevance we have `tt = ff`, so we can derive a
%%% contradiction.
%%% 
%%% Found by Anthony Wang using Aristotle.
sneq/0 : string-neq "MyBool.tt" "MyBool.ff".

%% inductive False
%%% HOLE
False/type-wf : of (esort lzero) (esort _).

%%% HOLE
False/ends-in-sort : ends-in-sort (esort lzero).

False/rec-name : name "False.rec" (is-rec-for "False").

False/eisl : ends-in-sort-with-level (esort lzero) lzero
   = ends-in-sort-with-level/sort.

False/cnd : cnames-distinct cnil
   = cnames-distinct/nil.

False/name : name "False" (is-decl (esort lzero) (indt cnil z)).

False/decl : declared "False" (esort lzero) (indt cnil z)
   = declared/ok-indt False/name False/rec-name False/cnd (dkind-ok/indt False/type-wf False/ends-in-sort).

%% inductive True
%%% HOLE
True/type-wf : of (esort lzero) (esort _).

%%% HOLE
True/ends-in-sort : ends-in-sort (esort lzero).

True/rec-name : name "True.rec" (is-rec-for "True").

True/eisl : ends-in-sort-with-level (esort lzero) lzero
   = ends-in-sort-with-level/sort.

True/cnd : cnames-distinct (ccons "True.intro" cnil)
   = (cnames-distinct/cons cnames-distinct/nil all-string-neq/nil).

True/name : name "True" (is-decl (esort lzero) (indt (ccons "True.intro" cnil) z)).

True/decl : declared "True" (esort lzero) (indt (ccons "True.intro" cnil) z)
   = declared/ok-indt True/name True/rec-name True/cnd (dkind-ok/indt True/type-wf True/ends-in-sort).

%% ctor True.intro (of True)
%%% HOLE
True_intro/type-wf : of (econst "True" lnil) (esort _).

%%% HOLE
True_intro/positivity : ctor-positive "True" lnil (econst "True" lnil).

True_intro/cmem : cmem "True.intro" (ccons "True.intro" cnil)
   = cmem/here.

%%% HOLE: True_intro/fuo
True_intro/fuo : field-universes-ok (econst "True" lnil) lzero.

True_intro/name : name "True.intro" (is-decl (econst "True" lnil) (ctor "True" z)).

True_intro/decl : declared "True.intro" (econst "True" lnil) (ctor "True" z)
   = declared/ok-ctor True_intro/name True/name True_intro/cmem True/eisl True_intro/fuo (dkind-ok/ctor True_intro/type-wf True_intro/positivity).

%% inductive MyBool
%%% HOLE
MyBool/type-wf : of (esort (lvar z)) (esort _).

%%% HOLE
MyBool/ends-in-sort : ends-in-sort (esort (lvar z)).

MyBool/rec-name : name "MyBool.rec" (is-rec-for "MyBool").

MyBool/eisl : ends-in-sort-with-level (esort (lvar z)) (lvar z)
   = ends-in-sort-with-level/sort.

MyBool/cnd : cnames-distinct (ccons "MyBool.tt" (ccons "MyBool.ff" cnil))
   = (cnames-distinct/cons
       (cnames-distinct/cons cnames-distinct/nil all-string-neq/nil)
       (all-string-neq/cons sneq/0 all-string-neq/nil)).

MyBool/name : name "MyBool" (is-decl (esort (lvar z)) (indt (ccons "MyBool.tt" (ccons "MyBool.ff" cnil)) z)).

MyBool/decl : declared "MyBool" (esort (lvar z)) (indt (ccons "MyBool.tt" (ccons "MyBool.ff" cnil)) z)
   = declared/ok-indt MyBool/name MyBool/rec-name MyBool/cnd (dkind-ok/indt MyBool/type-wf MyBool/ends-in-sort).

%% ctor MyBool.tt (of MyBool)
%%% HOLE
MyBool_tt/type-wf : of (econst "MyBool" (lcons (lvar z) lnil)) (esort _).

%%% HOLE
MyBool_tt/positivity : ctor-positive "MyBool" (lcons (lvar z) lnil) (econst "MyBool" (lcons (lvar z) lnil)).

MyBool_tt/cmem : cmem "MyBool.tt" (ccons "MyBool.tt" (ccons "MyBool.ff" cnil))
   = cmem/here.

%%% HOLE: MyBool_tt/fuo
MyBool_tt/fuo : field-universes-ok (econst "MyBool" (lcons (lvar z) lnil)) (lvar z).

MyBool_tt/name : name "MyBool.tt" (is-decl (econst "MyBool" (lcons (lvar z) lnil)) (ctor "MyBool" z)).

MyBool_tt/decl : declared "MyBool.tt" (econst "MyBool" (lcons (lvar z) lnil)) (ctor "MyBool" z)
   = declared/ok-ctor MyBool_tt/name MyBool/name MyBool_tt/cmem MyBool/eisl MyBool_tt/fuo (dkind-ok/ctor MyBool_tt/type-wf MyBool_tt/positivity).

%% ctor MyBool.ff (of MyBool)
%%% HOLE
MyBool_ff/type-wf : of (econst "MyBool" (lcons (lvar z) lnil)) (esort _).

%%% HOLE
MyBool_ff/positivity : ctor-positive "MyBool" (lcons (lvar z) lnil) (econst "MyBool" (lcons (lvar z) lnil)).

MyBool_ff/cmem : cmem "MyBool.ff" (ccons "MyBool.tt" (ccons "MyBool.ff" cnil))
   = (cmem/there cmem/here).

%%% HOLE: MyBool_ff/fuo
MyBool_ff/fuo : field-universes-ok (econst "MyBool" (lcons (lvar z) lnil)) (lvar z).

MyBool_ff/name : name "MyBool.ff" (is-decl (econst "MyBool" (lcons (lvar z) lnil)) (ctor "MyBool" (s z))).

MyBool_ff/decl : declared "MyBool.ff" (econst "MyBool" (lcons (lvar z) lnil)) (ctor "MyBool" (s z))
   = declared/ok-ctor MyBool_ff/name MyBool/name MyBool_ff/cmem MyBool/eisl MyBool_ff/fuo (dkind-ok/ctor MyBool_ff/type-wf MyBool_ff/positivity).

%% def cast
%%% HOLE
cast/type-wf : of
  (eforall (eforall (econst "MyBool" (lcons lzero lnil)) ([x] (esort lzero))) ([x] (eforall (eapp x (econst "MyBool.tt" (lcons lzero lnil))) ([y] (eapp x (econst "MyBool.ff" (lcons lzero lnil)))))))
  (esort _).

%%% HOLE
cast/value-typed : of
  (elam (eforall (econst "MyBool" (lcons lzero lnil)) ([x] (esort lzero))) ([x] (elam (eapp x (econst "MyBool.tt" (lcons lzero lnil))) ([y] y))))
  (eforall (eforall (econst "MyBool" (lcons lzero lnil)) ([x] (esort lzero))) ([x] (eforall (eapp x (econst "MyBool.tt" (lcons lzero lnil))) ([y] (eapp x (econst "MyBool.ff" (lcons lzero lnil))))))).

cast/name : name "cast" (is-decl
  (eforall (eforall (econst "MyBool" (lcons lzero lnil)) ([x] (esort lzero))) ([x] (eforall (eapp x (econst "MyBool.tt" (lcons lzero lnil))) ([y] (eapp x (econst "MyBool.ff" (lcons lzero lnil)))))))
  (defn (elam (eforall (econst "MyBool" (lcons lzero lnil)) ([x] (esort lzero))) ([x] (elam (eapp x (econst "MyBool.tt" (lcons lzero lnil))) ([y] y)))))).

cast/decl : declared "cast"
  (eforall (eforall (econst "MyBool" (lcons lzero lnil)) ([x] (esort lzero))) ([x] (eforall (eapp x (econst "MyBool.tt" (lcons lzero lnil))) ([y] (eapp x (econst "MyBool.ff" (lcons lzero lnil)))))))
  (defn (elam (eforall (econst "MyBool" (lcons lzero lnil)) ([x] (esort lzero))) ([x] (elam (eapp x (econst "MyBool.tt" (lcons lzero lnil))) ([y] y)))))
   = declared/ok cast/name dkind-non-inductive/defn (dkind-ok/defn cast/type-wf cast/value-typed).

%% thm false_proof
%%% HOLE
false_proof/type-wf : of (econst "False" lnil) (esort lzero).

%%% HOLE
false_proof/value-typed : of
  (eapp (eapp (econst "cast" lnil)
    (eapp (eapp (eapp (econst "MyBool.rec" (lcons (lsucc lzero) (lcons lzero lnil))) (elam (econst "MyBool" (lcons lzero lnil)) ([x] (esort lzero)))) (econst "True" lnil)) (econst "False" lnil)))
    (econst "True.intro" lnil))
  (econst "False" lnil).

false_proof/name : name "false_proof" (is-decl
  (econst "False" lnil)
  (thm (eapp (eapp (econst "cast" lnil) (eapp (eapp (eapp (econst "MyBool.rec" (lcons (lsucc lzero) (lcons lzero lnil))) (elam (econst "MyBool" (lcons lzero lnil)) ([x] (esort lzero)))) (econst "True" lnil)) (econst "False" lnil))) (econst "True.intro" lnil)))).

false_proof/decl : declared "false_proof"
  (econst "False" lnil)
  (thm (eapp (eapp (econst "cast" lnil) (eapp (eapp (eapp (econst "MyBool.rec" (lcons (lsucc lzero) (lcons lzero lnil))) (elam (econst "MyBool" (lcons lzero lnil)) ([x] (esort lzero)))) (econst "True" lnil)) (econst "False" lnil))) (econst "True.intro" lnil)))
   = declared/ok false_proof/name dkind-non-inductive/thm (dkind-ok/thm false_proof/type-wf false_proof/value-typed).
