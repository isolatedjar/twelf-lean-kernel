%%% Expected outcome: accept
%%% Asserting the type of the generated recursor
%% inductive PUnit
PUnit/type-wf-sort : lvl
   = (lsucc (lvar liz)).

PUnit/type-wf : of (esort (lvar liz)) (esort PUnit/type-wf-sort)
   = defeq/sort-refl.

PUnit/ends-in-sort : ends-in-sort (esort (lvar liz))
   = ends-in-sort/sort.

PUnit/rec-name : name "PUnit.rec" (is-rec-for "PUnit").

PUnit/name : name "PUnit" (is-decl (esort (lvar liz)) indt).

PUnit/decl : declared "PUnit" (esort (lvar liz)) indt
   = declared/ok PUnit/name (dkind-ok/indt PUnit/type-wf PUnit/ends-in-sort).

%% ctor PUnit.unit (of PUnit)
PUnit_unit/type-wf-sort : lvl
   = (lvar liz).

PUnit_unit/type-wf : of (econst "PUnit" (lcons (lvar liz) lnil)) (esort PUnit_unit/type-wf-sort)
   = (defeq/const PUnit/decl (inst-expr/sort (lvl-inst/var lvl-nth/zero))).

PUnit_unit/positivity : ctor-positive "PUnit" (lcons (lvar liz) lnil) (econst "PUnit" (lcons (lvar liz) lnil))
   = (ctor-positive/intro ([S] S) (ctor-spine/result applies-self/refl)).

PUnit_unit/name : name "PUnit.unit" (is-decl (econst "PUnit" (lcons (lvar liz) lnil)) ctor).

PUnit_unit/decl : declared "PUnit.unit" (econst "PUnit" (lcons (lvar liz) lnil)) ctor
   = declared/ok PUnit_unit/name (dkind-ok/ctor PUnit_unit/type-wf PUnit_unit/positivity).

%% recursor PUnit.rec
PUnit_rec/type-wf-sort : lvl
   = (limax
       (limax (lvar (lis liz)) (lsucc (lvar liz)))
       (limax (lvar liz) (limax (lvar (lis liz)) (lvar liz)))).

PUnit_rec/type-wf : of (eforall (eforall (econst "PUnit" (lcons (lvar (lis liz)) lnil)) ([x] (esort (lvar liz))))
                      ([x]
                        (eforall (eapp x (econst "PUnit.unit" (lcons (lvar (lis liz)) lnil)))
                          ([y] (eforall (econst "PUnit" (lcons (lvar (lis liz)) lnil)) ([z] (eapp x z))))))) (esort PUnit_rec/type-wf-sort)
   = (defeq/forall
       (defeq/forall
         (defeq/const PUnit/decl (inst-expr/sort (lvl-inst/var lvl-nth/zero)))
         ([x] ([h] defeq/sort-refl)))
       ([x]
         ([h]
           (defeq/forall
             (defeq/app
               h
               (defeq/const
                 PUnit_unit/decl
                 (inst-expr/const
                   (lvls-inst/cons (lvl-inst/var lvl-nth/zero) lvls-inst/nil))))
             ([y]
               ([h1]
                 (defeq/forall
                   (defeq/const
                     PUnit/decl
                     (inst-expr/sort (lvl-inst/var lvl-nth/zero)))
                   ([z] ([h2] (defeq/app h h2)))))))))).

PUnit_rec/decl : declared "PUnit.rec" (eforall (eforall (econst "PUnit" (lcons (lvar (lis liz)) lnil)) ([x] (esort (lvar liz)))) ([x] (eforall (eapp x (econst "PUnit.unit" (lcons (lvar (lis liz)) lnil))) ([y] (eforall (econst "PUnit" (lcons (lvar (lis liz)) lnil)) ([z] (eapp x z))))))) irec
   = declared/ok-irec PUnit/rec-name (dkind-ok/irec PUnit_rec/type-wf).

%% def punitRec
punitRec/type-wf-sort : lvl
   = (limax
       (limax (lvar liz) (lsucc (lvar (lis liz))))
       (limax (lvar (lis liz)) (limax (lvar liz) (lvar (lis liz))))).

punitRec/type-wf : of (eforall (eforall (econst "PUnit" (lcons (lvar liz) lnil)) ([x] (esort (lvar (lis liz)))))
                     ([x] (eforall (eapp x (econst "PUnit.unit" (lcons (lvar liz) lnil))) ([y] (eforall (econst "PUnit" (lcons (lvar liz) lnil)) ([z] (eapp x z))))))) (esort punitRec/type-wf-sort)
   = (defeq/forall
       (defeq/forall
         (defeq/const PUnit/decl (inst-expr/sort (lvl-inst/var lvl-nth/zero)))
         ([x] ([h] defeq/sort-refl)))
       ([x]
         ([h]
           (defeq/forall
             (defeq/app
               h
               (defeq/const
                 PUnit_unit/decl
                 (inst-expr/const
                   (lvls-inst/cons (lvl-inst/var lvl-nth/zero) lvls-inst/nil))))
             ([y]
               ([h1]
                 (defeq/forall
                   (defeq/const
                     PUnit/decl
                     (inst-expr/sort (lvl-inst/var lvl-nth/zero)))
                   ([z] ([h2] (defeq/app h h2)))))))))).

punitRec/value-typed : of (econst "PUnit.rec" (lcons (lvar (lis liz)) (lcons (lvar liz) lnil))) (eforall (eforall (econst "PUnit" (lcons (lvar liz) lnil)) ([x] (esort (lvar (lis liz)))))
                         ([x] (eforall (eapp x (econst "PUnit.unit" (lcons (lvar liz) lnil))) ([y] (eforall (econst "PUnit" (lcons (lvar liz) lnil)) ([z] (eapp x z)))))))
   = (defeq/const
       PUnit_rec/decl
       (inst-expr/forall
         (inst-expr/forall
           (inst-expr/const
             (lvls-inst/cons
               (lvl-inst/var (lvl-nth/succ lvl-nth/zero))
               lvls-inst/nil))
           ([x] ([h] (inst-expr/sort (lvl-inst/var lvl-nth/zero)))))
         ([x]
           ([h]
             (inst-expr/forall
               (inst-expr/app
                 h
                 (inst-expr/const
                   (lvls-inst/cons
                     (lvl-inst/var (lvl-nth/succ lvl-nth/zero))
                     lvls-inst/nil)))
               ([y]
                 ([h1]
                   (inst-expr/forall
                     (inst-expr/const
                       (lvls-inst/cons
                         (lvl-inst/var (lvl-nth/succ lvl-nth/zero))
                         lvls-inst/nil))
                     ([z] ([h2] (inst-expr/app h h2))))))))))).

punitRec/name : name "punitRec" (is-decl (eforall (eforall (econst "PUnit" (lcons (lvar liz) lnil)) ([x] (esort (lvar (lis liz))))) ([x] (eforall (eapp x (econst "PUnit.unit" (lcons (lvar liz) lnil))) ([y] (eforall (econst "PUnit" (lcons (lvar liz) lnil)) ([z] (eapp x z))))))) (defn (econst "PUnit.rec" (lcons (lvar (lis liz)) (lcons (lvar liz) lnil))))).

punitRec/decl : declared "punitRec" (eforall (eforall (econst "PUnit" (lcons (lvar liz) lnil)) ([x] (esort (lvar (lis liz))))) ([x] (eforall (eapp x (econst "PUnit.unit" (lcons (lvar liz) lnil))) ([y] (eforall (econst "PUnit" (lcons (lvar liz) lnil)) ([z] (eapp x z))))))) (defn (econst "PUnit.rec" (lcons (lvar (lis liz)) (lcons (lvar liz) lnil))))
   = declared/ok punitRec/name (dkind-ok/defn punitRec/type-wf punitRec/value-typed).
