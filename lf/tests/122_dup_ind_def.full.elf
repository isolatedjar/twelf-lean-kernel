dup_ind_def/rec-name : name "dup_ind_def.rec" (is-rec-for "dup_ind_def").

dup_ind_def/name : name "dup_ind_def" (is-decl (esort (lsucc lzero)) indt).

dup_ind_def/decl : declared "dup_ind_def" (esort (lsucc lzero)) indt
   = declared/ok dup_ind_def/name (dkind-ok/indt dup_ind_def/type-wf dup_ind_def/ends-in-sort).

%% ctor dup_ind_def.mk (of dup_ind_def)
dup_ind_def_mk/type-wf-sort : lvl
   = (lsucc lzero).

dup_ind_def_mk/type-wf : defeq (econst "dup_ind_def" lnil) (econst "dup_ind_def" lnil) (esort dup_ind_def_mk/type-wf-sort)
   = (defeq/const dup_ind_def/decl (inst-expr/sort (lvl-inst/succ lvl-inst/zero))).

dup_ind_def_mk/positivity : ctor-positive "dup_ind_def" lnil (econst "dup_ind_def" lnil)
   = (ctor-positive/intro ([S] S) (ctor-spine/result applies-self/refl)).

dup_ind_def_mk/name : name "dup_ind_def.mk" (is-decl (econst "dup_ind_def" lnil) ctor).

dup_ind_def_mk/decl : declared "dup_ind_def.mk" (econst "dup_ind_def" lnil) ctor
   = declared/ok dup_ind_def_mk/name (dkind-ok/ctor dup_ind_def_mk/type-wf dup_ind_def_mk/positivity).

%% recursor dup_ind_def.rec
dup_ind_def_rec/type-wf-sort : lvl
   = (limax (limax (lsucc lzero) (lsucc (lvar liz))) (limax (lvar liz) (limax (lsucc lzero) (lvar liz)))).

dup_ind_def_rec/type-wf : defeq (eforall (eforall (econst "dup_ind_def" lnil) ([x] (esort (lvar liz)))) ([x] (eforall (eapp x (econst "dup_ind_def.mk" lnil)) ([y] (eforall (econst "dup_ind_def" lnil) ([z] (eapp x z))))))) (eforall (eforall (econst "dup_ind_def" lnil) ([x] (esort (lvar liz)))) ([x] (eforall (eapp x (econst "dup_ind_def.mk" lnil)) ([y] (eforall (econst "dup_ind_def" lnil) ([z] (eapp x z))))))) (esort dup_ind_def_rec/type-wf-sort)
   = (defeq/forall (defeq/forall (defeq/const dup_ind_def/decl (inst-expr/sort (lvl-inst/succ lvl-inst/zero))) ([x] ([h] defeq/sort-refl))) ([x] ([h] (defeq/forall (defeq/app h (defeq/const dup_ind_def_mk/decl (inst-expr/const lvls-inst/nil))) ([y] ([h1] (defeq/forall (defeq/const dup_ind_def/decl (inst-expr/sort (lvl-inst/succ lvl-inst/zero))) ([z] ([h2] (defeq/app h h2)))))))))).

dup_ind_def_rec/decl : declared "dup_ind_def.rec" (eforall (eforall (econst "dup_ind_def" lnil) ([x] (esort (lvar liz)))) ([x] (eforall (eapp x (econst "dup_ind_def.mk" lnil)) ([y] (eforall (econst "dup_ind_def" lnil) ([z] (eapp x z))))))) irec
   = declared/ok-irec dup_ind_def/rec-name (dkind-ok/irec dup_ind_def_rec/type-wf).

