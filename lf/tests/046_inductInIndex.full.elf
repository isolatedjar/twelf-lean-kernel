%%% Expected outcome: reject
%%% A constructor with an unexpected occurrence of the type in index position of a return type.
%% axiom aProp
aProp/type-wf-sort : lvl
   = (lsucc lzero).

aProp/type-wf : of (esort lzero) (esort aProp/type-wf-sort)
   = defeq/sort-refl.

aProp/name : name "aProp" (is-decl (esort lzero) ax).

aProp/decl : declared "aProp" (esort lzero) ax
   = declared/ok aProp/name dkind-non-inductive/ax (dkind-ok/ax aProp/type-wf).

%%% SKIP: ctor inductInIndex.mk — result-type index arg #1 mentions the inductive "inductInIndex"
