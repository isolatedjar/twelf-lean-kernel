%%% Expected outcome: accept
%%% Some level computation
%solve nonneg_0 : 0 >= 0.
%solve nonneg_1 : 1 >= 0.

%% def levelComp3
levelComp3/type-wf-sort : lvl
   = (lsucc (lsucc (lsucc (lsucc lzero)))).

levelComp3/type-wf : defeq (esort (lsucc (lsucc (lsucc lzero)))) (esort (lsucc (lsucc (lsucc lzero)))) (esort levelComp3/type-wf-sort)
   = defeq/sort-refl.

levelComp3/value-typed : defeq (esort (limax (lsucc (lsucc lzero)) (lsucc lzero))) (esort (limax (lsucc (lsucc lzero)) (lsucc lzero))) (esort (lsucc (lsucc (lsucc lzero))))
   = (defeq/conv (defeq/sort-eq (lvl-eq/le (mleq/sL (mleq/imax-lsL (mleq/sR (mleq/sR (mleq/sR (mleq/maxL (mleq/sL (mleq/sL (mleq/self nonneg_0))) (mleq/sL (mleq/self nonneg_1)))))))) (mleq/sL (mleq/sL (mleq/sL (mleq/sR (mleq/imax-lsR (mleq/maxR-l (mleq/sR (mleq/sR (mleq/self nonneg_0))))))))))) defeq/sort-refl).

levelComp3/name : name "levelComp3" (is-decl (esort (lsucc (lsucc (lsucc lzero)))) (defn (esort (limax (lsucc (lsucc lzero)) (lsucc lzero))))).

levelComp3/decl : declared "levelComp3" (esort (lsucc (lsucc (lsucc lzero)))) (defn (esort (limax (lsucc (lsucc lzero)) (lsucc lzero))))
   = declared/ok levelComp3/name (dkind-ok/defn levelComp3/type-wf levelComp3/value-typed).
