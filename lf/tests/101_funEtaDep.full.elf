%%% Expected outcome: accept
%%% Function eta for dependent functions (pi types).
%% inductive Eq
%%% HOLE
Eq/type-wf-sort : {u_1 : lvl} lvl.

%%% HOLE
Eq/type-wf : {u_1 : lvl} defeq (eforall (esort u_1) ([x] (eforall x ([y] (eforall x ([z] (esort lzero))))))) (eforall (esort u_1) ([x] (eforall x ([y] (eforall x ([z] (esort lzero))))))) (esort (Eq/type-wf-sort u_1)).

%%% HOLE
Eq/ends-in-sort : {u_1 : lvl} ends-in-sort (eforall (esort u_1) ([x] (eforall x ([y] (eforall x ([z] (esort lzero))))))).

Eq/name : {u_1 : lvl} name "Eq" (is-decl (lcons u_1 lnil) (eforall (esort u_1) ([x] (eforall x ([y] (eforall x ([z] (esort lzero))))))) indt).

Eq/decl : {u_1 : lvl} declared "Eq" (lcons u_1 lnil)
   (eforall (esort u_1) ([x] (eforall x ([y] (eforall x ([z] (esort lzero)))))))
   indt
   (Eq/name u_1)
   (dkind-ok/indt (Eq/type-wf u_1) (Eq/ends-in-sort u_1)).

%% ctor Eq.refl (of Eq)
%%% HOLE
Eq_refl/type-wf-sort : {u_1 : lvl} lvl.

%%% HOLE
Eq_refl/type-wf : {u_1 : lvl} defeq (eforall (esort u_1) ([x] (eforall x ([y] (eapp (eapp (eapp (econst "Eq" (lcons u_1 lnil)) x) y) y))))) (eforall (esort u_1) ([x] (eforall x ([y] (eapp (eapp (eapp (econst "Eq" (lcons u_1 lnil)) x) y) y))))) (esort (Eq_refl/type-wf-sort u_1)).

%%% HOLE
Eq_refl/positivity : {u_1 : lvl} ctor-positive "Eq" (lcons u_1 lnil) (eforall (esort u_1) ([x] (eforall x ([y] (eapp (eapp (eapp (econst "Eq" (lcons u_1 lnil)) x) y) y))))).

Eq_refl/name : {u_1 : lvl} name "Eq.refl" (is-decl (lcons u_1 lnil) (eforall (esort u_1) ([x] (eforall x ([y] (eapp (eapp (eapp (econst "Eq" (lcons u_1 lnil)) x) y) y))))) ctor).

Eq_refl/decl : {u_1 : lvl} declared "Eq.refl" (lcons u_1 lnil)
   (eforall (esort u_1) ([x] (eforall x ([y] (eapp (eapp (eapp (econst "Eq" (lcons u_1 lnil)) x) y) y)))))
   ctor
   (Eq_refl/name u_1)
   (dkind-ok/ctor (Eq_refl/type-wf u_1) (Eq_refl/positivity u_1)).

%% recursor Eq.rec
%%% HOLE
Eq_rec/type-wf-sort : {u : lvl} {u_1 : lvl} lvl.

%%% HOLE
Eq_rec/type-wf : {u : lvl} {u_1 : lvl} defeq (eforall (esort u_1) ([x] (eforall x ([y] (eforall (eforall x ([z] (eforall (eapp (eapp (eapp (econst "Eq" (lcons u_1 lnil)) x) y) z) ([w] (esort u))))) ([z] (eforall (eapp (eapp z y) (eapp (eapp (econst "Eq.refl" (lcons u_1 lnil)) x) y)) ([w] (eforall x ([x1] (eforall (eapp (eapp (eapp (econst "Eq" (lcons u_1 lnil)) x) y) x1) ([y1] (eapp (eapp z x1) y1))))))))))))) (eforall (esort u_1) ([x] (eforall x ([y] (eforall (eforall x ([z] (eforall (eapp (eapp (eapp (econst "Eq" (lcons u_1 lnil)) x) y) z) ([w] (esort u))))) ([z] (eforall (eapp (eapp z y) (eapp (eapp (econst "Eq.refl" (lcons u_1 lnil)) x) y)) ([w] (eforall x ([x1] (eforall (eapp (eapp (eapp (econst "Eq" (lcons u_1 lnil)) x) y) x1) ([y1] (eapp (eapp z x1) y1))))))))))))) (esort (Eq_rec/type-wf-sort u u_1)).

Eq_rec/name : {u : lvl} {u_1 : lvl} name "Eq.rec" (is-decl (lcons u (lcons u_1 lnil)) (eforall (esort u_1) ([x] (eforall x ([y] (eforall (eforall x ([z] (eforall (eapp (eapp (eapp (econst "Eq" (lcons u_1 lnil)) x) y) z) ([w] (esort u))))) ([z] (eforall (eapp (eapp z y) (eapp (eapp (econst "Eq.refl" (lcons u_1 lnil)) x) y)) ([w] (eforall x ([x1] (eforall (eapp (eapp (eapp (econst "Eq" (lcons u_1 lnil)) x) y) x1) ([y1] (eapp (eapp z x1) y1))))))))))))) irec).

Eq_rec/decl : {u : lvl} {u_1 : lvl} declared "Eq.rec" (lcons u (lcons u_1 lnil))
   (eforall (esort u_1) ([x] (eforall x ([y] (eforall (eforall x ([z] (eforall (eapp (eapp (eapp (econst "Eq" (lcons u_1 lnil)) x) y) z) ([w] (esort u))))) ([z] (eforall (eapp (eapp z y) (eapp (eapp (econst "Eq.refl" (lcons u_1 lnil)) x) y)) ([w] (eforall x ([x1] (eforall (eapp (eapp (eapp (econst "Eq" (lcons u_1 lnil)) x) y) x1) ([y1] (eapp (eapp z x1) y1)))))))))))))
   irec
   (Eq_rec/name u u_1)
   (dkind-ok/irec (Eq_rec/type-wf u u_1)).

%% def rfl
%%% HOLE
rfl/type-wf-sort : {u : lvl} lvl.

%%% HOLE
rfl/type-wf : {u : lvl} defeq (eforall (esort u) ([x] (eforall x ([y] (eapp (eapp (eapp (econst "Eq" (lcons u lnil)) x) y) y))))) (eforall (esort u) ([x] (eforall x ([y] (eapp (eapp (eapp (econst "Eq" (lcons u lnil)) x) y) y))))) (esort (rfl/type-wf-sort u)).

%%% HOLE
rfl/value-typed : {u : lvl} defeq (elam (esort u) ([x] (elam x ([y] (eapp (eapp (econst "Eq.refl" (lcons u lnil)) x) y))))) (elam (esort u) ([x] (elam x ([y] (eapp (eapp (econst "Eq.refl" (lcons u lnil)) x) y))))) (eforall (esort u) ([x] (eforall x ([y] (eapp (eapp (eapp (econst "Eq" (lcons u lnil)) x) y) y))))).

rfl/name : {u : lvl} name "rfl" (is-decl (lcons u lnil) (eforall (esort u) ([x] (eforall x ([y] (eapp (eapp (eapp (econst "Eq" (lcons u lnil)) x) y) y))))) (defn (elam (esort u) ([x] (elam x ([y] (eapp (eapp (econst "Eq.refl" (lcons u lnil)) x) y))))))).

rfl/decl : {u : lvl} declared "rfl" (lcons u lnil)
   (eforall (esort u) ([x] (eforall x ([y] (eapp (eapp (eapp (econst "Eq" (lcons u lnil)) x) y) y)))))
   (defn (elam (esort u) ([x] (elam x ([y] (eapp (eapp (econst "Eq.refl" (lcons u lnil)) x) y))))))
   (rfl/name u)
   (dkind-ok/defn (rfl/type-wf u) (rfl/value-typed u)).

%% thm funEtaDep
%%% HOLE
funEtaDep/type-wf : defeq (eforall (esort (lsucc lzero)) ([x] (eforall (eforall x ([y] (esort (lsucc lzero)))) ([y] (eforall (eforall x ([z] (eapp y z))) ([z] (eapp (eapp (eapp (econst "Eq" (lcons (lsucc lzero) lnil)) (eforall x ([w] (eapp y w)))) (elam x ([w] (eapp z w)))) z))))))) (eforall (esort (lsucc lzero)) ([x] (eforall (eforall x ([y] (esort (lsucc lzero)))) ([y] (eforall (eforall x ([z] (eapp y z))) ([z] (eapp (eapp (eapp (econst "Eq" (lcons (lsucc lzero) lnil)) (eforall x ([w] (eapp y w)))) (elam x ([w] (eapp z w)))) z))))))) (esort lzero).

%%% HOLE
funEtaDep/value-typed : defeq (elam (esort (lsucc lzero)) ([x] (elam (eforall x ([y] (esort (lsucc lzero)))) ([y] (elam (eforall x ([z] (eapp y z))) ([z] (eapp (eapp (econst "rfl" (lcons (lsucc lzero) lnil)) (eforall x ([w] (eapp y w)))) (elam x ([w] (eapp z w)))))))))) (elam (esort (lsucc lzero)) ([x] (elam (eforall x ([y] (esort (lsucc lzero)))) ([y] (elam (eforall x ([z] (eapp y z))) ([z] (eapp (eapp (econst "rfl" (lcons (lsucc lzero) lnil)) (eforall x ([w] (eapp y w)))) (elam x ([w] (eapp z w)))))))))) (eforall (esort (lsucc lzero)) ([x] (eforall (eforall x ([y] (esort (lsucc lzero)))) ([y] (eforall (eforall x ([z] (eapp y z))) ([z] (eapp (eapp (eapp (econst "Eq" (lcons (lsucc lzero) lnil)) (eforall x ([w] (eapp y w)))) (elam x ([w] (eapp z w)))) z))))))).

funEtaDep/name : name "funEtaDep" (is-decl lnil (eforall (esort (lsucc lzero)) ([x] (eforall (eforall x ([y] (esort (lsucc lzero)))) ([y] (eforall (eforall x ([z] (eapp y z))) ([z] (eapp (eapp (eapp (econst "Eq" (lcons (lsucc lzero) lnil)) (eforall x ([w] (eapp y w)))) (elam x ([w] (eapp z w)))) z))))))) (thm (elam (esort (lsucc lzero)) ([x] (elam (eforall x ([y] (esort (lsucc lzero)))) ([y] (elam (eforall x ([z] (eapp y z))) ([z] (eapp (eapp (econst "rfl" (lcons (lsucc lzero) lnil)) (eforall x ([w] (eapp y w)))) (elam x ([w] (eapp z w)))))))))))).

funEtaDep/decl : declared "funEtaDep" lnil
   (eforall (esort (lsucc lzero)) ([x] (eforall (eforall x ([y] (esort (lsucc lzero)))) ([y] (eforall (eforall x ([z] (eapp y z))) ([z] (eapp (eapp (eapp (econst "Eq" (lcons (lsucc lzero) lnil)) (eforall x ([w] (eapp y w)))) (elam x ([w] (eapp z w)))) z)))))))
   (thm (elam (esort (lsucc lzero)) ([x] (elam (eforall x ([y] (esort (lsucc lzero)))) ([y] (elam (eforall x ([z] (eapp y z))) ([z] (eapp (eapp (econst "rfl" (lcons (lsucc lzero) lnil)) (eforall x ([w] (eapp y w)))) (elam x ([w] (eapp z w)))))))))))
   funEtaDep/name
   (dkind-ok/thm funEtaDep/type-wf funEtaDep/value-typed).

