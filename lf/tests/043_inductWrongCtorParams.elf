%%% Expected outcome: reject
%%% An inductive with a constructor with wrong parameters
%% axiom aProp
aProp/type-wf :
   defeq (esort lzero) (esort lzero) (esort (lsucc lzero))
   = (defeq/sort-refl-at lzero).

aProp/decl : declared "aProp" lnil
   (esort lzero)
   ax
   (dkind-ok/ax aProp/type-wf).

%% inductive inductWrongCtorParams
inductWrongCtorParams/type-wf :
   defeq (eforall (esort lzero) ([x] (esort (lsucc lzero)))) (eforall (esort lzero) ([x] (esort (lsucc lzero)))) (esort (limax (lsucc lzero) (lsucc (lsucc lzero))))
   = (defeq/forall (defeq/sort-refl-at lzero) ([x] [y] (defeq/sort-refl-at (lsucc lzero)))).

inductWrongCtorParams/decl : declared "inductWrongCtorParams" lnil
   (eforall (esort lzero) ([x] (esort (lsucc lzero))))
   indt
   (dkind-ok/indt inductWrongCtorParams/type-wf).

%% inductive ctor inductWrongCtorParams.mk
inductWrongCtorParams_mk/type-wf :
   defeq (eforall (esort (lsucc lzero)) ([x] (eapp (econst "inductWrongCtorParams" lnil) (econst "aProp" lnil)))) (eforall (esort (lsucc lzero)) ([x] (eapp (econst "inductWrongCtorParams" lnil) (econst "aProp" lnil)))) (esort (limax (lsucc (lsucc lzero)) (lsucc lzero)))
   = (defeq/forall (defeq/sort-refl-at (lsucc lzero)) ([x] [y] (defeq/app (defeq/const inductWrongCtorParams/decl) (defeq/const aProp/decl)))).

inductWrongCtorParams_mk/decl : declared "inductWrongCtorParams.mk" lnil
   (eforall (esort (lsucc lzero)) ([x] (eapp (econst "inductWrongCtorParams" lnil) (econst "aProp" lnil))))
   ctor
   (dkind-ok/ctor inductWrongCtorParams_mk/type-wf).

%% inductive recursor inductWrongCtorParams.rec
inductWrongCtorParams_rec/type-wf :
   defeq (esort lzero) (esort lzero) (esort (lsucc lzero))
   = (defeq/sort-refl-at lzero).

inductWrongCtorParams_rec/decl : declared "inductWrongCtorParams.rec" lnil
   (esort lzero)
   irec
   (dkind-ok/irec inductWrongCtorParams_rec/type-wf).

%mode declared +N +LS -T -DK -W.
%worlds () (declared _ _ _ _ _).
%unique declared +N +LS -1T -1DK *W.
