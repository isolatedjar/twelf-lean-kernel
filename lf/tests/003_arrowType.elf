%%% Expected outcome: accept
%%% Arrow type (function type)
%% def arrowType
arrowType/type-wf :
   defeq (esort (lsucc lzero)) (esort (lsucc lzero)) (esort (lsucc (lsucc lzero)))
   = defeq/sort-refl.

arrowType/value-typed :
   defeq (eforall (esort lzero) ([x] (esort lzero))) (eforall (esort lzero) ([x] (esort lzero))) (esort (lsucc lzero))
   = (defeq/conv (defeq/sort-eq (lvl-eq/trans lvl-eq/imax-succ (lvl-eq/trans lvl-eq/max-idem lvl-eq/refl))) (defeq/forall defeq/sort-refl ([x] [y] defeq/sort-refl))).

arrowType/decl : declared "arrowType" lnil
   (esort (lsucc lzero))
   (defn (eforall (esort lzero) ([x] (esort lzero))))
   (dkind-ok/defn arrowType/type-wf arrowType/value-typed).

%mode declared +N -LS -T -DK -W.
%worlds () (declared _ _ _ _ _).
%unique declared +N -1LS -1T -1DK *W.
