%%% Expected outcome: reject
%%% Another inductive type with a non-sort type
%% axiom aType
aType/type-wf :
   defeq (esort (lsucc lzero)) (esort (lsucc lzero)) (esort (lsucc (lsucc lzero)))
   = (defeq/sort-refl-at (lsucc lzero)).

aType/decl : declared "aType" lnil
   (esort (lsucc lzero))
   ax
   (dkind-ok/ax aType/type-wf).

%% inductive inductBadNonSort2
inductBadNonSort2/type-wf :
   defeq (econst "aType" lnil) (econst "aType" lnil) (esort (lsucc lzero))
   = (defeq/const aType/decl).

%% Translator can't construct ends-in-sort for "inductBadNonSort2";
%% deferring to Twelf — %solve ABORTs if no proof exists.
%solve inductBadNonSort2/ends-in-sort : ends-in-sort (econst "aType" lnil).

inductBadNonSort2/decl : declared "inductBadNonSort2" lnil
   (econst "aType" lnil)
   indt
   (dkind-ok/indt inductBadNonSort2/type-wf inductBadNonSort2/ends-in-sort).

%mode declared +N +LS -T -DK -W.
%worlds () (declared _ _ _ _ _).
%unique declared +N +LS -1T -1DK *W.
