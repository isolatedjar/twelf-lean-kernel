%%% Mismatched types
%% def badDef
%%% HOLE
badDef/type-wf-sort : lvl.

%%% HOLE
badDef/type-wf : defeq (esort lzero) (esort lzero) (esort badDef/type-wf-sort).

%%% HOLE
badDef/value-typed : defeq (esort (lsucc lzero)) (esort (lsucc lzero)) (esort lzero).

badDef/name : name "badDef" (is-decl (esort lzero) (defn (esort (lsucc lzero)))).

badDef/decl : declared "badDef" (esort lzero) (defn (esort (lsucc lzero)))
   = declared/ok badDef/name (dkind-ok/defn badDef/type-wf badDef/value-typed).
