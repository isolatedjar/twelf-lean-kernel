  (elam (eforall (econst "True" lnil) ([x] (econst "T" lnil))) ([x] (eapp (eapp (econst "Eq.refl" (lcons (lsucc lzero) lnil)) (eforall (econst "True" lnil) ([y] (econst "T" lnil)))) x)))
  (eforall (eforall (econst "True" lnil) ([x] (econst "T" lnil)))
    ([x]
      (eapp (eapp (eapp (econst "Eq" (lcons (lsucc lzero) lnil)) (eforall (econst "True" lnil) ([y] (econst "T" lnil))))
        (eapp (econst "T.mk" lnil) (eapp (econst "T.val" lnil) (eapp x (econst "True.intro" lnil)))))
        x))).

etaCtor/name : name "etaCtor" (is-decl
  (eforall (eforall (econst "True" lnil) ([x] (econst "T" lnil)))
    ([x]
