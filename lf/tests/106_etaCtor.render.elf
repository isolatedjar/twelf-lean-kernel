Eq/clf : count-leading-foralls (eforall (esort (lvar liz)) ([x] (eforall x ([y] (eforall x ([z] (esort lzero))))))) (lis (lis (lis liz)))
   = (count-leading-foralls/succ
       ([x]
         (count-leading-foralls/succ
           ([y]
             (count-leading-foralls/succ
               ([z] (count-leading-foralls/zero not-forall/sort))))))).

Eq/cnd : cnames-distinct (ccons "Eq.refl" cnil)
   = (cnames-distinct/cons cnames-distinct/nil all-string-neq/nil).

Eq/name : name "Eq" (is-decl (eforall (esort (lvar liz)) ([x] (eforall x ([y] (eforall x ([z] (esort lzero))))))) (indt (ccons "Eq.refl" cnil) (lis (lis (lis liz))))).

