NewSingleton_rec/type-wf-sort : lvl.

%%% HOLE
NewSingleton_rec/type-wf : of (eforall (eforall (econst "NewSingleton" lnil) ([x] (esort (lvar liz))))
                             ([x] (eforall (eapp x (econst "NewSingleton.mk" lnil)) ([y] (eforall (econst "NewSingleton" lnil) ([z] (eapp x z))))))) (esort NewSingleton_rec/type-wf-sort).

