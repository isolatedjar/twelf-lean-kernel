%%% Render-only view of: 068_typeSingletonRecReduction
%%% Because `NewSingleton` is a singleton, `NewSingleton.rec true x` reduces to
%%% `true` even though `x` is a variable.
%solve nonneg_0 : 0 >= 0.

sneq/0 : string-neq "Bool.false" "Bool.true".

%% inductive NewSingleton
%%% HOLE
NewSingleton/type-wf-sort : lvl.

%%% HOLE
NewSingleton/type-wf : of (esort (lsucc lzero)) (esort NewSingleton/type-wf-sort).

%%% HOLE
NewSingleton/ends-in-sort : ends-in-sort (esort (lsucc lzero)).

NewSingleton/rec-name : name "NewSingleton.rec" (is-rec-for "NewSingleton").

NewSingleton/eisl : ends-in-sort-with-level (esort (lsucc lzero)) (lsucc lzero)
   = ends-in-sort-with-level/sort.

NewSingleton/clf : count-leading-foralls (esort (lsucc lzero)) liz
   = count-leading-foralls/zero.

NewSingleton/cnd : cnames-distinct (ccons "NewSingleton.mk" cnil)
   = (cnames-distinct/cons cnames-distinct/nil all-string-neq/nil).

NewSingleton/name : name "NewSingleton" (is-decl (esort (lsucc lzero)) (indt (ccons "NewSingleton.mk" cnil) liz)).

NewSingleton/decl : declared "NewSingleton" (esort (lsucc lzero)) (indt (ccons "NewSingleton.mk" cnil) liz)
   = declared/ok-indt NewSingleton/name NewSingleton/rec-name NewSingleton/clf NewSingleton/cnd (dkind-ok/indt NewSingleton/type-wf NewSingleton/ends-in-sort).

%% ctor NewSingleton.mk (of NewSingleton)
%%% HOLE
NewSingleton_mk/type-wf-sort : lvl.

%%% HOLE
NewSingleton_mk/type-wf : of (econst "NewSingleton" lnil) (esort NewSingleton_mk/type-wf-sort).

%%% HOLE
NewSingleton_mk/positivity : ctor-positive "NewSingleton" lnil (econst "NewSingleton" lnil).

NewSingleton_mk/cmem : cmem "NewSingleton.mk" (ccons "NewSingleton.mk" cnil)
   = cmem/here.

%%% HOLE: NewSingleton_mk/fuo
NewSingleton_mk/fuo : field-universes-ok-skip-params liz (econst "NewSingleton" lnil) (lsucc lzero).

NewSingleton_mk/name : name "NewSingleton.mk" (is-decl (econst "NewSingleton" lnil) (ctor "NewSingleton" liz)).

NewSingleton_mk/decl : declared "NewSingleton.mk" (econst "NewSingleton" lnil) (ctor "NewSingleton" liz)
   = declared/ok-ctor NewSingleton_mk/name NewSingleton/name NewSingleton_mk/cmem NewSingleton/eisl NewSingleton_mk/fuo (dkind-ok/ctor NewSingleton_mk/type-wf NewSingleton_mk/positivity).

%% recursor NewSingleton.rec
%%% HOLE
NewSingleton_rec/type-wf-sort : lvl.

%%% HOLE
NewSingleton_rec/type-wf : of
  (eforall (eforall (econst "NewSingleton" lnil) ([x] (esort (lvar liz)))) ([x] (eforall (eapp x (econst "NewSingleton.mk" lnil)) ([y] (eforall (econst "NewSingleton" lnil) ([z] (eapp x z)))))))
  (esort NewSingleton_rec/type-wf-sort).

NewSingleton_rec/ert : enum-rec-type (eforall (eforall (econst "NewSingleton" lnil) ([x] (esort (lvar liz)))) ([x] (eforall (eapp x (econst "NewSingleton.mk" lnil)) ([y] (eforall (econst "NewSingleton" lnil) ([z] (eapp x z))))))) "NewSingleton" lnil (ccons "NewSingleton.mk" cnil) (lvar liz)
   = (enum-rec-type/intro
       ([x] ([h] (enum-rec-body/minor ([y] ([h1] enum-rec-body/done)))))).

NewSingleton_rec/lee : le-eligible (lsucc lzero) (ccons "NewSingleton.mk" cnil) (lvar liz)
   = le-eligible/csingle.

NewSingleton_rec/decl : declared "NewSingleton.rec"
  (eforall (eforall (econst "NewSingleton" lnil) ([x] (esort (lvar liz)))) ([x] (eforall (eapp x (econst "NewSingleton.mk" lnil)) ([y] (eforall (econst "NewSingleton" lnil) ([z] (eapp x z)))))))
  (irec "NewSingleton")
   = declared/ok-irec NewSingleton/rec-name (dkind-ok/irec NewSingleton_rec/type-wf NewSingleton/name NewSingleton/eisl NewSingleton_rec/ert NewSingleton_rec/lee).

%% inductive Eq
%%% HOLE
Eq/type-wf-sort : lvl.

%%% HOLE
Eq/type-wf : of (eforall (esort (lvar liz)) ([x] (eforall x ([y] (eforall x ([z] (esort lzero))))))) (esort Eq/type-wf-sort).

%%% HOLE
Eq/ends-in-sort : ends-in-sort (eforall (esort (lvar liz)) ([x] (eforall x ([y] (eforall x ([z] (esort lzero))))))).

Eq/rec-name : name "Eq.rec" (is-rec-for "Eq").

Eq/eisl : ends-in-sort-with-level (eforall (esort (lvar liz)) ([x] (eforall x ([y] (eforall x ([z] (esort lzero))))))) lzero
   = (ends-in-sort-with-level/forall
       ([x]
         (ends-in-sort-with-level/forall
           ([y]
             (ends-in-sort-with-level/forall
               ([z] ends-in-sort-with-level/sort)))))).

Eq/clf : count-leading-foralls (eforall (esort (lvar liz)) ([x] (eforall x ([y] (eforall x ([z] (esort lzero))))))) (lis (lis liz))
   = (count-leading-foralls/succ
       ([x] (count-leading-foralls/succ ([y] count-leading-foralls/zero)))).

Eq/cnd : cnames-distinct (ccons "Eq.refl" cnil)
   = (cnames-distinct/cons cnames-distinct/nil all-string-neq/nil).

Eq/name : name "Eq" (is-decl (eforall (esort (lvar liz)) ([x] (eforall x ([y] (eforall x ([z] (esort lzero))))))) (indt (ccons "Eq.refl" cnil) (lis (lis liz)))).

Eq/decl : declared "Eq" (eforall (esort (lvar liz)) ([x] (eforall x ([y] (eforall x ([z] (esort lzero))))))) (indt (ccons "Eq.refl" cnil) (lis (lis liz)))
   = declared/ok-indt Eq/name Eq/rec-name Eq/clf Eq/cnd (dkind-ok/indt Eq/type-wf Eq/ends-in-sort).

%% ctor Eq.refl (of Eq)
%%% HOLE
Eq_refl/type-wf-sort : lvl.

%%% HOLE
Eq_refl/type-wf : of (eforall (esort (lvar liz)) ([x] (eforall x ([y] (eapp (eapp (eapp (econst "Eq" (lcons (lvar liz) lnil)) x) y) y))))) (esort Eq_refl/type-wf-sort).

%%% HOLE
Eq_refl/positivity : ctor-positive "Eq" (lcons (lvar liz) lnil) (eforall (esort (lvar liz)) ([x] (eforall x ([y] (eapp (eapp (eapp (econst "Eq" (lcons (lvar liz) lnil)) x) y) y))))).

Eq_refl/cmem : cmem "Eq.refl" (ccons "Eq.refl" cnil)
   = cmem/here.

%%% HOLE: Eq_refl/fuo
Eq_refl/fuo : field-universes-ok-skip-params (lis (lis liz)) (eforall (esort (lvar liz)) ([x] (eforall x ([y] (eapp (eapp (eapp (econst "Eq" (lcons (lvar liz) lnil)) x) y) y))))) lzero.

Eq_refl/name : name "Eq.refl" (is-decl (eforall (esort (lvar liz)) ([x] (eforall x ([y] (eapp (eapp (eapp (econst "Eq" (lcons (lvar liz) lnil)) x) y) y))))) (ctor "Eq" liz)).

Eq_refl/decl : declared "Eq.refl" (eforall (esort (lvar liz)) ([x] (eforall x ([y] (eapp (eapp (eapp (econst "Eq" (lcons (lvar liz) lnil)) x) y) y))))) (ctor "Eq" liz)
   = declared/ok-ctor Eq_refl/name Eq/name Eq_refl/cmem Eq/eisl Eq_refl/fuo (dkind-ok/ctor Eq_refl/type-wf Eq_refl/positivity).

%% recursor Eq.rec
%%% HOLE
Eq_rec/type-wf-sort : lvl.

%%% HOLE
Eq_rec/type-wf : of
  (eforall (esort (lvar (lis liz)))
    ([x]
      (eforall x
        ([y]
          (eforall (eforall x ([z] (eforall (eapp (eapp (eapp (econst "Eq" (lcons (lvar (lis liz)) lnil)) x) y) z) ([w] (esort (lvar liz))))))
            ([z]
              (eforall (eapp (eapp z y) (eapp (eapp (econst "Eq.refl" (lcons (lvar (lis liz)) lnil)) x) y))
                ([w] (eforall x ([x1] (eforall (eapp (eapp (eapp (econst "Eq" (lcons (lvar (lis liz)) lnil)) x) y) x1) ([y1] (eapp (eapp z x1) y1)))))))))))))
  (esort Eq_rec/type-wf-sort).

%%% HOLE: recursor Eq.rec — non-enum shape (parametric/indexed inductive, or ctor with fields) — §3.1 canonical-schema only handles plain enums in phase 1
Eq_rec/decl : declared "Eq.rec"
  (eforall (esort (lvar (lis liz)))
    ([x]
      (eforall x
        ([y]
          (eforall (eforall x ([z] (eforall (eapp (eapp (eapp (econst "Eq" (lcons (lvar (lis liz)) lnil)) x) y) z) ([w] (esort (lvar liz))))))
            ([z]
              (eforall (eapp (eapp z y) (eapp (eapp (econst "Eq.refl" (lcons (lvar (lis liz)) lnil)) x) y))
                ([w] (eforall x ([x1] (eforall (eapp (eapp (eapp (econst "Eq" (lcons (lvar (lis liz)) lnil)) x) y) x1) ([y1] (eapp (eapp z x1) y1)))))))))))))
  (irec "Eq").

