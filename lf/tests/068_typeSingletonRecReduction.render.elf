%%   level params: u
%%   type:   (eforall (eforall (econst "NewSingleton" lnil) ([x] (esort (lvar liz)))) ([x] (eforall (eapp x (econst "NewSingleton.mk" lnil)) ([y] (eforall (econst "NewSingleton" lnil) ([z] (eapp x z)))))))
