  (eforall (econst "NewSingleton" lnil)
    ([x]
      (eapp (eapp (eapp (econst "Eq" (lcons (lsucc lzero) lnil)) (econst "Bool" lnil))
        (eapp (eapp (eapp (econst "NewSingleton.rec" (lcons (lsucc lzero) lnil)) (elam (econst "NewSingleton" lnil) ([y] (econst "Bool" lnil)))) (econst "Bool.true" lnil)) x))
        (econst "Bool.true" lnil)))).

