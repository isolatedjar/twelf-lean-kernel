%%% Expected outcome: reject
%%% Corner case for function eta:
%%% Does a defeq between a partially applied recursor with rule k and a free
%%% variable trigger eta expansion?
%%% 
%%% Taking the official kernel as the specification, the answer is no.
%%% See <https://github.com/leanprover/lean4/issues/12520> for a discussion.
%% inductive Eq
%%% HOLE
Eq/type-wf-sort : {u_1 : lvl} lvl.

%%% HOLE
Eq/type-wf : {u_1 : lvl} defeq (eforall (esort u_1) ([x] (eforall x ([y] (eforall x ([z] (esort lzero))))))) (eforall (esort u_1) ([x] (eforall x ([y] (eforall x ([z] (esort lzero))))))) (esort (Eq/type-wf-sort u_1)).

%%% HOLE
Eq/ends-in-sort : {u_1 : lvl} ends-in-sort (eforall (esort u_1) ([x] (eforall x ([y] (eforall x ([z] (esort lzero))))))).

Eq/decl : {u_1 : lvl} declared "Eq" (lcons u_1 lnil)
   (eforall (esort u_1) ([x] (eforall x ([y] (eforall x ([z] (esort lzero)))))))
   indt
   (dkind-ok/indt (Eq/type-wf u_1) (Eq/ends-in-sort u_1)).

%% ctor Eq.refl (of Eq)
%%% HOLE
Eq_refl/type-wf-sort : {u_1 : lvl} lvl.

%%% HOLE
Eq_refl/type-wf : {u_1 : lvl} defeq (eforall (esort u_1) ([x] (eforall x ([y] (eapp (eapp (eapp (econst "Eq" (lcons u_1 lnil)) x) y) y))))) (eforall (esort u_1) ([x] (eforall x ([y] (eapp (eapp (eapp (econst "Eq" (lcons u_1 lnil)) x) y) y))))) (esort (Eq_refl/type-wf-sort u_1)).

%%% HOLE
Eq_refl/positivity : {u_1 : lvl} ctor-positive "Eq" (lcons u_1 lnil) (eforall (esort u_1) ([x] (eforall x ([y] (eapp (eapp (eapp (econst "Eq" (lcons u_1 lnil)) x) y) y))))).

Eq_refl/decl : {u_1 : lvl} declared "Eq.refl" (lcons u_1 lnil)
   (eforall (esort u_1) ([x] (eforall x ([y] (eapp (eapp (eapp (econst "Eq" (lcons u_1 lnil)) x) y) y)))))
   ctor
   (dkind-ok/ctor (Eq_refl/type-wf u_1) (Eq_refl/positivity u_1)).

%% recursor Eq.rec
%%% HOLE
Eq_rec/type-wf-sort : {u : lvl} {u_1 : lvl} lvl.

%%% HOLE
Eq_rec/type-wf : {u : lvl} {u_1 : lvl} defeq (eforall (esort u_1) ([x] (eforall x ([y] (eforall (eforall x ([z] (eforall (eapp (eapp (eapp (econst "Eq" (lcons u_1 lnil)) x) y) z) ([w] (esort u))))) ([z] (eforall (eapp (eapp z y) (eapp (eapp (econst "Eq.refl" (lcons u_1 lnil)) x) y)) ([w] (eforall x ([x1] (eforall (eapp (eapp (eapp (econst "Eq" (lcons u_1 lnil)) x) y) x1) ([y1] (eapp (eapp z x1) y1))))))))))))) (eforall (esort u_1) ([x] (eforall x ([y] (eforall (eforall x ([z] (eforall (eapp (eapp (eapp (econst "Eq" (lcons u_1 lnil)) x) y) z) ([w] (esort u))))) ([z] (eforall (eapp (eapp z y) (eapp (eapp (econst "Eq.refl" (lcons u_1 lnil)) x) y)) ([w] (eforall x ([x1] (eforall (eapp (eapp (eapp (econst "Eq" (lcons u_1 lnil)) x) y) x1) ([y1] (eapp (eapp z x1) y1))))))))))))) (esort (Eq_rec/type-wf-sort u u_1)).

Eq_rec/decl : {u : lvl} {u_1 : lvl} declared "Eq.rec" (lcons u (lcons u_1 lnil))
   (eforall (esort u_1) ([x] (eforall x ([y] (eforall (eforall x ([z] (eforall (eapp (eapp (eapp (econst "Eq" (lcons u_1 lnil)) x) y) z) ([w] (esort u))))) ([z] (eforall (eapp (eapp z y) (eapp (eapp (econst "Eq.refl" (lcons u_1 lnil)) x) y)) ([w] (eforall x ([x1] (eforall (eapp (eapp (eapp (econst "Eq" (lcons u_1 lnil)) x) y) x1) ([y1] (eapp (eapp z x1) y1)))))))))))))
   irec
   (dkind-ok/irec (Eq_rec/type-wf u u_1)).

%% inductive Bool
%%% HOLE
Bool/type-wf-sort : lvl.

%%% HOLE
Bool/type-wf : defeq (esort (lsucc lzero)) (esort (lsucc lzero)) (esort Bool/type-wf-sort).

%%% HOLE
Bool/ends-in-sort : ends-in-sort (esort (lsucc lzero)).

Bool/decl : declared "Bool" lnil
   (esort (lsucc lzero))
   indt
   (dkind-ok/indt Bool/type-wf Bool/ends-in-sort).

%% ctor Bool.false (of Bool)
%%% HOLE
Bool_false/type-wf-sort : lvl.

%%% HOLE
Bool_false/type-wf : defeq (econst "Bool" lnil) (econst "Bool" lnil) (esort Bool_false/type-wf-sort).

%%% HOLE
Bool_false/positivity : ctor-positive "Bool" lnil (econst "Bool" lnil).

Bool_false/decl : declared "Bool.false" lnil
   (econst "Bool" lnil)
   ctor
   (dkind-ok/ctor Bool_false/type-wf Bool_false/positivity).

%% ctor Bool.true (of Bool)
%%% HOLE
Bool_true/type-wf-sort : lvl.

%%% HOLE
Bool_true/type-wf : defeq (econst "Bool" lnil) (econst "Bool" lnil) (esort Bool_true/type-wf-sort).

%%% HOLE
Bool_true/positivity : ctor-positive "Bool" lnil (econst "Bool" lnil).

Bool_true/decl : declared "Bool.true" lnil
   (econst "Bool" lnil)
   ctor
   (dkind-ok/ctor Bool_true/type-wf Bool_true/positivity).

%% recursor Bool.rec
%%% HOLE
Bool_rec/type-wf-sort : {u : lvl} lvl.

%%% HOLE
Bool_rec/type-wf : {u : lvl} defeq (eforall (eforall (econst "Bool" lnil) ([x] (esort u))) ([x] (eforall (eapp x (econst "Bool.false" lnil)) ([y] (eforall (eapp x (econst "Bool.true" lnil)) ([z] (eforall (econst "Bool" lnil) ([w] (eapp x w))))))))) (eforall (eforall (econst "Bool" lnil) ([x] (esort u))) ([x] (eforall (eapp x (econst "Bool.false" lnil)) ([y] (eforall (eapp x (econst "Bool.true" lnil)) ([z] (eforall (econst "Bool" lnil) ([w] (eapp x w))))))))) (esort (Bool_rec/type-wf-sort u)).

Bool_rec/decl : {u : lvl} declared "Bool.rec" (lcons u lnil)
   (eforall (eforall (econst "Bool" lnil) ([x] (esort u))) ([x] (eforall (eapp x (econst "Bool.false" lnil)) ([y] (eforall (eapp x (econst "Bool.true" lnil)) ([z] (eforall (econst "Bool" lnil) ([w] (eapp x w)))))))))
   irec
   (dkind-ok/irec (Bool_rec/type-wf u)).

%% def etaRuleK
%%% HOLE
etaRuleK/type-wf-sort : lvl.

%%% HOLE
etaRuleK/type-wf : defeq (eforall (eforall (eapp (eapp (eapp (econst "Eq" (lcons (lsucc lzero) lnil)) (econst "Bool" lnil)) (econst "Bool.true" lnil)) (econst "Bool.true" lnil)) ([x] (econst "Bool" lnil))) ([x] (eapp (eapp (eapp (econst "Eq" (lcons (lsucc lzero) lnil)) (eforall (eapp (eapp (eapp (econst "Eq" (lcons (lsucc lzero) lnil)) (econst "Bool" lnil)) (econst "Bool.true" lnil)) (econst "Bool.true" lnil)) ([y] (econst "Bool" lnil)))) (eapp (eapp (eapp (eapp (eapp (econst "Eq.rec" (lcons (lsucc lzero) (lcons (lsucc lzero) lnil))) (econst "Bool" lnil)) (econst "Bool.true" lnil)) (elam (econst "Bool" lnil) ([y] (elam (eapp (eapp (eapp (econst "Eq" (lcons (lsucc lzero) lnil)) (econst "Bool" lnil)) (econst "Bool.true" lnil)) y) ([z] (econst "Bool" lnil)))))) (eapp x (eapp (eapp (econst "Eq.refl" (lcons (lsucc lzero) lnil)) (econst "Bool" lnil)) (econst "Bool.true" lnil)))) (econst "Bool.true" lnil))) x))) (eforall (eforall (eapp (eapp (eapp (econst "Eq" (lcons (lsucc lzero) lnil)) (econst "Bool" lnil)) (econst "Bool.true" lnil)) (econst "Bool.true" lnil)) ([x] (econst "Bool" lnil))) ([x] (eapp (eapp (eapp (econst "Eq" (lcons (lsucc lzero) lnil)) (eforall (eapp (eapp (eapp (econst "Eq" (lcons (lsucc lzero) lnil)) (econst "Bool" lnil)) (econst "Bool.true" lnil)) (econst "Bool.true" lnil)) ([y] (econst "Bool" lnil)))) (eapp (eapp (eapp (eapp (eapp (econst "Eq.rec" (lcons (lsucc lzero) (lcons (lsucc lzero) lnil))) (econst "Bool" lnil)) (econst "Bool.true" lnil)) (elam (econst "Bool" lnil) ([y] (elam (eapp (eapp (eapp (econst "Eq" (lcons (lsucc lzero) lnil)) (econst "Bool" lnil)) (econst "Bool.true" lnil)) y) ([z] (econst "Bool" lnil)))))) (eapp x (eapp (eapp (econst "Eq.refl" (lcons (lsucc lzero) lnil)) (econst "Bool" lnil)) (econst "Bool.true" lnil)))) (econst "Bool.true" lnil))) x))) (esort etaRuleK/type-wf-sort).

