%%% Render-only view of: 048_reduceCtorParam.mk
%%% When checking inductives, we expect the kernel to reduce the types of constructor arguments.
%% def id
id/render-type : {u : lvl} expr =
   [u] (eforall (esort u) ([x] (eforall x ([y] x)))).
id/render-value : {u : lvl} expr =
   [u] (elam (esort u) ([x] (elam x ([y] y)))).

%% def constType
constType/render-type : expr =
   (eforall (esort (lsucc lzero)) ([x] (eforall (esort (lsucc lzero)) ([y] (esort (lsucc lzero)))))).
constType/render-value : expr =
   (elam (esort (lsucc lzero)) ([x] (elam (esort (lsucc lzero)) ([y] x)))).

%% inductive reduceCtorParam (numParams=1, numIndices=0)
reduceCtorParam/render-type : expr =
   (eforall (esort (lsucc lzero)) ([x] (esort (lsucc lzero)))).

%% ctor reduceCtorParam.mk (induct=reduceCtorParam, numFields=1)
reduceCtorParam_mk/render-type : expr =
   (eforall (eapp (eapp (econst "id" (lcons (lsucc (lsucc (lsucc lzero))) lnil)) (esort (lsucc (lsucc lzero)))) (esort (lsucc lzero))) ([x] (eforall (eapp (eapp (econst "constType" lnil) (eapp (econst "reduceCtorParam" lnil) x)) (eapp (econst "reduceCtorParam" lnil) x)) ([y] (eapp (econst "reduceCtorParam" lnil) x))))).

%% recursor reduceCtorParam.rec (numMotives=1, numMinors=1, k=false)
reduceCtorParam_rec/render-type : {u : lvl} expr =
   [u] (eforall (esort (lsucc lzero)) ([x] (eforall (eforall (eapp (econst "reduceCtorParam" lnil) x) ([y] (esort u))) ([y] (eforall (eforall (eapp (eapp (econst "constType" lnil) (eapp (econst "reduceCtorParam" lnil) x)) (eapp (econst "reduceCtorParam" lnil) x)) ([z] (eforall (eapp y z) ([w] (eapp y (eapp (eapp (econst "reduceCtorParam.mk" lnil) x) z)))))) ([z] (eforall (eapp (econst "reduceCtorParam" lnil) x) ([w] (eapp y w))))))))).
%%   rec-rule for reduceCtorParam.mk (nfields=1)
reduceCtorParam_rec/render-rule0-rhs : {u : lvl} expr =
   [u] (elam (esort (lsucc lzero)) ([x] (elam (eforall (eapp (econst "reduceCtorParam" lnil) x) ([y] (esort u))) ([y] (elam (eforall (eapp (eapp (econst "constType" lnil) (eapp (econst "reduceCtorParam" lnil) x)) (eapp (econst "reduceCtorParam" lnil) x)) ([z] (eforall (eapp y z) ([w] (eapp y (eapp (eapp (econst "reduceCtorParam.mk" lnil) x) z)))))) ([z] (elam (eapp (eapp (econst "constType" lnil) (eapp (econst "reduceCtorParam" lnil) x)) (eapp (econst "reduceCtorParam" lnil) x)) ([w] (eapp (eapp z w) (eapp (eapp (eapp (eapp (econst "reduceCtorParam.rec" (lcons u lnil)) x) y) z) w)))))))))).

