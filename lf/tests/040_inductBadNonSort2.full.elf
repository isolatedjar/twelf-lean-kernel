%%% Expected outcome: reject
%%% Another inductive type with a non-sort type
%% axiom aType
aType/type-wf : of (esort (lsucc lzero)) (esort (lsucc (lsucc lzero)))
   = defeq/sort-refl.

aType/name : name "aType" (is-decl (esort (lsucc lzero)) ax).

aType/decl : declared "aType" (esort (lsucc lzero)) ax
   = declared/ok aType/name dkind-non-inductive/ax (dkind-ok/ax aType/type-wf).

%% inductive inductBadNonSort2
inductBadNonSort2/type-wf : of (econst "aType" lnil) (esort (lsucc lzero))
   = (defeq/const aType/decl (inst-expr/sort (inst-lvl/succ inst-lvl/zero))).

%%% HOLE
inductBadNonSort2/ends-in-sort : ends-in-sort (econst "aType" lnil).

inductBadNonSort2/rec-name : name "inductBadNonSort2.rec" (is-rec-for "inductBadNonSort2").

inductBadNonSort2/cnd : cnames-distinct cnil
   = cnames-distinct/nil.

inductBadNonSort2/name : name "inductBadNonSort2" (is-decl (econst "aType" lnil) (indt cnil z)).

inductBadNonSort2/decl : declared "inductBadNonSort2" (econst "aType" lnil) (indt cnil z)
   = declared/ok-indt inductBadNonSort2/name inductBadNonSort2/rec-name inductBadNonSort2/cnd (dkind-ok/indt inductBadNonSort2/type-wf inductBadNonSort2/ends-in-sort).
