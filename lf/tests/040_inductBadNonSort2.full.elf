%%% Expected outcome: reject
%%% Another inductive type with a non-sort type
%% axiom aType
%%% HOLE
aType/type-wf-sort : lvl.

%%% HOLE
aType/type-wf : defeq (esort (lsucc lzero)) (esort (lsucc lzero)) (esort aType/type-wf-sort).

aType/name : name "aType" (is-decl lnil (esort (lsucc lzero)) ax).

aType/decl : declared "aType" lnil
   (esort (lsucc lzero))
   ax
   aType/name
   (dkind-ok/ax aType/type-wf).

%% inductive inductBadNonSort2
%%% HOLE
inductBadNonSort2/type-wf-sort : lvl.

%%% HOLE
inductBadNonSort2/type-wf : defeq (econst "aType" lnil) (econst "aType" lnil) (esort inductBadNonSort2/type-wf-sort).

%%% HOLE
inductBadNonSort2/ends-in-sort : ends-in-sort (econst "aType" lnil).

inductBadNonSort2/name : name "inductBadNonSort2" (is-decl lnil (econst "aType" lnil) indt).

inductBadNonSort2/decl : declared "inductBadNonSort2" lnil
   (econst "aType" lnil)
   indt
   inductBadNonSort2/name
   (dkind-ok/indt inductBadNonSort2/type-wf inductBadNonSort2/ends-in-sort).

