%%% Expected outcome: reject
%%% Another inductive type with a non-sort type
%% axiom aType
aType/type-wf-sort : lvl
   = (lsucc (lsucc lzero)).

aType/type-wf : defeq (esort (lsucc lzero)) (esort (lsucc lzero)) (esort aType/type-wf-sort)
   = defeq/sort-refl.

aType/name : name "aType" (is-decl (esort (lsucc lzero)) ax).

aType/decl : declared "aType" (esort (lsucc lzero)) ax
   = declared/ok aType/name (dkind-ok/ax aType/type-wf).

%% inductive inductBadNonSort2
inductBadNonSort2/type-wf-sort : lvl
   = (lsucc lzero).

inductBadNonSort2/type-wf : defeq (econst "aType" lnil) (econst "aType" lnil) (esort inductBadNonSort2/type-wf-sort)
   = (defeq/const aType/decl (inst-expr/sort (lvl-inst/succ lvl-inst/zero))).

%%% HOLE
inductBadNonSort2/ends-in-sort : ends-in-sort (econst "aType" lnil).

inductBadNonSort2/name : name "inductBadNonSort2" (is-decl (econst "aType" lnil) indt).

inductBadNonSort2/decl : declared "inductBadNonSort2" (econst "aType" lnil) indt
   = declared/ok inductBadNonSort2/name (dkind-ok/indt inductBadNonSort2/type-wf inductBadNonSort2/ends-in-sort).

