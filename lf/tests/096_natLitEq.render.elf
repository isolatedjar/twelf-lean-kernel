%%% Render-only view of: 096_natLitEq
%%% Reducing Nat literals
%solve nonneg_3 : 3 >= 0.

sneq/0 : string-neq "Nat.zero" "Nat.succ".

%% inductive Eq
%%% HOLE
Eq/type-wf-sort : lvl.

%%% HOLE
Eq/type-wf : of (eforall (esort (lvar liz)) ([x] (eforall x ([y] (eforall x ([z] (esort lzero))))))) (esort Eq/type-wf-sort).

%%% HOLE
Eq/ends-in-sort : ends-in-sort (eforall (esort (lvar liz)) ([x] (eforall x ([y] (eforall x ([z] (esort lzero))))))).

Eq/rec-name : name "Eq.rec" (is-rec-for "Eq").

Eq/clf : count-leading-foralls (eforall (esort (lvar liz)) ([x] (eforall x ([y] (eforall x ([z] (esort lzero))))))) (lis (lis liz))
   = (count-leading-foralls/succ
       ([x] (count-leading-foralls/succ ([y] count-leading-foralls/zero)))).

Eq/cnd : cnames-distinct (ccons "Eq.refl" cnil)
   = (cnames-distinct/cons cnames-distinct/nil all-string-neq/nil).

Eq/name : name "Eq" (is-decl (eforall (esort (lvar liz)) ([x] (eforall x ([y] (eforall x ([z] (esort lzero))))))) (indt (ccons "Eq.refl" cnil) (lis (lis liz)))).

Eq/decl : declared "Eq" (eforall (esort (lvar liz)) ([x] (eforall x ([y] (eforall x ([z] (esort lzero))))))) (indt (ccons "Eq.refl" cnil) (lis (lis liz)))
   = declared/ok-indt Eq/name Eq/rec-name Eq/clf Eq/cnd (dkind-ok/indt Eq/type-wf Eq/ends-in-sort).

%% ctor Eq.refl (of Eq)
%%% HOLE
Eq_refl/type-wf-sort : lvl.

%%% HOLE
Eq_refl/type-wf : of (eforall (esort (lvar liz)) ([x] (eforall x ([y] (eapp (eapp (eapp (econst "Eq" (lcons (lvar liz) lnil)) x) y) y))))) (esort Eq_refl/type-wf-sort).

%%% HOLE
Eq_refl/positivity : ctor-positive "Eq" (lcons (lvar liz) lnil) (eforall (esort (lvar liz)) ([x] (eforall x ([y] (eapp (eapp (eapp (econst "Eq" (lcons (lvar liz) lnil)) x) y) y))))).

Eq_refl/eisl : ends-in-sort-with-level (eforall (esort (lvar liz)) ([x] (eforall x ([y] (eforall x ([z] (esort lzero))))))) lzero
   = (ends-in-sort-with-level/forall
       ([x]
         (ends-in-sort-with-level/forall
           ([y]
             (ends-in-sort-with-level/forall
               ([z] ends-in-sort-with-level/sort)))))).

Eq_refl/cmem : cmem "Eq.refl" (ccons "Eq.refl" cnil)
   = cmem/here.

%%% HOLE: Eq_refl/fuo
Eq_refl/fuo : field-universes-ok-skip-params (lis (lis liz)) (eforall (esort (lvar liz)) ([x] (eforall x ([y] (eapp (eapp (eapp (econst "Eq" (lcons (lvar liz) lnil)) x) y) y))))) lzero.

Eq_refl/name : name "Eq.refl" (is-decl (eforall (esort (lvar liz)) ([x] (eforall x ([y] (eapp (eapp (eapp (econst "Eq" (lcons (lvar liz) lnil)) x) y) y))))) (ctor "Eq" liz)).

Eq_refl/decl : declared "Eq.refl" (eforall (esort (lvar liz)) ([x] (eforall x ([y] (eapp (eapp (eapp (econst "Eq" (lcons (lvar liz) lnil)) x) y) y))))) (ctor "Eq" liz)
   = declared/ok-ctor Eq_refl/name Eq/name Eq_refl/cmem Eq_refl/eisl Eq_refl/fuo (dkind-ok/ctor Eq_refl/type-wf Eq_refl/positivity).

%% recursor Eq.rec
%%% HOLE
Eq_rec/type-wf-sort : lvl.

%%% HOLE
Eq_rec/type-wf : of
  (eforall (esort (lvar (lis liz)))
    ([x]
      (eforall x
        ([y]
          (eforall (eforall x ([z] (eforall (eapp (eapp (eapp (econst "Eq" (lcons (lvar (lis liz)) lnil)) x) y) z) ([w] (esort (lvar liz))))))
            ([z]
              (eforall (eapp (eapp z y) (eapp (eapp (econst "Eq.refl" (lcons (lvar (lis liz)) lnil)) x) y))
                ([w] (eforall x ([x1] (eforall (eapp (eapp (eapp (econst "Eq" (lcons (lvar (lis liz)) lnil)) x) y) x1) ([y1] (eapp (eapp z x1) y1)))))))))))))
  (esort Eq_rec/type-wf-sort).

Eq_rec/decl : declared "Eq.rec"
  (eforall (esort (lvar (lis liz)))
    ([x]
      (eforall x
        ([y]
          (eforall (eforall x ([z] (eforall (eapp (eapp (eapp (econst "Eq" (lcons (lvar (lis liz)) lnil)) x) y) z) ([w] (esort (lvar liz))))))
            ([z]
              (eforall (eapp (eapp z y) (eapp (eapp (econst "Eq.refl" (lcons (lvar (lis liz)) lnil)) x) y))
                ([w] (eforall x ([x1] (eforall (eapp (eapp (eapp (econst "Eq" (lcons (lvar (lis liz)) lnil)) x) y) x1) ([y1] (eapp (eapp z x1) y1)))))))))))))
  (irec "Eq")
   = declared/ok-irec Eq/rec-name (dkind-ok/irec Eq_rec/type-wf).

%% inductive Nat
%%% HOLE
Nat/type-wf-sort : lvl.

%%% HOLE
Nat/type-wf : of (esort (lsucc lzero)) (esort Nat/type-wf-sort).

%%% HOLE
Nat/ends-in-sort : ends-in-sort (esort (lsucc lzero)).

Nat/rec-name : name "Nat.rec" (is-rec-for "Nat").

Nat/clf : count-leading-foralls (esort (lsucc lzero)) liz
   = count-leading-foralls/zero.

Nat/cnd : cnames-distinct (ccons "Nat.zero" (ccons "Nat.succ" cnil))
   = (cnames-distinct/cons
       (cnames-distinct/cons cnames-distinct/nil all-string-neq/nil)
       (all-string-neq/cons sneq/0 all-string-neq/nil)).

Nat/name : name "Nat" (is-decl (esort (lsucc lzero)) (indt (ccons "Nat.zero" (ccons "Nat.succ" cnil)) liz)).

Nat/decl : declared "Nat" (esort (lsucc lzero)) (indt (ccons "Nat.zero" (ccons "Nat.succ" cnil)) liz)
   = declared/ok-indt Nat/name Nat/rec-name Nat/clf Nat/cnd (dkind-ok/indt Nat/type-wf Nat/ends-in-sort).

%% ctor Nat.zero (of Nat)
%%% HOLE
Nat_zero/type-wf-sort : lvl.

%%% HOLE
Nat_zero/type-wf : of (econst "Nat" lnil) (esort Nat_zero/type-wf-sort).

%%% HOLE
Nat_zero/positivity : ctor-positive "Nat" lnil (econst "Nat" lnil).

Nat_zero/eisl : ends-in-sort-with-level (esort (lsucc lzero)) (lsucc lzero)
   = ends-in-sort-with-level/sort.

Nat_zero/cmem : cmem "Nat.zero" (ccons "Nat.zero" (ccons "Nat.succ" cnil))
   = cmem/here.

%%% HOLE: Nat_zero/fuo
Nat_zero/fuo : field-universes-ok-skip-params liz (econst "Nat" lnil) (lsucc lzero).

Nat_zero/name : name "Nat.zero" (is-decl (econst "Nat" lnil) (ctor "Nat" liz)).

Nat_zero/decl : declared "Nat.zero" (econst "Nat" lnil) (ctor "Nat" liz)
   = declared/ok-ctor Nat_zero/name Nat/name Nat_zero/cmem Nat_zero/eisl Nat_zero/fuo (dkind-ok/ctor Nat_zero/type-wf Nat_zero/positivity).

%% ctor Nat.succ (of Nat)
%%% HOLE
Nat_succ/type-wf-sort : lvl.

%%% HOLE
Nat_succ/type-wf : of (eforall (econst "Nat" lnil) ([x] (econst "Nat" lnil))) (esort Nat_succ/type-wf-sort).

%%% HOLE
Nat_succ/positivity : ctor-positive "Nat" lnil (eforall (econst "Nat" lnil) ([x] (econst "Nat" lnil))).

Nat_succ/eisl : ends-in-sort-with-level (esort (lsucc lzero)) (lsucc lzero)
   = ends-in-sort-with-level/sort.

Nat_succ/cmem : cmem "Nat.succ" (ccons "Nat.zero" (ccons "Nat.succ" cnil))
   = (cmem/there cmem/here).

%%% HOLE: Nat_succ/fuo
Nat_succ/fuo : field-universes-ok-skip-params liz (eforall (econst "Nat" lnil) ([x] (econst "Nat" lnil))) (lsucc lzero).

Nat_succ/name : name "Nat.succ" (is-decl (eforall (econst "Nat" lnil) ([x] (econst "Nat" lnil))) (ctor "Nat" (lis liz))).

Nat_succ/decl : declared "Nat.succ" (eforall (econst "Nat" lnil) ([x] (econst "Nat" lnil))) (ctor "Nat" (lis liz))
   = declared/ok-ctor Nat_succ/name Nat/name Nat_succ/cmem Nat_succ/eisl Nat_succ/fuo (dkind-ok/ctor Nat_succ/type-wf Nat_succ/positivity).

%% recursor Nat.rec
%%% HOLE
Nat_rec/type-wf-sort : lvl.

%%% HOLE
Nat_rec/type-wf : of
  (eforall (eforall (econst "Nat" lnil) ([x] (esort (lvar liz))))
    ([x]
      (eforall (eapp x (econst "Nat.zero" lnil))
        ([y] (eforall (eforall (econst "Nat" lnil) ([z] (eforall (eapp x z) ([w] (eapp x (eapp (econst "Nat.succ" lnil) z)))))) ([z] (eforall (econst "Nat" lnil) ([w] (eapp x w)))))))))
  (esort Nat_rec/type-wf-sort).

Nat_rec/decl : declared "Nat.rec"
  (eforall (eforall (econst "Nat" lnil) ([x] (esort (lvar liz))))
    ([x]
      (eforall (eapp x (econst "Nat.zero" lnil))
        ([y] (eforall (eforall (econst "Nat" lnil) ([z] (eforall (eapp x z) ([w] (eapp x (eapp (econst "Nat.succ" lnil) z)))))) ([z] (eforall (econst "Nat" lnil) ([w] (eapp x w)))))))))
  (irec "Nat")
   = declared/ok-irec Nat/rec-name (dkind-ok/irec Nat_rec/type-wf).

%% thm natLitEq
%%% HOLE
natLitEq/type-wf : of
  (eapp (eapp (eapp (econst "Eq" (lcons (lsucc lzero) lnil)) (econst "Nat" lnil)) (enatlit 3 nonneg_3))
    (eapp (econst "Nat.succ" lnil) (eapp (econst "Nat.succ" lnil) (eapp (econst "Nat.succ" lnil) (econst "Nat.zero" lnil)))))
  (esort lzero).

%%% HOLE
natLitEq/value-typed : of
  (eapp (eapp (econst "Eq.refl" (lcons (lsucc lzero) lnil)) (econst "Nat" lnil)) (enatlit 3 nonneg_3))
  (eapp (eapp (eapp (econst "Eq" (lcons (lsucc lzero) lnil)) (econst "Nat" lnil)) (enatlit 3 nonneg_3))
    (eapp (econst "Nat.succ" lnil) (eapp (econst "Nat.succ" lnil) (eapp (econst "Nat.succ" lnil) (econst "Nat.zero" lnil))))).

natLitEq/name : name "natLitEq" (is-decl
  (eapp (eapp (eapp (econst "Eq" (lcons (lsucc lzero) lnil)) (econst "Nat" lnil)) (enatlit 3 nonneg_3))
    (eapp (econst "Nat.succ" lnil) (eapp (econst "Nat.succ" lnil) (eapp (econst "Nat.succ" lnil) (econst "Nat.zero" lnil)))))
  (thm (eapp (eapp (econst "Eq.refl" (lcons (lsucc lzero) lnil)) (econst "Nat" lnil)) (enatlit 3 nonneg_3)))).

natLitEq/decl : declared "natLitEq"
  (eapp (eapp (eapp (econst "Eq" (lcons (lsucc lzero) lnil)) (econst "Nat" lnil)) (enatlit 3 nonneg_3))
    (eapp (econst "Nat.succ" lnil) (eapp (econst "Nat.succ" lnil) (eapp (econst "Nat.succ" lnil) (econst "Nat.zero" lnil)))))
  (thm (eapp (eapp (econst "Eq.refl" (lcons (lsucc lzero) lnil)) (econst "Nat" lnil)) (enatlit 3 nonneg_3)))
   = declared/ok natLitEq/name dkind-non-inductive/thm (dkind-ok/thm natLitEq/type-wf natLitEq/value-typed).
