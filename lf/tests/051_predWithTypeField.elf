%%% Expected outcome: accept
%%% An inductive proposition can have constructors with fields of arbitrary level.
%% inductive PredWithTypeField
PredWithTypeField/type-wf :
   defeq (esort lzero) (esort lzero) (esort (lsucc lzero))
   = (defeq/sort-refl-at lzero).

PredWithTypeField/decl : declared "PredWithTypeField" lnil
   (esort lzero)
   indt
   (dkind-ok/indt PredWithTypeField/type-wf).

%% inductive ctor PredWithTypeField.mk
PredWithTypeField_mk/type-wf :
   defeq (eforall (esort (lsucc lzero)) ([x] (econst "PredWithTypeField" lnil))) (eforall (esort (lsucc lzero)) ([x] (econst "PredWithTypeField" lnil))) (esort (limax (lsucc (lsucc lzero)) lzero))
   = (defeq/forall (defeq/sort-refl-at (lsucc lzero)) ([x] [y] (defeq/const PredWithTypeField/decl))).

PredWithTypeField_mk/decl : declared "PredWithTypeField.mk" lnil
   (eforall (esort (lsucc lzero)) ([x] (econst "PredWithTypeField" lnil)))
   ctor
   (dkind-ok/ctor PredWithTypeField_mk/type-wf).

%% inductive recursor PredWithTypeField.rec
PredWithTypeField_rec/type-wf :
   defeq (eforall (eforall (econst "PredWithTypeField" lnil) ([x] (esort lzero))) ([x] (eforall (eforall (esort (lsucc lzero)) ([y] (eapp x (eapp (econst "PredWithTypeField.mk" lnil) y)))) ([y] (eforall (econst "PredWithTypeField" lnil) ([z] (eapp x z))))))) (eforall (eforall (econst "PredWithTypeField" lnil) ([x] (esort lzero))) ([x] (eforall (eforall (esort (lsucc lzero)) ([y] (eapp x (eapp (econst "PredWithTypeField.mk" lnil) y)))) ([y] (eforall (econst "PredWithTypeField" lnil) ([z] (eapp x z))))))) (esort (limax (limax lzero (lsucc lzero)) (limax (limax (lsucc (lsucc lzero)) lzero) (limax lzero lzero))))
   = (defeq/forall (defeq/forall (defeq/const PredWithTypeField/decl) ([x] [y] (defeq/sort-refl-at lzero))) ([x] [y] (defeq/forall (defeq/forall (defeq/sort-refl-at (lsucc lzero)) ([z] [w] (defeq/app y (defeq/app (defeq/const PredWithTypeField_mk/decl) w)))) ([z] [w] (defeq/forall (defeq/const PredWithTypeField/decl) ([x1] [y1] (defeq/app y y1))))))).

PredWithTypeField_rec/decl : declared "PredWithTypeField.rec" lnil
   (eforall (eforall (econst "PredWithTypeField" lnil) ([x] (esort lzero))) ([x] (eforall (eforall (esort (lsucc lzero)) ([y] (eapp x (eapp (econst "PredWithTypeField.mk" lnil) y)))) ([y] (eforall (econst "PredWithTypeField" lnil) ([z] (eapp x z)))))))
   irec
   (dkind-ok/irec PredWithTypeField_rec/type-wf).

%% def predWithTypeField
predWithTypeField/type-wf :
   defeq (esort lzero) (esort lzero) (esort (lsucc lzero))
   = (defeq/sort-refl-at lzero).

predWithTypeField/value-typed :
   defeq (econst "PredWithTypeField" lnil) (econst "PredWithTypeField" lnil) (esort lzero)
   = (defeq/const PredWithTypeField/decl).

predWithTypeField/decl : declared "predWithTypeField" lnil
   (esort lzero)
   (defn (econst "PredWithTypeField" lnil))
   (dkind-ok/defn predWithTypeField/type-wf predWithTypeField/value-typed).

%mode declared +N +LS -T -DK -W.
%worlds () (declared _ _ _ _ _).
%unique declared +N +LS -1T -1DK *W.
