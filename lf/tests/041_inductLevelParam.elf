%%% Expected outcome: reject
%%% An inductive with duplicate level params
%% inductive inductLevelParam
%abbrev inductLevelParam/type-wf :
   {u : lvl} {u : lvl} defeq (esort (lsucc lzero)) (esort (lsucc lzero)) (esort (lsucc (lsucc lzero)))
   = [u] [u] (defeq/sort-refl-at (lsucc lzero)).

%abbrev inductLevelParam/ends-in-sort :
   {u : lvl} {u : lvl} ends-in-sort (esort (lsucc lzero))
   = [u] [u] ends-in-sort/sort.

inductLevelParam/decl : {u : lvl} {u : lvl} declared "inductLevelParam" (lcons u (lcons u lnil))
   (esort (lsucc lzero))
   indt
   (dkind-ok/indt (inductLevelParam/type-wf u u) (inductLevelParam/ends-in-sort u u)).

