%% thm boolRecEqns
boolRecEqns/type-wf : of
  (eapp (eapp (econst "And" lnil)
    (eforall (eforall (econst "Bool" lnil) ([x] (esort (lvar z))))
      ([x]
        (eforall (eapp x (econst "Bool.false" lnil))
          ([y]
            (eforall (eapp x (econst "Bool.true" lnil))
              ([w]
                (eapp (eapp (eapp (econst "Eq" (lcons (lvar z) lnil)) (eapp x (econst "Bool.false" lnil)))
                  (eapp (eapp (eapp (eapp (econst "Bool.rec" (lcons (lvar z) lnil)) (elam (econst "Bool" lnil) ([v] (eapp x v)))) y) w) (econst "Bool.false" lnil)))
                  y))))))))
    (eforall (eforall (econst "Bool" lnil) ([x] (esort (lvar z))))
      ([x]
        (eforall (eapp x (econst "Bool.false" lnil))
          ([y]
            (eforall (eapp x (econst "Bool.true" lnil))
              ([w]
                (eapp (eapp (eapp (econst "Eq" (lcons (lvar z) lnil)) (eapp x (econst "Bool.true" lnil)))
                  (eapp (eapp (eapp (eapp (econst "Bool.rec" (lcons (lvar z) lnil)) (elam (econst "Bool" lnil) ([v] (eapp x v)))) y) w) (econst "Bool.true" lnil)))
                  w))))))))
  (esort lzero)
   = (defeq/app
       (defeq/app
         (defeq/const
           And/decl
           (inst-expr/forall
             (inst-expr/sort inst-lvl/zero)
             ([x]
               ([h]
                 (inst-expr/forall
                   (inst-expr/sort inst-lvl/zero)
                   ([y] ([h1] (inst-expr/sort inst-lvl/zero))))))))
         (defeq/conv
           (defeq/sort-eq
             (eq-lvl/le
               leq-lvl/lz
               (leq-lvl/imaxLi
                 (leq-lvl/maxL
                   (leq-lvl/imaxLi
                     (leq-lvl/maxL
                       (leq-lvl/imaxLz leq-lvl/self)
                       (leq-lvl/imaxLz leq-lvl/self)))
                   (leq-lvl/imaxLi
                     (leq-lvl/maxL
                       (leq-lvl/imaxLz leq-lvl/self)
                       (leq-lvl/imaxLz leq-lvl/self)))))))
           (defeq/forall
             (defeq/forall
               (defeq/const
                 Bool/decl
                 (inst-expr/sort (inst-lvl/succ inst-lvl/zero)))
               ([x] ([h] defeq/sort-refl)))
             ([x]
               ([h]
                 (defeq/forall
                   (defeq/app
                     h
                     (defeq/const
                       Bool_false/decl
                       (inst-expr/const inst-lvls/nil)))
                   ([y]
                     ([h1]
                       (defeq/forall
                         (defeq/app
                           h
                           (defeq/const
                             Bool_true/decl
                             (inst-expr/const inst-lvls/nil)))
                         ([w]
                           ([h2]
                             (defeq/app
                               (defeq/app
                                 (defeq/app
                                   (defeq/const
                                     Eq/decl
                                     (inst-expr/forall
                                       (inst-expr/sort (inst-lvl/var nth-lvl/z))
                                       ([x]
                                         ([h]
                                           (inst-expr/forall
                                             h
                                             ([y]
                                               ([h1]
                                                 (inst-expr/forall
                                                   h
                                                   ([w]
                                                     ([h2]
                                                       (inst-expr/sort
                                                         inst-lvl/zero)))))))))))
                                   (defeq/app
                                     h
                                     (defeq/const
                                       Bool_false/decl
                                       (inst-expr/const inst-lvls/nil))))
                                 (defeq/conv
                                   (defeq/trans
                                     (defeq/beta
                                       ([v] ([h3] (defeq/app h h3)))
                                       (defeq/const
                                         Bool_false/decl
                                         (inst-expr/const inst-lvls/nil)))
                                     (defeq/app
                                       h
                                       (defeq/const
                                         Bool_false/decl
                                         (inst-expr/const inst-lvls/nil))))
                                   (defeq/app
                                     (defeq/app
                                       (defeq/app
                                         (defeq/app
                                           (defeq/const
                                             (rec-derived-declared
                                               (rec-derived/enum
                                                 Bool/decl
                                                 Bool/rec-name
                                                 (enum-rec-type/intro
                                                   ([x]
                                                     ([h]
                                                       (enum-rec-body/minor
                                                         ([y]
                                                           ([h1]
                                                             (enum-rec-body/minor
                                                               ([w]
                                                                 ([h2]
                                                                   enum-rec-body/done)))))))))
                                                 Bool/eisl
                                                 (le-eligible/non-prop
                                                   leq-lvl/self))
                                               Bool/rec-name)
                                             (inst-expr/forall
                                               (inst-expr/forall
                                                 (inst-expr/const inst-lvls/nil)
                                                 ([x]
                                                   ([h]
                                                     (inst-expr/sort
                                                       (inst-lvl/var
                                                         nth-lvl/z)))))
                                               ([x]
                                                 ([h]
                                                   (inst-expr/forall
                                                     (inst-expr/app
                                                       h
                                                       (inst-expr/const
                                                         inst-lvls/nil))
                                                     ([y]
                                                       ([h1]
                                                         (inst-expr/forall
                                                           (inst-expr/app
                                                             h
                                                             (inst-expr/const
                                                               inst-lvls/nil))
                                                           ([w]
                                                             ([h2]
                                                               (inst-expr/forall
                                                                 (inst-expr/const
                                                                   inst-lvls/nil)
                                                                 ([v]
                                                                   ([h3]
                                                                     (inst-expr/app
                                                                       h
                                                                       h3))))))))))))))
                                           (defeq/lam
                                             (defeq/const
                                               Bool/decl
                                               (inst-expr/sort
                                                 (inst-lvl/succ inst-lvl/zero)))
                                             ([v] ([h3] (defeq/app h h3)))))
                                         (defeq/conv
                                           (defeq/trans
                                             (defeq/app
                                               h
                                               (defeq/const
                                                 Bool_false/decl
                                                 (inst-expr/const
                                                   inst-lvls/nil)))
                                             (defeq/symm
                                               (defeq/beta
                                                 ([v] ([h3] (defeq/app h h3)))
                                                 (defeq/const
                                                   Bool_false/decl
                                                   (inst-expr/const
                                                     inst-lvls/nil)))))
                                           h1))
                                       (defeq/conv
                                         (defeq/trans
                                           (defeq/app
                                             h
                                             (defeq/const
                                               Bool_true/decl
                                               (inst-expr/const inst-lvls/nil)))
