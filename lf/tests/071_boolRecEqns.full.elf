%% thm boolRecEqns
boolRecEqns/type-wf : of
  (eapp (eapp (econst "And" lnil)
    (eforall (eforall (econst "Bool" lnil) ([x] (esort (lvar liz))))
      ([x]
        (eforall (eapp x (econst "Bool.false" lnil))
          ([y]
            (eforall (eapp x (econst "Bool.true" lnil))
              ([z]
                (eapp (eapp (eapp (econst "Eq" (lcons (lvar liz) lnil)) (eapp x (econst "Bool.false" lnil)))
                  (eapp (eapp (eapp (eapp (econst "Bool.rec" (lcons (lvar liz) lnil)) (elam (econst "Bool" lnil) ([w] (eapp x w)))) y) z) (econst "Bool.false" lnil)))
                  y))))))))
    (eforall (eforall (econst "Bool" lnil) ([x] (esort (lvar liz))))
      ([x]
        (eforall (eapp x (econst "Bool.false" lnil))
          ([y]
            (eforall (eapp x (econst "Bool.true" lnil))
              ([z]
                (eapp (eapp (eapp (econst "Eq" (lcons (lvar liz) lnil)) (eapp x (econst "Bool.true" lnil)))
                  (eapp (eapp (eapp (eapp (econst "Bool.rec" (lcons (lvar liz) lnil)) (elam (econst "Bool" lnil) ([w] (eapp x w)))) y) z) (econst "Bool.true" lnil)))
                  z))))))))
  (esort lzero)
   = (defeq/app
       (defeq/app
         (defeq/const
           And/decl
           (inst-expr/forall
             (inst-expr/sort lvl-inst/zero)
             ([x]
               ([h]
                 (inst-expr/forall
                   (inst-expr/sort lvl-inst/zero)
                   ([y] ([h1] (inst-expr/sort lvl-inst/zero))))))))
         (defeq/conv
           (defeq/sort-eq
             (lvl-eq/le
               (mleq/imax-imL
                 (mleq/maxL
                   (mleq/imax-imL
                     (mleq/maxL
                       (mleq/imax-lzL (mleq/self nonneg_0))
                       (mleq/imax-lzL (mleq/self nonneg_0))))
                   (mleq/imax-imL
                     (mleq/maxL
                       (mleq/imax-lzL (mleq/self nonneg_0))
                       (mleq/imax-lzL (mleq/self nonneg_0))))))
               (mleq/lz nonneg_0)))
           (defeq/forall
             (defeq/forall
               (defeq/const
                 Bool/decl
                 (inst-expr/sort (lvl-inst/succ lvl-inst/zero)))
               ([x] ([h] defeq/sort-refl)))
             ([x]
               ([h]
                 (defeq/forall
                   (defeq/app
                     h
                     (defeq/const
                       Bool_false/decl
                       (inst-expr/const lvls-inst/nil)))
                   ([y]
                     ([h1]
                       (defeq/forall
                         (defeq/app
                           h
                           (defeq/const
                             Bool_true/decl
                             (inst-expr/const lvls-inst/nil)))
                         ([z]
                           ([h2]
                             (defeq/app
                               (defeq/app
                                 (defeq/app
                                   (defeq/const
                                     Eq/decl
                                     (inst-expr/forall
                                       (inst-expr/sort
                                         (lvl-inst/var lvl-nth/zero))
                                       ([x]
                                         ([h]
                                           (inst-expr/forall
                                             h
                                             ([y]
                                               ([h1]
                                                 (inst-expr/forall
                                                   h
                                                   ([z]
                                                     ([h2]
                                                       (inst-expr/sort
                                                         lvl-inst/zero)))))))))))
                                   (defeq/app
                                     h
                                     (defeq/const
