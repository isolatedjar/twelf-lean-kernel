%%% Expected outcome: reject
%%% When checking inductives, we expect the kernel to **not** reduce the type of the constructor itself;
%%% that should be all manifest `forall`s
%% def id
%%% HOLE
id/type-wf : {u : lvl} defeq (eforall (esort u) ([x] (eforall x ([y] x)))) (eforall (esort u) ([x] (eforall x ([y] x)))) (esort lzero).

%%% HOLE
id/value-typed : {u : lvl} defeq (elam (esort u) ([x] (elam x ([y] y)))) (elam (esort u) ([x] (elam x ([y] y)))) (eforall (esort u) ([x] (eforall x ([y] x)))).

id/decl : {u : lvl} declared "id" (lcons u lnil)
   (eforall (esort u) ([x] (eforall x ([y] x))))
   (defn (elam (esort u) ([x] (elam x ([y] y)))))
   (dkind-ok/defn (id/type-wf u) (id/value-typed u)).

%% inductive reduceCtorType
%%% HOLE
reduceCtorType/type-wf : defeq (esort (lsucc lzero)) (esort (lsucc lzero)) (esort lzero).

%%% HOLE
reduceCtorType/ends-in-sort : ends-in-sort (esort (lsucc lzero)).

reduceCtorType/decl : declared "reduceCtorType" lnil
   (esort (lsucc lzero))
   indt
   (dkind-ok/indt reduceCtorType/type-wf reduceCtorType/ends-in-sort).

%% ctor reduceCtorType.mk (of reduceCtorType)
%%% HOLE
reduceCtorType_mk/type-wf : defeq (eapp (eapp (econst "id" (lcons (lsucc (lsucc lzero)) lnil)) (esort (lsucc lzero))) (econst "reduceCtorType" lnil)) (eapp (eapp (econst "id" (lcons (lsucc (lsucc lzero)) lnil)) (esort (lsucc lzero))) (econst "reduceCtorType" lnil)) (esort lzero).

%%% HOLE
reduceCtorType_mk/positivity : ctor-positive "reduceCtorType" lnil (eapp (eapp (econst "id" (lcons (lsucc (lsucc lzero)) lnil)) (esort (lsucc lzero))) (econst "reduceCtorType" lnil)).

reduceCtorType_mk/decl : declared "reduceCtorType.mk" lnil
   (eapp (eapp (econst "id" (lcons (lsucc (lsucc lzero)) lnil)) (esort (lsucc lzero))) (econst "reduceCtorType" lnil))
   ctor
   (dkind-ok/ctor reduceCtorType_mk/type-wf reduceCtorType_mk/positivity).

%% recursor reduceCtorType.rec
%%% HOLE
reduceCtorType_rec/type-wf : defeq (esort lzero) (esort lzero) (esort lzero).

reduceCtorType_rec/decl : declared "reduceCtorType.rec" lnil
   (esort lzero)
   irec
   (dkind-ok/irec reduceCtorType_rec/type-wf).

