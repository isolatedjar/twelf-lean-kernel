%%% Expected outcome: reject
%%% When checking inductives, we expect the kernel to **not** reduce the type of the constructor itself;
%%% that should be all manifest `forall`s
%% def id
id/type-wf-sort : lvl
   = (limax (lsucc (lvar liz)) (limax (lvar liz) (lvar liz))).

id/type-wf : defeq (eforall (esort (lvar liz)) ([x] (eforall x ([y] x)))) (eforall (esort (lvar liz)) ([x] (eforall x ([y] x)))) (esort id/type-wf-sort)
   = (defeq/forall defeq/sort-refl ([x] ([h] (defeq/forall h ([y] ([h1] h)))))).

id/value-typed : defeq (elam (esort (lvar liz)) ([x] (elam x ([y] y)))) (elam (esort (lvar liz)) ([x] (elam x ([y] y)))) (eforall (esort (lvar liz)) ([x] (eforall x ([y] x))))
   = (defeq/lam defeq/sort-refl ([x] ([h] (defeq/lam h ([y] ([h1] h1)))))).

id/name : name "id" (is-decl (eforall (esort (lvar liz)) ([x] (eforall x ([y] x)))) (defn (elam (esort (lvar liz)) ([x] (elam x ([y] y)))))).

id/decl : declared "id" (eforall (esort (lvar liz)) ([x] (eforall x ([y] x)))) (defn (elam (esort (lvar liz)) ([x] (elam x ([y] y)))))
   = declared/ok id/name (dkind-ok/defn id/type-wf id/value-typed).

%% inductive reduceCtorType
reduceCtorType/type-wf-sort : lvl
   = (lsucc (lsucc lzero)).

reduceCtorType/type-wf : defeq (esort (lsucc lzero)) (esort (lsucc lzero)) (esort reduceCtorType/type-wf-sort)
   = defeq/sort-refl.

reduceCtorType/ends-in-sort : ends-in-sort (esort (lsucc lzero))
   = ends-in-sort/sort.

reduceCtorType/name : name "reduceCtorType" (is-decl (esort (lsucc lzero)) indt).

reduceCtorType/decl : declared "reduceCtorType" (esort (lsucc lzero)) indt
   = declared/ok reduceCtorType/name (dkind-ok/indt reduceCtorType/type-wf reduceCtorType/ends-in-sort).

%% ctor reduceCtorType.mk (of reduceCtorType)
reduceCtorType_mk/type-wf-sort : lvl
   = (lsucc lzero).

reduceCtorType_mk/type-wf : defeq (eapp (eapp (econst "id" (lcons (lsucc (lsucc lzero)) lnil)) (esort (lsucc lzero))) (econst "reduceCtorType" lnil)) (eapp (eapp (econst "id" (lcons (lsucc (lsucc lzero)) lnil)) (esort (lsucc lzero))) (econst "reduceCtorType" lnil)) (esort reduceCtorType_mk/type-wf-sort)
   = (defeq/app (defeq/app (defeq/const id/decl (inst-expr/forall (inst-expr/sort (lvl-inst/var lvl-nth/zero)) ([x] ([h] (inst-expr/forall h ([y] ([h1] h))))))) defeq/sort-refl) (defeq/const reduceCtorType/decl (inst-expr/sort (lvl-inst/succ lvl-inst/zero)))).

%%% HOLE
reduceCtorType_mk/positivity : ctor-positive "reduceCtorType" lnil (eapp (eapp (econst "id" (lcons (lsucc (lsucc lzero)) lnil)) (esort (lsucc lzero))) (econst "reduceCtorType" lnil)).

reduceCtorType_mk/name : name "reduceCtorType.mk" (is-decl (eapp (eapp (econst "id" (lcons (lsucc (lsucc lzero)) lnil)) (esort (lsucc lzero))) (econst "reduceCtorType" lnil)) ctor).

reduceCtorType_mk/decl : declared "reduceCtorType.mk" (eapp (eapp (econst "id" (lcons (lsucc (lsucc lzero)) lnil)) (esort (lsucc lzero))) (econst "reduceCtorType" lnil)) ctor
   = declared/ok reduceCtorType_mk/name (dkind-ok/ctor reduceCtorType_mk/type-wf reduceCtorType_mk/positivity).

%% recursor reduceCtorType.rec
reduceCtorType_rec/type-wf-sort : lvl
   = (lsucc lzero).

reduceCtorType_rec/type-wf : defeq (esort lzero) (esort lzero) (esort reduceCtorType_rec/type-wf-sort)
   = defeq/sort-refl.

reduceCtorType_rec/name : name "reduceCtorType.rec" (is-decl (esort lzero) irec).

reduceCtorType_rec/decl : declared "reduceCtorType.rec" (esort lzero) irec
   = declared/ok reduceCtorType_rec/name (dkind-ok/irec reduceCtorType_rec/type-wf).

