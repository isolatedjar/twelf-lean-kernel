sortElimPropRec/decl : declared "sortElimPropRec"
  (eforall (econst "Bool" lnil)
    ([x]
      (eforall (eforall (econst "Bool" lnil) ([y] (eforall (econst "Bool" lnil) ([z] (eforall (eapp (eapp (eapp (econst "SortElimProp" lnil) x) y) z) ([w] (esort (lvar liz))))))))
