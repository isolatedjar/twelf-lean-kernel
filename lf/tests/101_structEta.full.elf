%%% Expected outcome: accept
%%% Structure eta
%% inductive Prod
Prod/type-wf : of
  (eforall (esort (lsucc (lvar z))) ([x] (eforall (esort (lsucc (lvar (s z)))) ([y] (esort (lmax (lsucc (lvar z)) (lsucc (lvar (s z)))))))))
  (esort (limax (lsucc (lsucc (lvar z))) (limax (lsucc (lsucc (lvar (s z)))) (lsucc (lmax (lsucc (lvar z)) (lsucc (lvar (s z))))))))
   = (defeq/forall
       defeq/sort-refl
       ([x] ([h] (defeq/forall defeq/sort-refl ([y] ([h1] defeq/sort-refl)))))).

Prod/ends-in-sort : ends-in-sort (eforall (esort (lsucc (lvar z))) ([x] (eforall (esort (lsucc (lvar (s z)))) ([y] (esort (lmax (lsucc (lvar z)) (lsucc (lvar (s z)))))))))
   = (ends-in-sort/forall ([x] (ends-in-sort/forall ([y] ends-in-sort/sort)))).

Prod/rec-name : name "Prod.rec" (is-rec-for "Prod").

Prod/eisl : ends-in-sort-with-level (eforall (esort (lsucc (lvar z))) ([x] (eforall (esort (lsucc (lvar (s z)))) ([y] (esort (lmax (lsucc (lvar z)) (lsucc (lvar (s z))))))))) (lmax (lsucc (lvar z)) (lsucc (lvar (s z))))
   = (ends-in-sort-with-level/forall
       ([x]
         (ends-in-sort-with-level/forall ([y] ends-in-sort-with-level/sort)))).

Prod/cnd : cnames-distinct (ccons "Prod.mk" cnil)
   = (cnames-distinct/cons cnames-distinct/nil all-string-neq/nil).

Prod/name : name "Prod" (is-decl (eforall (esort (lsucc (lvar z))) ([x] (eforall (esort (lsucc (lvar (s z)))) ([y] (esort (lmax (lsucc (lvar z)) (lsucc (lvar (s z))))))))) (indt (ccons "Prod.mk" cnil) (s (s z)))).

Prod/decl : declared "Prod" (eforall (esort (lsucc (lvar z))) ([x] (eforall (esort (lsucc (lvar (s z)))) ([y] (esort (lmax (lsucc (lvar z)) (lsucc (lvar (s z))))))))) (indt (ccons "Prod.mk" cnil) (s (s z)))
   = declared/ok-indt Prod/name Prod/rec-name Prod/cnd (dkind-ok/indt Prod/type-wf Prod/ends-in-sort).

%% ctor Prod.mk (of Prod)
Prod_mk/type-wf : of
  (eforall (esort (lsucc (lvar z))) ([x] (eforall (esort (lsucc (lvar (s z)))) ([y] (eforall x ([w] (eforall y ([v] (eapp (eapp (econst "Prod" (lcons (lvar z) (lcons (lvar (s z)) lnil))) x) y)))))))))
  (esort (limax (lsucc (lsucc (lvar z))) (limax (lsucc (lsucc (lvar (s z)))) (limax (lsucc (lvar z)) (limax (lsucc (lvar (s z))) (lmax (lsucc (lvar z)) (lsucc (lvar (s z)))))))))
   = (defeq/forall
       defeq/sort-refl
       ([x]
         ([h]
           (defeq/forall
             defeq/sort-refl
             ([y]
               ([h1]
                 (defeq/forall
                   h
                   ([w]
                     ([h2]
                       (defeq/forall
                         h1
                         ([v]
                           ([h3]
                             (defeq/app
                               (defeq/app
                                 (defeq/const
                                   Prod/decl
                                   (inst-expr/forall
                                     (inst-expr/sort
                                       (inst-lvl/succ (inst-lvl/var nth-lvl/z)))
                                     ([x]
                                       ([h]
                                         (inst-expr/forall
                                           (inst-expr/sort
                                             (inst-lvl/succ
                                               (inst-lvl/var
                                                 (nth-lvl/s nth-lvl/z))))
                                           ([y]
                                             ([h1]
                                               (inst-expr/sort
                                                 (inst-lvl/max
                                                   (inst-lvl/succ
                                                     (inst-lvl/var
                                                       (nth-lvl/s nth-lvl/z)))
                                                   (inst-lvl/succ
                                                     (inst-lvl/var
                                                       nth-lvl/z)))))))))))
                                 h)
                               h1))))))))))))).

Prod_mk/positivity : ctor-positive "Prod" (lcons (lvar z) (lcons (lvar (s z)) lnil)) (eforall (esort (lsucc (lvar z))) ([x] (eforall (esort (lsucc (lvar (s z)))) ([y] (eforall x ([w] (eforall y ([v] (eapp (eapp (econst "Prod" (lcons (lvar z) (lcons (lvar (s z)) lnil))) x) y)))))))))
   = (ctor-positive/intro ([S] (eforall (esort (lsucc (lvar z))) ([x] (eforall (esort (lsucc (lvar (s z)))) ([y] (eforall x ([w] (eforall y ([v] (eapp (eapp S x) y)))))))))) (ctor-spine/arg
       (strict-pos/no-occur (esort (lsucc (lvar z))) no-self-ref/sort)
       ([x]
         ([y]
           (ctor-spine/arg
             (strict-pos/no-occur (esort (lsucc (lvar (s z)))) no-self-ref/sort)
             ([w]
               ([v]
                 (ctor-spine/arg
                   (strict-pos/no-occur x y)
                   ([x1]
                     ([y1]
                       (ctor-spine/arg
                         (strict-pos/no-occur w v)
                         ([w1]
                           ([v1]
                             (ctor-spine/result
                               (applies-self/app
                                 (applies-self/app
                                   applies-self/refl)))))))))))))))).

Prod_mk/cmem : cmem "Prod.mk" (ccons "Prod.mk" cnil)
   = cmem/here.

%%% HOLE: Prod_mk/fuo
Prod_mk/fuo : field-universes-ok (eforall (esort (lsucc (lvar z))) ([x] (eforall (esort (lsucc (lvar (s z)))) ([y] (eforall x ([w] (eforall y ([v] (eapp (eapp (econst "Prod" (lcons (lvar z) (lcons (lvar (s z)) lnil))) x) y))))))))) (lmax (lsucc (lvar z)) (lsucc (lvar (s z)))).

Prod_mk/name : name "Prod.mk" (is-decl
  (eforall (esort (lsucc (lvar z))) ([x] (eforall (esort (lsucc (lvar (s z)))) ([y] (eforall x ([w] (eforall y ([v] (eapp (eapp (econst "Prod" (lcons (lvar z) (lcons (lvar (s z)) lnil))) x) y)))))))))
  (ctor "Prod" z)).

Prod_mk/decl : declared "Prod.mk"
  (eforall (esort (lsucc (lvar z))) ([x] (eforall (esort (lsucc (lvar (s z)))) ([y] (eforall x ([w] (eforall y ([v] (eapp (eapp (econst "Prod" (lcons (lvar z) (lcons (lvar (s z)) lnil))) x) y)))))))))
  (ctor "Prod" z)
   = declared/ok-ctor Prod_mk/name Prod/name Prod_mk/cmem Prod/eisl Prod_mk/fuo (dkind-ok/ctor Prod_mk/type-wf Prod_mk/positivity).

%% recursor Prod.rec (TCB-derived; informational only)
%%   level params: u_1 u v
%%   type:   (eforall (esort (lsucc (lvar (s z)))) ([x] (eforall (esort (lsucc (lvar (s (s z))))) ([y] (eforall (eforall (eapp (eapp (econst "Prod" (lcons (lvar (s z)) (lcons (lvar (s (s z))) lnil))) x) y) ([w] (esort (lvar z)))) ([w] (eforall (eforall x ([v] (eforall y ([x1] (eapp w (eapp (eapp (eapp (eapp (econst "Prod.mk" (lcons (lvar (s z)) (lcons (lvar (s (s z))) lnil))) x) y) v) x1)))))) ([v] (eforall (eapp (eapp (econst "Prod" (lcons (lvar (s z)) (lcons (lvar (s (s z))) lnil))) x) y) ([x1] (eapp w x1)))))))))))
%%   rules:
%%     Prod.rec … Prod.mk … = (elam (esort (lsucc (lvar (s z)))) ([x] (elam (esort (lsucc (lvar (s (s z))))) ([y] (elam (eforall (eapp (eapp (econst "Prod" (lcons (lvar (s z)) (lcons (lvar (s (s z))) lnil))) x) y) ([w] (esort (lvar z)))) ([w] (elam (eforall x ([v] (eforall y ([x1] (eapp w (eapp (eapp (eapp (eapp (econst "Prod.mk" (lcons (lvar (s z)) (lcons (lvar (s (s z))) lnil))) x) y) v) x1)))))) ([v] (elam x ([x1] (elam y ([y1] (eapp (eapp v x1) y1)))))))))))))   (2 fields)

%% inductive And
And/type-wf : of (eforall (esort lzero) ([x] (eforall (esort lzero) ([y] (esort lzero))))) (esort (limax (lsucc lzero) (limax (lsucc lzero) (lsucc lzero))))
   = (defeq/forall
       defeq/sort-refl
       ([x] ([h] (defeq/forall defeq/sort-refl ([y] ([h1] defeq/sort-refl)))))).

And/ends-in-sort : ends-in-sort (eforall (esort lzero) ([x] (eforall (esort lzero) ([y] (esort lzero)))))
   = (ends-in-sort/forall ([x] (ends-in-sort/forall ([y] ends-in-sort/sort)))).

And/rec-name : name "And.rec" (is-rec-for "And").

And/eisl : ends-in-sort-with-level (eforall (esort lzero) ([x] (eforall (esort lzero) ([y] (esort lzero))))) lzero
   = (ends-in-sort-with-level/forall
       ([x]
         (ends-in-sort-with-level/forall ([y] ends-in-sort-with-level/sort)))).

And/cnd : cnames-distinct (ccons "And.intro" cnil)
   = (cnames-distinct/cons cnames-distinct/nil all-string-neq/nil).

And/name : name "And" (is-decl (eforall (esort lzero) ([x] (eforall (esort lzero) ([y] (esort lzero))))) (indt (ccons "And.intro" cnil) (s (s z)))).

And/decl : declared "And" (eforall (esort lzero) ([x] (eforall (esort lzero) ([y] (esort lzero))))) (indt (ccons "And.intro" cnil) (s (s z)))
   = declared/ok-indt And/name And/rec-name And/cnd (dkind-ok/indt And/type-wf And/ends-in-sort).

%% ctor And.intro (of And)
And_intro/type-wf : of
  (eforall (esort lzero) ([x] (eforall (esort lzero) ([y] (eforall x ([w] (eforall y ([v] (eapp (eapp (econst "And" lnil) x) y)))))))))
  (esort (limax (lsucc lzero) (limax (lsucc lzero) (limax lzero (limax lzero lzero)))))
   = (defeq/forall
       defeq/sort-refl
       ([x]
         ([h]
           (defeq/forall
             defeq/sort-refl
             ([y]
               ([h1]
                 (defeq/forall
                   h
                   ([w]
                     ([h2]
                       (defeq/forall
                         h1
                         ([v]
                           ([h3]
                             (defeq/app
                               (defeq/app
                                 (defeq/const
                                   And/decl
                                   (inst-expr/forall
                                     (inst-expr/sort inst-lvl/zero)
                                     ([x]
                                       ([h]
                                         (inst-expr/forall
                                           (inst-expr/sort inst-lvl/zero)
                                           ([y]
                                             ([h1]
                                               (inst-expr/sort
                                                 inst-lvl/zero))))))))
                                 h)
                               h1))))))))))))).

And_intro/positivity : ctor-positive "And" lnil (eforall (esort lzero) ([x] (eforall (esort lzero) ([y] (eforall x ([w] (eforall y ([v] (eapp (eapp (econst "And" lnil) x) y)))))))))
   = (ctor-positive/intro ([S] (eforall (esort lzero) ([x] (eforall (esort lzero) ([y] (eforall x ([w] (eforall y ([v] (eapp (eapp S x) y)))))))))) (ctor-spine/arg
       (strict-pos/no-occur (esort lzero) no-self-ref/sort)
       ([x]
         ([y]
           (ctor-spine/arg
             (strict-pos/no-occur (esort lzero) no-self-ref/sort)
             ([w]
               ([v]
                 (ctor-spine/arg
                   (strict-pos/no-occur x y)
                   ([x1]
                     ([y1]
                       (ctor-spine/arg
                         (strict-pos/no-occur w v)
                         ([w1]
                           ([v1]
                             (ctor-spine/result
                               (applies-self/app
                                 (applies-self/app
                                   applies-self/refl)))))))))))))))).

And_intro/cmem : cmem "And.intro" (ccons "And.intro" cnil)
   = cmem/here.

And_intro/fuo : field-universes-ok (eforall (esort lzero) ([x] (eforall (esort lzero) ([y] (eforall x ([w] (eforall y ([v] (eapp (eapp (econst "And" lnil) x) y))))))))) lzero
   = (field-universes-ok/forall
