%% def Prod.fst
Prod_fst/type-wf : of
  (eforall (esort (lsucc (lvar z))) ([x] (eforall (esort (lsucc (lvar (s z)))) ([y] (eforall (eapp (eapp (econst "Prod" (lcons (lvar z) (lcons (lvar (s z)) lnil))) x) y) ([w] x))))))
  (esort (limax (lsucc (lsucc (lvar z))) (limax (lsucc (lsucc (lvar (s z)))) (limax (lmax (lsucc (lvar z)) (lsucc (lvar (s z)))) (lsucc (lvar z))))))
   = (defeq/forall
       defeq/sort-refl
       ([x]
         ([h]
           (defeq/forall
             defeq/sort-refl
             ([y]
               ([h1]
                 (defeq/forall
                   (defeq/app
                     (defeq/app
                       (defeq/const
                         Prod/decl
                         (inst-expr/forall
                           (inst-expr/sort
                             (inst-lvl/succ (inst-lvl/var nth-lvl/z)))
                           ([x]
                             ([h]
                               (inst-expr/forall
                                 (inst-expr/sort
                                   (inst-lvl/succ
                                     (inst-lvl/var (nth-lvl/s nth-lvl/z))))
                                 ([y]
                                   ([h1]
                                     (inst-expr/sort
                                       (inst-lvl/max
                                         (inst-lvl/succ
                                           (inst-lvl/var (nth-lvl/s nth-lvl/z)))
                                         (inst-lvl/succ
                                           (inst-lvl/var nth-lvl/z)))))))))))
                       h)
                     h1)
                   ([w] ([h2] h))))))))).

