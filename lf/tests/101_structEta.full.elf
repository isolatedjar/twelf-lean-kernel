Prod_fst/value-typed : of
  (elam (esort (lsucc (lvar z))) ([x] (elam (esort (lsucc (lvar (s z)))) ([y] (elam (eapp (eapp (econst "Prod" (lcons (lvar z) (lcons (lvar (s z)) lnil))) x) y) ([w] (eproj "Prod" 0 w)))))))
